---
export const prerender = false;
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const user = Astro.locals.user;

const ownerSidebarItems = [
  { label: '대시보드', href: '/admin', icon: 'dashboard' },
  { label: '글 관리', href: '/admin/posts', icon: 'posts' },
  { label: '카테고리', href: '/admin/categories', icon: 'categories' },
  { label: '태그', href: '/admin/tags', icon: 'tags' },
  { label: '사진 관리', href: '/admin/portfolio', icon: 'portfolio' },
  { label: '미디어', href: '/admin/media', icon: 'media' },
  { label: 'SEO 설정', href: '/admin/seo-settings', icon: 'seo' },
  { label: '사이트 설정', href: '/admin/settings', icon: 'settings' },
  { label: '패키지', href: '/admin/packages', icon: 'packages' },
  { label: '배경·백드롭', href: '/admin/gallery', icon: 'gallery' },
  { label: '포토스트립', href: '/admin/photostrip', icon: 'photostrip' },
  { label: '계정 관리', href: '/admin/accounts', icon: 'accounts' },
];

const editorSidebarItems = [
  { label: '허브', href: '/admin', icon: 'dashboard' },
  { label: '사진 관리', href: '/admin/portfolio', icon: 'portfolio' },
  { label: '블로그', href: '/admin/posts', icon: 'posts' },
  { label: '미디어', href: '/admin/media', icon: 'media' },
  { label: '팝업', href: '/admin/popups', icon: 'popup' },
  { label: '패키지', href: '/admin/packages', icon: 'packages' },
  { label: '배경·백드롭', href: '/admin/gallery', icon: 'gallery' },
  { label: '포토스트립', href: '/admin/photostrip', icon: 'photostrip' },
  { label: 'FAQ', href: '/admin/faq', icon: 'faq' },
];

const sidebarItems = user?.role === 'owner' ? ownerSidebarItems : editorSidebarItems;

function isActive(href: string): boolean {
  if (href === '/admin') {
    return currentPath === '/admin' || currentPath === '/admin/';
  }
  return currentPath.startsWith(href);
}
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <title>{title} | SIMPLE CUBE 관리자</title>
  </head>
  <body class="admin-body" data-user-role={user?.role || ''} data-user-name={user?.name || ''}>
    <!-- Mobile overlay -->
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="sidebar">
      <div class="sidebar-header">
        <span class="sidebar-logo">SIMPLE CUBE</span>
        <button id="sidebar-close" class="sidebar-close" aria-label="사이드바 닫기">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </div>

      <nav class="sidebar-nav">
        {sidebarItems.map((item) => (
          <a
            href={item.href}
            class:list={['sidebar-link', { active: isActive(item.href) }]}
          >
            <svg class="sidebar-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              {item.icon === 'dashboard' && (
                <><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></>
              )}
              {item.icon === 'posts' && (
                <><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10 9 9 9 8 9" /></>
              )}
              {item.icon === 'categories' && (
                <><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" /></>
              )}
              {item.icon === 'tags' && (
                <><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" /><line x1="7" y1="7" x2="7.01" y2="7" /></>
              )}
              {item.icon === 'portfolio' && (
                <><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><rect x="7" y="7" width="3" height="3" rx="0.5" /><rect x="14" y="7" width="3" height="3" rx="0.5" /><rect x="7" y="14" width="3" height="3" rx="0.5" /><rect x="14" y="14" width="3" height="3" rx="0.5" /></>
              )}
              {item.icon === 'media' && (
                <><rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" /></>
              )}
              {item.icon === 'seo' && (
                <><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></>
              )}
              {item.icon === 'settings' && (
                <><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" /></>
              )}
              {item.icon === 'accounts' && (
                <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></>
              )}
              {item.icon === 'popup' && (
                <><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 0 1-3.46 0" /></>
              )}
              {item.icon === 'packages' && (
                <><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" /><polyline points="3.27 6.96 12 12.01 20.73 6.96" /><line x1="12" y1="22.08" x2="12" y2="12" /></>
              )}
              {item.icon === 'gallery' && (
                <><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 15l4-4a2 2 0 0 1 2.8 0L14 15" /><path d="M14 13l1-1a2 2 0 0 1 2.8 0L21 15" /><circle cx="8" cy="9" r="2" /></>
              )}
              {item.icon === 'photostrip' && (
                <><rect x="6" y="2" width="12" height="20" rx="2" /><line x1="9" y1="6" x2="15" y2="6" /><line x1="9" y1="10" x2="15" y2="10" /><line x1="9" y1="14" x2="15" y2="14" /><line x1="9" y1="18" x2="15" y2="18" /></>
              )}
              {item.icon === 'faq' && (
                <><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" /></>
              )}
            </svg>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>
    </aside>

    <!-- Main area -->
    <div class="main-wrapper">
      <!-- Top bar -->
      <header class="topbar">
        <div class="topbar-left">
          <button id="sidebar-toggle" class="sidebar-toggle" aria-label="사이드바 열기">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
          </button>
          <h1 class="topbar-title">SIMPLE CUBE 관리자</h1>
        </div>
        <div class="topbar-right">
          {user && <span class="topbar-greeting">안녕하세요, {user.name}님</span>}
          <button id="change-pw-btn" class="topbar-link" style="background:none;border:none;cursor:pointer;font-family:inherit;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            비밀번호 변경
          </button>
          <a href="/" target="_blank" rel="noopener noreferrer" class="topbar-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
              <polyline points="15 3 21 3 21 9" />
              <line x1="10" y1="14" x2="21" y2="3" />
            </svg>
            사이트 보기
          </a>
          <button id="logout-btn" class="topbar-logout">로그아웃</button>
        </div>
      </header>

      <!-- Content -->
      <main class="admin-content">
        <slot />
      </main>
    </div>

    <!-- Password Change Modal -->
    <div id="pw-modal-overlay" class="pw-modal-overlay">
      <div class="pw-modal">
        <h2 class="pw-modal-title">비밀번호 변경</h2>
        <div id="pw-error" class="pw-error"></div>
        <div id="pw-success" class="pw-success"></div>
        <form id="pw-form">
          <div class="pw-field">
            <label for="pw-current">현재 비밀번호</label>
            <input type="password" id="pw-current" required autocomplete="current-password" />
          </div>
          <div class="pw-field">
            <label for="pw-new">새 비밀번호</label>
            <input type="password" id="pw-new" required autocomplete="new-password" />
          </div>
          <div class="pw-field">
            <label for="pw-confirm">새 비밀번호 확인</label>
            <input type="password" id="pw-confirm" required autocomplete="new-password" />
          </div>
          <div class="pw-actions">
            <button type="button" id="pw-cancel" class="pw-btn-cancel">취소</button>
            <button type="submit" id="pw-submit" class="pw-btn-submit">변경</button>
          </div>
        </form>
      </div>
    </div>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      .admin-body {
        font-family: 'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif;
        background-color: #f5f5f7;
        color: #1d1d1f;
        min-height: 100vh;
        display: flex;
        -webkit-font-smoothing: antialiased;
      }

      /* Sidebar */
      .sidebar {
        width: 260px;
        min-height: 100vh;
        background-color: #1d1d1f;
        color: #ffffff;
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 40;
        transition: transform 0.3s ease;
      }

      .sidebar-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #2a2a2c;
      }

      .sidebar-logo {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #D4AA45;
      }

      .sidebar-close {
        display: none;
        background: none;
        border: none;
        color: #8c8c8c;
        cursor: pointer;
        padding: 0.25rem;
      }
      .sidebar-close:hover { color: #ffffff; }

      .sidebar-nav {
        flex: 1;
        padding: 0.75rem 0;
        overflow-y: auto;
      }

      .sidebar-link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.625rem 1.5rem;
        color: #8c8c8c;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 400;
        transition: all 0.15s;
      }
      .sidebar-link:hover {
        color: #ffffff;
        background-color: rgba(255, 255, 255, 0.05);
      }
      .sidebar-link.active {
        color: #D4AA45;
        background-color: rgba(212, 170, 69, 0.08);
        font-weight: 500;
      }
      .sidebar-icon {
        flex-shrink: 0;
      }

      /* Sidebar overlay */
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 30;
      }
      .sidebar-overlay.visible {
        display: block;
      }

      /* Main wrapper */
      .main-wrapper {
        flex: 1;
        margin-left: 260px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* Top bar */
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        height: 56px;
        background-color: #ffffff;
        border-bottom: 1px solid #e8e8ed;
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .topbar-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }

      .sidebar-toggle {
        display: none;
        background: none;
        border: none;
        color: #1d1d1f;
        cursor: pointer;
        padding: 0.25rem;
      }

      .topbar-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: #1d1d1f;
      }

      .topbar-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .topbar-greeting {
        font-size: 0.8125rem;
        color: #6e6e73;
        font-weight: 400;
      }

      .topbar-link {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.8125rem;
        color: #6e6e73;
        text-decoration: none;
        transition: color 0.15s;
      }
      .topbar-link:hover { color: #1d1d1f; }

      .topbar-logout {
        background: none;
        border: 1px solid #d2d2d7;
        border-radius: 6px;
        padding: 0.375rem 0.875rem;
        font-size: 0.8125rem;
        font-family: inherit;
        color: #6e6e73;
        cursor: pointer;
        transition: all 0.15s;
      }
      .topbar-logout:hover {
        border-color: #1d1d1f;
        color: #1d1d1f;
      }

      /* Content area */
      .admin-content {
        flex: 1;
        padding: 2rem;
      }

      /* Password Change Modal */
      .pw-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 50;
        align-items: center;
        justify-content: center;
      }
      .pw-modal-overlay.visible {
        display: flex;
      }
      .pw-modal {
        background: #ffffff;
        border-radius: 12px;
        padding: 1.75rem;
        width: 100%;
        max-width: 400px;
        margin: 1rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
      }
      .pw-modal-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #1d1d1f;
        margin-bottom: 1.25rem;
      }
      .pw-field {
        margin-bottom: 1rem;
      }
      .pw-field label {
        display: block;
        font-size: 0.8125rem;
        font-weight: 500;
        color: #6e6e73;
        margin-bottom: 0.375rem;
      }
      .pw-field input {
        width: 100%;
        padding: 0.625rem 0.75rem;
        border: 1px solid #d2d2d7;
        border-radius: 8px;
        font-size: 0.875rem;
        font-family: inherit;
        color: #1d1d1f;
        outline: none;
        transition: border-color 0.15s;
      }
      .pw-field input:focus {
        border-color: #D4AA45;
      }
      .pw-error {
        display: none;
        background: rgba(239, 68, 68, 0.08);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #dc2626;
        padding: 0.625rem 0.75rem;
        border-radius: 8px;
        font-size: 0.8125rem;
        margin-bottom: 1rem;
      }
      .pw-error.visible { display: block; }
      .pw-success {
        display: none;
        background: rgba(34, 197, 94, 0.08);
        border: 1px solid rgba(34, 197, 94, 0.2);
        color: #16a34a;
        padding: 0.625rem 0.75rem;
        border-radius: 8px;
        font-size: 0.8125rem;
        margin-bottom: 1rem;
      }
      .pw-success.visible { display: block; }
      .pw-actions {
        display: flex;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-top: 1.25rem;
      }
      .pw-btn-cancel {
        padding: 0.5rem 1rem;
        border: 1px solid #d2d2d7;
        border-radius: 8px;
        background: none;
        font-size: 0.8125rem;
        font-family: inherit;
        color: #6e6e73;
        cursor: pointer;
        transition: all 0.15s;
      }
      .pw-btn-cancel:hover { border-color: #1d1d1f; color: #1d1d1f; }
      .pw-btn-submit {
        padding: 0.5rem 1rem;
        border: none;
        border-radius: 8px;
        background: #D4AA45;
        font-size: 0.8125rem;
        font-weight: 600;
        font-family: inherit;
        color: #ffffff;
        cursor: pointer;
        transition: background 0.15s;
      }
      .pw-btn-submit:hover { background: #C49A2F; }
      .pw-btn-submit:disabled { opacity: 0.6; cursor: not-allowed; }

      /* Responsive */
      @media (max-width: 768px) {
        .sidebar {
          transform: translateX(-100%);
        }
        .sidebar.open {
          transform: translateX(0);
        }
        .sidebar-close {
          display: block;
        }
        .sidebar-toggle {
          display: block;
        }
        .main-wrapper {
          margin-left: 0;
        }
        .admin-content {
          padding: 1rem;
        }
      }
    </style>

    <script>
      const sidebar = document.getElementById('sidebar')!;
      const overlay = document.getElementById('sidebar-overlay')!;
      const toggleBtn = document.getElementById('sidebar-toggle')!;
      const closeBtn = document.getElementById('sidebar-close')!;
      const logoutBtn = document.getElementById('logout-btn')!;

      function openSidebar() {
        sidebar.classList.add('open');
        overlay.classList.add('visible');
      }

      function closeSidebar() {
        sidebar.classList.remove('open');
        overlay.classList.remove('visible');
      }

      toggleBtn.addEventListener('click', openSidebar);
      closeBtn.addEventListener('click', closeSidebar);
      overlay.addEventListener('click', closeSidebar);

      // Password change modal
      const pwModal = document.getElementById('pw-modal-overlay')!;
      const pwForm = document.getElementById('pw-form') as HTMLFormElement;
      const pwError = document.getElementById('pw-error')!;
      const pwSuccess = document.getElementById('pw-success')!;
      const pwSubmitBtn = document.getElementById('pw-submit') as HTMLButtonElement;
      const changePwBtn = document.getElementById('change-pw-btn')!;
      const pwCancelBtn = document.getElementById('pw-cancel')!;

      function openPwModal() {
        pwModal.classList.add('visible');
        pwError.classList.remove('visible');
        pwSuccess.classList.remove('visible');
        pwForm.reset();
      }

      function closePwModal() {
        pwModal.classList.remove('visible');
      }

      changePwBtn.addEventListener('click', openPwModal);
      pwCancelBtn.addEventListener('click', closePwModal);
      pwModal.addEventListener('click', (e) => {
        if (e.target === pwModal) closePwModal();
      });

      pwForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        pwError.classList.remove('visible');
        pwSuccess.classList.remove('visible');

        const currentPassword = (document.getElementById('pw-current') as HTMLInputElement).value;
        const newPassword = (document.getElementById('pw-new') as HTMLInputElement).value;
        const confirmPassword = (document.getElementById('pw-confirm') as HTMLInputElement).value;

        if (newPassword !== confirmPassword) {
          pwError.textContent = '새 비밀번호가 일치하지 않습니다.';
          pwError.classList.add('visible');
          return;
        }

        if (newPassword.length < 4) {
          pwError.textContent = '새 비밀번호는 4자 이상이어야 합니다.';
          pwError.classList.add('visible');
          return;
        }

        pwSubmitBtn.disabled = true;
        pwSubmitBtn.textContent = '변경 중...';

        try {
          const res = await fetch('/api/auth/change-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ currentPassword, newPassword }),
          });

          const data = await res.json();

          if (res.ok) {
            pwSuccess.textContent = '비밀번호가 변경되었습니다.';
            pwSuccess.classList.add('visible');
            pwForm.reset();
            setTimeout(closePwModal, 1500);
          } else {
            pwError.textContent = data.error || '비밀번호 변경에 실패했습니다.';
            pwError.classList.add('visible');
          }
        } catch {
          pwError.textContent = '서버에 연결할 수 없습니다.';
          pwError.classList.add('visible');
        } finally {
          pwSubmitBtn.disabled = false;
          pwSubmitBtn.textContent = '변경';
        }
      });

      logoutBtn.addEventListener('click', async () => {
        try {
          await fetch('/api/auth/logout', { method: 'POST' });
        } catch {
          // ignore
        }
        window.location.href = '/admin/login';
      });
    </script>
  </body>
</html>
