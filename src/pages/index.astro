---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroSection from '@components/home/HeroSection.astro';
import ServicesSection from '@components/home/ServicesSection.astro';
import WhySimpleCube from '@components/home/WhySimpleCube.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import BrandStory from '@components/brand/BrandStory.astro';
import OrganizationSchema from '@components/seo/OrganizationSchema.astro';
import EventPopup from '@components/common/EventPopup.astro';
---

<BaseLayout
  title="심플큐브 | 포토부스 대여·렌탈 — 웨딩·팝업·기업행사 전문"
  description="2019년부터 14,000건 이상의 행사를 함께한 1세대 포토부스 브랜드 심플큐브. 웨딩 포토부스, 팝업 포토부스, 기업행사 포토부스 대여를 전국 출장으로 진행합니다."
  keywords="심플큐브, 심플큐브 포토부스, SIMPLE CUBE, 포토부스 대여, 포토부스 렌탈, 웨딩 포토부스, 결혼식 포토부스, 팝업 포토부스, 브랜드 팝업스토어 포토부스, 기업행사 포토부스, 페스티벌 포토부스, 행사 포토부스 대여, 전국 포토부스 출장"
  transparentNav={true}
>
  <OrganizationSchema />
  <EventPopup />
  <HeroSection />
  <ServicesSection />
  <WhySimpleCube />
  <ClientShowcase />
  <BrandStory />
</BaseLayout>

<script>
  // Scroll-down button → scroll to footer
  const scrollBtn = document.getElementById('scroll-down-btn');
  if (scrollBtn) {
    scrollBtn.addEventListener('click', () => {
      const hero = document.getElementById('hero');
      if (hero && hero.nextElementSibling) {
        hero.nextElementSibling.scrollIntoView({ behavior: 'smooth' });
      }
    });
  }
</script>
