---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import MachineShowcase from '@components/popup/MachineShowcase.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import RegionUniqueInfo from '@components/region/RegionUniqueInfo.astro';
import db from '@lib/db';

const [cheonanFaqResult, rentalFaqResult, popupFaqResult] = await Promise.all([
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['cheonan'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['rental'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['popup'] }),
]);
const faqItems = (
  cheonanFaqResult.rows.length > 0 ? cheonanFaqResult.rows
  : rentalFaqResult.rows.length > 0 ? rentalFaqResult.rows
  : popupFaqResult.rows
) as { question: string; answer: string }[];
---

<BaseLayout
  title="천안 포토부스 대여 | 불당동·천안아산역·아산 출장 설치 — 심플큐브"
  description="천안 전 지역 포토부스 출장 설치. 불당동, 신부동, 천안아산역, 아산 등 천안 어디든 설치 가능. 웨딩, 기업행사, 팝업스토어 맞춤 포토부스 렌탈."
  keywords="천안 포토부스, 천안 포토부스 대여, 불당동 포토부스, 신부동 포토부스, 천안아산역 포토부스, 아산 포토부스, 천안 웨딩 포토부스, 천안 비렌티웨딩 포토부스, 심플큐브 천안"
  ogImage="/images/photobooth-rental-simplecube.jpg"
  transparentNav={false}
>
  <BreadcrumbSchema items={[
    { name: '포토부스 대여', url: '/rental' },
    { name: '천안 포토부스', url: '/cheonan' },
  ]} />
  <ServiceSchema services={[
    {
      name: '천안 포토부스 대여 — 천안·아산 전 지역 출장 설치',
      description: '심플큐브의 천안 포토부스 대여 서비스. 불당동, 신부동, 천안아산역, 아산 등 천안 전 지역 출장 설치. 웨딩, 기업행사, 팝업스토어, 페스티벌 맞춤 포토부스 렌탈. 대전 지점에서 출장.',
      url: '/cheonan',
    },
  ]} />
  {faqItems.length > 0 && <FAQSchema faqs={faqItems} />}

  <!-- Hero -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">천안 포토부스 대여</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">CHEONAN</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">불당동, 신부동, 천안아산역, 아산 — 천안·아산 전 지역 출장 설치</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cheonan service introduction -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">01</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">CHEONAN SERVICE</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">천안 포토부스 서비스</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="space-y-4 text-sm leading-relaxed text-secondary">
          <p>
            <strong>심플큐브</strong>는 천안 전 지역에 포토부스 출장 설치를 제공하는 <strong>천안 포토부스 대여 전문 업체</strong>입니다.
            불당동, 신부동, 두정동, 천안아산역, 백석동, 아산시 등 천안·아산 어디든 설치가 가능하며,
            결혼식, 기업행사, 브랜드 팝업스토어, 페스티벌 등 행사 유형에 맞는 맞춤형 포토부스를 제공합니다.
          </p>
          <p>
            대전 지점이 인접해 있어 천안·아산 전 지역으로 빠르게 출장이 가능합니다.
            장비 설치부터 운영, 철거까지 원스톱으로 진행하며, 원목 소재의 프리미엄 포토부스, 브랜딩이 가능한 커스텀 부스 등 다양한 옵션을 갖추고 있습니다.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">14,000+</span>
            <span class="block mt-1 text-xs text-secondary">전체 누적 행사</span>
          </div>
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">대전 지점</span>
            <span class="block mt-1 text-xs text-secondary">출장 운영</span>
          </div>
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">당일</span>
            <span class="block mt-1 text-xs text-secondary">설치 · 철거</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Popular event types in Cheonan -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">EVENT TYPES</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">천안 인기 행사 유형</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/wedding" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">웨딩 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">불당동 · 천안아산역</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">상록리조트 천안, 불당동·아산 주요 웨딩홀에서 가장 많이 찾는 포토부스. 하객 포토 서비스로 결혼식의 추억을 선물합니다.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/corporate" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">기업행사 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">아산테크노밸리 · 천안산단</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">아산테크노밸리, 천안산업단지, 삼성디스플레이, 현대자동차 아산공장 등 천안·아산 기업행사를 위한 포토부스 렌탈.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">팝업스토어 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">불당동 · 신부동</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">불당동 갤러리아 센터시티, 신부동 신세계백화점, 천안 핫플레이스 팝업스토어를 위한 커스텀 포토부스. 브랜드 맞춤 디자인.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">페스티벌 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">독립기념관 · 흥타령</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">독립기념관, 천안흥타령춤축제, 아산 외암민속마을 등 천안·아산 대표 야외 행사장에서의 페스티벌 포토부스 렌탈.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Cheonan installation areas -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">03</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">AREAS</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">천안 주요 설치 지역</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { area: '불당동 · 백석동', venues: '갤러리아 센터시티, 불당동 웨딩홀, 백석동 행사장, 호텔 인근', highlight: true },
          { area: '신부동 · 천안역', venues: '신세계백화점 천안, 신부동 상권, 천안역 동·서광장', highlight: false },
          { area: '두정동 · 성정동', venues: '두정동 상권, 성정동 카페거리, 두정역 인근 행사장', highlight: false },
          { area: '천안아산역 · 배방', venues: 'KTX 천안아산역, 배방읍 펜타포트, 아산테크노밸리', highlight: false },
          { area: '아산 · 온양', venues: '온양관광호텔, 온양온천, 아산 외암민속마을, 아산시청', highlight: false },
          { area: '동남구 · 외곽', venues: '독립기념관, 광덕산, 천안삼거리공원, 동남구청 인근', highlight: false },
          { area: '서북구 · 입장', venues: '서북구청, 입장 산업단지, 직산읍 행사장', highlight: false },
          { area: '기타 천안·충남', venues: '아산·평택·세종 등 인근 어디든 출장 설치 가능. 맞춤 견적 안내.', highlight: false },
        ].map(item => (
          <div class:list={[
            'rounded-lg border p-5',
            item.highlight ? 'border-olive/40 bg-olive/5' : 'border-border-light bg-white'
          ]}>
            <h3 class="text-base font-semibold text-primary">{item.area}</h3>
            <p class="mt-2 text-sm text-secondary leading-relaxed">{item.venues}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <RegionUniqueInfo
    city="천안"
    cityEn="CHEONAN"
    branchOrigin="심플큐브 대전 지점"
    highlights={[
      { label: 'NEAREST BRANCH', value: '대전 지점 — 약 50분' },
      { label: 'COVERAGE', value: '천안·아산·평택권 당일 출장' },
      { label: 'RESPONSE', value: '평일 일과시간 내 30분 내 견적 회신' },
    ]}
    localStory={`<strong>천안</strong>은 KTX 천안아산역을 거점으로 수도권과 충청권을 연결하는 핵심 도시로, 불당동·신부지구의 신축 웨딩홀과 두정동·성정동의 신혼부부 인구가 빠르게 늘고 있습니다. 심플큐브는 대전 지점에서 50분 내 도착하며, 매주 2~3건의 천안·아산 결혼식 포토부스를 운영합니다.`}
    serviceTrend={`또한 KTX 역사 상권과 백화점·아울렛이 밀집한 천안아산 권역은 브랜드 <a href="/popup" class="text-olive underline">팝업스토어 포토부스</a> 설치도 활발합니다. 신부동 갤러리아 백화점, 천안아산역 인근 갤러리, 아산 신정호 행사장 등에서 최근 가장 자주 진행되었습니다.`}
    priceRows={[
      { type: '천안·아산 시내', detail: '동남·서북·불당·신부·두정·아산 — 별도 문의' },
      { type: '인접 권역', detail: '평택·안성·세종·공주 — 별도 문의' },
      { type: '운영 시간 (웨딩)', detail: '본식 90분 전 설치 → 예식 시작 후 30분까지 운영', note: '식장 상황·요청에 따라 조정 가능' },
      { type: '운영 시간 (팝업·기업)', detail: '최소 2시간부터 예약 가능', note: '일·주·월 단위 장기 예약 가능' },
    ]}
    nearbyAreas={[
      { name: '대전 포토부스', url: '/daejeon', note: '본 지점' },
      { name: '청주 포토부스', url: '/cheongju', note: '60분' },
      { name: '아산', note: '천안 권역' },
      { name: '평택', note: '협의 출장' },
      { name: '안성', note: '협의 출장' },
      { name: '진천', note: '협의 출장' },
    ]}
    bestVenues={[
      { category: '천안 대형 웨딩 컨벤션', venues: '천안 비렌티웨딩, CA웨딩컨벤션 (KTX 천안아산역), 천안웨딩베리컨벤션, 티웨딩 천안, 더포레 천안' },
      { category: 'KTX 천안아산역 권역', venues: 'CA웨딩컨벤션 (천안아산역사 2층), KTX역 인근 행사장, 신부동 갤러리아 센터시티' },
      { category: '신부·두정 신도심', venues: '신부동 갤러리아 센터시티, 신부동 상권, 두정동 카페거리' },
      { category: '아산 온양·탕정', venues: '온양관광호텔, 신정호 카페거리, 탕정 신도시 행사장, 아산테크노밸리' },
      { category: '동남구·구도심', venues: '천안종합운동장, 천안 구시가지 카페거리, 단국대 천안캠퍼스 행사장' },
      { category: '인근 평택·안성', venues: '평택·안성·진천 인근 행사장' },
    ]}
  />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Machine Showcase -->
  <MachineShowcase />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Client Showcase -->
  <ClientShowcase />

  <!-- FAQ -->
  {faqItems.length > 0 && (
    <Fragment>
    <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
    <section id="qna" class="bg-white py-12 lg:py-16">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <div class="mb-10">
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">06</div>
          <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">FAQ</span>
          <h2 class="mt-3 text-2xl font-bold text-primary md:text-3xl">천안 포토부스 자주 묻는 질문</h2>
          <div class="mt-4 h-[2px] w-8 bg-olive"></div>
        </div>
        <AccordionList items={faqItems} />
      </div>
    </section>
    </Fragment>
  )}

  <!-- CTA -->
  <section class="bg-[#6B5B4D] py-12 lg:py-16">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-[#FFFAF4] md:text-3xl">천안 지역 맞춤 견적 받기</h2>
      <p class="mt-4 text-sm text-[#FFFAF4]/60 leading-relaxed">
        천안·아산 행사 일정과 장소를 알려주시면, 대전 지점에서 빠르게 출장 견적을 안내해드립니다.
      </p>
