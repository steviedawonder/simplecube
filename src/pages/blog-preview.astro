---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>블로그 포스트 미리보기</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Pretendard', -apple-system, sans-serif; background: #f5f5f0; color: #333; }
    .header { background: #2c2c2c; color: white; padding: 2rem; text-align: center; }
    .header h1 { font-size: 1.5rem; margin-bottom: 0.5rem; }
    .header p { color: #aaa; font-size: 0.9rem; }
    .grid { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 1.5rem; }
    .card { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); transition: transform 0.2s; }
    .card:hover { transform: translateY(-4px); box-shadow: 0 4px 16px rgba(0,0,0,0.12); }
    .card img { width: 100%; height: 200px; object-fit: cover; }
    .card-body { padding: 1.25rem; }
    .category { display: inline-block; background: #b8a88a; color: white; font-size: 0.75rem; padding: 0.2rem 0.6rem; border-radius: 4px; margin-bottom: 0.5rem; }
    .card-body h2 { font-size: 1.1rem; line-height: 1.5; margin-bottom: 0.5rem; color: #2c2c2c; }
    .card-body p { font-size: 0.85rem; color: #666; line-height: 1.6; margin-bottom: 0.75rem; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tag { font-size: 0.7rem; background: #f0ede6; color: #888; padding: 0.15rem 0.5rem; border-radius: 3px; }
    .date { font-size: 0.75rem; color: #aaa; }
    .badge { display: inline-block; background: #e74c3c; color: white; font-size: 0.65rem; padding: 0.15rem 0.4rem; border-radius: 3px; margin-left: 0.5rem; }
    .stats { max-width: 1200px; margin: 0 auto; padding: 1rem; display: flex; gap: 1rem; flex-wrap: wrap; }
    .stat { background: white; padding: 1rem 1.5rem; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .stat strong { font-size: 1.5rem; color: #b8a88a; }
    .stat span { display: block; font-size: 0.8rem; color: #888; margin-top: 0.25rem; }
    a { text-decoration: none; color: inherit; }
  </style>
</head>
<body>
  <div class="header">
    <h1>📝 SEO 블로그 포스트 미리보기</h1>
    <p>Phase 2에서 생성된 콘텐츠 컬렉션 블로그 포스트 목록 (DB가 아닌 마크다운 파일)</p>
  </div>

  <div class="stats">
    <div class="stat">
      <strong>{sortedPosts.length}</strong>
      <span>총 포스트 수</span>
    </div>
    <div class="stat">
      <strong>{sortedPosts.filter(p => p.data.category === '가이드').length}</strong>
      <span>가이드</span>
    </div>
    <div class="stat">
      <strong>{sortedPosts.filter(p => p.data.category === '비교가이드').length}</strong>
      <span>비교가이드 (GEO)</span>
    </div>
    <div class="stat">
      <strong>{sortedPosts.filter(p => p.data.category === '지역가이드').length}</strong>
      <span>지역가이드</span>
    </div>
    <div class="stat">
      <strong>{sortedPosts.filter(p => p.data.category === '트렌드').length}</strong>
      <span>트렌드</span>
    </div>
  </div>

  <div class="grid">
    {sortedPosts.map((post) => (
      <a href={`/blog-preview/${post.id}`} class="card">
        {post.data.image && <img src={post.data.image} alt={post.data.title} loading="lazy" />}
        <div class="card-body">
          <span class="category">{post.data.category}</span>
          {post.data.tags?.some(t => t.includes('GEO') || t.includes('추천') || t.includes('비교')) && <span class="badge">GEO</span>}
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <div class="tags">
            {post.data.tags?.map(tag => <span class="tag">#{tag}</span>)}
          </div>
          <div class="date" style="margin-top: 0.5rem;">{post.data.date.toLocaleDateString('ko-KR')}</div>
        </div>
      </a>
    ))}
  </div>
</body>
</html>
