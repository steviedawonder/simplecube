---
import BaseLayout from '@layouts/BaseLayout.astro';

const models = [
  {
    id: 'popup-booth',
    modelNo: 'PHOTO-P-320AL',
    name: '팝업부스',
    badge: '추천',
    image: '/images/popup/popup-model.png',
    specs: [
      { label: '소재', value: '알루미늄 (화이트)' },
      { label: '크기', value: 'W460 × L480 × H1700mm' },
      { label: '사용전력', value: '300w (최대 700w)' },
      { label: '촬영방식', value: 'DSLR 무료촬영' },
    ],
  },
  {
    id: 'module',
    modelNo: 'PHOTO-M-270AC',
    name: '모듈형',
    badge: '추천',
    image: '/images/popup/module-model.png',
    specs: [
      { label: '소재', value: '아크릴 (블랙)' },
      { label: '크기', value: 'W600 × L450 × H1900mm' },
      { label: '사용전력', value: '400w (최대 700w)' },
      { label: '촬영방식', value: 'DSLR 무료촬영' },
    ],
  },
  {
    id: 'wood-edge',
    modelNo: 'PHOTO-W-270ED',
    name: '우드 (Edge)',
    badge: '',
    image: '/images/popup/wood-edge.jpg',
    specs: [
      { label: '소재', value: '원목 자체제작' },
      { label: '크기', value: 'W700 × L480 × H1950mm' },
      { label: '사용전력', value: '400w (최대 700w)' },
      { label: '촬영방식', value: 'DSLR 무료촬영' },
    ],
  },
  {
    id: 'wood-round',
    modelNo: 'PHOTO-W-270RD',
    name: '우드 (Round)',
    badge: '',
    image: '/images/popup/wood-round.png',
    specs: [
      { label: '소재', value: '원목 자체제작 (라운드)' },
      { label: '크기', value: 'W680 × L470 × H1950mm' },
      { label: '사용전력', value: '400w (최대 700w)' },
      { label: '촬영방식', value: 'DSLR 무료촬영' },
    ],
  },
];
---

<BaseLayout title="모달 애니메이션 테스트" transparentNav={false}>
  <div class="pt-24 pb-24 bg-bg-light">
    <div class="mx-auto max-w-6xl px-6">
      <h1 class="text-3xl font-bold text-primary mb-2">모달 애니메이션 비교</h1>
      <p class="text-sm text-secondary mb-12">모델 카드를 클릭했을 때의 상세보기 모션을 비교합니다. 각 버전의 카드를 클릭해보세요.</p>

      <!-- ===== Version A: 카드 확장형 ===== -->
      <section class="mb-20">
        <div class="mb-4">
          <h2 class="text-lg font-bold text-primary mb-1">A. 카드 확장형</h2>
          <p class="text-xs text-secondary">클릭한 카드 이미지가 중앙으로 날아오면서 확대되고, 스펙이 아래에서 슬라이드업됩니다.</p>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          {models.map((model) => (
            <button
              class="card-a group relative flex flex-col rounded-xl border border-border-light bg-white overflow-hidden hover:border-olive/40 hover:shadow-lg text-left transition-all duration-300"
              data-model={JSON.stringify(model)}
            >
              {model.badge && (
                <span class="absolute top-2 right-2 text-white text-[9px] font-bold px-2 py-1 rounded-full z-10 bg-olive">{model.badge}</span>
              )}
              <div class="flex items-center justify-center bg-[#f5f5f3] p-4 aspect-[3/4]">
                <img src={model.image} alt={model.name} class="h-full w-auto object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="px-3 py-2.5">
                <h3 class="text-sm font-bold text-primary">{model.name}</h3>
                <p class="text-[10px] text-secondary/60 mt-0.5">{model.modelNo}</p>
              </div>
            </button>
          ))}
        </div>
      </section>

      <!-- ===== Version B: 바텀시트형 ===== -->
      <section class="mb-20">
        <div class="mb-4">
          <h2 class="text-lg font-bold text-primary mb-1">B. 바텀시트형</h2>
          <p class="text-xs text-secondary">배경이 어두워지면서 하단에서 시트가 올라옵니다. 이미지가 상단에 작게 배치되고 스펙이 아래에 표시됩니다.</p>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          {models.map((model) => (
            <button
              class="card-b group relative flex flex-col rounded-xl border border-border-light bg-white overflow-hidden hover:border-olive/40 hover:shadow-lg text-left transition-all duration-300"
              data-model={JSON.stringify(model)}
            >
              {model.badge && (
                <span class="absolute top-2 right-2 text-white text-[9px] font-bold px-2 py-1 rounded-full z-10 bg-olive">{model.badge}</span>
              )}
              <div class="flex items-center justify-center bg-[#f5f5f3] p-4 aspect-[3/4]">
                <img src={model.image} alt={model.name} class="h-full w-auto object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="px-3 py-2.5">
                <h3 class="text-sm font-bold text-primary">{model.name}</h3>
                <p class="text-[10px] text-secondary/60 mt-0.5">{model.modelNo}</p>
              </div>
            </button>
          ))}
        </div>
      </section>

      <!-- ===== Version C: 인라인 확장형 ===== -->
      <section class="mb-20">
        <div class="mb-4">
          <h2 class="text-lg font-bold text-primary mb-1">C. 인라인 확장형</h2>
          <p class="text-xs text-secondary">클릭한 카드 아래에 상세 패널이 펼쳐집니다. 페이지 이탈감 없이 자연스러운 흐름.</p>
        </div>
        <div id="grid-c" class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          {models.map((model) => (
            <button
              class="card-c group relative flex flex-col rounded-xl border border-border-light bg-white overflow-hidden hover:border-olive/40 hover:shadow-lg text-left transition-all duration-300"
              data-model={JSON.stringify(model)}
            >
              {model.badge && (
                <span class="absolute top-2 right-2 text-white text-[9px] font-bold px-2 py-1 rounded-full z-10 bg-olive">{model.badge}</span>
              )}
              <div class="flex items-center justify-center bg-[#f5f5f3] p-4 aspect-[3/4]">
                <img src={model.image} alt={model.name} class="h-full w-auto object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="px-3 py-2.5">
                <h3 class="text-sm font-bold text-primary">{model.name}</h3>
                <p class="text-[10px] text-secondary/60 mt-0.5">{model.modelNo}</p>
              </div>
            </button>
          ))}
        </div>
        <!-- Inline detail panel (spans full width below grid) -->
        <div id="detail-c" class="hidden mt-3 rounded-xl border border-olive/20 bg-white shadow-lg" style="max-height:0;opacity:0;overflow:hidden;transition:max-height 0.4s ease-out, opacity 0.3s ease-out;">
        </div>
      </section>

      <!-- ===== Version D: 센터 팝업 (컴팩트) ===== -->
      <section class="mb-20">
        <div class="mb-4">
          <h2 class="text-lg font-bold text-primary mb-1">D. 센터 팝업 (컴팩트)</h2>
          <p class="text-xs text-secondary">화면 중앙에 작은 카드형 팝업이 스케일업으로 나타납니다. 전체화면을 차지하지 않아 페이지 이탈감이 없습니다.</p>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          {models.map((model) => (
            <button
              class="card-d group relative flex flex-col rounded-xl border border-border-light bg-white overflow-hidden hover:border-olive/40 hover:shadow-lg text-left transition-all duration-300"
              data-model={JSON.stringify(model)}
            >
              {model.badge && (
                <span class="absolute top-2 right-2 text-white text-[9px] font-bold px-2 py-1 rounded-full z-10 bg-olive">{model.badge}</span>
              )}
              <div class="flex items-center justify-center bg-[#f5f5f3] p-4 aspect-[3/4]">
                <img src={model.image} alt={model.name} class="h-full w-auto object-contain transition-transform duration-500 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="px-3 py-2.5">
                <h3 class="text-sm font-bold text-primary">{model.name}</h3>
                <p class="text-[10px] text-secondary/60 mt-0.5">{model.modelNo}</p>
              </div>
            </button>
          ))}
        </div>
      </section>

    </div>
  </div>

  <!-- ===== Modal A: 카드 확장형 ===== -->
  <div id="modal-a" class="fixed inset-0 z-[9998] hidden" style="pointer-events:none;">
    <div class="modal-a-backdrop absolute inset-0 bg-black/0 transition-all duration-500" style="pointer-events:auto;"></div>
    <div class="relative z-10 h-full flex items-start justify-center overflow-y-auto" style="pointer-events:none;">
      <div class="modal-a-content w-full max-w-lg mx-4 mt-[10vh] mb-10" style="pointer-events:auto;">
        <!-- Flying image -->
        <div class="modal-a-image rounded-2xl bg-[#f5f5f3] flex items-center justify-center p-8 opacity-0 scale-75 transition-all duration-500 ease-out">
          <img id="modal-a-img" src="" alt="" class="h-[200px] lg:h-[280px] w-auto object-contain" />
        </div>
        <!-- Specs sliding up -->
        <div class="modal-a-specs bg-white rounded-2xl mt-3 overflow-hidden opacity-0 translate-y-6 transition-all duration-500 ease-out delay-200 shadow-xl">
          <div class="px-5 py-4 border-b border-border-light flex items-center justify-between">
            <div>
              <p class="text-[10px] font-medium tracking-widest text-secondary/50 uppercase" id="modal-a-model-no"></p>
              <h3 class="text-lg font-bold text-primary" id="modal-a-name"></h3>
            </div>
            <button class="modal-a-close p-1.5 rounded-full hover:bg-[#f5f5f3] transition-colors" style="pointer-events:auto;cursor:pointer;">
              <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <div id="modal-a-specs" class="px-5 py-4"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Modal B: 바텀시트형 ===== -->
  <div id="modal-b" class="fixed inset-0 z-[9998] hidden" style="pointer-events:none;">
    <div class="modal-b-backdrop absolute inset-0 bg-black/0 transition-all duration-400" style="pointer-events:auto;"></div>
    <div class="relative z-10 h-full flex items-end" style="pointer-events:none;">
      <div class="modal-b-sheet w-full bg-white rounded-t-3xl max-h-[85vh] overflow-y-auto translate-y-full transition-transform duration-500 ease-out shadow-2xl" style="pointer-events:auto;">
        <!-- Handle bar -->
        <div class="sticky top-0 z-10 bg-white pt-3 pb-2 flex justify-center rounded-t-3xl">
          <div class="w-10 h-1 rounded-full bg-border-light"></div>
        </div>
        <!-- Image + close -->
        <div class="relative flex items-center justify-center bg-[#f5f5f3] mx-4 rounded-xl p-6 mb-4">
          <img id="modal-b-img" src="" alt="" class="h-[160px] lg:h-[220px] w-auto object-contain" />
          <button class="modal-b-close absolute top-3 right-3 p-1.5 rounded-full bg-white/80 hover:bg-white transition-colors shadow-sm" style="pointer-events:auto;cursor:pointer;">
            <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <!-- Content -->
        <div class="px-5 pb-8">
          <p class="text-[10px] font-medium tracking-widest text-secondary/50 uppercase" id="modal-b-model-no"></p>
          <h3 class="text-xl font-bold text-primary mt-1 mb-4" id="modal-b-name"></h3>
          <div id="modal-b-specs"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== Modal D: 센터 팝업 (컴팩트) ===== -->
  <div id="modal-d" class="fixed inset-0 z-[9998] hidden" style="pointer-events:none;">
    <div class="modal-d-backdrop absolute inset-0 bg-black/0 transition-all duration-400" style="pointer-events:auto;"></div>
    <div class="relative z-10 h-full flex items-center justify-center px-6" style="pointer-events:none;">
      <div class="modal-d-card w-full max-w-sm bg-white rounded-2xl overflow-hidden shadow-2xl opacity-0 scale-90 transition-all duration-400 ease-out" style="pointer-events:auto;">
        <!-- Image -->
        <div class="relative flex items-center justify-center bg-[#f5f5f3] p-6">
          <img id="modal-d-img" src="" alt="" class="h-[180px] lg:h-[240px] w-auto object-contain" />
          <button class="modal-d-close absolute top-3 right-3 p-1.5 rounded-full bg-white/80 hover:bg-white transition-colors shadow-sm" style="pointer-events:auto;cursor:pointer;">
            <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <!-- Content -->
        <div class="px-5 py-5">
          <p class="text-[10px] font-medium tracking-widest text-secondary/50 uppercase" id="modal-d-model-no"></p>
          <h3 class="text-lg font-bold text-primary mt-0.5 mb-4" id="modal-d-name"></h3>
          <div id="modal-d-specs"></div>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<script>
{
  // === Helper: build specs HTML ===
  function buildSpecs(specs: any[]) {
    return specs.map((s: any, i: number) => `
      <div class="flex items-baseline justify-between py-2.5 ${i < specs.length - 1 ? 'border-b border-dashed border-[#e5e5e3]' : ''}">
        <span class="text-[12px] text-[#888]">${s.label}</span>
        <span class="text-[13px] font-semibold text-[#1d1d1f]">${s.value}</span>
      </div>
    `).join('');
  }

  // ===== VERSION A: 카드 확장형 =====
  const modalA = document.getElementById('modal-a') as HTMLDivElement;
  const modalABackdrop = modalA.querySelector('.modal-a-backdrop') as HTMLDivElement;
  const modalAImage = modalA.querySelector('.modal-a-image') as HTMLDivElement;
  const modalASpecs = modalA.querySelector('.modal-a-specs') as HTMLDivElement;
  const modalACloseBtn = modalA.querySelector('.modal-a-close') as HTMLButtonElement;

  function openA(model: any) {
    (document.getElementById('modal-a-img') as HTMLImageElement).src = model.image;
    (document.getElementById('modal-a-name') as HTMLElement).textContent = model.name;
    (document.getElementById('modal-a-model-no') as HTMLElement).textContent = model.modelNo;
    (document.getElementById('modal-a-specs') as HTMLElement).innerHTML = buildSpecs(model.specs);

    modalA.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      modalABackdrop.classList.replace('bg-black/0', 'bg-black/50');
      modalAImage.classList.remove('opacity-0', 'scale-75');
      modalAImage.classList.add('opacity-100', 'scale-100');
      modalASpecs.classList.remove('opacity-0', 'translate-y-6');
      modalASpecs.classList.add('opacity-100', 'translate-y-0');
    });
  }

  function closeA() {
    if (modalA.classList.contains('hidden')) return;
    modalABackdrop.classList.replace('bg-black/50', 'bg-black/0');
    modalAImage.classList.remove('opacity-100', 'scale-100');
    modalAImage.classList.add('opacity-0', 'scale-75');
    modalASpecs.classList.remove('opacity-100', 'translate-y-0');
    modalASpecs.classList.add('opacity-0', 'translate-y-6');
    setTimeout(() => {
      modalA.classList.add('hidden');
      document.body.style.overflow = '';
    }, 500);
  }

  document.querySelectorAll('.card-a').forEach(btn => {
    btn.addEventListener('click', () => {
      const model = JSON.parse((btn as HTMLElement).dataset.model || '{}');
      openA(model);
    });
  });
  modalACloseBtn.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); closeA(); });
  modalABackdrop.addEventListener('click', (e) => { if (e.target === modalABackdrop) closeA(); });

  // ===== VERSION B: 바텀시트형 =====
  const modalB = document.getElementById('modal-b') as HTMLDivElement;
  const modalBBackdrop = modalB.querySelector('.modal-b-backdrop') as HTMLDivElement;
  const modalBSheet = modalB.querySelector('.modal-b-sheet') as HTMLDivElement;
  const modalBCloseBtn = modalB.querySelector('.modal-b-close') as HTMLButtonElement;

  function openB(model: any) {
    (document.getElementById('modal-b-img') as HTMLImageElement).src = model.image;
    (document.getElementById('modal-b-name') as HTMLElement).textContent = model.name;
    (document.getElementById('modal-b-model-no') as HTMLElement).textContent = model.modelNo;
    (document.getElementById('modal-b-specs') as HTMLElement).innerHTML = buildSpecs(model.specs);

    modalB.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      modalBBackdrop.classList.replace('bg-black/0', 'bg-black/50');
      modalBSheet.classList.remove('translate-y-full');
      modalBSheet.classList.add('translate-y-0');
    });
  }

  function closeB() {
    if (modalB.classList.contains('hidden')) return;
    modalBBackdrop.classList.replace('bg-black/50', 'bg-black/0');
    modalBSheet.classList.remove('translate-y-0');
    modalBSheet.classList.add('translate-y-full');
    setTimeout(() => {
      modalB.classList.add('hidden');
      document.body.style.overflow = '';
    }, 500);
  }

  document.querySelectorAll('.card-b').forEach(btn => {
    btn.addEventListener('click', () => {
      const model = JSON.parse((btn as HTMLElement).dataset.model || '{}');
      openB(model);
    });
  });
  modalBCloseBtn.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); closeB(); });
  modalBBackdrop.addEventListener('click', (e) => { if (e.target === modalBBackdrop) closeB(); });
  // Also close B when clicking outside the sheet (on the wrapper area)
  modalBSheet.addEventListener('click', (e) => { e.stopPropagation(); });

  // ===== VERSION C: 인라인 확장형 =====
  const detailC = document.getElementById('detail-c') as HTMLDivElement;
  let activeCBtn: HTMLElement | null = null;

  function closeC() {
    detailC.style.overflow = 'hidden';
    detailC.style.maxHeight = '0px';
    detailC.style.opacity = '0';
    setTimeout(() => {
      detailC.classList.add('hidden');
      detailC.innerHTML = '';
      if (activeCBtn) activeCBtn.classList.remove('ring-2', 'ring-olive');
      activeCBtn = null;
    }, 400);
  }

  document.querySelectorAll('.card-c').forEach(btn => {
    btn.addEventListener('click', () => {
      const model = JSON.parse((btn as HTMLElement).dataset.model || '{}');

      // If same card clicked, toggle close
      if (activeCBtn === btn && !detailC.classList.contains('hidden')) {
        closeC();
        return;
      }

      // Highlight active card
      if (activeCBtn) activeCBtn.classList.remove('ring-2', 'ring-olive');
      (btn as HTMLElement).classList.add('ring-2', 'ring-olive');
      activeCBtn = btn as HTMLElement;

      // Build content
      detailC.innerHTML = `
        <div class="flex flex-col sm:flex-row gap-4 p-5">
          <div class="flex items-center justify-center bg-[#f5f5f3] rounded-xl p-5 sm:w-[180px] shrink-0">
            <img src="${model.image}" alt="${model.name}" class="h-[120px] w-auto object-contain" />
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between mb-3">
              <div>
                <p class="text-[10px] font-medium tracking-widest text-secondary/50 uppercase">${model.modelNo}</p>
                <h4 class="text-base font-bold text-primary">${model.name}</h4>
              </div>
              <button class="close-c-btn p-1.5 rounded-full hover:bg-[#f5f5f3] transition-colors">
                <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
            </div>
            ${buildSpecs(model.specs)}
          </div>
        </div>
      `;

      // Bind close button immediately after building content
      const closeCBtn = detailC.querySelector('.close-c-btn');
      if (closeCBtn) {
        closeCBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          e.preventDefault();
          closeC();
        });
      }

      detailC.classList.remove('hidden');
      detailC.style.overflow = 'hidden';
      detailC.style.maxHeight = '0px';
      detailC.style.opacity = '0';

      requestAnimationFrame(() => {
        const fullHeight = detailC.scrollHeight;
        detailC.style.maxHeight = fullHeight + 'px';
        detailC.style.opacity = '1';

        // After animation completes, remove height constraint so all content is visible
        setTimeout(() => {
          detailC.style.maxHeight = 'none';
          detailC.style.overflow = 'visible';
        }, 450);
      });

      setTimeout(() => {
        detailC.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 150);
    });
  });

  // ===== VERSION D: 센터 팝업 (컴팩트) =====
  const modalD = document.getElementById('modal-d') as HTMLDivElement;
  const modalDBackdrop = modalD.querySelector('.modal-d-backdrop') as HTMLDivElement;
  const modalDCard = modalD.querySelector('.modal-d-card') as HTMLDivElement;
  const modalDCloseBtn = modalD.querySelector('.modal-d-close') as HTMLButtonElement;

  function openD(model: any) {
    (document.getElementById('modal-d-img') as HTMLImageElement).src = model.image;
    (document.getElementById('modal-d-name') as HTMLElement).textContent = model.name;
    (document.getElementById('modal-d-model-no') as HTMLElement).textContent = model.modelNo;
    (document.getElementById('modal-d-specs') as HTMLElement).innerHTML = buildSpecs(model.specs);

    modalD.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      modalDBackdrop.classList.replace('bg-black/0', 'bg-black/40');
      modalDCard.classList.remove('opacity-0', 'scale-90');
      modalDCard.classList.add('opacity-100', 'scale-100');
    });
  }

  function closeD() {
    if (modalD.classList.contains('hidden')) return;
    modalDBackdrop.classList.replace('bg-black/40', 'bg-black/0');
    modalDCard.classList.remove('opacity-100', 'scale-100');
    modalDCard.classList.add('opacity-0', 'scale-90');
    setTimeout(() => {
      modalD.classList.add('hidden');
      document.body.style.overflow = '';
    }, 400);
  }

  document.querySelectorAll('.card-d').forEach(btn => {
    btn.addEventListener('click', () => {
      const model = JSON.parse((btn as HTMLElement).dataset.model || '{}');
      openD(model);
    });
  });
  modalDCloseBtn.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); closeD(); });
  modalDBackdrop.addEventListener('click', (e) => { if (e.target === modalDBackdrop) closeD(); });
  // Prevent clicks inside the card from reaching the backdrop
  modalDCard.addEventListener('click', (e) => { e.stopPropagation(); });

  // ===== Global ESC =====
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (!modalA.classList.contains('hidden')) closeA();
      if (!modalB.classList.contains('hidden')) closeB();
      if (!modalD.classList.contains('hidden')) closeD();
    }
  });
}
</script>
