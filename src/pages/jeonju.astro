---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import MachineShowcase from '@components/popup/MachineShowcase.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import RegionUniqueInfo from '@components/region/RegionUniqueInfo.astro';
import db from '@lib/db';

const [jeonjuFaqResult, rentalFaqResult, popupFaqResult] = await Promise.all([
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['jeonju'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['rental'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['popup'] }),
]);
const faqItems = (
  jeonjuFaqResult.rows.length > 0 ? jeonjuFaqResult.rows
  : rentalFaqResult.rows.length > 0 ? rentalFaqResult.rows
  : popupFaqResult.rows
) as { question: string; answer: string }[];
---

<BaseLayout
  title="전주 포토부스 대여 | 한옥마을·서신동·완산구 출장 설치 — 심플큐브"
  description="전주 전 지역 포토부스 출장 설치. 전주한옥마을, 서신동, 완산구, 덕진구 등 전주 어디든 설치 가능. 웨딩, 기업행사, 팝업스토어 맞춤 포토부스. 심플큐브 전주 지점 직접 운영."
  keywords="전주 포토부스, 전주 포토부스 대여, 한옥마을 포토부스, 서신동 포토부스, 완산구 포토부스, 전주 웨딩 포토부스, 전주 팝업 포토부스, JIFF 포토부스, 심플큐브 전주"
  ogImage="/images/photobooth-rental-simplecube.jpg"
  transparentNav={false}
>
  <BreadcrumbSchema items={[
    { name: '포토부스 대여', url: '/rental' },
    { name: '전주 포토부스', url: '/jeonju' },
  ]} />
  <ServiceSchema services={[
    {
      name: '전주 포토부스 대여 — 전주 전 지역 출장 설치',
      description: '심플큐브의 전주 포토부스 대여 서비스. 전주한옥마을, 서신동, 완산구, 덕진구 등 전주 전 지역 출장 설치. 웨딩, 기업행사, 팝업스토어, 페스티벌 맞춤 포토부스 렌탈. 전주 지점 직접 운영.',
      url: '/jeonju',
    },
  ]} />
  {faqItems.length > 0 && <FAQSchema faqs={faqItems} />}

  <!-- Hero -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">전주 포토부스 대여</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">JEONJU</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">한옥마을, 서신동, 완산구, 덕진구 — 전주 전 지역 출장 설치</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Jeonju service introduction -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">01</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">JEONJU SERVICE</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">전주 포토부스 서비스</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="space-y-4 text-sm leading-relaxed text-secondary">
          <p>
            <strong>심플큐브 전주 지점</strong>은 전주 전 지역에 포토부스 출장 설치를 제공하는 <strong>전주 포토부스 대여 전문 업체</strong>입니다.
            전주한옥마을, 서신동, 효자동, 송천동, 완산구, 덕진구 등 전주 어디든 당일 설치가 가능하며,
            결혼식, 기업행사, 브랜드 팝업스토어, 페스티벌 등 행사 유형에 맞는 맞춤형 포토부스를 제공합니다.
          </p>
          <p>
            전주 현지 지점이 직접 운영하므로 빠른 응대와 합리적인 견적이 가능합니다.
            장비 설치부터 운영, 철거까지 원스톱으로 진행하며, 원목 소재의 프리미엄 포토부스, 브랜딩이 가능한 커스텀 부스 등 다양한 옵션을 갖추고 있습니다.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">14,000+</span>
            <span class="block mt-1 text-xs text-secondary">전체 누적 행사</span>
          </div>
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">전주 지점</span>
            <span class="block mt-1 text-xs text-secondary">직접 운영</span>
          </div>
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">당일</span>
            <span class="block mt-1 text-xs text-secondary">설치 · 철거</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Popular event types in Jeonju -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">EVENT TYPES</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">전주 인기 행사 유형</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/wedding" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">웨딩 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">서신동 · 효자동</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">베스트웨스턴 전주, 르윈호텔, 라한호텔, 서신동·효자동 주요 웨딩홀에서 가장 많이 찾는 포토부스. 하객 포토 서비스로 결혼식의 추억을 선물합니다.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/corporate" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">기업행사 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">완산구 · 덕진구</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">전북도청, 전주시청, 농촌진흥청, 전주첨단벤처단지 등 전주·전북 기업·공공행사를 위한 포토부스 렌탈.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">팝업스토어 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">한옥마을 · 객리단길</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">전주한옥마을, 객리단길, 풍남문 인근, 전주 핫플레이스 팝업스토어를 위한 커스텀 포토부스. 한옥 감성 맞춤 디자인.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">페스티벌 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">덕진공원 · 한옥마을</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">전주국제영화제, 전주비빔밥축제, 한옥마을 야간 행사 등 전주 대표 야외 행사장에서의 페스티벌·축제 포토부스 렌탈.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Jeonju installation areas -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">03</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">AREAS</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">전주 주요 설치 지역</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { area: '한옥마을 · 풍남동', venues: '전주한옥마을, 경기전, 풍남문, 객리단길, 라한호텔 전주', highlight: true },
          { area: '서신동 · 중화산', venues: '서신동 웨딩홀, 중화산동 행사장, 베스트웨스턴 전주, 롯데백화점 전주', highlight: false },
          { area: '효자동 · 평화', venues: '효자동 웨딩홀, 평화동, 전주월드컵경기장 인근', highlight: false },
          { area: '덕진구 · 송천', venues: '덕진공원, 송천동 행사장, 전북대학교, 첨단벤처단지', highlight: false },
          { area: '완산구 · 인후동', venues: '완산구청, 인후동, 아중리 행사장', highlight: false },
          { area: '혁신도시 · 만성', venues: '전북혁신도시, 만성동, 농촌진흥청, LX 한국국토정보공사', highlight: false },
          { area: '동산 · 팔복', venues: '팔복예술공장, 동산동 행사장, 전주산업단지', highlight: false },
          { area: '기타 전북 권역', venues: '익산·군산·정읍·남원 등 전북 어디든 출장 설치 가능. 맞춤 견적 안내.', highlight: false },
        ].map(item => (
          <div class:list={[
            'rounded-lg border p-5',
            item.highlight ? 'border-olive/40 bg-olive/5' : 'border-border-light bg-white'
          ]}>
            <h3 class="text-base font-semibold text-primary">{item.area}</h3>
            <p class="mt-2 text-sm text-secondary leading-relaxed">{item.venues}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <RegionUniqueInfo
    city="전주"
    cityEn="JEONJU"
    branchOrigin="심플큐브 전주 지점"
    highlights={[
      { label: 'BRANCH', value: '전주 지점 직영 운영' },
      { label: 'COVERAGE', value: '전주·전북·호남 권역 당일 출장' },
      { label: 'RESPONSE', value: '평일 일과시간 내 30분 내 견적 회신' },
    ]}
    localStory={`<strong>전주</strong>는 한옥마을 관광 상권과 서신·완산구 신축 웨딩홀, 전주국제영화제(JIFF)·전주비빔밥축제 등 연중 끊이지 않는 도시 축제가 어우러진 호남의 대표 도시입니다. 심플큐브 전주 지점은 한옥마을·서신동·완산구를 30분 내 커버하며, 한옥마을 분위기에 어울리는 원목 부스 디자인과 한식 콘셉트 옵션을 따로 운영합니다.`}
    serviceTrend={`또한 전주 본점은 호남권 hub 역할을 겸해 광주·군산·익산·정읍을 같은 권역으로 출장합니다. 전주 한옥마을 브랜드 <a href="/popup" class="text-olive underline">팝업스토어 포토부스</a>와 영화제 야외 부스 운영 사례가 매년 늘고 있으며, 한복 대여점·한식당과의 협업 포토 옵션도 인기입니다.`}
    priceRows={[
      { type: '전주 시내', detail: '완산·덕진·한옥마을·서신·송천 등 — 별도 문의' },
      { type: '전북·호남 권역', detail: '군산·익산·정읍·남원·김제·광주 — 별도 문의' },
      { type: '운영 시간 (웨딩)', detail: '본식 90분 전 설치 → 예식 시작 후 30분까지 운영', note: '식장 상황·요청에 따라 조정 가능' },
      { type: '운영 시간 (팝업·기업·영화제·축제)', detail: '최소 2시간부터 예약 가능', note: '일·주·월 단위 장기 예약 가능' },
    ]}
    nearbyAreas={[
      { name: '광주 포토부스', url: '/gwangju', note: '70분' },
      { name: '군산', note: '전주 권역' },
      { name: '익산', note: '전주 권역' },
      { name: '정읍', note: '전주 권역' },
      { name: '남원', note: '전주 권역' },
      { name: '김제', note: '전주 권역' },
      { name: '대전·천안', note: '협의 출장' },
    ]}
    bestVenues={[
      { category: '전주 호텔·컨벤션 웨딩홀', venues: '라한호텔 전주(완산구 기린대로 85, 4성급), 베스트웨스턴 플러스 전주 호텔, 서신·완산 신축 웨딩 컨벤션 권역' },
      { category: '한옥마을·풍남동', venues: '경기전, 전주한옥마을 거리 행사, 풍남문 야외, 오목대 행사장' },
      { category: '덕진·송천 신도심', venues: '덕진공원, 송천 신축 웨딩홀, 효자동 행사장, 전북대학교 본관' },
      { category: 'JIFF·축제 야외', venues: '전주국제영화제(JIFF), 전주비빔밥축제, 한지문화축제, 풍남제' },
      { category: '익산·군산·정읍·김제', venues: '익산 미륵사지, 군산 시간여행마을, 정읍 내장산, 김제 지평선축제' },
      { category: '한복·한식 협업', venues: '한복 대여점 협업 포토, 한식당 외부 행사, 한지공예 갤러리 컬래버' },
    ]}
  />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Machine Showcase -->
  <MachineShowcase />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Client Showcase -->
  <ClientShowcase />

  <!-- FAQ -->
  {faqItems.length > 0 && (
    <Fragment>
    <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
    <section id="qna" class="bg-white py-12 lg:py-16">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <div class="mb-10">
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">06</div>
          <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">FAQ</span>
          <h2 class="mt-3 text-2xl font-bold text-primary md:text-3xl">전주 포토부스 자주 묻는 질문</h2>
          <div class="mt-4 h-[2px] w-8 bg-olive"></div>
        </div>
        <AccordionList items={faqItems} />
      </div>
    </section>
    </Fragment>
  )}

  <!-- CTA -->
  <section class="bg-[#6B5B4D] py-12 lg:py-16">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
