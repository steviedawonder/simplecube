---
import BaseLayout from '@layouts/BaseLayout.astro';

const specs = [
  { label: '소재', value: '알루미늄 (화이트)' },
  { label: '크기', value: 'W460mm × L480mm × H1700mm' },
  { label: '사용전력', value: '300w (최대 700w)' },
  { label: '촬영방식', value: '무료 촬영 (카메라: DSLR)' },
  { label: '인화지 종류', value: '2×6 inches / 4×6 inches 중 선택' },
  { label: '커스텀', value: '인화지 프레임 / UI 디자인 변경 가능' },
  { label: '외관 커스텀', value: '전면 랩핑 가능 (기본 색상: 화이트)' },
  { label: '1회 촬영 간격', value: '60sec' },
];
const note = '*랩핑 진행시 추가 비용이 발생합니다.';
const modelImage = '/images/popup/popup-model.png';
---

<BaseLayout title="스펙 디자인 테스트" transparentNav={false}>
  <div class="pt-28 pb-24 bg-bg-light">
    <div class="mx-auto max-w-6xl px-6">
      <h1 class="text-3xl font-bold text-primary mb-2">스펙 디자인 비교</h1>
      <p class="text-sm text-secondary mb-16">팝업부스 모델 기준으로 6가지 디자인을 비교합니다. (이미지 + 스펙 통합 레이아웃)</p>

      <!-- ===== Version D: 도트 구분선 (기존 선택) ===== -->
      <section class="mb-24">
        <div class="mb-6">
          <span class="inline-block bg-olive/10 text-olive text-[10px] font-bold tracking-wider uppercase px-3 py-1 rounded mb-2">기존 선택</span>
          <h2 class="text-lg font-bold text-primary mb-1">D. 도트 구분선</h2>
          <p class="text-xs text-secondary">라벨과 값 사이를 점선으로 연결. 클래식하면서도 가독성이 좋은 스타일.</p>
        </div>

        <div class="rounded-2xl bg-white overflow-hidden border border-border-light">
          <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr]">
            <div class="flex items-center justify-center bg-[#f5f5f3] p-8 lg:p-10">
              <img src={modelImage} alt="팝업부스" class="h-[300px] lg:h-[380px] w-auto object-contain" />
            </div>
            <div class="p-8 lg:p-10">
              <p class="text-[11px] font-semibold tracking-[0.3em] text-olive uppercase mb-1">PHOTO-P-320AL</p>
              <h3 class="text-xl font-bold text-primary mb-6">팝업부스</h3>
              <div class="space-y-0">
                {specs.map((s, i) => (
                  <div class:list={[
                    'flex items-baseline gap-3 py-3',
                    i < specs.length - 1 ? 'border-b border-dashed border-border-light' : '',
                  ]}>
                    <span class="shrink-0 text-[12px] font-medium text-secondary w-[90px]">{s.label}</span>
                    <span class="flex-1 border-b border-dotted border-secondary/20 mb-1"></span>
                    <span class="shrink-0 text-[13px] font-semibold text-primary text-right max-w-[55%]">{s.value}</span>
                  </div>
                ))}
              </div>
              <p class="mt-4 text-[10px] text-secondary/50 text-right">{note}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== Version E: 오버레이 히어로 ===== -->
      <section class="mb-24">
        <div class="mb-6">
          <h2 class="text-lg font-bold text-primary mb-1">E. 오버레이 히어로</h2>
          <p class="text-xs text-secondary">제품 이미지를 배경으로, 스펙을 반투명 패널 위에 오버레이. 임팩트 있는 스타일.</p>
        </div>

        <div class="relative rounded-2xl overflow-hidden bg-[#1d1d1f] min-h-[520px] flex items-center">
          <!-- BG image -->
          <img src={modelImage} alt="팝업부스" class="absolute left-8 lg:left-16 bottom-0 h-[90%] w-auto object-contain opacity-20 lg:opacity-40" />
          <!-- Content -->
          <div class="relative z-10 ml-auto w-full lg:w-[55%] p-8 lg:p-12">
            <p class="text-[11px] font-semibold tracking-[0.3em] text-olive uppercase mb-1">PHOTO-P-320AL</p>
            <h3 class="text-2xl font-bold text-white mb-8">팝업부스</h3>
            <div class="grid grid-cols-2 gap-x-8 gap-y-5">
              {specs.map((s) => (
                <div>
                  <p class="text-[10px] font-medium tracking-wider text-white/40 uppercase mb-1">{s.label}</p>
                  <p class="text-[14px] font-semibold text-white/90">{s.value}</p>
                </div>
              ))}
            </div>
            <p class="mt-8 text-[10px] text-white/30">{note}</p>
          </div>
        </div>
      </section>

      <!-- ===== Version F: 하이라이트 넘버 ===== -->
      <section class="mb-24">
        <div class="mb-6">
          <h2 class="text-lg font-bold text-primary mb-1">F. 하이라이트 넘버</h2>
          <p class="text-xs text-secondary">주요 수치를 크게 강조하고, 나머지를 아이콘형 리스트로 표현. 한눈에 핵심 파악 가능.</p>
        </div>

        <div class="rounded-2xl bg-white overflow-hidden border border-border-light">
          <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr]">
            <div class="relative flex items-center justify-center bg-[#f5f5f3] p-8 lg:p-10">
              <span class="absolute top-3 right-3 bg-olive text-white text-[10px] font-bold px-3 py-1.5 rounded-full">추천</span>
              <img src={modelImage} alt="팝업부스" class="h-[300px] lg:h-[380px] w-auto object-contain" />
            </div>
            <div class="p-8 lg:p-10">
              <p class="text-[11px] font-semibold tracking-[0.3em] text-olive uppercase mb-1">PHOTO-P-320AL</p>
              <h3 class="text-xl font-bold text-primary mb-6">팝업부스</h3>

              <!-- Highlighted numbers -->
              <div class="grid grid-cols-3 gap-4 mb-8">
                <div class="text-center rounded-xl bg-[#fafaf9] py-4 px-2">
                  <p class="text-2xl font-bold text-primary">300<span class="text-sm font-medium text-secondary">w</span></p>
                  <p class="text-[10px] text-secondary mt-1">사용전력</p>
                </div>
                <div class="text-center rounded-xl bg-[#fafaf9] py-4 px-2">
                  <p class="text-2xl font-bold text-primary">60<span class="text-sm font-medium text-secondary">sec</span></p>
                  <p class="text-[10px] text-secondary mt-1">촬영 간격</p>
                </div>
                <div class="text-center rounded-xl bg-[#fafaf9] py-4 px-2">
                  <p class="text-2xl font-bold text-primary">DSLR</p>
                  <p class="text-[10px] text-secondary mt-1">카메라</p>
                </div>
              </div>

              <!-- Remaining specs -->
              <div class="space-y-3">
                {specs.filter(s => !['사용전력', '1회 촬영 간격', '촬영방식'].includes(s.label)).map((s) => (
                  <div class="flex items-start gap-3">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-olive/40 shrink-0"></span>
                    <div>
                      <span class="text-[11px] text-secondary/60">{s.label}</span>
                      <p class="text-[13px] font-semibold text-primary -mt-0.5">{s.value}</p>
                    </div>
                  </div>
                ))}
              </div>
              <p class="mt-6 text-[10px] text-secondary/50">{note}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== Version G: 스플릿 다크 ===== -->
      <section class="mb-24">
        <div class="mb-6">
          <h2 class="text-lg font-bold text-primary mb-1">G. 스플릿 다크</h2>
          <p class="text-xs text-secondary">좌측 다크 배경에 이미지, 우측 화이트에 깔끔한 스펙. 고급스러운 대비 효과.</p>
        </div>

        <div class="rounded-2xl overflow-hidden border border-border-light">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <!-- Dark side with image -->
            <div class="relative flex items-center justify-center bg-[#1d1d1f] p-10 lg:p-14 min-h-[400px]">
              <img src={modelImage} alt="팝업부스" class="h-[320px] lg:h-[400px] w-auto object-contain" />
              <div class="absolute bottom-6 left-8 lg:left-14">
                <p class="text-[10px] font-medium tracking-widest text-white/30 uppercase">PHOTO-P-320AL</p>
                <h3 class="text-2xl font-bold text-white mt-1">팝업부스</h3>
              </div>
            </div>
            <!-- White side with specs -->
            <div class="bg-white p-8 lg:p-10 flex flex-col justify-center">
              <p class="text-[11px] font-semibold tracking-[0.3em] text-olive uppercase mb-6">Specifications</p>
              {specs.map((s, i) => (
                <div class:list={[
                  'flex justify-between items-baseline py-3',
                  i < specs.length - 1 ? 'border-b border-border-light/50' : '',
                ]}>
                  <span class="text-[12px] text-secondary">{s.label}</span>
                  <span class="text-[13px] font-semibold text-primary text-right ml-4">{s.value}</span>
                </div>
              ))}
              <p class="mt-6 text-[10px] text-secondary/50 text-right">{note}</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== Version H: 아이콘 타일 ===== -->
      <section class="mb-24">
        <div class="mb-6">
          <h2 class="text-lg font-bold text-primary mb-1">H. 아이콘 타일</h2>
          <p class="text-xs text-secondary">각 스펙에 아이콘을 부여하고 타일형으로 배치. 직관적이고 시각적인 스타일.</p>
        </div>

        <div class="rounded-2xl bg-white overflow-hidden border border-border-light p-8 lg:p-10">
          <!-- Top: Image centered -->
          <div class="flex flex-col lg:flex-row items-center gap-8 mb-10">
            <div class="shrink-0 rounded-xl bg-[#f5f5f3] p-8 flex items-center justify-center">
              <img src={modelImage} alt="팝업부스" class="h-[220px] lg:h-[280px] w-auto object-contain" />
            </div>
            <div>
              <p class="text-[11px] font-semibold tracking-[0.3em] text-olive uppercase mb-1">PHOTO-P-320AL</p>
              <h3 class="text-2xl font-bold text-primary mb-2">팝업부스</h3>
              <p class="text-sm text-secondary max-w-md">팝업스토어와 브랜드 행사에 특화된 모델. 알루미늄 소재로 가볍고 외관 커스텀이 자유롭습니다.</p>
            </div>
          </div>
          <!-- Spec tiles -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">소재</p>
              <p class="text-[13px] font-bold text-primary">알루미늄</p>
            </div>
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">크기</p>
              <p class="text-[13px] font-bold text-primary">W460×H1700</p>
            </div>
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">사용전력</p>
              <p class="text-[13px] font-bold text-primary">300w</p>
            </div>
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">카메라</p>
              <p class="text-[13px] font-bold text-primary">DSLR</p>
            </div>
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 12h.008v.008h-.008V12zm-2.25 0h.008v.008H16.5V12z" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">인화지</p>
              <p class="text-[13px] font-bold text-primary">2×6 / 4×6</p>
            </div>
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">커스텀</p>
              <p class="text-[13px] font-bold text-primary">프레임/UI</p>
            </div>
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">외관 랩핑</p>
              <p class="text-[13px] font-bold text-primary">전면 가능</p>
            </div>
            <div class="rounded-xl bg-[#fafaf9] p-4 text-center">
              <svg class="w-6 h-6 mx-auto text-olive/60 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <p class="text-[11px] text-secondary mb-0.5">촬영 간격</p>
              <p class="text-[13px] font-bold text-primary">60초</p>
            </div>
          </div>
          <p class="mt-6 text-[10px] text-secondary/50 text-right">{note}</p>
        </div>
      </section>

      <!-- ===== Version I: 가로 스크롤 카드 ===== -->
      <section class="mb-24">
        <div class="mb-6">
          <h2 class="text-lg font-bold text-primary mb-1">I. 가로 슬라이드</h2>
          <p class="text-xs text-secondary">이미지와 스펙이 가로로 넓게 펼쳐지는 풀와이드 레이아웃. 모던하고 시원한 느낌.</p>
        </div>

        <div class="rounded-2xl bg-white overflow-hidden border border-border-light">
          <!-- Top band -->
          <div class="bg-[#f5f5f3] px-8 lg:px-10 py-6 flex items-end gap-8">
            <img src={modelImage} alt="팝업부스" class="h-[200px] w-auto object-contain shrink-0" />
            <div class="pb-2">
              <p class="text-[10px] font-medium tracking-widest text-secondary/50 uppercase">PHOTO-P-320AL</p>
              <h3 class="text-2xl font-bold text-primary">팝업부스</h3>
              <p class="text-xs text-secondary mt-1">알루미늄 소재 · 외관 랩핑 가능</p>
            </div>
          </div>
          <!-- Horizontal spec strip -->
          <div class="px-8 lg:px-10 py-6 flex gap-0 overflow-x-auto">
            {specs.map((s, i) => (
              <div class:list={[
                'shrink-0 px-5 py-3',
                i < specs.length - 1 ? 'border-r border-border-light' : '',
              ]}>
                <p class="text-[10px] font-medium text-secondary/50 uppercase whitespace-nowrap mb-1">{s.label}</p>
                <p class="text-[13px] font-semibold text-primary whitespace-nowrap">{s.value}</p>
              </div>
            ))}
          </div>
          <div class="px-8 lg:px-10 pb-4">
            <p class="text-[10px] text-secondary/50 text-right">{note}</p>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
