---
import BaseLayout from '@layouts/BaseLayout.astro';
import DarkTextHero from '@components/common/DarkTextHero.astro';
import ServiceIntro from '@components/wedding/ServiceIntro.astro';
import PackageDetails from '@components/wedding/PackageDetails.astro';
import TemplateGallery from '@components/wedding/TemplateGallery.astro';
import BookingInquiry from '@components/wedding/BookingInquiry.astro';
---

<BaseLayout
  title="WEDDING | 심플큐브"
  description="심플큐브 웨딩 포토부스. 결혼식을 더 특별하게 만드는 맞춤형 포토부스 서비스."
  transparentNav={true}
>
  <DarkTextHero
    title="WEDDING PHOTO BOOTH"
    subtitle="가장 아름다운 날의 특별한 순간"
    description="웨딩홀에 설치하는 즉석 사진 서비스로, 소중한 하객분들과 함께 추억을 남길 수 있습니다."
    bgImage="/images/wedding/hero.png"
  />
  <ServiceIntro />
  <PackageDetails />
  <TemplateGallery />
  <BookingInquiry />
</BaseLayout>
