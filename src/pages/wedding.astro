---
export const prerender = false;
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceIntro from '@components/wedding/ServiceIntro.astro';
import PackageDetails from '@components/wedding/PackageDetails.astro';
import BookingInquiry from '@components/wedding/BookingInquiry.astro';
import PartnerHalls from '@components/wedding/PartnerHalls.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import db from '@lib/db';

const faqResult = await db.execute({
  sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC',
  args: ['wedding'],
});
const faqItems = faqResult.rows as { question: string; answer: string }[];

// Photostrip categories
let photostripCategories: { id: number; name: string; sort_order: number }[] = [];
try {
  const catResult = await db.execute('SELECT * FROM photostrip_categories ORDER BY sort_order ASC, id ASC');
  photostripCategories = catResult.rows as any[];
} catch { /* table may not exist yet */ }

// Photostrip portfolio items (server-side)
let photostripItems: any[] = [];
try {
  const psResult = await db.execute({
    sql: "SELECT * FROM portfolio WHERE page_tag = ? AND tags LIKE ? ORDER BY sort_order ASC, id DESC",
    args: ['wedding', '%포토스트립%'],
  });
  photostripItems = psResult.rows as any[];
} catch { /* table may not exist yet */ }

// Backdrops
let backdrops: any[] = [];
try {
  const bdResult = await db.execute('SELECT * FROM backdrops WHERE visible = 1 ORDER BY sort_order ASC, id DESC');
  backdrops = bdResult.rows as any[];
} catch { /* table may not exist yet */ }
---

<BaseLayout
  title="WEDDING | 심플큐브"
  description="심플큐브 웨딩 포토부스. 결혼식을 더 특별하게 만드는 맞춤형 포토부스 서비스."
  transparentNav={false}
>
  <!-- 좌측 골드 보더 히어로 (투명 배경) -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">웨딩 포토부스</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">WEDDING</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">결혼식 · 웨딩홀 · 하객 포토 서비스</p>
        </div>
      </div>
    </div>
  </section>
  <ServiceIntro />
  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
  <PackageDetails />
  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- 현장사진 갤러리 -->
  <section id="gallery" class="bg-bg-light py-14 lg:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">03</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">GALLERY</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">현장 사진</h2>
        <p class="mt-4 text-sm text-secondary">심플큐브 웨딩 포토부스의 실제 현장 모습입니다.</p>
      </div>
      <div id="wedding-gallery-grid" class="grid grid-cols-2 gap-2 md:grid-cols-3"></div>
      <div id="wedding-gallery-empty" class="text-center py-12 hidden">
        <p class="text-secondary text-sm">등록된 현장사진이 없습니다.</p>
        <p class="text-secondary/60 text-xs mt-2">관리자에서 사진 관리 &gt; 웨딩 탭에서 현장사진 태그로 업로드 가능</p>
      </div>
      <div id="wedding-gallery-loading" class="text-center py-12">
        <p class="text-secondary text-sm">불러오는 중...</p>
      </div>
    </div>
  </section>

  <!-- 현장사진 라이트박스 -->
  <div id="wg-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
    <button id="wg-lb-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
      <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button id="wg-lb-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
      <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </button>
    <button id="wg-lb-close" class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors" aria-label="닫기">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <img id="wg-lb-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
    <p id="wg-lb-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm"></p>
  </div>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
  <!-- 포토스트립 섹션 -->
  <section id="photostrip" class="bg-white py-14 lg:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="gs-fade-up mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">04</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PHOTOSTRIP</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">포토스트립</h2>
        <div class="mt-4 text-sm text-secondary space-y-1">
          <p>1. 다양한 포토스트립 디자인을 확인해 보세요.</p>
          <p>2. 간단한 문구, 배경색 변경 가능합니다.</p>
          <p>3. 직접 신랑, 신부님의 커스터 마이즈 포토스트립으로도 변경 가능 합니다.</p>
        </div>
      </div>

      <div id="ps-tabs" class="gs-fade-up flex flex-wrap gap-2.5 mb-8">
        <button
          class="ps-tab-btn px-5 py-2 text-sm rounded-full font-medium transition-colors bg-primary text-white"
          data-cut-type="all"
        >
          전체
        </button>
        {photostripCategories.map((cat) => (
          <button
            class="ps-tab-btn px-5 py-2 text-sm rounded-full font-medium transition-colors bg-white border border-gray-200 text-secondary hover:border-olive hover:text-olive"
            data-cut-type={cat.name}
          >
            {cat.name}
          </button>
        ))}
      </div>

      {photostripItems.length > 0 ? (
        <div id="ps-grid" class="gs-fade-up">
          <div id="ps-source" class="hidden">
            {photostripItems.map((item: any) => (
              <div
                class="ps-item"
                data-cut-type={item.cut_type || ''}
                data-src={item.image_url}
                data-alt={item.title || '포토스트립'}
              />
            ))}
          </div>

          <div id="ps-carousel-section" class="relative">
            <div class="overflow-hidden">
              <div id="ps-slider" class="flex transition-transform duration-500 ease-in-out"></div>
            </div>
            <button id="ps-prev" class="absolute -left-5 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-primary text-white shadow-lg flex items-center justify-center hover:bg-olive transition-colors z-10 disabled:opacity-20 disabled:cursor-not-allowed">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
            </button>
            <button id="ps-next" class="absolute -right-5 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full bg-primary text-white shadow-lg flex items-center justify-center hover:bg-olive transition-colors z-10 disabled:opacity-20 disabled:cursor-not-allowed">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </button>
            <div id="ps-page-indicator" class="flex items-center justify-center gap-2 mt-6"></div>
          </div>
        </div>
      ) : (
        <div id="ps-empty" class="text-center py-12">
          <p class="text-secondary text-sm">등록된 포토스트립 사진이 없습니다.</p>
          <p class="text-secondary/60 text-xs mt-2">관리자에서 사진 관리 &gt; 웨딩 탭에서 업로드 가능</p>
        </div>
      )}
    </div>
  </section>

  <!-- 포토스트립 라이트박스 -->
  <div id="ps-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
    <button id="ps-lb-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
      <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button id="ps-lb-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
      <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </button>
    <button id="ps-lb-close" class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors" aria-label="닫기">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <img id="ps-lb-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
    <p id="ps-lb-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm"></p>
  </div>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
  <!-- 백드롭 섹션 -->
  <section id="backdrop" class="bg-bg-light py-14 lg:py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="gs-fade-up mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">05</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">BACKDROP</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">백드롭 선택</h2>
        <p class="mt-4 text-sm text-secondary">시퀸 2종 + 화이트 커튼 4종, 총 6가지 옵션을 제공합니다.</p>
      </div>

      {backdrops.length > 0 ? (
        <div id="bd-grid" class="gs-stagger grid grid-cols-2 gap-2 md:grid-cols-3 md:gap-4">
          {backdrops.map((bd: any) => (
            <div class="bd-item group cursor-pointer overflow-hidden rounded-xl border border-border-light relative"
                 data-url={bd.image_url} data-title={bd.title || '백드롭'}>
              <img
                src={bd.image_url.includes('res.cloudinary.com') ? bd.image_url.replace('/upload/', '/upload/w_400,f_auto,q_auto/') : bd.image_url}
                alt={bd.title || '백드롭'}
                class="w-full aspect-[4/3] object-cover object-top transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
                <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
                </svg>
              </div>
              {bd.title && <p class="text-center text-xs text-secondary py-2">{bd.title}</p>}
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-secondary text-sm">등록된 백드롭 사진이 없습니다.</p>
          <p class="text-secondary/60 text-xs mt-2">관리자에서 배경·백드롭 메뉴에서 업로드 가능</p>
        </div>
      )}
    </div>
  </section>

  <!-- 백드롭 라이트박스 -->
  {backdrops.length > 0 && (
    <div id="bd-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
      <button id="bd-lb-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
        <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      </button>
      <button id="bd-lb-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
        <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </button>
      <button id="bd-lb-close" class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors" aria-label="닫기">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
      <img id="bd-lb-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
      <p id="bd-lb-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm"></p>
    </div>
  )}

  <!-- BookingInquiry removed -->
  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
  <PartnerHalls />

  {faqItems.length > 0 && (
    <Fragment>
    <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
    <section id="qna" class="bg-white py-16 lg:py-24">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <div class="mb-10">
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">07</div>
          <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">Q&A</span>
          <h2 class="mt-3 text-2xl font-bold text-primary md:text-3xl">자주 묻는 질문</h2>
          <div class="mt-4 h-[2px] w-8 bg-olive"></div>
        </div>
        <AccordionList items={faqItems} />
      </div>
    </section>
    </Fragment>
  )}
</BaseLayout>

<script>
{
  // === Wedding Gallery with Lightbox ===
  async function loadWeddingGallery() {
    const grid = document.getElementById('wedding-gallery-grid')!;
    const empty = document.getElementById('wedding-gallery-empty')!;
    const loading = document.getElementById('wedding-gallery-loading')!;
    const gallerySection = document.getElementById('gallery')!;

    try {
      const res = await fetch('/api/portfolio?page_tag=wedding&tags=현장사진');
      const items: any[] = await res.json();

      loading.classList.add('hidden');

      if (items.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      grid.innerHTML = items.map((item: any) => `
        <div class="wg-item group cursor-pointer overflow-hidden rounded-lg" data-src="${item.image_url}" data-alt="${item.title || '웨딩 현장사진'}">
          <div class="relative">
            <img
              src="${item.image_url}"
              alt="${item.title || '웨딩 현장사진'}"
              class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
              <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
              </svg>
            </div>
          </div>
        </div>
      `).join('');

      // Lightbox for gallery
      const lightbox = document.getElementById('wg-lightbox')!;
      const lbImg = document.getElementById('wg-lb-img') as HTMLImageElement;
      const lbCaption = document.getElementById('wg-lb-caption')!;
      let wgItems: { src: string; alt: string }[] = [];
      let wgIdx = 0;

      function showWg() {
        const item = wgItems[wgIdx];
        if (!item) return;
        lbImg.src = item.src;
        lbImg.alt = item.alt;
        lbCaption.textContent = item.alt;
      }
      function openWg(idx: number) {
        wgItems = Array.from(grid.querySelectorAll('.wg-item')).map(el => ({
          src: (el as HTMLElement).dataset.src || '',
          alt: (el as HTMLElement).dataset.alt || '',
        }));
        wgIdx = idx;
        showWg();
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
      function closeWg() {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        document.body.style.overflow = '';
      }

      grid.addEventListener('click', (e) => {
        const item = (e.target as HTMLElement).closest('.wg-item');
        if (!item) return;
        const all = Array.from(grid.querySelectorAll('.wg-item'));
        const idx = all.indexOf(item as Element);
        if (idx >= 0) openWg(idx);
      });

      document.getElementById('wg-lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); wgIdx = (wgIdx - 1 + wgItems.length) % wgItems.length; showWg(); });
      document.getElementById('wg-lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); wgIdx = (wgIdx + 1) % wgItems.length; showWg(); });
      document.getElementById('wg-lb-close')!.addEventListener('click', closeWg);
      lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeWg(); });
      document.addEventListener('keydown', (e) => {
        if (lightbox.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeWg();
        if (e.key === 'ArrowLeft') { wgIdx = (wgIdx - 1 + wgItems.length) % wgItems.length; showWg(); }
        if (e.key === 'ArrowRight') { wgIdx = (wgIdx + 1) % wgItems.length; showWg(); }
      });

    } catch {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  loadWeddingGallery();

  // === Photostrip: Unified carousel (portrait first, then landscape) ===
  const psGrid = document.getElementById('ps-grid');
  const psTabs = document.querySelectorAll<HTMLButtonElement>('.ps-tab-btn');

  if (psGrid) {
    const sourceItems = Array.from(psGrid.querySelectorAll<HTMLElement>('#ps-source .ps-item'));
    const COLS = 5;
    const PER_PAGE = 10;

    interface PsData { src: string; alt: string; cutType: string; orientation?: string; }
    let allData: PsData[] = sourceItems.map(el => ({
      src: el.dataset.src || '',
      alt: el.dataset.alt || '',
      cutType: el.dataset.cutType || '',
    }));

    let classified = 0;
    allData.forEach((d) => {
      const img = new Image();
      img.src = d.src;
      img.onload = () => {
        d.orientation = img.naturalWidth > img.naturalHeight ? 'landscape' : 'portrait';
        classified++;
        if (classified === allData.length) buildAll();
      };
      img.onerror = () => {
        d.orientation = 'portrait';
        classified++;
        if (classified === allData.length) buildAll();
      };
    });

    const psSlider = document.getElementById('ps-slider')!;
    const psPrev = document.getElementById('ps-prev') as HTMLButtonElement;
    const psNext = document.getElementById('ps-next') as HTMLButtonElement;
    const psIndicator = document.getElementById('ps-page-indicator')!;
    let psPage = 0;
    let allVisibleData: PsData[] = [];

    function makeCard(d: PsData): HTMLElement {
      const card = document.createElement('div');
      card.className = 'ps-item group cursor-pointer';
      card.dataset.src = d.src;
      card.dataset.alt = d.alt;
      card.innerHTML = `
        <div class="relative overflow-hidden flex items-center justify-center" style="height: ${d.orientation === 'landscape' ? '140px' : '220px'};">
          <img src="${d.src}" alt="${d.alt}" class="max-w-full max-h-full object-contain transition-transform duration-500 group-hover:scale-105 shadow-[0_2px_8px_rgba(0,0,0,0.12)]" loading="lazy" />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
            <svg class="w-5 h-5 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
            </svg>
          </div>
        </div>
      `;
      return card;
    }

    function updateCarousel() {
      const totalPages = psSlider.children.length;
      psSlider.style.transform = `translateX(-${psPage * 100}%)`;
      psPrev.disabled = psPage <= 0;
      psNext.disabled = psPage >= totalPages - 1;
      psPrev.style.display = totalPages <= 1 ? 'none' : 'flex';
      psNext.style.display = totalPages <= 1 ? 'none' : 'flex';

      // Update indicator
      psIndicator.innerHTML = '';
      if (totalPages > 1) {
        for (let i = 0; i < totalPages; i++) {
          const dot = document.createElement('button');
          dot.className = i === psPage
            ? 'w-8 h-2 rounded-full bg-primary transition-all'
            : 'w-2 h-2 rounded-full bg-gray-300 hover:bg-gray-400 transition-all';
          dot.addEventListener('click', () => { psPage = i; updateCarousel(); });
          psIndicator.appendChild(dot);
        }
      }
    }

    function buildAll(cutFilter = 'all') {
      const filtered = cutFilter === 'all' ? allData : allData.filter(d => d.cutType === cutFilter);
      // Sort: portrait first, then landscape
      const sorted = [
        ...filtered.filter(d => d.orientation === 'portrait'),
        ...filtered.filter(d => d.orientation === 'landscape'),
      ];
      allVisibleData = sorted;

      psSlider.innerHTML = '';
      if (sorted.length === 0) { updateCarousel(); return; }

      const totalPages = Math.ceil(sorted.length / PER_PAGE);
      for (let p = 0; p < totalPages; p++) {
        const page = document.createElement('div');
        page.className = 'flex-shrink-0 w-full';
        page.style.cssText = 'display: grid; grid-template-columns: repeat(5, 1fr); gap: 1.5rem; row-gap: 2.5rem; padding: 0.5rem;';
        const start = p * PER_PAGE;
        const end = Math.min(start + PER_PAGE, sorted.length);
        for (let i = start; i < end; i++) {
          page.appendChild(makeCard(sorted[i]));
        }
        psSlider.appendChild(page);
      }

      psPage = 0;
      updateCarousel();
    }

    psPrev.addEventListener('click', () => { if (psPage > 0) { psPage--; updateCarousel(); } });
    psNext.addEventListener('click', () => { if (psPage < psSlider.children.length - 1) { psPage++; updateCarousel(); } });

    // Tab filtering
    psTabs.forEach(btn => {
      btn.addEventListener('click', () => {
        const cutType = btn.dataset.cutType || 'all';
        psTabs.forEach(b => {
          if (b === btn) {
            b.classList.remove('bg-white', 'border', 'border-gray-200', 'text-secondary');
            b.classList.add('bg-primary', 'text-white');
          } else {
            b.classList.remove('bg-primary', 'text-white');
            b.classList.add('bg-white', 'border', 'border-gray-200', 'text-secondary');
          }
        });
        buildAll(cutType);
      });
    });

    // Photostrip lightbox
    const psLb = document.getElementById('ps-lightbox')!;
    const psLbImg = document.getElementById('ps-lb-img') as HTMLImageElement;
    const psLbCaption = document.getElementById('ps-lb-caption')!;
    let psLbItems: { src: string; alt: string }[] = [];
    let psLbIdx = 0;

    function showPsLb() {
      const item = psLbItems[psLbIdx];
      if (!item) return;
      psLbImg.src = item.src;
      psLbImg.alt = item.alt;
      psLbCaption.textContent = item.alt;
    }
    function openPsLb(idx: number) {
      psLbItems = allVisibleData.map(d => ({ src: d.src, alt: d.alt }));
      psLbIdx = idx;
      showPsLb();
      psLb.classList.remove('hidden');
      psLb.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
    function closePsLb() {
      psLb.classList.add('hidden');
      psLb.classList.remove('flex');
      document.body.style.overflow = '';
    }

    psGrid.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest('.ps-item');
      if (!item) return;
      const src = (item as HTMLElement).dataset.src || '';
      const idx = allVisibleData.findIndex(d => d.src === src);
      if (idx >= 0) openPsLb(idx);
    });

    document.getElementById('ps-lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); psLbIdx = (psLbIdx - 1 + psLbItems.length) % psLbItems.length; showPsLb(); });
    document.getElementById('ps-lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); psLbIdx = (psLbIdx + 1) % psLbItems.length; showPsLb(); });
    document.getElementById('ps-lb-close')!.addEventListener('click', closePsLb);
    psLb.addEventListener('click', (e) => { if (e.target === psLb) closePsLb(); });
    document.addEventListener('keydown', (e) => {
      if (psLb.classList.contains('hidden')) return;
      if (e.key === 'Escape') closePsLb();
      if (e.key === 'ArrowLeft') { psLbIdx = (psLbIdx - 1 + psLbItems.length) % psLbItems.length; showPsLb(); }
      if (e.key === 'ArrowRight') { psLbIdx = (psLbIdx + 1) % psLbItems.length; showPsLb(); }
    });
  }

  // === Backdrop Lightbox ===
  const bdGrid = document.getElementById('bd-grid');
  const bdLb = document.getElementById('bd-lightbox');
  if (bdGrid && bdLb) {
    const bdThumbs = bdGrid.querySelectorAll('.bd-item');
    const bdImages = Array.from(bdThumbs).map(t => ({
      url: (t as HTMLElement).dataset.url || '',
      title: (t as HTMLElement).dataset.title || '',
    }));

    const bdLbImg = document.getElementById('bd-lb-img') as HTMLImageElement;
    const bdLbCaption = document.getElementById('bd-lb-caption')!;
    let bdIdx = 0;

    function fullBdUrl(url: string) {
      if (url.includes('res.cloudinary.com') && url.includes('/upload/')) {
        return url.replace('/upload/', '/upload/f_auto,q_auto/');
      }
      return url;
    }

    function showBd() {
      const item = bdImages[bdIdx];
      if (!item) return;
      bdLbImg.src = fullBdUrl(item.url);
      bdLbImg.alt = item.title;
      bdLbCaption.textContent = item.title;
    }

    function openBd(idx: number) {
      bdIdx = idx;
      showBd();
      bdLb!.classList.remove('hidden');
      bdLb!.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeBd() {
      bdLb!.classList.add('hidden');
      bdLb!.classList.remove('flex');
      document.body.style.overflow = '';
    }

    bdThumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => openBd(i));
    });

    document.getElementById('bd-lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); bdIdx = (bdIdx - 1 + bdImages.length) % bdImages.length; showBd(); });
    document.getElementById('bd-lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); bdIdx = (bdIdx + 1) % bdImages.length; showBd(); });
    document.getElementById('bd-lb-close')!.addEventListener('click', closeBd);
    bdLb.addEventListener('click', (e) => { if (e.target === bdLb) closeBd(); });
    document.addEventListener('keydown', (e) => {
      if (bdLb!.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeBd();
      if (e.key === 'ArrowLeft') { bdIdx = (bdIdx - 1 + bdImages.length) % bdImages.length; showBd(); }
      if (e.key === 'ArrowRight') { bdIdx = (bdIdx + 1) % bdImages.length; showBd(); }
    });
  }
}
</script>
