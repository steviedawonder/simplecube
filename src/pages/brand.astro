---
import BaseLayout from '@layouts/BaseLayout.astro';
import BrandStory from '@components/brand/BrandStory.astro';
import BranchOffices from '@components/brand/BranchOffices.astro';

---

<BaseLayout
  title="BRAND | 심플큐브"
  description="심플큐브의 브랜드 스토리와 전국 지점 안내. Simple but Special."
  transparentNav={false}
>
  <!-- 좌측 골드 보더 히어로 (투명 배경) -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">브랜드소개</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">BRAND</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">브랜드 스토리 · 전국 지점 안내</p>
        </div>
      </div>
    </div>
  </section>
  <BrandStory />
  <BranchOffices />
</BaseLayout>
