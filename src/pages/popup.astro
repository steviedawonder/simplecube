---
import BaseLayout from '@layouts/BaseLayout.astro';
import ServiceIntro from '@components/popup/ServiceIntro.astro';
import PortfolioGallery from '@components/popup/PortfolioGallery.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import MachineShowcase from '@components/popup/MachineShowcase.astro';
import CustomOptions from '@components/popup/CustomOptions.astro';
import BookingProcess from '@components/popup/BookingProcess.astro';
---

<BaseLayout
  title="POP-UP | 심플큐브"
  description="심플큐브 팝업 포토부스. 브랜드 팝업스토어, 기업 행사, 페스티벌을 위한 맞춤형 포토부스 서비스."
  transparentNav={true}
>
  <!-- Custom Hero: 높이 축소 + 한글 메인 타이틀 -->
  <section class="relative flex min-h-[33vh] items-center overflow-hidden bg-[#6B5B4D]">
    <div class="absolute inset-0">
      <img
        src="/images/popup/booth.jpg"
        alt=""
        class="h-full w-full object-cover opacity-20 blur-sm"
        loading="eager"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-[#6B5B4D]/70"></div>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-7xl px-6 pt-28 pb-12 lg:px-8 lg:pt-32 lg:pb-16">
      <div class="max-w-3xl gs-fade-up">
        <p class="mb-4 text-sm font-medium tracking-[0.3em] text-[#FFFAF4]/60 md:tracking-[0.4em]">
          브랜드를 특별한 경험으로
        </p>
        <div class="mb-6 h-[1px] w-12 bg-olive/60"></div>
        <h1 class="text-[clamp(2.2rem,5vw,4.5rem)] font-bold tracking-[0.02em] text-[#FFFAF4] leading-[1.1]">
          팝업 포토부스
        </h1>
        <p class="mt-2 text-[clamp(0.85rem,1.8vw,1.5rem)] font-medium tracking-[0.15em] text-[#FFFAF4]/50">
          POP-UP PHOTOBOOTH
        </p>
        <p class="mt-6 text-base leading-relaxed text-[#FFFAF4]/60 max-w-xl">
          브랜드 팝업스토어, 기업 행사, 페스티벌까지. 맞춤형 디자인으로 브랜드를 특별하게 만듭니다.
        </p>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-px bg-[#FFFAF4]/5"></div>
  </section>
  <ServiceIntro />
  <PortfolioGallery />
  <ClientShowcase />
  <MachineShowcase />
  <CustomOptions />
  <BookingProcess />
</BaseLayout>
