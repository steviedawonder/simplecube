---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import db from '@lib/db';

const result = await db.execute('SELECT * FROM portfolio ORDER BY sort_order ASC, created_at DESC');
const items = result.rows as any[];

// Collect all unique tags
const allTags = new Set<string>();
items.forEach((item: any) => {
  if (item.tags) {
    item.tags.split(',').map((t: string) => t.trim()).filter(Boolean).forEach((t: string) => allTags.add(t));
  }
});
const tagList = Array.from(allTags).sort();
---

<AdminLayout title="포트폴리오">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">포트폴리오 관리</h1>
      <p class="text-sm text-gray-500 mt-1">이미지를 업로드하고 태그로 분류하세요.</p>
    </div>
    <button id="upload-btn" class="px-5 py-2.5 bg-[#D4AA45] text-white rounded-lg text-sm font-medium hover:bg-[#C49A2F] transition-colors flex items-center gap-2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
      </svg>
      이미지 업로드
    </button>
  </div>

  <!-- Upload Modal -->
  <div id="upload-modal" style="display:none" class="fixed inset-0 z-50 items-center justify-center bg-black/50">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h3 class="text-lg font-semibold">이미지 업로드</h3>
        <button id="upload-close" class="text-gray-400 hover:text-gray-600">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
        </button>
      </div>
      <form id="upload-form" class="p-6 space-y-4">
        <!-- Drop zone -->
        <div id="drop-zone" class="border-2 border-dashed border-gray-300 rounded-xl p-8 text-center cursor-pointer hover:border-[#D4AA45] transition-colors">
          <svg class="mx-auto mb-3 text-gray-400" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" />
          </svg>
          <p class="text-sm text-gray-500">클릭하거나 이미지를 드래그하세요</p>
          <p id="file-name" class="text-xs text-[#D4AA45] mt-2 hidden"></p>
          <input type="file" id="file-input" accept="image/*" class="hidden" multiple />
        </div>

        <!-- Preview -->
        <div id="preview-area" class="hidden grid grid-cols-3 gap-2"></div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">제목 (선택)</label>
          <input type="text" name="title" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" placeholder="포트폴리오 제목" />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">태그</label>
          <input type="text" name="tags" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" placeholder="쉼표로 구분 (예: 부활절, 크리스마스, 생일)" />
          {tagList.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-2">
              {tagList.map((tag) => (
                <button type="button" class="tag-suggest px-2 py-0.5 text-xs rounded-full bg-gray-100 text-gray-600 hover:bg-[#D4AA45]/10 hover:text-[#D4AA45] transition-colors" data-tag={tag}>{tag}</button>
              ))}
            </div>
          )}
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">페이지</label>
          <select name="page" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none">
            <option value="popup">행사 (Popup)</option>
            <option value="event">이벤트 (Event)</option>
            <option value="all">전체</option>
          </select>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="upload-cancel" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50">취소</button>
          <button type="submit" id="upload-submit" class="px-5 py-2 bg-[#D4AA45] text-white rounded-lg text-sm font-medium hover:bg-[#C49A2F] transition-colors disabled:opacity-50" disabled>업로드</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Edit Modal -->
  <div id="edit-modal" style="display:none" class="fixed inset-0 z-50 items-center justify-center bg-black/50">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
        <h3 class="text-lg font-semibold">항목 수정</h3>
        <button id="edit-close" class="text-gray-400 hover:text-gray-600">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12" /></svg>
        </button>
      </div>
      <form id="edit-form" class="p-6 space-y-4">
        <input type="hidden" name="id" />
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">제목</label>
          <input type="text" name="title" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">태그</label>
          <input type="text" name="tags" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">페이지</label>
          <select name="page" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none">
            <option value="popup">행사 (Popup)</option>
            <option value="event">이벤트 (Event)</option>
            <option value="all">전체</option>
          </select>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" name="visible" id="edit-visible" class="rounded" />
          <label for="edit-visible" class="text-sm text-gray-700">표시</label>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="edit-cancel" class="px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50">취소</button>
          <button type="submit" class="px-5 py-2 bg-[#D4AA45] text-white rounded-lg text-sm font-medium hover:bg-[#C49A2F] transition-colors">저장</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-2xl font-bold text-gray-900">{items.length}</p>
      <p class="text-xs text-gray-500 mt-1">전체 이미지</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-2xl font-bold text-gray-900">{items.filter((i: any) => Boolean(i.visible)).length}</p>
      <p class="text-xs text-gray-500 mt-1">표시 중</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-2xl font-bold text-gray-900">{tagList.length}</p>
      <p class="text-xs text-gray-500 mt-1">태그 수</p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-2xl font-bold text-[#D4AA45]">{items.filter((i: any) => i.page === 'popup').length}</p>
      <p class="text-xs text-gray-500 mt-1">행사 페이지</p>
    </div>
  </div>

  <!-- Tag filter -->
  {tagList.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-6">
      <button class="tag-filter px-3 py-1.5 text-xs rounded-full bg-[#D4AA45] text-white font-medium" data-tag="">전체</button>
      {tagList.map((tag) => (
        <button class="tag-filter px-3 py-1.5 text-xs rounded-full bg-gray-100 text-gray-600 hover:bg-[#D4AA45]/10 hover:text-[#D4AA45] transition-colors font-medium" data-tag={tag}>{tag}</button>
      ))}
    </div>
  )}

  <!-- Portfolio Grid -->
  <div id="portfolio-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {items.map((item: any) => (
      <div class="portfolio-card group relative bg-white rounded-xl border border-gray-200 overflow-hidden" data-id={item.id} data-tags={item.tags} data-title={item.title} data-page={item.page} data-visible={item.visible}>
        <div class="aspect-[4/3] overflow-hidden">
          <img src={item.image_url} alt={item.title || '포트폴리오'} class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />
        </div>
        {!item.visible && (
          <div class="absolute top-2 left-2 px-2 py-0.5 bg-red-500 text-white text-[10px] rounded-full font-medium">숨김</div>
        )}
        <div class="absolute top-2 right-2 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
          <button class="edit-btn p-1.5 bg-white/90 rounded-lg shadow-sm hover:bg-white" title="수정">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
          </button>
          <button class="delete-btn p-1.5 bg-white/90 rounded-lg shadow-sm hover:bg-red-50" title="삭제">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="red" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /></svg>
          </button>
        </div>
        <div class="p-3">
          {item.title && <p class="text-sm font-medium text-gray-900 truncate">{item.title}</p>}
          {item.tags && (
            <div class="flex flex-wrap gap-1 mt-1.5">
              {item.tags.split(',').map((t: string) => t.trim()).filter(Boolean).map((t: string) => (
                <span class="px-1.5 py-0.5 text-[10px] bg-gray-100 text-gray-500 rounded">{t}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  {items.length === 0 && (
    <div class="text-center py-20">
      <svg class="mx-auto mb-4 text-gray-300" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" /><circle cx="8.5" cy="8.5" r="1.5" /><polyline points="21 15 16 10 5 21" />
      </svg>
      <p class="text-gray-500 text-sm">아직 포트폴리오 이미지가 없습니다.</p>
      <p class="text-gray-400 text-xs mt-1">위의 "이미지 업로드" 버튼으로 추가하세요.</p>
    </div>
  )}
</AdminLayout>

<script>
  // Upload Modal
  const uploadBtn = document.getElementById('upload-btn')!;
  const uploadModal = document.getElementById('upload-modal')!;
  const uploadClose = document.getElementById('upload-close')!;
  const uploadCancel = document.getElementById('upload-cancel')!;
  const uploadForm = document.getElementById('upload-form') as HTMLFormElement;
  const uploadSubmit = document.getElementById('upload-submit') as HTMLButtonElement;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const dropZone = document.getElementById('drop-zone')!;
  const fileName = document.getElementById('file-name')!;
  const previewArea = document.getElementById('preview-area')!;

  let selectedFiles: File[] = [];

  function openUploadModal() { uploadModal.style.display = 'flex'; }
  function closeUploadModal() {
    uploadModal.style.display = 'none';
    uploadForm.reset();
    selectedFiles = [];
    fileName.classList.add('hidden');
    previewArea.innerHTML = '';
    previewArea.classList.add('hidden');
    uploadSubmit.disabled = true;
  }

  uploadBtn.addEventListener('click', openUploadModal);
  uploadClose.addEventListener('click', closeUploadModal);
  uploadCancel.addEventListener('click', closeUploadModal);
  uploadModal.addEventListener('click', (e) => { if (e.target === uploadModal) closeUploadModal(); });

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-[#D4AA45]'); });
  dropZone.addEventListener('dragleave', () => { dropZone.classList.remove('border-[#D4AA45]'); });
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-[#D4AA45]');
    if (e.dataTransfer?.files) {
      handleFiles(Array.from(e.dataTransfer.files));
    }
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files) handleFiles(Array.from(fileInput.files));
  });

  function handleFiles(files: File[]) {
    selectedFiles = files.filter(f => f.type.startsWith('image/'));
    if (selectedFiles.length > 0) {
      fileName.textContent = selectedFiles.length === 1 ? selectedFiles[0].name : `${selectedFiles.length}개 파일 선택됨`;
      fileName.classList.remove('hidden');
      uploadSubmit.disabled = false;

      // Preview
      previewArea.innerHTML = '';
      previewArea.classList.remove('hidden');
      selectedFiles.forEach(file => {
        const reader = new FileReader();
        reader.onload = (e) => {
          const div = document.createElement('div');
          div.className = 'aspect-square rounded-lg overflow-hidden';
          div.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-cover" />`;
          previewArea.appendChild(div);
        };
        reader.readAsDataURL(file);
      });
    }
  }

  // Tag suggest buttons
  document.querySelectorAll('.tag-suggest').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag!;
      const tagsInput = uploadForm.querySelector('input[name="tags"]') as HTMLInputElement;
      const current = tagsInput.value.split(',').map(t => t.trim()).filter(Boolean);
      if (!current.includes(tag)) {
        current.push(tag);
        tagsInput.value = current.join(', ');
      }
    });
  });

  // Upload submit
  uploadForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (selectedFiles.length === 0) return;

    uploadSubmit.disabled = true;
    uploadSubmit.textContent = '업로드 중...';

    const title = (uploadForm.querySelector('input[name="title"]') as HTMLInputElement).value;
    const tags = (uploadForm.querySelector('input[name="tags"]') as HTMLInputElement).value;
    const page = (uploadForm.querySelector('select[name="page"]') as HTMLSelectElement).value;

    try {
      for (const file of selectedFiles) {
        const formData = new FormData();
        formData.append('file', file);
        formData.append('title', title);
        formData.append('tags', tags);
        formData.append('page', page);

        const res = await fetch('/api/portfolio', { method: 'POST', body: formData });
        if (!res.ok) {
          const err = await res.json();
          throw new Error(err.error || '업로드 실패');
        }
      }
      window.location.reload();
    } catch (err: any) {
      alert(err.message || '업로드 중 오류가 발생했습니다.');
      uploadSubmit.disabled = false;
      uploadSubmit.textContent = '업로드';
    }
  });

  // Edit Modal
  const editModal = document.getElementById('edit-modal')!;
  const editClose = document.getElementById('edit-close')!;
  const editCancel = document.getElementById('edit-cancel')!;
  const editForm = document.getElementById('edit-form') as HTMLFormElement;

  function closeEditModal() { editModal.style.display = 'none'; }
  editClose.addEventListener('click', closeEditModal);
  editCancel.addEventListener('click', closeEditModal);
  editModal.addEventListener('click', (e) => { if (e.target === editModal) closeEditModal(); });

  // Edit buttons
  document.querySelectorAll('.edit-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const card = (btn as HTMLElement).closest('.portfolio-card') as HTMLElement;
      const id = card.dataset.id!;
      const title = card.dataset.title || '';
      const tags = card.dataset.tags || '';
      const page = card.dataset.page || 'popup';
      const visible = card.dataset.visible === '1';

      (editForm.querySelector('input[name="id"]') as HTMLInputElement).value = id;
      (editForm.querySelector('input[name="title"]') as HTMLInputElement).value = title;
      (editForm.querySelector('input[name="tags"]') as HTMLInputElement).value = tags;
      (editForm.querySelector('select[name="page"]') as HTMLSelectElement).value = page;
      (editForm.querySelector('#edit-visible') as HTMLInputElement).checked = visible;

      editModal.style.display = 'flex';
    });
  });

  editForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (editForm.querySelector('input[name="id"]') as HTMLInputElement).value;
    const title = (editForm.querySelector('input[name="title"]') as HTMLInputElement).value;
    const tags = (editForm.querySelector('input[name="tags"]') as HTMLInputElement).value;
    const page = (editForm.querySelector('select[name="page"]') as HTMLSelectElement).value;
    const visible = (editForm.querySelector('#edit-visible') as HTMLInputElement).checked;

    const res = await fetch(`/api/portfolio/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ title, tags, page, visible }),
    });

    if (res.ok) {
      window.location.reload();
    } else {
      alert('저장 중 오류가 발생했습니다.');
    }
  });

  // Delete buttons
  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      if (!confirm('이 이미지를 삭제하시겠습니까?')) return;

      const card = (btn as HTMLElement).closest('.portfolio-card') as HTMLElement;
      const id = card.dataset.id!;

      const res = await fetch(`/api/portfolio/${id}`, { method: 'DELETE' });
      if (res.ok) {
        card.remove();
      } else {
        alert('삭제 중 오류가 발생했습니다.');
      }
    });
  });

  // Tag filter
  document.querySelectorAll('.tag-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag!;

      // Update active state
      document.querySelectorAll('.tag-filter').forEach((b) => {
        b.classList.remove('bg-[#D4AA45]', 'text-white');
        b.classList.add('bg-gray-100', 'text-gray-600');
      });
      (btn as HTMLElement).classList.remove('bg-gray-100', 'text-gray-600');
      (btn as HTMLElement).classList.add('bg-[#D4AA45]', 'text-white');

      // Filter cards
      document.querySelectorAll('.portfolio-card').forEach((card) => {
        const cardTags = (card as HTMLElement).dataset.tags || '';
        if (!tag || cardTags.split(',').map(t => t.trim()).includes(tag)) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // ESC key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeUploadModal();
      closeEditModal();
    }
  });
</script>
