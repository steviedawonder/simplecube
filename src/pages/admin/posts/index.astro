---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import PostList from '@components/admin/PostList';
import db from '@lib/db';

const view = Astro.url.searchParams.get('view');
const isTrash = view === 'trash';

const result = await db.execute(`
  SELECT p.id, p.title, p.slug, p.draft, p.seo_score, p.scheduled_at,
         p.created_at, p.updated_at, p.deleted_at, p.external_url,
         c.name as category_name
  FROM posts p
  LEFT JOIN categories c ON p.category_id = c.id
  WHERE ${isTrash ? 'p.deleted_at IS NOT NULL' : 'p.deleted_at IS NULL'}
  ORDER BY ${isTrash ? 'p.deleted_at DESC' : 'p.created_at DESC'}
`);

const posts = result.rows as any[];
---

<AdminLayout title={isTrash ? '휴지통' : '글 관리'}>
  <PostList
    initialPosts={posts}
    viewMode={isTrash ? 'trash' : 'active'}
    client:load
  />
</AdminLayout>
