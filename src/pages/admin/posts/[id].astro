---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import PostEditor from '@components/admin/PostEditor';
import db from '@lib/db';

const { id } = Astro.params;
const postId = Number(id);

if (isNaN(postId)) {
  return Astro.redirect('/admin/posts');
}

// Fetch post
const postResult = await db.execute({
  sql: `
    SELECT p.*
    FROM posts p
    WHERE p.id = ? AND p.deleted_at IS NULL
  `,
  args: [postId],
});

if (postResult.rows.length === 0) {
  return Astro.redirect('/admin/posts');
}

const post = postResult.rows[0] as any;

// Fetch post tags
const postTagsResult = await db.execute({
  sql: `
    SELECT t.id, t.name, t.slug
    FROM post_tags pt
    JOIN tags t ON pt.tag_id = t.id
    WHERE pt.post_id = ?
    ORDER BY t.name
  `,
  args: [postId],
});

post.tags = postTagsResult.rows as any[];

// Fetch all categories and tags
const categoriesResult = await db.execute('SELECT id, name, slug FROM categories ORDER BY name');
const tagsResult = await db.execute('SELECT id, name, slug FROM tags ORDER BY name');

const categories = categoriesResult.rows as any[];
const tags = tagsResult.rows as any[];
---

<AdminLayout title="글 수정">
  <PostEditor post={post} categories={categories} tags={tags} client:load />
</AdminLayout>
