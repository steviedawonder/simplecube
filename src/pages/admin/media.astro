---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import db from '@lib/db';

const result = await db.execute('SELECT * FROM media ORDER BY created_at DESC');
const mediaList = result.rows as any[];
---

<AdminLayout title="미디어 라이브러리">
  <script is:inline src="/js/image-compress.js"></script>
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
    <h2 style="font-size: 1.25rem; font-weight: 700; color: #1d1d1f;">
      미디어 라이브러리
      <span style="font-weight: 400; font-size: 0.875rem; color: #8c8c8c; margin-left: 8px;">
        ({mediaList.length}개)
      </span>
    </h2>
    <div id="media-toolbar-normal" style="display: flex; gap: 8px; align-items: center;">
      <label
        id="upload-btn"
        style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background-color: #1d1d1f; color: #ffffff; border-radius: 8px; font-size: 0.875rem; font-weight: 500; cursor: pointer;"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="17 8 12 3 7 8" />
          <line x1="12" y1="3" x2="12" y2="15" />
        </svg>
        업로드
        <input type="file" id="file-input" accept="image/*" multiple style="display: none;" />
      </label>
      <button id="media-delete-mode-btn" style="padding: 8px 16px; border-radius: 8px; border: 1px solid #e8e8ed; background: #fff; color: #6e6e73; font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: inherit;">삭제</button>
    </div>
    <div id="media-toolbar-delete" style="display: none; gap: 8px; align-items: center;">
      <button id="media-delete-confirm" disabled style="padding: 8px 16px; border-radius: 8px; border: none; background: #ff3b30; color: #fff; font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: inherit; opacity: 0.5;">선택 삭제 (0)</button>
      <button id="media-delete-cancel" style="padding: 8px 16px; border-radius: 8px; border: 1px solid #e8e8ed; background: #fff; color: #6e6e73; font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: inherit;">취소</button>
    </div>
  </div>

  <!-- Upload progress -->
  <div id="upload-progress" style="display: none; margin-bottom: 20px; padding: 12px 16px; background-color: #f0f9ff; border: 1px solid #bae6fd; border-radius: 8px; font-size: 0.875rem; color: #0369a1;">
    <span id="upload-status">업로드 중...</span>
  </div>

  <!-- Drop zone overlay -->
  <div
    id="drop-zone"
    style="display: none; position: fixed; inset: 0; z-index: 100; background-color: rgba(212, 170, 69, 0.1); border: 3px dashed #D4AA45; display: none; align-items: center; justify-content: center;"
  >
    <div style="padding: 40px; background-color: white; border-radius: 16px; text-align: center;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#D4AA45" stroke-width="1.5" style="margin: 0 auto 12px;">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="17 8 12 3 7 8" />
        <line x1="12" y1="3" x2="12" y2="15" />
      </svg>
      <p style="font-size: 1rem; font-weight: 600; color: #1d1d1f;">이미지를 놓으세요</p>
    </div>
  </div>

  <!-- Media Grid -->
  <div id="media-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px;">
    {mediaList.length === 0 ? (
      <div style="grid-column: 1 / -1; padding: 80px 0; text-align: center; color: #8c8c8c;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d2d2d7" stroke-width="1.5" style="margin: 0 auto 12px;">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
        <p style="font-size: 0.875rem;">업로드된 미디어가 없습니다</p>
        <p style="font-size: 0.8125rem; margin-top: 4px; color: #aaa;">이미지를 드래그하거나 업로드 버튼을 클릭하세요</p>
      </div>
    ) : (
      mediaList.map((media: any) => (
        <div
          class="media-card"
          data-id={media.id}
          data-url={media.url}
          style="position: relative; background-color: #ffffff; border: 1px solid #e8e8ed; border-radius: 10px; overflow: hidden; cursor: pointer; transition: all 0.15s;"
        >
          <div style="aspect-ratio: 1; overflow: hidden; background-color: #f5f5f7;">
            <img
              src={media.url}
              alt={media.filename}
              loading="lazy"
              style="width: 100%; height: 100%; object-fit: cover;"
            />
          </div>
          <div style="padding: 8px 10px;">
            <div style="font-size: 0.75rem; color: #1d1d1f; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              {media.filename}
            </div>
            <div style="font-size: 0.6875rem; color: #8c8c8c; margin-top: 2px;">
              {media.width}×{media.height}
            </div>
          </div>
          <div class="media-checkbox" style="position: absolute; top: 6px; left: 6px; z-index: 10; display: none;">
            <input type="checkbox" data-id={media.id} style="width: 22px; height: 22px; accent-color: #D4AA45; cursor: pointer;" />
          </div>
        </div>
      ))
    )}
  </div>

  <!-- Delete Modal -->
  <div id="delete-modal" class="modal-overlay hidden">
    <div class="modal-card modal-small">
      <div class="modal-header">
        <h3 class="modal-title">삭제 확인</h3>
        <button id="delete-modal-close" class="modal-close">&times;</button>
      </div>
      <div class="modal-body">
        <p>이 항목을 영구적으로 삭제하시겠습니까?<br/>이 작업은 되돌릴 수 없습니다.</p>
      </div>
      <div class="modal-footer">
        <button id="delete-cancel" class="btn-secondary">취소</button>
        <button id="delete-confirm" class="btn-danger">삭제</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="media-toast" class="gallery-toast"></div>

  <!-- Copy URL Modal -->
  <div id="url-modal" style="display: none; position: fixed; inset: 0; z-index: 50; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
    <div style="background-color: white; border-radius: 12px; padding: 24px; width: 90%; max-width: 480px;">
      <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 12px;">이미지 URL</h3>
      <input
        id="url-input"
        type="text"
        readonly
        style="width: 100%; padding: 10px 12px; border: 1px solid #e8e8ed; border-radius: 6px; font-size: 0.8125rem; font-family: monospace; color: #1d1d1f; background-color: #fafafa;"
      />
      <div style="display: flex; gap: 8px; margin-top: 16px; justify-content: flex-end;">
        <button id="copy-url-btn" style="padding: 8px 16px; border-radius: 6px; border: none; background-color: #1d1d1f; color: #fff; font-size: 0.8125rem; font-family: inherit; cursor: pointer;">
          URL 복사
        </button>
        <button id="close-modal-btn" style="padding: 8px 16px; border-radius: 6px; border: 1px solid #e8e8ed; background-color: #fff; color: #6e6e73; font-size: 0.8125rem; font-family: inherit; cursor: pointer;">
          닫기
        </button>
      </div>
    </div>
  </div>

  <style>
    .media-card:hover {
      border-color: #D4AA45;
      box-shadow: 0 2px 8px rgba(212, 170, 69, 0.12);
    }
    .media-card.selected {
      border-color: #D4AA45 !important;
      box-shadow: 0 0 0 2px rgba(212, 170, 69, 0.4) !important;
    }
    .btn-secondary {
      padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid #e8e8ed; background: #fff;
      color: #6e6e73; font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: inherit;
    }
    .btn-secondary:hover { border-color: #1d1d1f; color: #1d1d1f; }
    .btn-danger {
      padding: 0.5rem 1rem; border-radius: 8px; border: none; background: #ef4444;
      color: #fff; font-size: 0.875rem; font-weight: 500; cursor: pointer; font-family: inherit;
    }
    .btn-danger:hover { background: #dc2626; }
    .modal-overlay {
      position: fixed; inset: 0; z-index: 50; background: rgba(0,0,0,0.5);
      display: flex; align-items: center; justify-content: center;
    }
    .modal-overlay.hidden { display: none; }
    .modal-card {
      background: #fff; border-radius: 14px; width: 90%; max-width: 480px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.15); overflow: hidden;
    }
    .modal-small { max-width: 380px; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; border-bottom: 1px solid #e8e8ed; }
    .modal-title { font-size: 1rem; font-weight: 600; color: #1d1d1f; }
    .modal-close { background: none; border: none; font-size: 1.5rem; color: #8c8c8c; cursor: pointer; line-height: 1; }
    .modal-close:hover { color: #1d1d1f; }
    .modal-body { padding: 1.25rem 1.5rem; }
    .modal-footer { display: flex; justify-content: flex-end; gap: 0.75rem; padding: 1rem 1.5rem; border-top: 1px solid #e8e8ed; }
  </style>
  <style is:global>
    .gallery-toast {
      position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(20px);
      background: #1d1d1f; color: #fff; padding: 0.75rem 1.5rem; border-radius: 10px;
      font-size: 0.875rem; font-weight: 500; opacity: 0; pointer-events: none;
      transition: opacity 0.3s, transform 0.3s; z-index: 200;
    }
    .gallery-toast.visible { opacity: 1; transform: translateX(-50%) translateY(0); }
    .gallery-toast.error { background: #ef4444; }
  </style>

  <script>
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const progressDiv = document.getElementById('upload-progress')!;
    const statusSpan = document.getElementById('upload-status')!;
    const mediaGrid = document.getElementById('media-grid')!;
    const dropZone = document.getElementById('drop-zone')!;
    const urlModal = document.getElementById('url-modal')!;
    const urlInput = document.getElementById('url-input') as HTMLInputElement;
    const copyUrlBtn = document.getElementById('copy-url-btn')!;
    const closeModalBtn = document.getElementById('close-modal-btn')!;

    // Toast
    const toast = document.getElementById('media-toast')!;
    function showToast(msg: string, isError = false) {
      toast.textContent = msg;
      toast.classList.toggle('error', isError);
      toast.classList.add('visible');
      setTimeout(() => toast.classList.remove('visible'), 2500);
    }

    // File upload handler
    async function uploadFiles(files: FileList | File[]) {
      progressDiv.style.display = 'block';
      const fileArray = Array.from(files);
      const total = fileArray.length;
      let uploaded = 0;

      // 업로드 전 압축
      statusSpan.textContent = '이미지 압축 중...';
      const compressed = await (window as any).compressImages(fileArray);

      for (const file of compressed) {
        statusSpan.textContent = `업로드 중... (${uploaded + 1}/${total})`;
        const formData = new FormData();
        formData.append('file', file);

        try {
          const res = await fetch('/api/media/upload', { method: 'POST', body: formData });
          if (res.ok) {
            uploaded++;
          } else {
            const err = await res.json();
            console.error('Upload error:', err.error);
          }
        } catch (e) {
          console.error('Upload failed:', e);
        }
      }

      statusSpan.textContent = `${uploaded}/${total}개 업로드 완료`;
      setTimeout(() => {
        progressDiv.style.display = 'none';
        window.location.reload();
      }, 1000);
    }

    fileInput.addEventListener('change', () => {
      if (fileInput.files && fileInput.files.length > 0) {
        uploadFiles(fileInput.files);
      }
    });

    // Drag & drop
    let dragCounter = 0;
    document.addEventListener('dragenter', (e) => {
      e.preventDefault();
      dragCounter++;
      dropZone.style.display = 'flex';
    });
    document.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dragCounter--;
      if (dragCounter === 0) dropZone.style.display = 'none';
    });
    document.addEventListener('dragover', (e) => {
      e.preventDefault();
    });
    document.addEventListener('drop', (e) => {
      e.preventDefault();
      dragCounter = 0;
      dropZone.style.display = 'none';
      if (e.dataTransfer?.files.length) {
        uploadFiles(e.dataTransfer.files);
      }
    });

    // === Delete mode ===
    let mediaDeleteMode = false;
    let mediaSelectedIds = new Set<number>();

    function enterMediaDeleteMode() {
      mediaDeleteMode = true;
      mediaSelectedIds.clear();
      document.getElementById('media-toolbar-normal')!.style.display = 'none';
      document.getElementById('media-toolbar-delete')!.style.display = 'flex';
      const confirmBtn = document.getElementById('media-delete-confirm') as HTMLButtonElement;
      confirmBtn.disabled = true;
      confirmBtn.style.opacity = '0.5';
      confirmBtn.textContent = '선택 삭제 (0)';
      document.querySelectorAll<HTMLElement>('.media-checkbox').forEach(cb => cb.style.display = 'block');
    }

    function exitMediaDeleteMode() {
      mediaDeleteMode = false;
      mediaSelectedIds.clear();
      document.getElementById('media-toolbar-normal')!.style.display = 'flex';
      document.getElementById('media-toolbar-delete')!.style.display = 'none';
      document.querySelectorAll<HTMLElement>('.media-checkbox').forEach(cb => cb.style.display = 'none');
      document.querySelectorAll<HTMLInputElement>('.media-checkbox input').forEach(cb => cb.checked = false);
      document.querySelectorAll('.media-card').forEach(c => c.classList.remove('selected'));
    }

    function updateMediaDeleteCount() {
      const confirmBtn = document.getElementById('media-delete-confirm') as HTMLButtonElement;
      confirmBtn.textContent = `선택 삭제 (${mediaSelectedIds.size})`;
      confirmBtn.disabled = mediaSelectedIds.size === 0;
      confirmBtn.style.opacity = mediaSelectedIds.size === 0 ? '0.5' : '1';
    }

    document.getElementById('media-delete-mode-btn')!.addEventListener('click', enterMediaDeleteMode);
    document.getElementById('media-delete-cancel')!.addEventListener('click', exitMediaDeleteMode);

    // Show delete modal on confirm button click
    document.getElementById('media-delete-confirm')!.addEventListener('click', () => {
      if (mediaSelectedIds.size === 0) return;
      document.querySelector('#delete-modal .modal-body p')!.innerHTML =
        `선택한 <strong>${mediaSelectedIds.size}개</strong> 항목을 영구적으로 삭제하시겠습니까?<br/>이 작업은 되돌릴 수 없습니다.`;
      document.getElementById('delete-modal')!.classList.remove('hidden');
    });

    // Delete modal buttons
    document.getElementById('delete-modal-close')!.addEventListener('click', () => {
      document.getElementById('delete-modal')!.classList.add('hidden');
    });
    document.getElementById('delete-cancel')!.addEventListener('click', () => {
      document.getElementById('delete-modal')!.classList.add('hidden');
    });
    document.getElementById('delete-confirm')!.addEventListener('click', async () => {
      let success = 0;
      let failed = 0;
      for (const id of mediaSelectedIds) {
        try {
          const res = await fetch(`/api/media/${id}`, { method: 'DELETE' });
          if (res.ok) {
            success++;
            // Remove card from DOM
            const card = document.querySelector(`.media-card[data-id="${id}"]`);
            if (card) card.remove();
          } else { failed++; }
        } catch { failed++; }
      }
      if (failed === 0) showToast(`${success}개 삭제 완료!`);
      else showToast(`${success}개 삭제, ${failed}개 실패`, true);
      exitMediaDeleteMode();
      document.getElementById('delete-modal')!.classList.add('hidden');
    });

    // Click to show URL or toggle checkbox
    document.querySelectorAll('.media-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        if (mediaDeleteMode) {
          e.preventDefault();
          const id = Number((card as HTMLElement).dataset.id);
          const checkbox = card.querySelector<HTMLInputElement>('.media-checkbox input');
          if (!checkbox) return;
          if (mediaSelectedIds.has(id)) {
            mediaSelectedIds.delete(id);
            checkbox.checked = false;
            card.classList.remove('selected');
          } else {
            mediaSelectedIds.add(id);
            checkbox.checked = true;
            card.classList.add('selected');
          }
          updateMediaDeleteCount();
          return;
        }
        const url = (card as HTMLElement).dataset.url;
        if (url) {
          urlInput.value = url;
          urlModal.style.display = 'flex';
        }
      });
    });

    copyUrlBtn.addEventListener('click', () => {
      urlInput.select();
      navigator.clipboard.writeText(urlInput.value);
      copyUrlBtn.textContent = '복사됨!';
      setTimeout(() => (copyUrlBtn.textContent = 'URL 복사'), 1500);
    });

    closeModalBtn.addEventListener('click', () => {
      urlModal.style.display = 'none';
    });
    urlModal.addEventListener('click', (e) => {
      if (e.target === urlModal) urlModal.style.display = 'none';
    });
  </script>
</AdminLayout>
