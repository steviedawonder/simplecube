---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import db from '@lib/db';

const result = await db.execute('SELECT * FROM media ORDER BY created_at DESC');
const mediaList = result.rows as any[];
---

<AdminLayout title="미디어 라이브러리">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
    <h2 style="font-size: 1.25rem; font-weight: 700; color: #1d1d1f;">
      미디어 라이브러리
      <span style="font-weight: 400; font-size: 0.875rem; color: #8c8c8c; margin-left: 8px;">
        ({mediaList.length}개)
      </span>
    </h2>
    <label
      id="upload-btn"
      style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background-color: #1d1d1f; color: #ffffff; border-radius: 8px; font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: background-color 0.15s;"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="17 8 12 3 7 8" />
        <line x1="12" y1="3" x2="12" y2="15" />
      </svg>
      업로드
      <input type="file" id="file-input" accept="image/*" multiple style="display: none;" />
    </label>
  </div>

  <!-- Upload progress -->
  <div id="upload-progress" style="display: none; margin-bottom: 20px; padding: 12px 16px; background-color: #f0f9ff; border: 1px solid #bae6fd; border-radius: 8px; font-size: 0.875rem; color: #0369a1;">
    <span id="upload-status">업로드 중...</span>
  </div>

  <!-- Drop zone overlay -->
  <div
    id="drop-zone"
    style="display: none; position: fixed; inset: 0; z-index: 100; background-color: rgba(212, 170, 69, 0.1); border: 3px dashed #D4AA45; display: none; align-items: center; justify-content: center;"
  >
    <div style="padding: 40px; background-color: white; border-radius: 16px; text-align: center;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#D4AA45" stroke-width="1.5" style="margin: 0 auto 12px;">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="17 8 12 3 7 8" />
        <line x1="12" y1="3" x2="12" y2="15" />
      </svg>
      <p style="font-size: 1rem; font-weight: 600; color: #1d1d1f;">이미지를 놓으세요</p>
    </div>
  </div>

  <!-- Media Grid -->
  <div id="media-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px;">
    {mediaList.length === 0 ? (
      <div style="grid-column: 1 / -1; padding: 80px 0; text-align: center; color: #8c8c8c;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d2d2d7" stroke-width="1.5" style="margin: 0 auto 12px;">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
        <p style="font-size: 0.875rem;">업로드된 미디어가 없습니다</p>
        <p style="font-size: 0.8125rem; margin-top: 4px; color: #aaa;">이미지를 드래그하거나 업로드 버튼을 클릭하세요</p>
      </div>
    ) : (
      mediaList.map((media: any) => (
        <div
          class="media-card"
          data-id={media.id}
          data-url={media.url}
          style="position: relative; background-color: #ffffff; border: 1px solid #e8e8ed; border-radius: 10px; overflow: hidden; cursor: pointer; transition: all 0.15s;"
        >
          <div style="aspect-ratio: 1; overflow: hidden; background-color: #f5f5f7;">
            <img
              src={media.url}
              alt={media.filename}
              loading="lazy"
              style="width: 100%; height: 100%; object-fit: cover;"
            />
          </div>
          <div style="padding: 8px 10px;">
            <div style="font-size: 0.75rem; color: #1d1d1f; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
              {media.filename}
            </div>
            <div style="font-size: 0.6875rem; color: #8c8c8c; margin-top: 2px;">
              {media.width}×{media.height}
            </div>
          </div>
          <button
            class="delete-media-btn"
            data-id={media.id}
            style="position: absolute; top: 6px; right: 6px; width: 28px; height: 28px; border-radius: 50%; border: none; background-color: rgba(0,0,0,0.6); color: #fff; cursor: pointer; display: none; align-items: center; justify-content: center;"
            title="삭제"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="18" y1="6" x2="6" y2="18" />
              <line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          </button>
        </div>
      ))
    )}
  </div>

  <!-- Copy URL Modal -->
  <div id="url-modal" style="display: none; position: fixed; inset: 0; z-index: 50; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
    <div style="background-color: white; border-radius: 12px; padding: 24px; width: 90%; max-width: 480px;">
      <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 12px;">이미지 URL</h3>
      <input
        id="url-input"
        type="text"
        readonly
        style="width: 100%; padding: 10px 12px; border: 1px solid #e8e8ed; border-radius: 6px; font-size: 0.8125rem; font-family: monospace; color: #1d1d1f; background-color: #fafafa;"
      />
      <div style="display: flex; gap: 8px; margin-top: 16px; justify-content: flex-end;">
        <button id="copy-url-btn" style="padding: 8px 16px; border-radius: 6px; border: none; background-color: #1d1d1f; color: #fff; font-size: 0.8125rem; font-family: inherit; cursor: pointer;">
          URL 복사
        </button>
        <button id="close-modal-btn" style="padding: 8px 16px; border-radius: 6px; border: 1px solid #e8e8ed; background-color: #fff; color: #6e6e73; font-size: 0.8125rem; font-family: inherit; cursor: pointer;">
          닫기
        </button>
      </div>
    </div>
  </div>

  <style>
    .media-card:hover {
      border-color: #D4AA45;
      box-shadow: 0 2px 8px rgba(212, 170, 69, 0.12);
    }
    .media-card:hover .delete-media-btn {
      display: flex !important;
    }
  </style>

  <script>
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const progressDiv = document.getElementById('upload-progress')!;
    const statusSpan = document.getElementById('upload-status')!;
    const mediaGrid = document.getElementById('media-grid')!;
    const dropZone = document.getElementById('drop-zone')!;
    const urlModal = document.getElementById('url-modal')!;
    const urlInput = document.getElementById('url-input') as HTMLInputElement;
    const copyUrlBtn = document.getElementById('copy-url-btn')!;
    const closeModalBtn = document.getElementById('close-modal-btn')!;

    // File upload handler
    async function uploadFiles(files: FileList | File[]) {
      progressDiv.style.display = 'block';
      const total = files.length;
      let uploaded = 0;

      for (const file of Array.from(files)) {
        statusSpan.textContent = `업로드 중... (${uploaded + 1}/${total})`;
        const formData = new FormData();
        formData.append('file', file);

        try {
          const res = await fetch('/api/media/upload', { method: 'POST', body: formData });
          if (res.ok) {
            uploaded++;
          } else {
            const err = await res.json();
            console.error('Upload error:', err.error);
          }
        } catch (e) {
          console.error('Upload failed:', e);
        }
      }

      statusSpan.textContent = `${uploaded}/${total}개 업로드 완료`;
      setTimeout(() => {
        progressDiv.style.display = 'none';
        window.location.reload();
      }, 1000);
    }

    fileInput.addEventListener('change', () => {
      if (fileInput.files && fileInput.files.length > 0) {
        uploadFiles(fileInput.files);
      }
    });

    // Drag & drop
    let dragCounter = 0;
    document.addEventListener('dragenter', (e) => {
      e.preventDefault();
      dragCounter++;
      dropZone.style.display = 'flex';
    });
    document.addEventListener('dragleave', (e) => {
      e.preventDefault();
      dragCounter--;
      if (dragCounter === 0) dropZone.style.display = 'none';
    });
    document.addEventListener('dragover', (e) => {
      e.preventDefault();
    });
    document.addEventListener('drop', (e) => {
      e.preventDefault();
      dragCounter = 0;
      dropZone.style.display = 'none';
      if (e.dataTransfer?.files.length) {
        uploadFiles(e.dataTransfer.files);
      }
    });

    // Click to show URL
    document.querySelectorAll('.media-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.delete-media-btn')) return;
        const url = (card as HTMLElement).dataset.url;
        if (url) {
          urlInput.value = url;
          urlModal.style.display = 'flex';
        }
      });
    });

    copyUrlBtn.addEventListener('click', () => {
      urlInput.select();
      navigator.clipboard.writeText(urlInput.value);
      copyUrlBtn.textContent = '복사됨!';
      setTimeout(() => (copyUrlBtn.textContent = 'URL 복사'), 1500);
    });

    closeModalBtn.addEventListener('click', () => {
      urlModal.style.display = 'none';
    });
    urlModal.addEventListener('click', (e) => {
      if (e.target === urlModal) urlModal.style.display = 'none';
    });

    // Delete media
    document.querySelectorAll('.delete-media-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id;
        if (!confirm('이 미디어를 삭제하시겠습니까?')) return;

        try {
          const res = await fetch(`/api/media/${id}`, { method: 'DELETE' });
          if (res.ok) {
            (btn as HTMLElement).closest('.media-card')?.remove();
          } else {
            alert('삭제에 실패했습니다.');
          }
        } catch {
          alert('삭제에 실패했습니다.');
        }
      });
    });
  </script>
</AdminLayout>
