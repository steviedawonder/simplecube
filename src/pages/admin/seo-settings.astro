---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import db from '@lib/db';

const result = await db.execute('SELECT * FROM seo_rules ORDER BY category, id');
const rules = result.rows as any[];

const categoryLabels: Record<string, string> = {
  basic: '기본 SEO',
  title: '제목 가독성',
  content: '콘텐츠 가독성',
  links: '링크 분석',
};

const grouped = rules.reduce((acc: Record<string, any[]>, rule: any) => {
  if (!acc[rule.category]) acc[rule.category] = [];
  acc[rule.category].push(rule);
  return acc;
}, {});
---

<AdminLayout title="SEO 설정">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">SEO 규칙 관리</h1>
      <p class="text-sm text-gray-500 mt-1">SEO 점수 체크 항목을 관리합니다. 규칙을 비활성화하거나 배점을 조정할 수 있습니다.</p>
    </div>
    <button id="reset-btn" class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">기본값 초기화</button>
  </div>

  {Object.entries(grouped).map(([category, catRules]) => (
    <div class="bg-white rounded-xl border border-gray-200 mb-6 overflow-hidden">
      <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
        <h2 class="text-lg font-semibold">{categoryLabels[category] || category}</h2>
        <p class="text-xs text-gray-500 mt-0.5">
          총 {(catRules as any[]).reduce((s: number, r: any) => s + r.max_score, 0)}점
        </p>
      </div>
      <div class="divide-y divide-gray-100">
        {(catRules as any[]).map((rule: any) => (
          <div class="px-6 py-4 flex items-center gap-4" data-rule-id={rule.id}>
            <label class="relative inline-flex cursor-pointer items-center">
              <input
                type="checkbox"
                class="rule-toggle peer sr-only"
                checked={Boolean(rule.enabled)}
                data-id={rule.id}
              />
              <div class="h-5 w-9 rounded-full bg-gray-300 peer-checked:bg-[#D4AA45] after:absolute after:left-[2px] after:top-[2px] after:h-4 after:w-4 after:rounded-full after:bg-white after:transition-all peer-checked:after:translate-x-full"></div>
            </label>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">{rule.label}</div>
              <div class="text-xs text-gray-500">{rule.id}</div>
            </div>
            <div class="flex items-center gap-2">
              <label class="text-xs text-gray-500">배점:</label>
              <input
                type="number"
                min="0"
                max="20"
                value={rule.max_score}
                class="score-input w-16 rounded border border-gray-300 px-2 py-1 text-sm text-center focus:border-[#D4AA45] focus:outline-none"
                data-id={rule.id}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <div class="flex justify-end">
    <button id="save-btn" class="px-6 py-2.5 bg-[#D4AA45] text-white rounded-lg text-sm font-medium hover:bg-[#C49A2F] transition-colors">변경사항 저장</button>
  </div>
</AdminLayout>

<script>
  document.getElementById('save-btn')?.addEventListener('click', async () => {
    const toggles = document.querySelectorAll('.rule-toggle') as NodeListOf<HTMLInputElement>;
    const scores = document.querySelectorAll('.score-input') as NodeListOf<HTMLInputElement>;

    const updates: { id: string; enabled: boolean; max_score: number }[] = [];

    toggles.forEach((toggle) => {
      const id = toggle.dataset.id!;
      const scoreInput = document.querySelector(`.score-input[data-id="${id}"]`) as HTMLInputElement;
      updates.push({
        id,
        enabled: toggle.checked,
        max_score: parseInt(scoreInput.value) || 0,
      });
    });

    const res = await fetch('/api/seo/rules', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ rules: updates }),
    });

    if (res.ok) {
      alert('저장되었습니다.');
    } else {
      alert('저장 중 오류가 발생했습니다.');
    }
  });

  document.getElementById('reset-btn')?.addEventListener('click', async () => {
    if (!confirm('모든 SEO 규칙을 기본값으로 초기화하시겠습니까?')) return;
    const res = await fetch('/api/seo/rules', { method: 'DELETE' });
    if (res.ok) window.location.reload();
  });
</script>
