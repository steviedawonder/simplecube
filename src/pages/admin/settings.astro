---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import db from '@lib/db';

// Get existing settings
const result = await db.execute('SELECT * FROM settings');
const settingsMap: Record<string, string> = {};
for (const row of result.rows as any[]) {
  settingsMap[row.key] = row.value;
}
---

<AdminLayout title="사이트 설정">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">사이트 설정</h1>
    <p class="text-sm text-gray-500 mt-1">사이트 기본 정보를 관리합니다.</p>
  </div>

  <form id="settings-form" class="space-y-6">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold mb-4">기본 정보</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">사이트 제목</label>
          <input type="text" name="site_title" value={settingsMap.site_title || '심플큐브 포토부스'} class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">사이트 설명</label>
          <textarea name="site_description" rows="2" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none">{settingsMap.site_description || '브랜드 팝업부터 웨딩까지, 특별한 순간을 완성하는 포토부스'}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">기본 OG 이미지 URL</label>
          <input type="text" name="og_image" value={settingsMap.og_image || ''} placeholder="https://..." class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold mb-4">소셜 링크</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Instagram</label>
          <input type="text" name="social_instagram" value={settingsMap.social_instagram || ''} placeholder="https://instagram.com/..." class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">카카오톡 채널</label>
          <input type="text" name="social_kakao" value={settingsMap.social_kakao || ''} placeholder="https://pf.kakao.com/..." class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">네이버 블로그</label>
          <input type="text" name="social_naver" value={settingsMap.social_naver || ''} placeholder="https://blog.naver.com/..." class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
        </div>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-semibold mb-4">관리자 비밀번호 변경</h2>
      <p class="text-xs text-gray-500 mb-3">비밀번호를 변경하려면 환경 변수(ADMIN_PASSWORD)를 Vercel 대시보드에서 수정해주세요.</p>
    </div>

    <div class="flex justify-end">
      <button type="submit" class="px-6 py-2.5 bg-[#D4AA45] text-white rounded-lg text-sm font-medium hover:bg-[#C49A2F] transition-colors">저장</button>
    </div>
  </form>
</AdminLayout>

<script>
  document.getElementById('settings-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const settings: Record<string, string> = {};
    formData.forEach((value, key) => { settings[key] = value.toString(); });

    const res = await fetch('/api/settings', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(settings),
    });

    if (res.ok) {
      alert('저장되었습니다.');
    } else {
      alert('저장 중 오류가 발생했습니다.');
    }
  });
</script>
