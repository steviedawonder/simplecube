---
export const prerender = false;

import AdminLayout from '@layouts/AdminLayout.astro';
import db from '@lib/db';

const user = Astro.locals.user;
const isOwner = user?.role === 'owner';

// Editor hub data
const today = new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });

// Owner-only stats (skip DB queries for editors)
let totalPosts = 0, publishedPosts = 0, draftPosts = 0, scheduledPosts = 0, trashPosts = 0;
let totalCategories = 0, totalMedia = 0, avgSeoScore = 0;
let recentPosts: any[] = [];
let seoGood = 0, seoOk = 0, seoPoor = 0;
let catDist: any[] = [];

if (isOwner) {
  const totalResult = await db.execute('SELECT COUNT(*) as count FROM posts WHERE deleted_at IS NULL');
  const publishedResult = await db.execute('SELECT COUNT(*) as count FROM posts WHERE deleted_at IS NULL AND draft = 0');
  const draftResult = await db.execute('SELECT COUNT(*) as count FROM posts WHERE deleted_at IS NULL AND draft = 1');
  const scheduledResult = await db.execute("SELECT COUNT(*) as count FROM posts WHERE deleted_at IS NULL AND draft = 1 AND scheduled_at IS NOT NULL AND scheduled_at > datetime('now')");
  const trashResult = await db.execute('SELECT COUNT(*) as count FROM posts WHERE deleted_at IS NOT NULL');
  const categoryResult = await db.execute('SELECT COUNT(*) as count FROM categories');
  const mediaResult = await db.execute('SELECT COUNT(*) as count FROM media');
  const avgSeoResult = await db.execute('SELECT AVG(seo_score) as avg_score FROM posts WHERE deleted_at IS NULL AND draft = 0 AND seo_score > 0');

  totalPosts = Number((totalResult.rows[0] as any).count);
  publishedPosts = Number((publishedResult.rows[0] as any).count);
  draftPosts = Number((draftResult.rows[0] as any).count);
  scheduledPosts = Number((scheduledResult.rows[0] as any).count);
  trashPosts = Number((trashResult.rows[0] as any).count);
  totalCategories = Number((categoryResult.rows[0] as any).count);
  totalMedia = Number((mediaResult.rows[0] as any).count);
  avgSeoScore = Math.round(Number((avgSeoResult.rows[0] as any).avg_score) || 0);

  const recentPostsResult = await db.execute(`
    SELECT p.id, p.title, p.slug, p.draft, p.seo_score, p.created_at, p.updated_at,
           c.name as category_name
    FROM posts p
    LEFT JOIN categories c ON p.category_id = c.id
    WHERE p.deleted_at IS NULL
    ORDER BY p.updated_at DESC
    LIMIT 5
  `);
  recentPosts = recentPostsResult.rows as any[];

  const seoDistResult = await db.execute(`
    SELECT
      SUM(CASE WHEN seo_score >= 70 THEN 1 ELSE 0 END) as good,
      SUM(CASE WHEN seo_score >= 40 AND seo_score < 70 THEN 1 ELSE 0 END) as ok,
      SUM(CASE WHEN seo_score < 40 THEN 1 ELSE 0 END) as poor
    FROM posts
    WHERE deleted_at IS NULL AND draft = 0
  `);
  const seoDist = seoDistResult.rows[0] as any;
  seoGood = Number(seoDist.good || 0);
  seoOk = Number(seoDist.ok || 0);
  seoPoor = Number(seoDist.poor || 0);

  const catDistResult = await db.execute(`
    SELECT c.name, COUNT(p.id) as post_count
    FROM categories c
    LEFT JOIN posts p ON p.category_id = c.id AND p.deleted_at IS NULL
    GROUP BY c.id, c.name
    ORDER BY post_count DESC
    LIMIT 5
  `);
  catDist = catDistResult.rows as any[];
}

function seoColor(score: number) {
  if (score >= 70) return '#22c55e';
  if (score >= 40) return '#D4AA45';
  return '#ef4444';
}

const hubCards = [
  { emoji: '📸', label: '사진 관리', desc: '포트폴리오, 현장사진, 포토스트립 업로드', href: '/admin/portfolio', ready: true },
  { emoji: '✍️', label: '블로그', desc: '블로그 글 작성 및 관리', href: '/admin/posts', ready: true },
  { emoji: '📢', label: '공지/팝업', desc: '팝업 배너 관리', href: '/admin/popups', ready: true },
  { emoji: '📦', label: '패키지·스펙', desc: '패키지 구성, 가격, 모델 스펙 수정', href: '/admin/packages', ready: true },
  { emoji: '🎨', label: '배경·백드롭', desc: '프로그램 배경, 웨딩 백드롭 이미지 관리', href: '/admin/gallery', ready: true },
  { emoji: '🎞️', label: '포토스트립', desc: '웨딩 포토스트립 디자인 관리', href: '/admin/photostrip', ready: true },
  { emoji: '❓', label: 'FAQ·연락처', desc: '자주 묻는 질문, 지점 연락처 수정', href: '/admin/faq', ready: true },
];
---

<AdminLayout title={isOwner ? '대시보드' : '허브'}>
  {!isOwner ? (
  <!-- Editor Hub -->
  <div class="hub-container">
    <div class="hub-header">
      <h2 class="hub-greeting">안녕하세요, {user?.name}님 👋</h2>
      <p class="hub-date">{today}</p>
    </div>

    <div class="hub-grid">
      {hubCards.map((card) => (
        <a
          href={card.ready ? card.href : '#'}
          class:list={['hub-card', { 'hub-card--disabled': !card.ready }]}
          data-ready={card.ready ? 'true' : 'false'}
        >
          <span class="hub-card-emoji">{card.emoji}</span>
          <div class="hub-card-body">
            <h3 class="hub-card-label">{card.label}</h3>
            <p class="hub-card-desc">{card.desc}</p>
          </div>
          {!card.ready && <span class="hub-card-badge">준비 중</span>}
        </a>
      ))}
    </div>
  </div>
  ) : (
  <!-- Owner Dashboard -->
  <div>
    <h2 class="page-title">대시보드</h2>
    <p class="page-desc">SIMPLE CUBE 관리자 페이지에 오신 것을 환영합니다.</p>

    <!-- Stats cards -->
    <div class="stats-grid-4">
      <div class="stat-card">
        <div class="stat-icon" style="background-color: rgba(29, 29, 31, 0.06);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1d1d1f" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="16" y1="13" x2="8" y2="13" />
            <line x1="16" y1="17" x2="8" y2="17" />
          </svg>
        </div>
        <div class="stat-label">전체 글</div>
        <div class="stat-value">{totalPosts}</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background-color: rgba(34, 197, 94, 0.08);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
        <div class="stat-label">발행됨</div>
        <div class="stat-value published">{publishedPosts}</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background-color: rgba(212, 170, 69, 0.08);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D4AA45" stroke-width="2">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
          </svg>
        </div>
        <div class="stat-label">임시저장</div>
        <div class="stat-value draft">{draftPosts}</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style={`background-color: rgba(${avgSeoScore >= 70 ? '34, 197, 94' : avgSeoScore >= 40 ? '212, 170, 69' : '239, 68, 68'}, 0.08);`}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke={seoColor(avgSeoScore)} stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 6v6l4 2" />
          </svg>
        </div>
        <div class="stat-label">평균 SEO 점수</div>
        <div class="stat-value" style={`color: ${seoColor(avgSeoScore)};`}>{avgSeoScore}</div>
      </div>
    </div>

    <!-- Sub stats -->
    <div class="sub-stats">
      {scheduledPosts > 0 && (
        <span class="sub-stat">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6d28d9" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 6v6l4 2" />
          </svg>
          예약 발행 {scheduledPosts}개
        </span>
      )}
      {trashPosts > 0 && (
        <a href="/admin/posts?view=trash" class="sub-stat trash-link">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2">
            <polyline points="3 6 5 6 21 6" />
            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
          </svg>
          휴지통 {trashPosts}개
        </a>
      )}
      <span class="sub-stat">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6e6e73" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" />
          <rect x="14" y="3" width="7" height="7" />
          <rect x="14" y="14" width="7" height="7" />
          <rect x="3" y="14" width="7" height="7" />
        </svg>
        카테고리 {totalCategories}개
      </span>
      <span class="sub-stat">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6e6e73" stroke-width="2">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
          <circle cx="8.5" cy="8.5" r="1.5" />
          <polyline points="21 15 16 10 5 21" />
        </svg>
        미디어 {totalMedia}개
      </span>
    </div>

    <div class="dashboard-grid">
      <!-- Recent posts -->
      <div class="recent-section">
        <div class="section-header">
          <h3 class="section-title">최근 수정된 글</h3>
          <a href="/admin/posts" class="section-link">전체 보기 →</a>
        </div>
        {recentPosts.length === 0 ? (
          <div class="empty-state">
            <p>아직 작성된 글이 없습니다.</p>
            <a href="/admin/posts/new" class="cta-link">첫 글 작성하기 →</a>
          </div>
        ) : (
          <div class="posts-table-wrapper">
            <table class="posts-table">
              <thead>
                <tr>
                  <th>제목</th>
                  <th>카테고리</th>
                  <th style="text-align: center;">SEO</th>
                  <th>상태</th>
                  <th>수정일</th>
                </tr>
              </thead>
              <tbody>
                {recentPosts.map((post) => (
                  <tr>
                    <td>
                      <a href={`/admin/posts/${post.id}`} class="post-link">
                        {post.title}
                      </a>
                    </td>
                    <td class="text-secondary">
                      {post.category_name || '-'}
                    </td>
                    <td style="text-align: center;">
                      <span class:list={['seo-badge', post.seo_score >= 70 ? 'good' : post.seo_score >= 40 ? 'ok' : 'poor']}>
                        {post.seo_score || 0}
                      </span>
                    </td>
                    <td>
                      <span class:list={['status-badge', post.draft ? 'draft' : 'published']}>
                        {post.draft ? '임시저장' : '발행됨'}
                      </span>
                    </td>
                    <td class="text-secondary">
                      {post.updated_at ? new Date(post.updated_at).toLocaleDateString('ko-KR') : '-'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      <!-- Side panels -->
      <div class="side-panels">
        <!-- SEO Score Distribution -->
        {publishedPosts > 0 && (
          <div class="panel">
            <h3 class="section-title">SEO 점수 분포</h3>
            <div class="seo-dist">
              <div class="seo-dist-row">
                <div class="seo-dist-label">
                  <span class="seo-dot good"></span>
                  좋음 (70+)
                </div>
                <div class="seo-dist-bar-wrapper">
                  <div class="seo-dist-bar good" style={`width: ${publishedPosts > 0 ? (seoGood / publishedPosts * 100) : 0}%`}></div>
                </div>
                <span class="seo-dist-count">{seoGood}</span>
              </div>
              <div class="seo-dist-row">
                <div class="seo-dist-label">
                  <span class="seo-dot ok"></span>
                  보통 (40-69)
                </div>
                <div class="seo-dist-bar-wrapper">
                  <div class="seo-dist-bar ok" style={`width: ${publishedPosts > 0 ? (seoOk / publishedPosts * 100) : 0}%`}></div>
                </div>
                <span class="seo-dist-count">{seoOk}</span>
              </div>
              <div class="seo-dist-row">
                <div class="seo-dist-label">
                  <span class="seo-dot poor"></span>
                  개선 필요 (0-39)
                </div>
                <div class="seo-dist-bar-wrapper">
                  <div class="seo-dist-bar poor" style={`width: ${publishedPosts > 0 ? (seoPoor / publishedPosts * 100) : 0}%`}></div>
                </div>
                <span class="seo-dist-count">{seoPoor}</span>
              </div>
            </div>
          </div>
        )}

        <!-- Category Distribution -->
        {catDist.length > 0 && (
          <div class="panel">
            <h3 class="section-title">카테고리별 글 수</h3>
            <div class="cat-dist">
              {catDist.map((cat) => (
                <div class="cat-dist-row">
                  <span class="cat-name">{cat.name}</span>
                  <span class="cat-count">{cat.post_count}개</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Quick links -->
        <div class="panel">
          <h3 class="section-title">바로가기</h3>
          <div class="quick-links">
            <a href="/admin/posts/new" class="quick-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19" />
                <line x1="5" y1="12" x2="19" y2="12" />
              </svg>
              새 글 작성
            </a>
            <a href="/admin/categories" class="quick-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="7" height="7" />
                <rect x="14" y="3" width="7" height="7" />
                <rect x="14" y="14" width="7" height="7" />
                <rect x="3" y="14" width="7" height="7" />
              </svg>
              카테고리 관리
            </a>
            <a href="/admin/media" class="quick-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <polyline points="21 15 16 10 5 21" />
              </svg>
              미디어 라이브러리
            </a>
            <a href="/admin/seo-settings" class="quick-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />
              </svg>
              SEO 설정
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
  )}

  <style>
    /* ─── Editor Hub ─── */
    .hub-container {
      max-width: 720px;
      margin: 0 auto;
      padding: 1rem 0;
    }
    .hub-header {
      margin-bottom: 2rem;
    }
    .hub-greeting {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1d1d1f;
      margin-bottom: 0.25rem;
    }
    .hub-date {
      font-size: 0.875rem;
      color: #8c8c8c;
    }
    .hub-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    @media (max-width: 560px) {
      .hub-grid { grid-template-columns: 1fr; }
    }
    .hub-card {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.25rem;
      background-color: #ffffff;
      border: 1px solid #e8e8ed;
      border-radius: 12px;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, box-shadow 0.2s;
      position: relative;
    }
    .hub-card:hover {
      border-color: #D4AA45;
      box-shadow: 0 2px 8px rgba(212, 170, 69, 0.10);
    }
    .hub-card--disabled {
      opacity: 0.65;
      cursor: default;
    }
    .hub-card--disabled:hover {
      border-color: #e8e8ed;
      box-shadow: none;
    }
    .hub-card-emoji {
      font-size: 1.75rem;
      line-height: 1;
      flex-shrink: 0;
    }
    .hub-card-body {
      flex: 1;
      min-width: 0;
    }
    .hub-card-label {
      font-size: 0.9375rem;
      font-weight: 600;
      color: #1d1d1f;
      margin-bottom: 0.25rem;
    }
    .hub-card-desc {
      font-size: 0.8125rem;
      color: #8c8c8c;
      line-height: 1.4;
    }
    .hub-card-badge {
      position: absolute;
      top: 0.75rem;
      right: 0.75rem;
      font-size: 0.6875rem;
      font-weight: 500;
      color: #8c8c8c;
      background-color: #f5f5f7;
      padding: 0.125rem 0.5rem;
      border-radius: 100px;
    }

    /* Toast */
    .hub-toast {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%) translateY(20px);
      background-color: #1d1d1f;
      color: #ffffff;
      padding: 0.75rem 1.5rem;
      border-radius: 10px;
      font-size: 0.875rem;
      font-weight: 500;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s, transform 0.3s;
      z-index: 100;
    }
    .hub-toast.visible {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    /* ─── Owner Dashboard ─── */
    .page-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1d1d1f;
      margin-bottom: 0.25rem;
    }
    .page-desc {
      font-size: 0.9rem;
      color: #6e6e73;
      margin-bottom: 1.5rem;
    }

    .stats-grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1rem;
    }
    @media (max-width: 768px) {
      .stats-grid-4 {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 480px) {
      .stats-grid-4 {
        grid-template-columns: 1fr;
      }
    }

    .stat-card {
      background-color: #ffffff;
      border: 1px solid #e8e8ed;
      border-radius: 10px;
      padding: 1.25rem;
    }
    .stat-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.75rem;
    }
    .stat-label {
      font-size: 0.8125rem;
      font-weight: 500;
      color: #6e6e73;
      margin-bottom: 0.25rem;
    }
    .stat-value {
      font-size: 1.75rem;
      font-weight: 700;
      color: #1d1d1f;
    }
    .stat-value.published { color: #22c55e; }
    .stat-value.draft { color: #D4AA45; }

    .sub-stats {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
    }
    .sub-stat {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 0.8125rem;
      color: #6e6e73;
    }
    .trash-link {
      color: #ef4444;
      text-decoration: none;
    }
    .trash-link:hover {
      text-decoration: underline;
    }

    .dashboard-grid {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 1.5rem;
      align-items: flex-start;
    }
    @media (max-width: 900px) {
      .dashboard-grid {
        grid-template-columns: 1fr;
      }
    }

    .recent-section {
      background-color: #ffffff;
      border: 1px solid #e8e8ed;
      border-radius: 10px;
      padding: 1.25rem;
    }
    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }
    .section-title {
      font-size: 1rem;
      font-weight: 600;
      color: #1d1d1f;
      margin: 0;
    }
    .section-link {
