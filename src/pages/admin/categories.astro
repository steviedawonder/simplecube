---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import db from '@lib/db';

const result = await db.execute(`
  SELECT c.*, (SELECT COUNT(*) FROM posts WHERE category_id = c.id AND deleted_at IS NULL) as post_count
  FROM categories c ORDER BY c.name
`);
const categories = result.rows;
---

<AdminLayout title="카테고리 관리">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-gray-900">카테고리 관리</h1>
  </div>

  <!-- Add Form -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
    <h2 class="text-lg font-semibold mb-4">새 카테고리 추가</h2>
    <form id="add-category-form" class="flex gap-4 items-end">
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">이름</label>
        <input type="text" name="name" required placeholder="카테고리 이름" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
      </div>
      <div class="flex-1">
        <label class="block text-sm font-medium text-gray-700 mb-1">슬러그</label>
        <input type="text" name="slug" required placeholder="url-slug" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-[#D4AA45] focus:outline-none" />
      </div>
      <button type="submit" class="px-4 py-2 bg-[#D4AA45] text-white rounded-lg text-sm font-medium hover:bg-[#C49A2F] transition-colors">추가</button>
    </form>
  </div>

  <!-- Category List -->
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">이름</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">슬러그</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">글 수</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">작업</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200" id="category-list">
        {categories.map((cat: any) => (
          <tr data-id={cat.id}>
            <td class="px-6 py-4 text-sm font-medium text-gray-900">{cat.name}</td>
            <td class="px-6 py-4 text-sm text-gray-500">{cat.slug}</td>
            <td class="px-6 py-4 text-sm text-gray-500">{cat.post_count}</td>
            <td class="px-6 py-4 text-right">
              <button onclick={`deleteCategory(${cat.id}, '${cat.name}')`} class="text-sm text-red-600 hover:text-red-800">삭제</button>
            </td>
          </tr>
        ))}
        {categories.length === 0 && (
          <tr><td colspan="4" class="px-6 py-8 text-center text-sm text-gray-500">카테고리가 없습니다.</td></tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('add-category-form') as HTMLFormElement;
  const nameInput = form.querySelector('input[name="name"]') as HTMLInputElement;
  const slugInput = form.querySelector('input[name="slug"]') as HTMLInputElement;

  nameInput.addEventListener('input', () => {
    slugInput.value = nameInput.value.toLowerCase().replace(/[^a-z0-9가-힣]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const name = nameInput.value.trim();
    const slug = slugInput.value.trim();
    if (!name || !slug) return;

    const res = await fetch('/api/categories', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, slug }),
    });

    if (res.ok) {
      window.location.reload();
    } else {
      const data = await res.json();
      alert(data.error || '오류가 발생했습니다.');
    }
  });

  (window as any).deleteCategory = async (id: number, name: string) => {
    if (!confirm(`"${name}" 카테고리를 삭제하시겠습니까?`)) return;
    const res = await fetch(`/api/categories/${id}`, { method: 'DELETE' });
    if (res.ok) {
      window.location.reload();
    } else {
      const data = await res.json();
      alert(data.error || '삭제할 수 없습니다.');
    }
  };
</script>
