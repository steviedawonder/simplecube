  @media (min-width: 768px) {
    .d-typo-row { font-size: 80px; }
    .d-typo-row span { padding: 20px 28px; }
  }
</style>

<script>
  // Universal slider for all photo-slider elements
  document.querySelectorAll('.photo-slider').forEach((slider) => {
    const el = slider as HTMLElement;
    const container = el.parentElement!;
    const totalUnique = 5;
    let currentIndex = 0;

    setInterval(() => {
      currentIndex++;
      const slideHeight = container.clientHeight;
      el.style.transition = 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
      el.style.transform = `translateY(-${currentIndex * slideHeight}px)`;

      if (currentIndex >= totalUnique) {
        setTimeout(() => {
          el.style.transition = 'none';
          el.style.transform = 'translateY(0)';
          currentIndex = 0;
        }, 850);
      }
    }, 2000);
  });

  // Mobile horizontal sliders
  document.querySelectorAll('.mobile-slider').forEach((slider) => {
    const el = slider as HTMLElement;
    const container = el.parentElement!;
    const totalUnique = 5;
    let currentIndex = 0;

    setInterval(() => {
      currentIndex++;
      const slideWidth = container.clientWidth;
      el.style.transition = 'transform 0.8s cubic-bezier(0.4, 0, 0.2, 1)';
      el.style.transform = `translateX(-${currentIndex * slideWidth}px)`;

      if (currentIndex >= totalUnique) {
        setTimeout(() => {
          el.style.transition = 'none';
          el.style.transform = 'translateX(0)';
          currentIndex = 0;
        }, 850);
      }
    }, 2000);
  });

  // C1: Background slideshow
  const c1Slides = document.querySelectorAll<HTMLImageElement>('.c1-slide');
  if (c1Slides.length > 1) {
    let current = 0;
    setInterval(() => {
      c1Slides[current].classList.remove('opacity-100');
      c1Slides[current].classList.add('opacity-0');
      current = (current + 1) % c1Slides.length;
      c1Slides[current].classList.remove('opacity-0');
      c1Slides[current].classList.add('opacity-100');
    }, 3000);
  }

  // ── Fullpage Scroll (PC only, ≥768px) ──
  (function initFullpageScroll() {
    const isDesktop = window.matchMedia('(min-width: 768px)').matches;
    if (!isDesktop) return;

    const sections = document.querySelectorAll<HTMLElement>('[data-fullpage-section]');
    if (sections.length < 2) return;

    let isAnimating = false;
    const COOLDOWN = 1000;

    function getCurrentIndex(): number {
      const scrollY = window.scrollY;
      let best = 0;
      let bestDist = Infinity;
      sections.forEach((sec, i) => {
        const dist = Math.abs(sec.offsetTop - scrollY);
        if (dist < bestDist) {
          bestDist = dist;
          best = i;
        }
      });
      return best;
    }

    function scrollToSection(index: number) {
      if (index < 0 || index >= sections.length || isAnimating) return;
      isAnimating = true;
      const target = sections[index];
      window.scrollTo({ top: target.offsetTop, behavior: 'smooth' });
      // Update nav active state
      document.querySelectorAll('.fp-nav-link').forEach((a, i) => {
        a.classList.toggle('!bg-[#D4AA45]', i === index);
      });
      setTimeout(() => { isAnimating = false; }, COOLDOWN);
    }

    window.addEventListener('wheel', (e: WheelEvent) => {
      if (isAnimating) { e.preventDefault(); return; }
      const current = getCurrentIndex();
      const lastSection = sections[sections.length - 1];
      const lastBottom = lastSection.offsetTop + lastSection.offsetHeight;
      if (window.scrollY >= lastBottom - window.innerHeight && e.deltaY > 0) return;
      if (Math.abs(e.deltaY) < 30) return;
      e.preventDefault();
      scrollToSection(e.deltaY > 0 ? current + 1 : current - 1);
    }, { passive: false });

    window.addEventListener('keydown', (e: KeyboardEvent) => {
      if (isAnimating) return;
      const current = getCurrentIndex();
      if (e.key === 'ArrowDown' || e.key === 'PageDown') {
        e.preventDefault();
        scrollToSection(current + 1);
      } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        e.preventDefault();
        scrollToSection(current - 1);
      }
    });

    // Nav link clicks → smooth jump
    document.querySelectorAll('.fp-nav-link').forEach((a, i) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        scrollToSection(i);
      });
    });
  })();
</script>
