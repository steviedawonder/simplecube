---
import BaseLayout from '@layouts/BaseLayout.astro';

const sliderImages = [
  { src: '/images/popup/booth.jpg', cls: '' },
  { src: '/images/wedding/hero.png', cls: '' },
  { src: '/images/popup/wood-round.jpg', cls: '' },
  { src: '/images/popup/모듈형모델.png', cls: 'object-[center_30%]' },
  { src: '/images/wedding/setup-hall.jpg', cls: '' },
];
---

<BaseLayout>
  <!-- Nav -->
  <nav class="fixed top-20 right-6 z-50 flex flex-col gap-1.5 text-[11px] font-medium max-h-[70vh] overflow-y-auto">
    <a href="#b1" class="fp-nav-link rounded-full bg-[#2E2318] px-3 py-1.5 text-white hover:bg-[#D4AA45] transition">B1. 센터 + 원형마크</a>
    <a href="#b1a" class="fp-nav-link rounded-full bg-[#2E2318] px-3 py-1.5 text-white hover:bg-[#D4AA45] transition">B1a. 센터 + 마퀴배경</a>
    <a href="#b5" class="fp-nav-link rounded-full bg-[#2E2318] px-3 py-1.5 text-white hover:bg-[#D4AA45] transition">B5. 좌정렬 + 슬라이드</a>
    <a href="#b6" class="fp-nav-link rounded-full bg-[#2E2318] px-3 py-1.5 text-white hover:bg-[#D4AA45] transition">B6. 좌정렬 (그라데이션X)</a>
    <a href="#c1" class="fp-nav-link rounded-full bg-[#D4AA45] px-3 py-1.5 text-[#1A1714] hover:bg-[#2E2318] hover:text-white transition">C1. 풀이미지 오버레이</a>
    <a href="#c2" class="fp-nav-link rounded-full bg-[#D4AA45] px-3 py-1.5 text-[#1A1714] hover:bg-[#2E2318] hover:text-white transition">C2. 2단 가로분할</a>
    <a href="#c3" class="fp-nav-link rounded-full bg-[#D4AA45] px-3 py-1.5 text-[#1A1714] hover:bg-[#2E2318] hover:text-white transition">C3. 세로 타임라인</a>
    <a href="#c4" class="fp-nav-link rounded-full bg-[#D4AA45] px-3 py-1.5 text-[#1A1714] hover:bg-[#2E2318] hover:text-white transition">C4. 모션 그라데이션</a>
  </nav>

  <!-- ============================================ -->
  <!-- B1: 센터 정렬 + 원형 로고마크 -->
  <!-- ============================================ -->
  <section id="b1" data-fullpage-section class="relative flex h-screen min-h-screen flex-col items-center justify-center overflow-hidden bg-[#FAF8F5]">
    <div class="absolute top-8 left-8 z-30">
      <span class="rounded-full bg-[#2E2318] px-4 py-1.5 text-[10px] font-bold tracking-widest text-white">B1 — 센터 + 원형마크</span>
    </div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#2E2318 1px, transparent 1px), linear-gradient(90deg, #2E2318 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="relative z-10 text-center px-6">
      <div class="mx-auto mb-8 flex h-12 w-12 items-center justify-center rounded-full border border-[#2E2318]/10">
        <span class="text-lg font-bold text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif;">S</span>
      </div>
      <h1 class="text-[clamp(3.5rem,10vw,9rem)] leading-[1.05] text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.15em;">심플큐브</h1>
      <div class="mx-auto my-6 h-[1px] w-20 bg-[#2E2318]/15"></div>
      <p class="text-[clamp(0.8rem,1.5vw,1.1rem)] font-light tracking-[0.1em] text-[#8B7E72]">특별한 순간을 완성하는 포토부스</p>
      <div class="mt-12">
        <p class="text-[11px] font-medium tracking-[0.4em] text-[#8B7E72]/50 uppercase">Events completed</p>
        <p class="mt-1 text-[clamp(2rem,4vw,3.5rem)] font-bold text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.05em;">12,000<span class="text-[#D4AA45]">+</span></p>
      </div>
      <div class="mt-14 flex items-center justify-center gap-8">
        <a href="/popup" class="group flex items-center gap-2 text-sm font-medium text-[#2E2318] transition-colors hover:text-[#D4AA45]">POP-UP <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
        <div class="h-4 w-[1px] bg-[#2E2318]/15"></div>
        <a href="/wedding" class="group flex items-center gap-2 text-sm font-medium text-[#2E2318] transition-colors hover:text-[#D4AA45]">WEDDING <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
      </div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2">
      <div class="flex flex-col items-center gap-2 text-[#8B7E72]/30">
        <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
        <div class="h-8 w-[1px] bg-[#8B7E72]/15 relative overflow-hidden"><div class="absolute top-0 left-0 w-full h-1/2 bg-[#8B7E72]/40 animate-scroll-line"></div></div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- B1a: 센터 + 마퀴배경 (기존 디자인) -->
  <!-- ============================================ -->
  <section id="b1a" data-fullpage-section class="relative flex h-screen min-h-screen flex-col items-center justify-center overflow-hidden bg-white">
    <div class="absolute top-8 left-8 z-30">
      <span class="rounded-full bg-[#2E2318] px-4 py-1.5 text-[10px] font-bold tracking-widest text-white">B1a — 센터 + 마퀴배경</span>
    </div>

    <!-- Background: 대각선 텍스트 마퀴 -->
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
      <div class="d-typo-marquee-container">
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-even"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-even"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-even"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-even"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-even"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-even"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-even"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
        <div class="d-typo-row d-typo-odd"><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span><span>SIMPLE CUBE</span></div>
      </div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(255,255,255,0.6) 20%, transparent 65%);"></div>
    </div>

    <div class="relative z-10 text-center px-6">
      <p class="mb-2 text-[clamp(0.65rem,1.9vw,1.1rem)] font-medium text-[#8B7E72]">국내 오픈형 포토부스 대표 브랜드</p>
      <div class="mx-auto mb-3 h-[1px] w-16 bg-[#D4AA45]/40"></div>
      <h1 class="text-[clamp(3.5rem,10vw,8rem)] leading-[1.05] text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.12em;">
        <span class="relative inline-block">
          <span class="relative z-10">심플큐브</span>
          <span class="absolute bottom-[0.1em] left-0 right-0 h-[0.35em] bg-[#D4AA45]/30 -z-0"></span>
        </span>
      </h1>
      <div class="mx-auto mt-2 h-[1px] w-16 bg-[#D4AA45]/40"></div>
      <p class="mt-3 text-[clamp(0.7rem,1.8vw,1.1rem)] font-light leading-relaxed text-[#8B7E72]">브랜드 팝업부터 웨딩까지,<br/>특별한 순간을 완성하는 포토부스</p>
      <div class="mt-5">
        <p class="text-[clamp(0.75rem,2.2vw,1rem)] font-semibold tracking-[0.25em] text-[#8B7E72]/70">누적행사</p>
        <p class="-mt-1 text-[clamp(1.8rem,5vw,3.5rem)] font-bold text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif;">12,000<span class="text-[#D4AA45]">+</span></p>
      </div>
      <div class="mt-6 flex items-center justify-center gap-4">
        <a href="/popup" class="group flex items-center gap-2 text-sm font-medium text-[#2E2318] transition-colors hover:text-[#D4AA45]">POP-UP <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
        <div class="h-4 w-[1px] bg-[#2E2318]/15"></div>
        <a href="/wedding" class="group flex items-center gap-2 text-sm font-medium text-[#2E2318] transition-colors hover:text-[#D4AA45]">WEDDING <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
      </div>
    </div>

    <div class="absolute bottom-10 left-1/2 -translate-x-1/2">
      <div class="flex flex-col items-center gap-2 text-[#8B7E72]/30">
        <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
        <div class="h-8 w-[1px] bg-[#8B7E72]/15 relative overflow-hidden"><div class="absolute top-0 left-0 w-full h-1/2 bg-[#8B7E72]/40 animate-scroll-line"></div></div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- B5: 좌정렬 + 슬라이드 (패딩 보정) -->
  <!-- ============================================ -->
  <section id="b5" data-fullpage-section class="relative flex h-screen min-h-screen overflow-hidden bg-[#FAF8F5]">
    <div class="absolute top-8 left-8 z-30">
      <span class="rounded-full bg-[#2E2318] px-4 py-1.5 text-[10px] font-bold tracking-widest text-white">B5 — 좌정렬 + 슬라이드</span>
    </div>
    <div class="flex flex-col md:flex-row w-full min-h-screen">
      <!-- Left: Typography (더 안쪽으로) -->
      <div class="relative flex flex-1 flex-col items-center justify-center px-8 py-20 md:px-20 lg:px-28">
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#2E2318 1px, transparent 1px), linear-gradient(90deg, #2E2318 1px, transparent 1px); background-size: 60px 60px;"></div>
        <div class="max-w-lg w-full">
          <div class="flex items-center gap-3 mb-8">
            <div class="h-[1px] w-8 bg-[#D4AA45]"></div>
            <p class="text-[10px] font-medium tracking-[0.5em] text-[#D4AA45] uppercase">Est. 2015</p>
          </div>
          <h1 class="text-[clamp(3.5rem,9vw,7rem)] leading-[1.05] text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.08em;">심플큐브</h1>
          <p class="mt-6 text-base font-light leading-relaxed text-[#8B7E72] max-w-xs">브랜드 팝업부터 웨딩까지,<br/>특별한 순간을 완성합니다.</p>
          <div class="mt-8">
            <p class="text-[clamp(1.5rem,3vw,2.5rem)] font-bold text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif;">12,000<span class="text-[#D4AA45]">+</span></p>
            <p class="text-[9px] tracking-[0.2em] text-[#8B7E72]/40 uppercase mt-0.5">Events</p>
          </div>
          <div class="mt-10 flex items-center gap-5">
            <a href="/popup" class="inline-flex items-center gap-2 bg-[#2E2318] px-6 py-3.5 text-[11px] font-medium tracking-[0.15em] text-white uppercase transition-all hover:bg-[#D4AA45]">POP-UP <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
            <a href="/wedding" class="inline-flex items-center gap-2 border border-[#2E2318]/15 px-6 py-3.5 text-[11px] font-medium tracking-[0.15em] text-[#2E2318] uppercase transition-all hover:border-[#D4AA45] hover:text-[#D4AA45]">WEDDING <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
          </div>
        </div>
      </div>
      <!-- Right: Sliding photo -->
      <div class="hidden md:block w-[38%] overflow-hidden relative">
        <div class="photo-slider absolute inset-x-0 flex flex-col" data-slider="b5">
          {sliderImages.map(img => <img src={img.src} alt="" class={`w-full h-screen object-cover flex-shrink-0 ${img.cls}`} />)}
          <img src={sliderImages[0].src} alt="" class="w-full h-screen object-cover flex-shrink-0" />
        </div>
        <div class="absolute inset-y-0 left-0 w-40 z-10 pointer-events-none" style="background: linear-gradient(to right, #FAF8F5 10%, transparent);"></div>
      </div>
      <!-- Mobile: horizontal slider -->
      <div class="md:hidden h-[45vh] overflow-hidden relative">
        <div class="mobile-slider absolute inset-0 flex flex-row" data-mobile-slider="b5">
          {sliderImages.map(img => <img src={img.src} alt="" class={`h-full w-full object-cover flex-shrink-0 ${img.cls}`} />)}
          <img src={sliderImages[0].src} alt="" class="h-full w-full object-cover flex-shrink-0" />
        </div>
        <div class="absolute inset-x-0 top-0 h-16 z-10 pointer-events-none" style="background: linear-gradient(to bottom, #FAF8F5, transparent);"></div>
      </div>
    </div>
  </section>


  <!-- ============================================ -->
  <!-- B6: 좌정렬 + 슬라이드 (그라데이션 없음) -->
