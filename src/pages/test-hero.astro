    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .c4-gradient {
    background: linear-gradient(-45deg, #FFFFFF, #FAF8F5, #F5EDE3, #E8DDD0, #FAF8F5, #FFFFFF);
    background-size: 400% 400%;
    animation: gradient-shift 12s ease infinite;
  }

  /* D section: diagonal SIMPLE CUBE marquee */
  .d-typo-marquee-container {
    position: absolute;
    inset: -40%;
    width: 180%;
    height: 180%;
    display: flex;
