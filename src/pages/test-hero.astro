    gap: 4px;
    transform: rotate(-15deg);
    transform-origin: center;
  }
  .d-typo-row {
    display: flex;
    white-space: nowrap;
    font-size: 56px;
    font-weight: 900;
    letter-spacing: 0.02em;
    color: #8B7E72;
  }
  .d-typo-row span {
    padding: 16px 20px;
    flex-shrink: 0;
  }
  .d-typo-odd {
    opacity: 0.05;
  }
  .d-typo-even {
    opacity: 0.035;
