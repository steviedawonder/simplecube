---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import MachineShowcase from '@components/popup/MachineShowcase.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import db from '@lib/db';

const [gwangjuFaqResult, rentalFaqResult, popupFaqResult] = await Promise.all([
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['gwangju'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['rental'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['popup'] }),
]);
const faqItems = (
  gwangjuFaqResult.rows.length > 0 ? gwangjuFaqResult.rows
  : rentalFaqResult.rows.length > 0 ? rentalFaqResult.rows
  : popupFaqResult.rows
) as { question: string; answer: string }[];
---

<BaseLayout
  title="광주 포토부스 대여 | 상무지구·충장로·김대중컨벤션 출장 설치 — 심플큐브"
  description="광주 전 지역 포토부스 출장 설치. 상무지구, 충장로, 김대중컨벤션센터, 첨단지구 등 광주 어디든 설치 가능. 웨딩, 기업행사, 팝업스토어 맞춤 포토부스 렌탈."
  ogImage="/images/photobooth-rental-simplecube.jpg"
  transparentNav={false}
>
  <BreadcrumbSchema items={[
    { name: '포토부스 대여', url: '/rental' },
    { name: '광주 포토부스', url: '/gwangju' },
  ]} />
  <ServiceSchema services={[
    {
      name: '광주 포토부스 대여 — 광주 전 지역 출장 설치',
      description: '심플큐브의 광주 포토부스 대여 서비스. 상무지구, 충장로, 김대중컨벤션센터(KDJ), 첨단지구 등 광주 전 지역 출장 설치. 웨딩, 기업행사, 팝업스토어, 페스티벌 맞춤 포토부스 렌탈. 전주 지점에서 출장.',
      url: '/gwangju',
    },
  ]} />
  {faqItems.length > 0 && <FAQSchema faqs={faqItems} />}

  <!-- Hero -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">광주 포토부스 대여</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">GWANGJU</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">상무지구, 충장로, 김대중컨벤션센터, 첨단지구 — 광주 전 지역 출장 설치</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Gwangju service introduction -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">01</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">GWANGJU SERVICE</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">광주 포토부스 서비스</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="space-y-4 text-sm leading-relaxed text-secondary">
          <p>
            <strong>심플큐브</strong>는 광주 전 지역에 포토부스 출장 설치를 제공하는 <strong>광주 포토부스 대여 전문 업체</strong>입니다.
            상무지구, 충장로, 동명동, 양림동, 첨단지구, 광산구, 송정동 등 광주 어디든 설치가 가능하며,
            결혼식, 기업행사, 브랜드 팝업스토어, 페스티벌 등 행사 유형에 맞는 맞춤형 포토부스를 제공합니다.
          </p>
          <p>
            전주 지점이 인접해 있어 광주·전남 전 지역으로 빠르게 출장이 가능합니다.
            장비 설치부터 운영, 철거까지 원스톱으로 진행하며, 원목 소재의 프리미엄 포토부스, 브랜딩이 가능한 커스텀 부스 등 다양한 옵션을 갖추고 있습니다.
          </p>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">14,000+</span>
            <span class="block mt-1 text-xs text-secondary">전체 누적 행사</span>
          </div>
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">전주 지점</span>
            <span class="block mt-1 text-xs text-secondary">출장 운영</span>
          </div>
          <div class="rounded-lg border border-border-light bg-white p-5 text-center">
            <span class="block text-2xl font-bold text-olive">당일</span>
            <span class="block mt-1 text-xs text-secondary">설치 · 철거</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Popular event types in Gwangju -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">EVENT TYPES</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">광주 인기 행사 유형</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/wedding" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">웨딩 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">상무지구 · 봉선동</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">홀리데이인 광주, 라마다플라자 광주, 상무지구·봉선동 주요 웨딩홀에서 가장 많이 찾는 포토부스. 하객 포토 서비스로 결혼식의 추억을 선물합니다.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/corporate" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">기업행사 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">김대중컨벤션 · 첨단지구</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">김대중컨벤션센터(KDJ) 전시회, 첨단과학산업단지, 광주광역시청, 전남대·조선대 등 광주 비즈니스 행사를 위한 포토부스 렌탈.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">팝업스토어 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">충장로 · 동명동</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">충장로 메인 상권, 동명동 카페거리, 양림동 근대문화거리 등 광주 핫플레이스 팝업스토어를 위한 커스텀 포토부스. 브랜드 맞춤 디자인.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">페스티벌 포토부스</h3>
          <p class="mt-1 text-xs text-olive font-medium">광주비엔날레 · 5·18광장</p>
          <p class="mt-2 text-sm text-secondary leading-relaxed">광주비엔날레, 광주디자인비엔날레, 5·18민주광장 행사, 무등산·광주프린지페스티벌 등 광주 대표 야외 행사장 포토부스 렌탈.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Gwangju installation areas -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">03</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">AREAS</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">광주 주요 설치 지역</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { area: '서구 · 상무지구', venues: '김대중컨벤션센터(KDJ), 홀리데이인 광주, 광주시청, 5·18기념공원, 상무지구 웨딩홀', highlight: true },
          { area: '동구 · 충장로', venues: '충장로 메인 상권, 동명동 카페거리, 5·18민주광장, 아시아문화전당', highlight: false },
          { area: '남구 · 봉선·양림', venues: '봉선동 웨딩홀, 양림동 근대문화거리, 펭귄마을, 남구청 인근', highlight: false },
          { area: '북구 · 전남대', venues: '전남대학교, 용봉동, 일곡지구, 광주역 인근 행사장', highlight: false },
          { area: '광산구 · 첨단·송정', venues: '첨단과학산업단지, 송정역(KTX), 광주공항, 수완지구', highlight: false },
          { area: '무등산 · 외곽', venues: '무등산국립공원, 증심사, 광주호 야외 행사장', highlight: false },
          { area: '하남·평동·진곡', venues: '하남산단, 평동·진곡 산업단지 행사장', highlight: false },
          { area: '기타 호남 권역', venues: '나주·담양·화순·목포·여수 등 호남권 어디든 출장 설치 가능. 맞춤 견적 안내.', highlight: false },
        ].map(item => (
          <div class:list={[
            'rounded-lg border p-5',
            item.highlight ? 'border-olive/40 bg-olive/5' : 'border-border-light bg-white'
          ]}>
            <h3 class="text-base font-semibold text-primary">{item.area}</h3>
            <p class="mt-2 text-sm text-secondary leading-relaxed">{item.venues}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Machine Showcase -->
  <MachineShowcase />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Client Showcase -->
  <ClientShowcase />

  <!-- FAQ -->
  {faqItems.length > 0 && (
    <Fragment>
    <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
    <section id="qna" class="bg-white py-12 lg:py-16">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <div class="mb-10">
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">06</div>
          <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">FAQ</span>
          <h2 class="mt-3 text-2xl font-bold text-primary md:text-3xl">광주 포토부스 자주 묻는 질문</h2>
          <div class="mt-4 h-[2px] w-8 bg-olive"></div>
        </div>
        <AccordionList items={faqItems} />
      </div>
    </section>
    </Fragment>
  )}

  <!-- CTA -->
  <section class="bg-[#6B5B4D] py-12 lg:py-16">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-[#FFFAF4] md:text-3xl">광주 지역 맞춤 견적 받기</h2>
      <p class="mt-4 text-sm text-[#FFFAF4]/60 leading-relaxed">
        광주 행사 일정과 장소를 알려주시면, 전주 지점에서 빠르게 출장 견적을 안내해드립니다.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-olive px-8 py-3 text-sm font-semibold text-white hover:bg-olive/90 transition-colors">
          문의하기
        </a>
        <a href="tel:01057438122" class="inline-flex items-center gap-2 text-sm text-[#FFFAF4]/80 hover:text-[#FFFAF4] transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          010-5743-8122 (전주 지점)
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
