---
import BaseLayout from '@layouts/BaseLayout.astro';
import TextHero from '@components/common/TextHero.astro';

const base = import.meta.env.BASE_URL;

const branches = [
  {
    name: '서울 본점',
    region: '서울 · 경기 · 강원',
    kakao: '심플큐브',
    kakaoUrl: 'https://pf.kakao.com/_simplecube',
    instagram: 'simplecube_photobooth',
    phone: '02-338-9180',
    csHours: '10:00 ~ 18:00',
    csNote: '*주말, 공휴일 휴무',
    isHQ: true,
  },
  {
    name: '부산 지점',
    region: '부산 · 경남',
    kakao: '심플큐브 부산',
    kakaoUrl: 'https://pf.kakao.com/_simplecube_busan',
    instagram: 'simplecube_busan',
    phone: '010-3122-4746',
    csHours: '10:00 ~ 18:00',
    csNote: '*주말, 공휴일 휴무',
    isHQ: false,
  },
  {
    name: '대전 지점',
    region: '대전 · 충청',
    kakao: '심플큐브 대전',
    kakaoUrl: 'https://pf.kakao.com/_simplecube_daejeon',
    instagram: 'simplecube_daejeon',
    phone: '010-8838-8122',
    csHours: '10:00 ~ 18:00',
    csNote: '*주말, 공휴일 휴무',
    isHQ: false,
  },
  {
    name: '전주 지점',
    region: '전라',
    kakao: '심플큐브 전주',
    kakaoUrl: 'https://pf.kakao.com/_simplecube_jeonju',
    instagram: 'simplecube_jeonju',
    phone: '010-5743-8122',
    csHours: '10:00 ~ 18:00',
    csNote: '*주말, 공휴일 휴무',
    isHQ: false,
  },
];
---

<BaseLayout
  title="예약문의 | 심플큐브"
  description="심플큐브 포토부스 예약 및 문의. 카카오톡으로 실시간 상담이 가능합니다."
  transparentNav={false}
>
  <!-- Hero -->
  <section class="relative bg-bg-light pt-36 pb-16 lg:pt-44 lg:pb-20 overflow-hidden">
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-8">
        <!-- Text -->
        <div class="gs-fade-up">
          <h1 class="text-[clamp(2.2rem,5vw,4rem)] font-bold tracking-[0.02em] text-primary leading-[1.1]">
            예약문의
          </h1>
        </div>
        <!-- Illustration -->
        <div class="gs-fade-in flex-shrink-0">
          <div class="relative w-40 h-40 lg:w-52 lg:h-52">
            <!-- Headset icon illustration -->
            <svg viewBox="0 0 200 200" class="w-full h-full" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Glow circle -->
              <circle cx="100" cy="100" r="90" fill="url(#glow)" opacity="0.3"/>
              <!-- Main headset body -->
              <path d="M60 110V95C60 72.9 77.9 55 100 55C122.1 55 140 72.9 140 95V110" stroke="#D4AA45" stroke-width="5" stroke-linecap="round"/>
              <!-- Left earpiece -->
              <rect x="45" y="100" width="20" height="35" rx="10" fill="#D4AA45"/>
              <!-- Right earpiece -->
              <rect x="135" y="100" width="20" height="35" rx="10" fill="#D4AA45"/>
              <!-- Mic arm -->
              <path d="M135 130C135 142 125 152 113 152H108" stroke="#D4AA45" stroke-width="4" stroke-linecap="round"/>
              <!-- Mic -->
              <rect x="95" y="145" width="16" height="22" rx="8" fill="#D4AA45" opacity="0.8"/>
              <!-- Chat bubble -->
              <rect x="78" y="82" width="44" height="30" rx="8" fill="#D4AA45" opacity="0.15"/>
              <line x1="88" y1="92" x2="112" y2="92" stroke="#D4AA45" stroke-width="3" stroke-linecap="round" opacity="0.6"/>
              <line x1="88" y1="100" x2="106" y2="100" stroke="#D4AA45" stroke-width="3" stroke-linecap="round" opacity="0.6"/>
              <defs>
                <radialGradient id="glow" cx="0.5" cy="0.5" r="0.5">
                  <stop offset="0%" stop-color="#D4AA45" stop-opacity="0.4"/>
                  <stop offset="100%" stop-color="#D4AA45" stop-opacity="0"/>
                </radialGradient>
              </defs>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Branch Cards Section -->
  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="gs-fade-up mb-14 lg:mb-16">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
          <div>
            <h2 class="text-[clamp(1.75rem,3.5vw,2.8rem)] font-bold text-primary leading-tight">
              각 지역의 심플큐브에<br />문의해주세요.
            </h2>
            <p class="mt-4 text-sm text-secondary">
              카카오톡으로 실시간 상담이 가능합니다.
            </p>
          </div>
        </div>
      </div>

      <!-- Branch grid -->
      <div class="gs-stagger grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        {branches.map((branch) => (
          <div class="group relative rounded-2xl border border-border-light bg-white p-7 transition-all duration-300 hover:border-olive/40 hover:shadow-lg">
            <!-- Header -->
            <div class="flex items-center justify-between mb-5">
              <div>
                <h3 class="text-lg font-bold text-primary">{branch.region}</h3>
                {branch.isHQ && (
                  <span class="text-[9px] font-semibold tracking-wider uppercase bg-olive/10 text-olive px-2 py-0.5 rounded mt-1 inline-block">본점</span>
                )}
              </div>
              <!-- KakaoTalk button -->
              <a
                href={branch.kakaoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1.5 rounded-full bg-[#FEE500] px-4 py-2 text-xs font-bold text-[#3C1E1E] transition-all duration-300 hover:bg-[#F5DC00] hover:shadow-md"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="#3C1E1E">
                  <path d="M12 3c-4.97 0-9 3.185-9 7.115 0 2.557 1.707 4.8 4.27 6.054-.188.702-.682 2.545-.78 2.94-.123.496.182.489.382.356.157-.105 2.501-1.7 3.515-2.389.533.078 1.08.12 1.613.12 4.97 0 9-3.186 9-7.115C21 6.185 16.97 3 12 3z"/>
                </svg>
                TALK
              </a>
            </div>

            <div class="h-[1px] w-full bg-border-light mb-5"></div>

            <!-- CS Info -->
            <div class="space-y-3">
              <div>
                <span class="text-xs font-semibold text-olive">CS 운영시간</span>
                <p class="mt-1 text-sm font-medium text-primary">{branch.csHours}</p>
                <p class="mt-0.5 text-xs text-secondary-light">{branch.csNote}</p>
              </div>
              <div>
                <span class="text-xs text-secondary-light">전화</span>
                <p class="text-sm text-primary">
                  <a href={`tel:${branch.phone.replace(/-/g, '')}`} class="hover:text-olive transition-colors">
                    {branch.phone}
                  </a>
                </p>
              </div>
              <div>
                <span class="text-xs text-secondary-light">인스타그램</span>
                <p class="text-sm text-primary">
                  <a
                    href={`https://www.instagram.com/${branch.instagram}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-olive transition-colors"
                  >
                    @{branch.instagram}
                  </a>
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Note -->
      <div class="gs-fade-up mt-12 rounded-xl bg-bg-light p-6 lg:p-8">
        <div class="flex items-start gap-3">
          <span class="flex h-6 w-6 items-center justify-center rounded-full bg-olive/10 text-olive text-xs shrink-0 mt-0.5">i</span>
          <div class="text-sm text-secondary leading-relaxed">
            <p class="font-medium text-primary mb-2">안내사항</p>
            <ul class="space-y-1">
              <li>전국 어디서든 출장 서비스가 가능합니다.</li>
              <li>웨딩, 팝업 행사 모두 카카오톡으로 편하게 문의해 주세요.</li>
              <li>상담 후 견적서를 안내해 드립니다.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
