---
import '../styles/global.css';
import Navbar from '@components/common/Navbar.astro';
import FloatingContactButton from '@components/common/FloatingContactButton.astro';

const branches = [
  { name: '서울 본점', kakao: '심플큐브', instagram: 'simplecube_photobooth', phone: '02-338-9180', phoneType: 'tel' },
  { name: '부산 지점', kakao: '심플큐브 부산', instagram: 'simplecube_busan', phone: '010-3122-4746', phoneType: 'mobile' },
  { name: '대전 지점', kakao: '심플큐브 대전', instagram: 'simplecube_daejeon', phone: '010-8838-8122', phoneType: 'mobile' },
  { name: '전주 지점', kakao: '심플큐브 전주', instagram: 'simplecube_jeonju', phone: '010-5743-8122', phoneType: 'mobile' },
];
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Footer 레이아웃 테스트</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="bg-white text-primary antialiased">
  <Navbar transparent={false} />

  <!-- Nav -->
  <nav class="fixed top-20 left-4 z-50 flex flex-col gap-1.5 text-[11px] font-medium">
    <a href="#optA" class="rounded-full bg-[#2E2318] px-3 py-1.5 text-white hover:bg-[#D4AA45] transition text-center">A. 1열 리스트</a>
    <a href="#optB" class="rounded-full bg-[#2E2318] px-3 py-1.5 text-white hover:bg-[#D4AA45] transition text-center">B. 아코디언</a>
    <a href="#optC" class="rounded-full bg-[#D4AA45] px-3 py-1.5 text-[#1A1714] hover:bg-[#2E2318] hover:text-white transition text-center">C. 가로 스크롤</a>
  </nav>

  <main class="pt-20">
    <section class="py-12 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-2xl font-bold text-primary mb-4">푸터 지점 레이아웃 개선안</h1>
        <p class="text-secondary text-sm">플로팅 버튼은 그대로 유지. 지점 정보가 모바일에서 깔끔하게 보이는 3가지 방안.</p>
      </div>
    </section>

    <!-- ================================================ -->
    <!-- Option A: 모바일 1열 리스트형 -->
    <!-- ================================================ -->
    <section id="optA" class="border-t-4 border-[#D4AA45]">
      <div class="bg-[#2E2318] py-3 px-6">
        <p class="text-center text-xs font-bold tracking-widest text-[#D4AA45]">A — 모바일 1열 리스트형</p>
        <p class="text-center text-[10px] text-white/50 mt-1">모바일: 지점명 + 정보를 한 줄씩 1열로 정렬. PC: 4열 그리드 유지.</p>
      </div>

      <footer class="bg-[#FAFAF8] border-t border-[#E8E4DE]">
        <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8 lg:py-14">
          <!-- Brand -->
          <div class="mb-10">
            <p class="text-base font-bold leading-snug text-[#2E2318]">보다 간결한 즐거움</p>
            <p class="mt-1 text-base font-bold leading-snug tracking-[0.05em] text-[#2E2318]">SIMPLE CUBE PHOTO BOOTH</p>
            <a href="mailto:simple_cube@naver.com" class="mt-3 inline-block text-sm text-[#8B7E72] hover:text-[#D4AA45] transition-colors">simple_cube@naver.com</a>
          </div>

          <!-- Branches: 모바일 1열, PC 4열 -->
          <div class="hidden lg:grid lg:grid-cols-4 lg:gap-8">
            {branches.map((b) => (
              <div>
                <h3 class="text-sm font-bold text-[#2E2318] mb-2">{b.name}</h3>
                <div class="h-[1px] w-full bg-[#E8E4DE] mb-3"></div>
                <ul class="space-y-1.5 text-xs text-[#8B7E72]">
                  <li>카카오톡 : {b.kakao}</li>
                  <li>{b.instagram}</li>
                  <li>{b.phone}</li>
                </ul>
              </div>
            ))}
          </div>

          <!-- 모바일: 1열 리스트 -->
          <div class="lg:hidden space-y-0">
            {branches.map((b) => (
              <div class="flex items-start gap-5 py-4 border-b border-[#E8E4DE] last:border-b-0">
                <h3 class="text-sm font-bold text-[#2E2318] whitespace-nowrap min-w-[72px] pt-0.5">{b.name}</h3>
                <ul class="text-xs text-[#8B7E72] space-y-1">
                  <li>카카오톡 : {b.kakao}</li>
                  <li>{b.instagram}</li>
                  <li>{b.phone}</li>
                </ul>
              </div>
            ))}
          </div>
        </div>
        <!-- 플로팅 버튼 겹침 방지 여백 -->
        <div class="h-48 lg:h-0"></div>
      </footer>
    </section>


    <!-- ================================================ -->
    <!-- Option B: 아코디언 (접기/펼치기) -->
    <!-- ================================================ -->
    <section id="optB" class="border-t-4 border-[#D4AA45] mt-8">
      <div class="bg-[#2E2318] py-3 px-6">
        <p class="text-center text-xs font-bold tracking-widest text-[#D4AA45]">B — 아코디언 (접기/펼치기)</p>
        <p class="text-center text-[10px] text-white/50 mt-1">모바일: 지점명 클릭 시 정보 펼침. 기본 접혀있어 컴팩트. PC: 4열 그리드.</p>
      </div>

      <footer class="bg-[#FAFAF8] border-t border-[#E8E4DE]">
        <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8 lg:py-14">
          <!-- Brand -->
          <div class="mb-10">
            <p class="text-base font-bold leading-snug text-[#2E2318]">보다 간결한 즐거움</p>
            <p class="mt-1 text-base font-bold leading-snug tracking-[0.05em] text-[#2E2318]">SIMPLE CUBE PHOTO BOOTH</p>
            <a href="mailto:simple_cube@naver.com" class="mt-3 inline-block text-sm text-[#8B7E72] hover:text-[#D4AA45] transition-colors">simple_cube@naver.com</a>
          </div>

          <!-- PC: 4열 그리드 -->
          <div class="hidden lg:grid lg:grid-cols-4 lg:gap-8">
            {branches.map((b) => (
              <div>
                <h3 class="text-sm font-bold text-[#2E2318] mb-2">{b.name}</h3>
                <div class="h-[1px] w-full bg-[#E8E4DE] mb-3"></div>
                <ul class="space-y-1.5 text-xs text-[#8B7E72]">
                  <li>카카오톡 : {b.kakao}</li>
                  <li>{b.instagram}</li>
                  <li>{b.phone}</li>
                </ul>
              </div>
            ))}
          </div>

          <!-- 모바일: 아코디언 -->
          <div class="lg:hidden border-t border-[#E8E4DE]">
            {branches.map((b, i) => (
              <div class="border-b border-[#E8E4DE]">
                <button class="acc-trigger w-full flex items-center justify-between py-4 text-left" data-acc={`acc-${i}`}>
                  <h3 class="text-sm font-bold text-[#2E2318]">{b.name}</h3>
                  <svg class="acc-chevron h-4 w-4 text-[#8B7E72]/40 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </button>
                <div class="acc-panel overflow-hidden transition-all duration-300" style="max-height:0;" data-panel={`acc-${i}`}>
                  <ul class="pb-4 pl-1 text-xs text-[#8B7E72] space-y-1.5">
                    <li>카카오톡 : {b.kakao}</li>
                    <li>{b.instagram}</li>
                    <li>{b.phone}</li>
                  </ul>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="h-48 lg:h-0"></div>
      </footer>
    </section>


    <!-- ================================================ -->
    <!-- Option C: 가로 스크롤 카드 -->
    <!-- ================================================ -->
    <section id="optC" class="border-t-4 border-[#D4AA45] mt-8">
      <div class="bg-[#2E2318] py-3 px-6">
        <p class="text-center text-xs font-bold tracking-widest text-[#D4AA45]">C — 가로 스크롤 카드</p>
        <p class="text-center text-[10px] text-white/50 mt-1">모바일: 지점 카드를 가로 스크롤. 한 번에 1.5개 보여 스와이프 유도. PC: 4열 그리드.</p>
      </div>

      <footer class="bg-[#FAFAF8] border-t border-[#E8E4DE]">
        <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8 lg:py-14">
          <!-- Brand -->
          <div class="mb-10">
            <p class="text-base font-bold leading-snug text-[#2E2318]">보다 간결한 즐거움</p>
            <p class="mt-1 text-base font-bold leading-snug tracking-[0.05em] text-[#2E2318]">SIMPLE CUBE PHOTO BOOTH</p>
            <a href="mailto:simple_cube@naver.com" class="mt-3 inline-block text-sm text-[#8B7E72] hover:text-[#D4AA45] transition-colors">simple_cube@naver.com</a>
          </div>

          <!-- PC: 4열 그리드 -->
          <div class="hidden lg:grid lg:grid-cols-4 lg:gap-8">
            {branches.map((b) => (
              <div>
                <h3 class="text-sm font-bold text-[#2E2318] mb-2">{b.name}</h3>
                <div class="h-[1px] w-full bg-[#E8E4DE] mb-3"></div>
                <ul class="space-y-1.5 text-xs text-[#8B7E72]">
                  <li>카카오톡 : {b.kakao}</li>
                  <li>{b.instagram}</li>
                  <li>{b.phone}</li>
                </ul>
              </div>
            ))}
          </div>

          <!-- 모바일: 가로 스크롤 카드 -->
          <div class="lg:hidden -mx-6 px-6 overflow-x-auto scrollbar-hide">
            <div class="flex gap-3" style="width:max-content;">
              {branches.map((b) => (
                <div class="rounded-xl border border-[#E8E4DE] bg-white p-4" style="min-width:200px;max-width:220px;">
                  <h3 class="text-sm font-bold text-[#2E2318] mb-2">{b.name}</h3>
                  <div class="h-[1px] w-full bg-[#E8E4DE] mb-3"></div>
                  <ul class="space-y-1.5 text-xs text-[#8B7E72]">
                    <li>카카오톡 : {b.kakao}</li>
                    <li>{b.instagram}</li>
                    <li>{b.phone}</li>
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
        <div class="h-48 lg:h-0"></div>
      </footer>
    </section>

    <div class="h-20"></div>
  </main>

  <!-- 실제 플로팅 버튼 (원본 그대로) -->
  <FloatingContactButton />

  <style>
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
  </style>

  <script>
    // 아코디언 (Option B)
    document.querySelectorAll('.acc-trigger').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.acc;
        const panel = document.querySelector(`[data-panel="${id}"]`) as HTMLElement;
        const chevron = btn.querySelector('.acc-chevron') as HTMLElement;
        if (!panel || !chevron) return;

        const isOpen = panel.style.maxHeight !== '0px' && panel.style.maxHeight !== '';
        if (isOpen) {
          panel.style.maxHeight = '0px';
          chevron.style.transform = 'rotate(0deg)';
        } else {
          panel.style.maxHeight = panel.scrollHeight + 'px';
          chevron.style.transform = 'rotate(180deg)';
        }
      });
    });
  </script>
</body>
</html>
