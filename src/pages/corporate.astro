---
export const prerender = false;
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import MachineShowcase from '@components/popup/MachineShowcase.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import PortfolioGallery from '@components/popup/PortfolioGallery.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import db from '@lib/db';

// Fetch both page-specific and fallback FAQs in parallel
const [corporateFaqResult, popupFaqResult] = await Promise.all([
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['corporate'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['popup'] }),
]);
const faqItems = (corporateFaqResult.rows.length > 0 ? corporateFaqResult.rows : popupFaqResult.rows) as { question: string; answer: string }[];
---

<BaseLayout
  title="기업행사 포토부스 | 심플큐브 — 기업 이벤트·컨퍼런스 포토부스 대여"
  description="기업행사 포토부스 전문 심플큐브. 기업 이벤트, 컨퍼런스, 전시회, 세미나, 송년회를 위한 맞춤형 포토부스 대여. 브랜드 로고 삽입, 맞춤 디자인, 전문 운영까지."
  transparentNav={false}
>
  <BreadcrumbSchema items={[{ name: '기업행사 포토부스', url: '/corporate' }]} />
  <ServiceSchema services={[
    {
      name: '기업행사 포토부스 대여',
      description: '기업 이벤트, 컨퍼런스, 전시회, 세미나, 송년회 등 기업행사를 위한 맞춤형 포토부스 렌탈 서비스. 브랜드 로고 삽입, CI/BI 반영 포토스트립 디자인, 전문 운영 스태프 지원.',
      url: '/corporate',
    },
  ]} />
  {faqItems.length > 0 && <FAQSchema faqs={faqItems} />}

  <!-- Hero -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">기업행사 포토부스</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">CORPORATE</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">기업 이벤트 · 컨퍼런스 · 전시회 · 세미나</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why corporate photobooth -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">01</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">WHY PHOTOBOOTH</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">왜 기업행사에 포토부스인가?</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="rounded-lg border border-border-light bg-white p-6">
          <h3 class="text-base font-semibold text-primary mb-3">브랜드 노출 극대화</h3>
          <p class="text-sm text-secondary leading-relaxed">
            포토스트립에 기업 로고와 CI를 삽입하여 참석자가 직접 SNS에 공유하는
            자연스러운 바이럴 마케팅 효과를 얻을 수 있습니다.
          </p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-6">
          <h3 class="text-base font-semibold text-primary mb-3">참석자 만족도 향상</h3>
          <p class="text-sm text-secondary leading-relaxed">
            즉석 인화 사진은 행사의 하이라이트가 됩니다. 참석자들에게 기억에 남는
            경험을 제공하여 행사 만족도를 크게 높입니다.
          </p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-6">
          <h3 class="text-base font-semibold text-primary mb-3">콘텐츠 자산 확보</h3>
          <p class="text-sm text-secondary leading-relaxed">
            촬영된 모든 사진은 디지털 원본으로 전달됩니다. 행사 후 사내 뉴스레터,
            SNS 콘텐츠 등으로 재활용할 수 있는 콘텐츠 자산이 됩니다.
          </p>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Use cases -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">USE CASES</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">기업행사 포토부스 활용 사례</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: '기업 송년회·신년회', desc: '한 해를 마무리하는 특별한 포토 타임. 팀별 단체 촬영과 개인 촬영으로 추억을 남깁니다.' },
          { title: '제품 런칭 이벤트', desc: '신제품과 함께하는 포토존. 제품 이미지가 담긴 포토스트립으로 자연스러운 홍보 효과.' },
          { title: '컨퍼런스·세미나', desc: '네트워킹 시간을 더 풍성하게. 참석자 간 교류를 촉진하는 포토 이벤트.' },
          { title: '전시회·박람회', desc: '부스 방문객에게 특별한 경험 제공. 브랜드 인지도를 높이는 포토부스 마케팅.' },
          { title: '사내 행사·워크숍', desc: '팀빌딩, 워크숍, 체육대회 등 사내 행사의 즐거움을 배가시키는 포토부스.' },
          { title: '브랜드 팝업스토어', desc: '브랜드 세계관을 담은 커스텀 포토부스. 방문객의 SNS 공유를 자연스럽게 유도합니다.' },
        ].map(item => (
          <div class="rounded-lg border border-border-light p-5 hover:border-olive/30 transition-colors">
            <h3 class="text-sm font-semibold text-primary">{item.title}</h3>
            <p class="mt-2 text-sm text-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Machine showcase -->
  <MachineShowcase />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Portfolio -->
  <PortfolioGallery />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Client showcase -->
  <ClientShowcase />

  <!-- FAQ -->
  {faqItems.length > 0 && (
    <Fragment>
    <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
    <section id="qna" class="bg-white py-12 lg:py-16">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <div class="mb-10">
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">06</div>
          <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">FAQ</span>
          <h2 class="mt-3 text-2xl font-bold text-primary md:text-3xl">기업행사 포토부스 자주 묻는 질문</h2>
          <div class="mt-4 h-[2px] w-8 bg-olive"></div>
        </div>
        <AccordionList items={faqItems} />
      </div>
    </section>
    </Fragment>
  )}

  <!-- CTA -->
  <section class="bg-[#6B5B4D] py-12 lg:py-16">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-[#FFFAF4] md:text-3xl">기업행사 포토부스 견적 문의</h2>
      <p class="mt-4 text-sm text-[#FFFAF4]/60 leading-relaxed">
        행사 일정, 장소, 예상 인원을 알려주시면 최적의 포토부스 패키지를 제안해드립니다.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/contact" class="inline-flex items-center gap-2 rounded-lg bg-olive px-8 py-3 text-sm font-semibold text-white hover:bg-olive/90 transition-colors">
          견적 문의하기
        </a>
        <a href="tel:02-338-9180" class="inline-flex items-center gap-2 text-sm text-[#FFFAF4]/80 hover:text-[#FFFAF4] transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          02-338-9180
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
