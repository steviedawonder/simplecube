---
export const prerender = false;
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import MachineShowcase from '@components/popup/MachineShowcase.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import PortfolioGallery from '@components/popup/PortfolioGallery.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import db from '@lib/db';

// Fetch both page-specific and fallback FAQs in parallel
const [corporateFaqResult, popupFaqResult] = await Promise.all([
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['corporate'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['popup'] }),
]);
const faqItems = (corporateFaqResult.rows.length > 0 ? corporateFaqResult.rows : popupFaqResult.rows) as { question: string; answer: string }[];
---

<BaseLayout
  title="기업행사 포토부스 | 심플큐브 — 기업 이벤트·컨퍼런스 포토부스 대여"
  description="기업행사 포토부스 전문 심플큐브. 기업 이벤트, 컨퍼런스, 전시회, 세미나, 송년회를 위한 맞춤형 포토부스 대여. 브랜드 로고 삽입, 맞춤 디자인, 전문 운영까지."
  transparentNav={false}
>
  <BreadcrumbSchema items={[{ name: '기업행사 포토부스', url: '/corporate' }]} />
  <ServiceSchema services={[
    {
      name: '기업행사 포토부스 대여',
      description: '기업 이벤트, 컨퍼런스, 전시회, 세미나, 송년회 등 기업행사를 위한 맞춤형 포토부스 렌탈 서비스. 브랜드 로고 삽입, CI/BI 반영 포토스트립 디자인, 전문 운영 스태프 지원.',
      url: '/corporate',
    },
  ]} />
  {faqItems.length > 0 && <FAQSchema faqs={faqItems} />}

  <!-- Hero -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">기업행사 포토부스</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">CORPORATE</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">기업 이벤트 · 컨퍼런스 · 전시회 · 세미나</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="bg-white py-8 lg:py-10">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 rounded-xl bg-white shadow-md p-8">
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">8<span class="text-olive">년</span></p>
          <p class="mt-1 text-sm text-secondary">기업행사 경험</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">15,000<span class="text-olive">+</span></p>
          <p class="mt-1 text-sm text-secondary">누적 행사</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">500<span class="text-olive">+</span></p>
          <p class="mt-1 text-sm text-secondary">기업 파트너</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">전국<span class="text-olive"> 출장</span></p>
          <p class="mt-1 text-sm text-secondary">서울·부산·대전·전주</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why corporate photobooth -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">01</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">WHY PHOTOBOOTH</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">왜 기업행사에 포토부스인가?</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="rounded-lg border border-border-light bg-white p-6">
          <h3 class="text-base font-semibold text-primary mb-3">브랜드 노출 극대화</h3>
          <p class="text-sm text-secondary leading-relaxed">
            포토스트립에 기업 로고와 CI를 삽입하여 참석자가 직접 SNS에 공유하는
            자연스러운 바이럴 마케팅 효과를 얻을 수 있습니다.
          </p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-6">
          <h3 class="text-base font-semibold text-primary mb-3">참석자 만족도 향상</h3>
          <p class="text-sm text-secondary leading-relaxed">
            즉석 인화 사진은 행사의 하이라이트가 됩니다. 참석자들에게 기억에 남는
            경험을 제공하여 행사 만족도를 크게 높입니다.
          </p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-6">
          <h3 class="text-base font-semibold text-primary mb-3">콘텐츠 자산 확보</h3>
          <p class="text-sm text-secondary leading-relaxed">
            촬영된 모든 사진은 디지털 원본으로 전달됩니다. 행사 후 사내 뉴스레터,
            SNS 콘텐츠 등으로 재활용할 수 있는 콘텐츠 자산이 됩니다.
          </p>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Use cases -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">USE CASES</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">기업행사 포토부스 활용 사례</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: '기업 송년회·신년회', desc: '한 해를 마무리하는 특별한 포토 타임. 팀별 단체 촬영과 개인 촬영으로 추억을 남깁니다.' },
          { title: '제품 런칭 이벤트', desc: '신제품과 함께하는 포토존. 제품 이미지가 담긴 포토스트립으로 자연스러운 홍보 효과.' },
          { title: '컨퍼런스·세미나', desc: '네트워킹 시간을 더 풍성하게. 참석자 간 교류를 촉진하는 포토 이벤트.' },
          { title: '전시회·박람회', desc: '부스 방문객에게 특별한 경험 제공. 브랜드 인지도를 높이는 포토부스 마케팅.' },
          { title: '사내 행사·워크숍', desc: '팀빌딩, 워크숍, 체육대회 등 사내 행사의 즐거움을 배가시키는 포토부스.' },
          { title: '브랜드 팝업스토어', desc: '브랜드 세계관을 담은 커스텀 포토부스. 방문객의 SNS 공유를 자연스럽게 유도합니다.' },
        ].map(item => (
          <div class="rounded-lg border border-border-light p-5 hover:border-olive/30 transition-colors">
            <h3 class="text-sm font-semibold text-primary">{item.title}</h3>
            <p class="mt-2 text-sm text-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Branding customization (03) -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">03</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">BRANDING</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">기업 맞춤 브랜딩</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <p class="text-sm leading-relaxed text-secondary mb-8 max-w-3xl">
        심플큐브는 기업의 CI/BI를 포토부스 전체에 반영합니다. 포토스트립 프레임부터 부스 외관, 촬영 UI, QR 다운로드 페이지까지 — 행사의 모든 접점에서 브랜드를 경험할 수 있도록 설계합니다.
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-lg border border-border-light bg-white p-5">
          <div class="w-10 h-10 rounded-full bg-olive/10 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-sm font-semibold text-primary">포토스트립 프레임</h3>
          <p class="mt-2 text-xs text-secondary leading-relaxed">기업 로고, 슬로건, 행사명을 반영한 맞춤 포토스트립 디자인. 1종 기본 포함.</p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-5">
          <div class="w-10 h-10 rounded-full bg-olive/10 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-sm font-semibold text-primary">촬영 UI 커스텀</h3>
          <p class="mt-2 text-xs text-secondary leading-relaxed">촬영 화면의 배경, 카운트다운, 완료 화면까지 브랜드 컬러와 이미지로 구성.</p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-5">
          <div class="w-10 h-10 rounded-full bg-olive/10 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-sm font-semibold text-primary">QR 다운로드 페이지</h3>
          <p class="mt-2 text-xs text-secondary leading-relaxed">QR 스캔 후 열리는 다운로드 페이지에도 브랜드 로고와 행사 정보를 적용.</p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-5">
          <div class="w-10 h-10 rounded-full bg-olive/10 flex items-center justify-center mb-3">
            <svg class="w-5 h-5 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          </div>
          <h3 class="text-sm font-semibold text-primary">부스 외관 래핑</h3>
          <p class="mt-2 text-xs text-secondary leading-relaxed">부스 외관 전체를 브랜드 비주얼로 래핑. 행사장에서 강력한 시각적 존재감.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Machine showcase -->
  <MachineShowcase />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Service process (04) -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">04</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PROCESS</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">서비스 진행 절차</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
        {[
          { step: '01', title: '사전 미팅', desc: '행사 목적, 일정, 장소, 예상 인원, 브랜딩 니즈를 파악합니다.' },
          { step: '02', title: '기획 & 디자인', desc: '포토스트립, UI, 부스 구성을 기업 CI/BI에 맞춰 디자인합니다.' },
          { step: '03', title: '시안 확인', desc: '디자인 시안을 전달하고 피드백을 반영하여 최종 확정합니다.' },
          { step: '04', title: '현장 설치', desc: '행사 당일 전문 스태프가 현장에 도착하여 세팅을 완료합니다.' },
          { step: '05', title: '운영 & 리포트', desc: '행사 중 전문 운영, 행사 후 촬영 데이터와 리포트를 전달합니다.' },
        ].map(item => (
          <div class="relative rounded-lg border border-border-light p-5">
            <span class="text-2xl font-bold text-olive/20">{item.step}</span>
            <h3 class="mt-2 text-sm font-semibold text-primary">{item.title}</h3>
            <p class="mt-2 text-xs text-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Portfolio -->
  <PortfolioGallery />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Client showcase -->
  <ClientShowcase />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Pricing hint (05) -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-md px-6 lg:px-8">
      <div class="mb-10 text-center">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">05</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PRICING</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">기업행사 포토부스 가격</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive mx-auto"></div>
      </div>
      <div class="relative bg-white rounded-2xl shadow-sm border border-border-light p-8 lg:p-10 flex flex-col">
        <h3 class="text-base font-semibold text-primary">행사 포토부스</h3>
        <p class="mt-1 text-sm text-secondary">기업 이벤트 · 컨퍼런스 · 전시회</p>
        <div class="mt-6 flex items-baseline gap-1">
          <span class="text-3xl lg:text-4xl font-bold text-primary">50만원</span>
          <span class="text-xl text-secondary/60 font-medium">~</span>
        </div>
        <ul class="mt-6 space-y-3 text-sm text-secondary flex-1">
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>CI/BI 맞춤 프레임 디자인</li>
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>무제한 즉석 인화</li>
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>전문 스태프 운영</li>
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>QR 디지털 다운로드</li>
          <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>행사 후 데이터 리포트</li>
        </ul>
        <a href="/inquiry/popup" class="mt-8 inline-flex items-center justify-center w-full rounded-lg bg-olive text-white text-sm font-semibold py-3 hover:bg-olive/90 transition-colors">예약 문의 &rarr;</a>
      </div>
      <p class="mt-6 text-center text-sm text-secondary/70">※ 행사 규모, 운영 시간, 커스텀 범위에 따라 달라집니다.</p>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Testimonials (06) -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">06</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">TESTIMONIALS</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">기업 고객 후기</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-lg border border-border-light bg-bg-light p-6">
