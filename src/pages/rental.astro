---
export const prerender = false;
import BaseLayout from '@layouts/BaseLayout.astro';
import BreadcrumbSchema from '@components/seo/BreadcrumbSchema.astro';
import FAQSchema from '@components/seo/FAQSchema.astro';
import ServiceSchema from '@components/seo/ServiceSchema.astro';
import MachineShowcase from '@components/popup/MachineShowcase.astro';
import ClientShowcase from '@components/popup/ClientShowcase.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import db from '@lib/db';

// Fetch both page-specific and fallback FAQs in parallel
const [rentalFaqResult, popupFaqResult] = await Promise.all([
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['rental'] }),
  db.execute({ sql: 'SELECT question, answer FROM faqs WHERE page = ? AND active = 1 ORDER BY sort_order ASC, id ASC', args: ['popup'] }),
]);
const faqItems = (rentalFaqResult.rows.length > 0 ? rentalFaqResult.rows : popupFaqResult.rows) as { question: string; answer: string }[];
---

<BaseLayout
  title="포토부스 대여 · 렌탈 | 심플큐브 — 행사용 포토부스 렌탈 전문"
  description="포토부스 대여 전문 심플큐브. 결혼식, 기업행사 등 다양한 행사를 위한 포토부스 렌탈 서비스. 전국 출장 설치, 맞춤 디자인, 즉석 인화까지."
  transparentNav={false}
>
  <BreadcrumbSchema items={[{ name: '포토부스 대여', url: '/rental' }]} />
  <ServiceSchema services={[
    {
      name: '포토부스 대여 — 행사용 포토부스 렌탈',
      description: '심플큐브의 포토부스 대여 서비스. 결혼식, 기업행사 등 행사 유형에 맞는 맞춤형 포토부스를 렌탈해드립니다. 전국 출장 설치 및 전문 운영 스태프 지원.',
      url: '/rental',
    },
  ]} />
  {faqItems.length > 0 && <FAQSchema faqs={faqItems} />}

  <!-- Hero -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">포토부스 대여 · 렌탈</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">RENTAL</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">결혼식 · 행사</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats bar — social proof numbers -->
  <section class="bg-white py-8 lg:py-10">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 rounded-xl bg-white shadow-md p-8">
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">14,000<span class="text-olive">+</span></p>
          <p class="mt-1 text-sm text-secondary">누적 행사</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">전국 4<span class="text-olive">개</span></p>
          <p class="mt-1 text-sm text-secondary">거점</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">99<span class="text-olive">%</span></p>
          <p class="mt-1 text-sm text-secondary">고객 만족도</p>
        </div>
        <div class="text-center">
          <p class="text-3xl md:text-4xl font-bold text-primary">500<span class="text-olive">+</span></p>
          <p class="mt-1 text-sm text-secondary">브랜드 파트너</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What is photobooth rental -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">01</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">ABOUT RENTAL</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">포토부스 대여 서비스란?</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="space-y-4 text-sm leading-relaxed text-secondary">
          <p>
            <strong>포토부스 대여(렌탈)</strong>는 결혼식, 기업행사 등 각종 행사 현장에
            전문 포토부스 장비와 운영 인력을 함께 제공하는 서비스입니다.
          </p>
          <p>
            심플큐브는 <strong>전국 출장 설치</strong>가 가능하며, 행사 규모와 콘셉트에 맞춘
            <strong>맞춤형 포토부스 렌탈</strong>을 제공합니다. 원목 소재의 프리미엄 포토부스부터
            브랜딩이 가능한 커스텀 부스까지 다양한 옵션을 갖추고 있습니다.
          </p>
          <p>
            즉석 인화, 포토스트립 디자인, 디지털 다운로드, 영상 촬영 등
            행사 특성에 맞는 다양한 콘텐츠 옵션을 선택할 수 있습니다.
          </p>
        </div>
        <div class="space-y-3">
          <div class="rounded-lg border border-border-light bg-white p-4">
            <h3 class="text-sm font-semibold text-primary mb-2">포토부스 대여 포함 사항</h3>
            <ul class="space-y-1.5 text-sm text-secondary">
              <li class="flex items-start gap-2"><span class="text-olive mt-0.5">✓</span> 포토부스 장비 설치 및 철거</li>
              <li class="flex items-start gap-2"><span class="text-olive mt-0.5">✓</span> 전문 운영 스태프 배치</li>
              <li class="flex items-start gap-2"><span class="text-olive mt-0.5">✓</span> 맞춤 포토스트립 디자인</li>
              <li class="flex items-start gap-2"><span class="text-olive mt-0.5">✓</span> 즉석 인화 (무제한)</li>
              <li class="flex items-start gap-2"><span class="text-olive mt-0.5">✓</span> 디지털 원본 전달</li>
              <li class="flex items-start gap-2"><span class="text-olive mt-0.5">✓</span> 전국 출장 가능 (서울·부산·대전·전주)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Rental types -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">RENTAL TYPES</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">포토부스 대여 유형</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/wedding" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">웨딩 포토부스</h3>
          <p class="mt-2 text-sm text-secondary leading-relaxed">결혼식·웨딩홀에 어울리는 원목 포토부스. 하객 포토 서비스로 특별한 추억을 선물합니다.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">팝업 포토부스</h3>
          <p class="mt-2 text-sm text-secondary leading-relaxed">브랜드 팝업스토어와 완벽히 어울리는 커스텀 포토부스. 브랜드 아이덴티티를 반영한 디자인.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/corporate" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">기업행사 포토부스</h3>
          <p class="mt-2 text-sm text-secondary leading-relaxed">기업 행사, 컨퍼런스, 전시회를 위한 포토부스. 브랜드 로고 삽입과 맞춤 콘텐츠 제작.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
        <a href="/popup" class="group rounded-lg border border-border-light p-6 hover:border-olive/40 transition-colors">
          <h3 class="text-lg font-bold text-primary group-hover:text-olive transition-colors">페스티벌 포토부스</h3>
          <p class="mt-2 text-sm text-secondary leading-relaxed">뮤직 페스티벌, 지역 축제, 대학 축제 등 대규모 행사를 위한 포토부스 렌탈.</p>
          <span class="mt-3 inline-block text-xs text-olive font-medium">자세히 보기 →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Machine Showcase (reuse popup component) -->
  <MachineShowcase />

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Rental process -->
  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">03</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PROCESS</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">포토부스 대여 절차</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { step: '01', title: '문의 및 상담', desc: '행사 일정, 장소, 규모를 알려주시면 맞춤 견적을 안내해드립니다.' },
          { step: '02', title: '디자인 확정', desc: '포토스트립 디자인, 배경, 소품 등 행사에 맞는 옵션을 함께 결정합니다.' },
          { step: '03', title: '현장 설치', desc: '행사 당일 전문 스태프가 현장에 도착하여 장비를 설치하고 운영합니다.' },
          { step: '04', title: '촬영 및 인화', desc: '행사 중 무제한 촬영과 즉석 인화. 행사 후 디지털 원본을 전달합니다.' },
        ].map(item => (
          <div class="relative rounded-lg border border-border-light p-6">
            <span class="text-3xl font-bold text-olive/20">{item.step}</span>
            <h3 class="mt-2 text-base font-semibold text-primary">{item.title}</h3>
            <p class="mt-2 text-sm text-secondary leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Client showcase -->
  <ClientShowcase />

  <!-- FAQ -->
  {faqItems.length > 0 && (
    <Fragment>
    <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />
    <section id="qna" class="bg-white py-12 lg:py-16">
      <div class="mx-auto max-w-3xl px-6 lg:px-8">
        <div class="mb-10">
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">04</div>
          <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">FAQ</span>
          <h2 class="mt-3 text-2xl font-bold text-primary md:text-3xl">포토부스 대여 자주 묻는 질문</h2>
          <div class="mt-4 h-[2px] w-8 bg-olive"></div>
        </div>
        <AccordionList items={faqItems} />
      </div>
    </section>
    </Fragment>
  )}

  <!-- Testimonials -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mb-8 lg:mb-10">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">05</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">TESTIMONIALS</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">고객 후기</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <div class="rounded-lg border border-border-light bg-white p-6">
          <p class="text-sm text-secondary leading-relaxed italic">"삼성전자 신제품 런칭 행사에서 심플큐브 포토부스를 이용했습니다. 완벽한 세팅과 전문적인 운영에 매우 만족합니다."</p>
          <p class="mt-4 text-xs font-semibold text-primary">— 삼성전자 마케팅팀</p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-6">
          <p class="text-sm text-secondary leading-relaxed italic">"결혼식 포토부스로 심플큐브를 선택한 건 최고의 결정이었어요."</p>
          <p class="mt-4 text-xs font-semibold text-primary">— 2025년 5월 웨딩 고객</p>
        </div>
        <div class="rounded-lg border border-border-light bg-white p-6">
          <p class="text-sm text-secondary leading-relaxed italic">"팝업스토어에 2주간 포토부스를 설치했는데, 방문자 체류 시간이 크게 늘었습니다."</p>
          <p class="mt-4 text-xs font-semibold text-primary">— 뷰티 브랜드 팝업 담당자</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="border-0 h-px bg-gradient-to-r from-transparent via-[#d4aa4580] to-transparent" />

  <!-- Pricing section -->
  <section class="bg-bg-light py-12 lg:py-16">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <!-- Section header — centered to match card area -->
      <div class="mb-10 lg:mb-14 text-center">
        <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">06</div>
        <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PRICING</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">합리적인 포토부스 대여 가격</h2>
        <div class="mt-4 h-[2px] w-8 bg-olive mx-auto"></div>
      </div>

      <!-- Pricing cards -->
      <div class="grid gap-6 lg:gap-8 grid-cols-1 md:grid-cols-2">
        <!-- Wedding photo booth — recommended -->
        <div class="relative bg-white rounded-2xl shadow-sm border border-border-light border-t-4 border-t-olive p-8 lg:p-10 flex flex-col">
          <span class="absolute top-4 right-4 bg-olive text-white text-[11px] font-semibold px-2.5 py-1 rounded-full tracking-wide">인기</span>
          <h3 class="text-base font-semibold text-primary">웨딩 포토부스</h3>
          <p class="mt-1 text-sm text-secondary">결혼식 · 웨딩홀 맞춤 세팅</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-3xl lg:text-4xl font-bold text-primary">50만원</span>
            <span class="text-xl text-secondary/60 font-medium">~</span>
          </div>
          <span class="mt-2 inline-flex items-center gap-1 bg-olive/15 text-olive text-[13px] font-semibold px-3 py-1 rounded-full w-fit">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            최대 할인가 42만원
          </span>
          <ul class="mt-6 space-y-3 text-sm text-secondary flex-1">
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>커스텀 프레임 디자인</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>무제한 즉석 인화</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>전문 스태프 운영</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>디지털 원본 제공</li>
          </ul>
          <div class="mt-8 flex flex-col gap-3">
            <a href="/wedding" class="inline-flex items-center justify-center w-full rounded-lg bg-olive text-white text-sm font-semibold py-3 hover:bg-olive/90 transition-colors">자세히 알아보기 &rarr;</a>
            <a href="/contact" class="inline-flex items-center justify-center w-full rounded-lg border border-olive text-olive text-sm font-semibold py-3 hover:bg-olive hover:text-white transition-colors">예약 문의 &rarr;</a>
          </div>
        </div>

        <!-- Event photo booth -->
        <div class="relative bg-white rounded-2xl shadow-sm border border-border-light p-8 lg:p-10 flex flex-col">
          <h3 class="text-base font-semibold text-primary">행사 포토부스</h3>
          <p class="mt-1 text-sm text-secondary">브랜드 행사 · 기업 이벤트</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-3xl lg:text-4xl font-bold text-primary">50만원</span>
            <span class="text-xl text-secondary/60 font-medium">~</span>
          </div>
          <!-- spacer to align with wedding card's discount badge -->
          <div class="mt-2 h-5"></div>
          <ul class="mt-6 space-y-3 text-sm text-secondary flex-1">
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>CI/BI 맞춤 디자인</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>무제한 즉석 인화</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>전문 스태프 운영</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-olive"></span>QR 디지털 다운로드</li>
          </ul>
          <div class="mt-8 flex flex-col gap-3">
