---
import BaseLayout from '@layouts/BaseLayout.astro';
import AccordionList from '@components/faq/AccordionList.astro';
import Button from '@components/common/Button.astro';
---

<BaseLayout
  title="FAQ | 심플큐브"
  description="심플큐브 자주 묻는 질문. 포토부스 서비스에 대한 궁금증을 해결해 드립니다."
>
  <!-- Header -->
  <section class="flex min-h-[30vh] items-center justify-center bg-bg-light pt-20">
    <div class="px-6 text-center">
      <h1 class="text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-tight text-primary">
        FAQ
      </h1>
      <p class="mt-3 text-lg text-secondary">자주 묻는 질문</p>
    </div>
  </section>

  <!-- FAQ List -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <AccordionList />
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="bg-bg-light py-16 lg:py-24">
    <div class="mx-auto max-w-2xl px-6 text-center lg:px-8">
      <h2 class="text-2xl font-bold text-primary">궁금한 점이 더 있으신가요?</h2>
      <p class="mt-4 text-secondary">
        언제든 편하게 문의해 주세요. 친절하게 안내드리겠습니다.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <Button href="mailto:hello@simplecube.net" variant="primary" external>
          이메일 문의
        </Button>
        <Button href="https://www.instagram.com/simplecube" variant="outline" external>
          Instagram DM
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
