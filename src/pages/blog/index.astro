---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Get unique categories
const categories = [...new Set(posts.map((post) => post.data.category))];

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="BLOG | 심플큐브"
  description="심플큐브의 포토부스 이야기. 팝업, 웨딩 포토부스 트렌드와 유용한 가이드를 만나보세요."
>
  <!-- Header -->
  <section class="bg-bg-light pt-28 pb-12 lg:pt-32 lg:pb-16">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <h1 class="text-[clamp(2rem,4vw,3rem)] font-bold tracking-tight text-primary">
        BLOG
      </h1>
      <p class="mt-3 text-lg text-secondary">
        심플큐브의 포토부스 이야기
      </p>

      <!-- Search -->
      <div class="mt-8">
        <div class="relative">
          <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-secondary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            id="blog-search"
            type="text"
            placeholder="검색어를 입력하세요..."
            class="w-full rounded-xl border border-border bg-white py-3 pl-12 pr-4 text-sm text-primary outline-none transition-all focus:border-olive focus:ring-1 focus:ring-olive"
          />
        </div>
      </div>

      <!-- Category Filter -->
      <div class="mt-6 flex flex-wrap gap-2">
        <button
          class="category-btn active rounded-full bg-olive px-4 py-1.5 text-xs font-medium text-white transition-all"
          data-category="all"
        >
          전체
        </button>
        {categories.map((cat) => (
          <button
            class="category-btn rounded-full bg-white px-4 py-1.5 text-xs font-medium text-secondary border border-border-light transition-all hover:border-olive hover:text-olive"
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Post List -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div id="post-list" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article
            class="blog-card group"
            data-title={post.data.title.toLowerCase()}
            data-description={post.data.description.toLowerCase()}
            data-tags={post.data.tags?.join(' ').toLowerCase() || ''}
            data-category={post.data.category}
          >
            <a href={`${base}/blog/${post.id}`} class="block overflow-hidden rounded-2xl border border-border-light bg-white transition-shadow duration-300 hover:shadow-lg">
              {post.data.image && (
                <div class="overflow-hidden">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5">
                <div class="flex items-center gap-3">
                  <span class="rounded-full bg-olive-tint px-2.5 py-0.5 text-xs font-medium text-olive">
                    {post.data.category}
                  </span>
                  <time class="text-xs text-secondary-light" datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                <h2 class="mt-3 text-base font-bold leading-snug text-primary line-clamp-2 group-hover:text-olive transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm text-secondary line-clamp-2">
                  {post.data.description}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>

      <!-- No Results -->
      <div id="no-results" class="hidden py-16 text-center">
        <p class="text-secondary">검색 결과가 없습니다.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-btn.active {
    background-color: var(--color-olive);
    color: white;
    border-color: var(--color-olive);
  }
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Search functionality
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const cards = document.querySelectorAll('.blog-card');
  const noResults = document.getElementById('no-results');
  const categoryBtns = document.querySelectorAll('.category-btn');

  let currentCategory = 'all';

  function filterPosts() {
    const query = searchInput?.value.toLowerCase() || '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const el = card as HTMLElement;
      const title = el.dataset.title || '';
      const desc = el.dataset.description || '';
      const tags = el.dataset.tags || '';
      const category = el.dataset.category || '';

      const matchesSearch = !query || title.includes(query) || desc.includes(query) || tags.includes(query);
      const matchesCategory = currentCategory === 'all' || category === currentCategory;

      if (matchesSearch && matchesCategory) {
        el.style.display = '';
        visibleCount++;
      } else {
        el.style.display = 'none';
      }
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
  }

  searchInput?.addEventListener('input', filterPosts);

  categoryBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      categoryBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentCategory = (btn as HTMLElement).dataset.category || 'all';
      filterPosts();
    });
  });
</script>
