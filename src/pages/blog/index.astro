---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import db from '@lib/db';

// Single query with GROUP_CONCAT to avoid N+1 tag queries
const result = await db.execute(`
  SELECT p.*, c.name as category_name,
    GROUP_CONCAT(t.name, ',') as tags_list
  FROM posts p
  LEFT JOIN categories c ON p.category_id = c.id
  LEFT JOIN post_tags pt ON p.id = pt.post_id
  LEFT JOIN tags t ON pt.tag_id = t.id
  WHERE p.draft = 0 AND p.deleted_at IS NULL
  AND (p.scheduled_at IS NULL OR p.scheduled_at <= datetime('now'))
  GROUP BY p.id
  ORDER BY p.created_at DESC
`);
const posts = (result.rows as any[]).map((post) => ({
  ...post,
  tags: post.tags_list ? post.tags_list.split(',') : [],
}));

const categories = [...new Set(posts.map((p) => p.category_name).filter(Boolean))];
---

<BaseLayout
  title="BLOG | 심플큐브"
  description="심플큐브의 포토부스 이야기. 팝업, 웨딩 포토부스 트렌드와 유용한 가이드를 만나보세요."
  transparentNav={false}
>
  <!-- 좌측 골드 보더 히어로 (투명 배경) -->
  <section class="pt-20 lg:pt-22">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 py-6 border-b border-border-light">
      <div class="flex items-start gap-4">
        <div class="w-[3px] h-12 bg-olive rounded-full shrink-0 mt-0.5"></div>
        <div>
          <div class="flex items-baseline gap-3">
            <h1 class="text-2xl font-bold text-primary">블로그</h1>
            <span class="text-[11px] font-medium tracking-[0.12em] text-secondary/40">BLOG</span>
          </div>
          <p class="text-[12px] text-secondary/50 mt-1">포토부스 트렌드 · 가이드 · 소식</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 검색 & 카테고리 필터 -->
  <section class="bg-white pt-8 pb-4">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="relative">
        <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-secondary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input id="blog-search" type="text" placeholder="검색어를 입력하세요..." class="w-full rounded-lg border border-border-light bg-bg-light py-3 pl-12 pr-4 text-sm text-primary placeholder-secondary-light outline-none transition-all focus:border-olive/60 focus:bg-white" />
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        <button class="category-btn active rounded-full px-4 py-1.5 text-xs font-semibold tracking-wider text-white transition-all bg-olive" data-category="all">전체</button>
        {categories.map((cat) => (
          <button class="category-btn rounded-full px-4 py-1.5 text-xs font-medium text-secondary border border-border-light transition-all hover:border-olive/60 hover:text-olive" data-category={cat}>{cat}</button>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-12 lg:py-16">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div id="post-list" class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="blog-card group" data-title={post.title.toLowerCase()} data-description={(post.description || '').toLowerCase()} data-tags={post.tags?.join(' ').toLowerCase() || ''} data-category={post.category_name || ''}>
            <a href={post.external_url || `/blog/${post.slug}`} target={post.external_url ? '_blank' : undefined} rel={post.external_url ? 'noopener noreferrer' : undefined} class="block overflow-hidden rounded-xl border border-border-light bg-white transition-all duration-300 hover:border-olive/40 hover:shadow-md">
              {post.image && (
                <div class="overflow-hidden">
                  <img src={post.image} alt={post.title} class="aspect-[16/10] w-full object-cover transition-all duration-500 group-hover:scale-105" loading="lazy" />
                </div>
              )}
              <div class="p-5">
                <div class="flex items-center gap-3">
                  {post.category_name && <span class="px-2.5 py-0.5 text-xs font-medium text-olive border border-olive/30 rounded-full">{post.category_name}</span>}
                  <time class="text-xs text-secondary-light" datetime={post.created_at}>{new Date(post.created_at).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                  {post.external_url && (
                    <svg class="h-3.5 w-3.5 text-secondary-light ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                  )}
                </div>
                <h2 class="mt-3 text-base font-bold leading-snug text-primary line-clamp-2 group-hover:text-olive transition-colors">{post.title}</h2>
                <p class="mt-2 text-sm text-secondary line-clamp-2">{post.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
      {posts.length === 0 && <div class="py-16 text-center"><p class="text-secondary">게시글이 없습니다.</p></div>}
      <div id="no-results" class="hidden py-16 text-center"><p class="text-secondary">검색 결과가 없습니다.</p></div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-btn.active { background-color: var(--color-olive); color: white; border-color: var(--color-olive); }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
  const searchInput = document.getElementById('blog-search') as HTMLInputElement;
  const cards = document.querySelectorAll('.blog-card');
  const noResults = document.getElementById('no-results');
  const categoryBtns = document.querySelectorAll('.category-btn');
  let currentCategory = 'all';

  function filterPosts() {
    const query = searchInput?.value.toLowerCase() || '';
    let visibleCount = 0;
    cards.forEach((card) => {
      const el = card as HTMLElement;
      const matchesSearch = !query || (el.dataset.title || '').includes(query) || (el.dataset.description || '').includes(query) || (el.dataset.tags || '').includes(query);
      const matchesCategory = currentCategory === 'all' || el.dataset.category === currentCategory;
      el.style.display = matchesSearch && matchesCategory ? '' : 'none';
      if (matchesSearch && matchesCategory) visibleCount++;
    });
    if (noResults) noResults.classList.toggle('hidden', visibleCount > 0);
  }

  searchInput?.addEventListener('input', filterPosts);
  categoryBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      categoryBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      currentCategory = (btn as HTMLElement).dataset.category || 'all';
      filterPosts();
    });
  });
</script>
