---
const branches = [
  {
    name: '서울 본점',
    kakao: 'https://pf.kakao.com/_vxhEfj/chat',
    instagram: 'https://instagram.com/simplecube_photobooth',
    phone: 'tel:02-338-9180',
  },
  {
    name: '부산 지점',
    kakao: 'https://pf.kakao.com/_RxgxkPb/chat',
    instagram: 'https://instagram.com/simplecube_busan',
    phone: 'tel:010-3122-4746',
  },
  {
    name: '대전 지점',
    kakao: 'https://pf.kakao.com/_xgqgyb/chat',
    instagram: 'https://instagram.com/simplecube_daejeon',
    phone: 'tel:010-8838-8122',
  },
  {
    name: '전주 지점',
    kakao: 'https://pf.kakao.com/_TPxjxoG/chat',
    instagram: 'https://instagram.com/simplecube_jeonju',
    phone: 'tel:010-5743-8122',
  },
];
---

<footer class="bg-bg-light border-t border-border-light">
  <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8 lg:py-14">
    <!-- Brand -->
    <div class="mb-8 text-center lg:text-left">
      <p class="text-sm font-bold leading-snug text-primary">보다 간결한 즐거움</p>
      <p class="mt-0.5 text-sm font-bold leading-snug tracking-[0.05em] text-primary">SIMPLE CUBE PHOTO BOOTH</p>
      <a
        href="mailto:simple_cube@naver.com"
        class="mt-2 inline-block text-xs text-secondary transition-colors duration-300 hover:text-olive"
      >
        simple_cube@naver.com
      </a>
    </div>

    <!-- PC: 4열 그리드 -->
    <div class="hidden lg:grid lg:grid-cols-4 lg:gap-0">
      {branches.map((branch, i) => (
        <div class:list={["pl-6 first:pl-0", i > 0 && "border-l border-border-light"]}>
          <h3 class="text-sm font-bold text-primary mb-2">{branch.name}</h3>
          <div class="h-[1px] w-full bg-border-light mb-3"></div>
          <div class="flex items-center gap-4">
            <a href={branch.kakao} target="_blank" rel="noopener noreferrer" class="footer-icon-btn" aria-label={`${branch.name} 카카오톡`}>
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 3c-4.97 0-9 3.185-9 7.115 0 2.557 1.707 4.8 4.27 6.054-.188.702-.682 2.545-.78 2.94-.123.496.182.489.382.356.157-.105 2.501-1.7 3.515-2.389.533.078 1.08.12 1.613.12 4.97 0 9-3.186 9-7.115C21 6.185 16.97 3 12 3z"/>
              </svg>
            </a>
            <a href={branch.instagram} target="_blank" rel="noopener noreferrer" class="footer-icon-btn" aria-label={`${branch.name} 인스타그램`}>
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a href={branch.phone} class="footer-icon-btn" aria-label={`${branch.name} 전화`}>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- 모바일: 지점명 + 아이콘 버튼 리스트 -->
    <div class="lg:hidden border-t border-border-light">
      {branches.map((branch) => (
        <div class="flex items-center justify-between py-4 border-b border-border-light">
          <h3 class="text-sm font-bold text-primary">{branch.name}</h3>
          <div class="flex items-center gap-4">
            <a href={branch.kakao} target="_blank" rel="noopener noreferrer" class="footer-icon-btn" aria-label={`${branch.name} 카카오톡`}>
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 3c-4.97 0-9 3.185-9 7.115 0 2.557 1.707 4.8 4.27 6.054-.188.702-.682 2.545-.78 2.94-.123.496.182.489.382.356.157-.105 2.501-1.7 3.515-2.389.533.078 1.08.12 1.613.12 4.97 0 9-3.186 9-7.115C21 6.185 16.97 3 12 3z"/>
              </svg>
            </a>
            <a href={branch.instagram} target="_blank" rel="noopener noreferrer" class="footer-icon-btn" aria-label={`${branch.name} 인스타그램`}>
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a href={branch.phone} class="footer-icon-btn" aria-label={`${branch.name} 전화`}>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- 플로팅 버튼 겹침 방지 여백 -->
  <div class="h-44 lg:h-0"></div>
</footer>

<style>
  .footer-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px;
    color: var(--color-secondary-light, #a09a90);
    transition: all 0.2s;
  }
  .footer-icon-btn:hover {
    color: var(--color-olive, #D4AA45);
  }
</style>
