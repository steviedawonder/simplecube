---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'outline-white';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  external?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  external = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const resolvedHref = href && !external && !href.startsWith('http') ? `${base}${href}` : href;

const variantClasses = {
  primary: 'bg-olive text-black hover:bg-olive-hover font-semibold',
  secondary: 'bg-bg-dark text-white hover:bg-primary-light border border-white/10',
  outline: 'border border-primary text-primary hover:bg-primary hover:text-white',
  'outline-white': 'border border-white/40 text-white/80 hover:border-white hover:text-white',
};

const sizeClasses = {
  sm: 'px-5 py-2 text-xs',
  md: 'px-7 py-3 text-sm',
  lg: 'px-9 py-4 text-base',
};
---

{href ? (
  <a
    href={resolvedHref}
    target={external ? '_blank' : undefined}
    rel={external ? 'noopener noreferrer' : undefined}
    class:list={[
      'inline-block font-medium tracking-[0.08em] transition-all duration-300',
      variantClasses[variant],
      sizeClasses[size],
      className,
    ]}
  >
    <slot />
  </a>
) : (
  <button
    class:list={[
      'inline-block font-medium tracking-[0.08em] transition-all duration-300',
      variantClasses[variant],
      sizeClasses[size],
      className,
    ]}
  >
    <slot />
  </button>
)}
