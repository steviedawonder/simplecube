---
---

<!-- Floating Quick Buttons - 항상 3개 표시 -->
<div id="floating-quick" class="fixed bottom-8 right-8 z-40 flex flex-col items-end gap-3">
  <a
    href="/contact?type=wedding"
    class="quick-btn flex items-center gap-3 rounded-full bg-[#C4B5A6] shadow-lg shadow-[#C4B5A6]/20 transition-all duration-300 hover:bg-[#b8a999] hover:-translate-y-0.5 hover:shadow-xl"
  >
    <!-- 하트 아이콘 (웨딩) -->
    <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
    </svg>
    <span>웨딩문의</span>
  </a>
  <a
    href="/contact?type=popup"
    class="quick-btn flex items-center gap-3 rounded-full bg-[#505050] shadow-lg shadow-black/15 transition-all duration-300 hover:bg-[#424242] hover:-translate-y-0.5 hover:shadow-xl"
  >
    <!-- 스파클 아이콘 (행사) -->
    <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
    </svg>
    <span>행사문의</span>
  </a>
  <a
    href="/contact"
    class="quick-btn flex items-center gap-3 rounded-full bg-olive shadow-lg shadow-olive/25 transition-all duration-300 hover:bg-olive-hover hover:shadow-xl hover:shadow-olive/30 hover:-translate-y-0.5"
  >
    <!-- 채팅 아이콘 (예약문의) -->
    <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
    </svg>
    <span>예약문의</span>
  </a>
</div>

<style>
  .quick-btn {
    padding: 0.875rem 2rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: white;
    white-space: nowrap;
    min-width: 170px;
    justify-content: center;
  }

  #floating-quick {
    opacity: 0;
    transform: translateY(20px);
    animation: floatingBtnIn 0.6s ease-out 1s forwards;
  }

  @keyframes floatingBtnIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    #floating-quick {
      right: 1rem;
      bottom: 1.25rem;
    }
    .quick-btn {
      padding: 0.75rem 1.5rem;
      font-size: 0.875rem;
      min-width: 150px;
    }
  }
</style>
