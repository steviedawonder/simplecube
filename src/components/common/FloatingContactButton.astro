---
const base = import.meta.env.BASE_URL;
---

<!-- Floating Contact Button -->
<a
  id="floating-contact-btn"
  href={`${base}/contact`}
  class="fixed bottom-8 right-8 z-40 flex items-center gap-2.5 rounded-full bg-olive px-6 py-3.5 text-sm font-bold text-white shadow-lg shadow-olive/25 transition-all duration-300 hover:bg-olive-hover hover:shadow-xl hover:shadow-olive/30 hover:-translate-y-0.5 active:translate-y-0"
  aria-label="예약문의 페이지로 이동"
>
  <!-- Chat icon -->
  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
  </svg>
  <span>예약문의</span>
</a>

<style>
  /* Initial hidden state for entrance animation */
  #floating-contact-btn {
    opacity: 0;
    transform: translateY(20px);
    animation: floatingBtnIn 0.6s ease-out 1s forwards;
  }

  @keyframes floatingBtnIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile: slightly smaller */
  @media (max-width: 640px) {
    #floating-contact-btn {
      right: 1rem;
      bottom: 1.25rem;
      padding: 0.75rem 1.25rem;
      font-size: 0.8125rem;
    }
  }
</style>
