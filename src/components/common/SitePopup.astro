---
---

<!-- Site Popup Container -->
<div id="site-popup-container"></div>

<style is:global>
  .popup-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    background: rgba(0, 0, 0, 0.5);
    padding: 5rem 1.5rem 1rem;
  }

  .popup-wrapper {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    max-width: 100%;
  }

  .popup-box {
    position: relative;
    border-radius: 0;
    overflow: hidden;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
    max-width: 440px;
    width: 100%;
    animation: popupSlideIn 0.4s ease-out;
  }

  .popup-box:nth-child(2) {
    animation-delay: 0.1s;
  }

  @keyframes popupSlideIn {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .popup-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
    border: none;
    border-radius: 50%;
    color: inherit;
    font-size: 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 2;
  }

  .popup-close:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .popup-content {
    padding: 2.5rem 2.5rem 2rem;
    text-align: center;
  }

  .popup-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.2);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .popup-subtitle {
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .popup-body {
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.9;
    white-space: pre-line;
  }

  .popup-body strong {
    font-weight: 700;
  }

  .popup-image {
    width: 100%;
    display: block;
  }

  .popup-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .popup-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .popup-footer {
    display: flex;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    background: #fff;
  }

  .popup-footer button {
    flex: 1;
    padding: 0.875rem;
    background: none;
    border: none;
    font-size: 0.8125rem;
    font-family: inherit;
    color: #6e6e73;
    cursor: pointer;
    transition: background 0.15s;
  }

  .popup-footer button:hover {
    background: #f5f5f7;
  }

  .popup-footer button:first-child {
    border-right: 1px solid rgba(0, 0, 0, 0.1);
  }

  @media (max-width: 640px) {
    .popup-wrapper {
      flex-direction: column;
      align-items: center;
    }
    .popup-box {
      max-width: 360px;
    }
    .popup-subtitle {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  async function initPopups() {
    const container = document.getElementById('site-popup-container');
    if (!container) return;

    // 홈페이지(/)에서만 팝업 표시
    if (window.location.pathname !== '/') return;

    // 이번 세션에서 이미 팝업을 본 경우 표시하지 않음
    if (sessionStorage.getItem('popup_shown')) return;

    try {
      const res = await fetch('/api/popups?active=1');
      const popups = await res.json();
      if (!Array.isArray(popups) || popups.length === 0) return;

      // Filter out popups that user dismissed for 1 day
      const visiblePopups = popups.filter((p: any) => {
        const dismissedUntil = localStorage.getItem(`popup_dismissed_${p.id}`);
        if (dismissedUntil && new Date(dismissedUntil) > new Date()) return false;
        return true;
      });

      if (visiblePopups.length === 0) return;

      // 세션에 팝업 표시 기록
      sessionStorage.setItem('popup_shown', '1');

      const overlay = document.createElement('div');
      overlay.className = 'popup-overlay';

      const wrapper = document.createElement('div');
      wrapper.className = 'popup-wrapper';

      visiblePopups.forEach((popup: any) => {
        const box = document.createElement('div');
        box.className = 'popup-box';
        box.style.color = popup.text_color || '#ffffff';

        let contentHTML = '';

        // Close button
        contentHTML += `<button class="popup-close" data-action="close" data-id="${popup.id}" style="color:${popup.text_color || '#fff'}">&times;</button>`;

        // Main content area
        const linkStart = popup.link_url ? `<a href="${popup.link_url}" class="popup-link">` : '';
        const linkEnd = popup.link_url ? '</a>' : '';

        contentHTML += linkStart;

        // Content section with bg color
        contentHTML += `<div class="popup-content" style="background-color:${popup.bg_color || '#dc2626'};">`;
        if (popup.title) {
          contentHTML += `<div class="popup-badge">${popup.title}</div>`;
        }
        if (popup.subtitle) {
          contentHTML += `<div class="popup-subtitle">${popup.subtitle}</div>`;
        }
        if (popup.body) {
          contentHTML += `<div class="popup-body">${popup.body}</div>`;
        }
        contentHTML += '</div>';

        // Image
        if (popup.image_url) {
          contentHTML += `<div class="popup-image" style="background-color:${popup.bg_color || '#dc2626'};"><img src="${popup.image_url}" alt="${popup.title || ''}" /></div>`;
        }

        contentHTML += linkEnd;

        // Footer
        contentHTML += `<div class="popup-footer">
          <button data-action="dismiss-day" data-id="${popup.id}">1일 동안 보지 않음</button>
          <button data-action="close" data-id="${popup.id}">닫기</button>
        </div>`;

        box.innerHTML = contentHTML;
        wrapper.appendChild(box);
      });

      overlay.appendChild(wrapper);
      container.appendChild(overlay);

      // Event handlers
      overlay.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const action = target.dataset.action;
        const id = target.dataset.id;

        if (action === 'close' && id) {
          const box = target.closest('.popup-box');
          box?.remove();
          if (wrapper.children.length === 0) overlay.remove();
        }

        if (action === 'dismiss-day' && id) {
          const tomorrow = new Date();
          tomorrow.setDate(tomorrow.getDate() + 1);
          tomorrow.setHours(0, 0, 0, 0);
          localStorage.setItem(`popup_dismissed_${id}`, tomorrow.toISOString());
          const box = target.closest('.popup-box');
          box?.remove();
          if (wrapper.children.length === 0) overlay.remove();
        }
      });

    } catch {
      // Silently fail
    }
  }

  initPopups();
</script>
