---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  bgImage?: string;
}

const { title, subtitle, description, bgImage } = Astro.props;
---

<section class="relative flex min-h-[50vh] items-center overflow-hidden bg-[#6B5B4D]">
  <!-- Optional Background Image (blurred) -->
  {bgImage && (
    <div class="absolute inset-0">
      <img
        src={bgImage}
        alt=""
        class="h-full w-full object-cover opacity-20 blur-sm"
        loading="eager"
        aria-hidden="true"
      />
      <div class="absolute inset-0 bg-[#6B5B4D]/70"></div>
    </div>
  )}

  <!-- Content -->
  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 pt-32 pb-16 lg:px-8 lg:pt-40 lg:pb-20">
    <div class="max-w-3xl gs-fade-up">
      {subtitle && (
        <p class="mb-4 text-sm font-medium tracking-[0.3em] text-[#FFFAF4]/60 md:tracking-[0.4em]">
          {subtitle}
        </p>
      )}
      <div class="mb-6 h-[1px] w-12 bg-olive/60"></div>
      <h1 class="text-[clamp(2.2rem,5vw,4.5rem)] font-bold tracking-[0.02em] text-[#FFFAF4] leading-[1.1]">
        {title}
      </h1>
      {description && (
        <p class="mt-8 text-base leading-relaxed text-[#FFFAF4]/60 max-w-xl">
          {description}
        </p>
      )}
    </div>
  </div>

  <!-- Bottom subtle gradient -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-[#FFFAF4]/5"></div>
</section>
