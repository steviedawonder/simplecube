---
interface Props {
  title: string;
  subtitle?: string;
  backgroundImage: string;
  height?: string;
}

const {
  title,
  subtitle,
  backgroundImage,
  height = 'h-[50vh] min-h-[400px]',
} = Astro.props;
---

<section
  class:list={[
    'relative flex items-center justify-center overflow-hidden',
    height,
  ]}
>
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src={backgroundImage}
      alt=""
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center text-white">
    <h1 class="text-[clamp(2rem,4vw,3.5rem)] font-bold tracking-[0.1em]">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-3 text-base font-light tracking-wide text-white/80 lg:text-lg">
        {subtitle}
      </p>
    )}
  </div>
</section>
