---
interface Props {
  context?: 'rental' | 'wedding' | 'popup';
}

const { context = 'rental' } = Astro.props;

const operations = {
  rental: '결혼식·기업행사·팝업스토어·페스티벌 등 행사 유형에 맞춘 맞춤형 운영',
  wedding: '본식 90분 전 설치 → 예식 시작 후 30분까지 운영. 식장 상황과 요청에 따라 시간 조정 가능',
  popup: '최소 2시간부터 예약 가능. 일·주·월 단위 장기 예약도 진행',
};

// Wedding rows are intentionally trimmed — items duplicated by upstream
// wedding sections (printing, onsite manager, custom template) live there.
// This block keeps only the truly operational SOP info.
const operationsTable = context === 'wedding'
  ? [
      {
        item: '운영 시간',
        detail: '본식 시작 90분 전 설치 시작 → 예식 시작 후 30분까지 운영 <span class="text-[80%]">(식장의 상황과 요청에 따라 시간이 조정될 수 있습니다.)</span>',
      },
      {
        item: '설치·철수',
        detail: '설치 약 30분 / 철수 약 20분 소요 <span class="text-[80%]">(식장 일정과 동선에 맞춰 진행됩니다.)</span>',
      },
    ]
  : [
      {
        item: '운영 시간',
        detail: context === 'popup'
          ? '최소 2시간부터 예약 가능. 일 단위·주 단위·월 단위 장기 예약도 진행합니다.'
          : '웨딩은 본식 90분 전 설치 → 예식 시작 후 30분까지 운영. 팝업·기업·페스티벌은 최소 2시간부터 일·주·월 단위 장기 예약 가능.',
      },
      {
        item: '인쇄·디지털',
        detail: '현장 무제한 인화. QR 디지털 다운로드는 옵션으로 제공합니다.',
      },
      {
        item: '운영 인력',
        detail: context === 'popup'
          ? '팝업·기업·페스티벌은 운영 형태에 따라 현장 매니저 상주 또는 실시간 원격 대응 운영이 가능합니다.'
          : '웨딩은 매니저 2인 현장 상주, 팝업·기업은 현장 상주 또는 실시간 원격 대응 중 선택 가능합니다.',
      },
      {
        item: '커스텀 디자인',
        detail: '신랑신부 이름·브랜드 로고·컬러·이벤트 컨셉을 반영한 커스텀 템플릿 제작이 가능합니다.',
      },
    ];

// Cancellation, penalty, and compensation policy.
// 위약금 (penalty) is identical between general events (rental·popup) and
// wedding. 환불 조건 / 보상 규정 differ — handled per context below.
const showEventRefund = context === 'rental' || context === 'popup';
const showWeddingRefund = context === 'wedding';

const refundConditions = [
  {
    when: '계약 후 14일 이내이면서 행사 당일 60일 전까지 취소',
    amount: '위약금 없이 100% 환불',
    note: '두 조건 모두 충족해야 합니다.',
  },
  {
    when: '계약 후 14일 이내이지만 행사일까지 14일 미만',
    amount: '환불 불가',
    note: '이 경우 이용료 전액이 위약금으로 지불됩니다.',
  },
];

// Penalty rows are identical for all event types per contract §10·§13.
const penaltyRows = [
  { period: '행사일까지 60일 이상 남은 시점 취소', amount: '총 렌탈 금액의 30%' },
  { period: '행사일까지 30일~59일 남은 시점 취소', amount: '총 렌탈 금액의 50%' },
  { period: '행사일까지 1일~29일 남은 시점 취소', amount: '총 렌탈 금액의 100% (환불 불가)' },
];

// General event compensation (rental·popup) — contract §11
const compensationRows = [
  { situation: '심플큐브 과실로 계약한 운영 시간을 채우지 못한 경우', detail: '(결제 금액 − 할인 금액) ÷ 계약 시간 × 부족 시간 환불' },
  { situation: '기기 오작동·고장으로 촬영이 지연된 경우', detail: '(결제 금액 − 할인 금액) ÷ 계약 시간 × 부족 시간 환불' },
  { situation: '기본 구성 사항 누락 (백월·가랜드·테이블 등)', detail: '행사비의 20% 환불' },
  { situation: '기기 고장·지각 등 심플큐브 과실로 촬영을 진행하지 못했거나 계약 시간의 50%를 채우지 못한 경우', detail: '이용 금액의 100% 환불' },
  { situation: '단순 변심·개인적 취향·기대와의 차이·이용 빈도 등 주관적 사유', detail: '환불 불가' },
];

// Wedding compensation cases (전액·부분) are intentionally not surfaced on
// the public site — the detailed list was distracting and the policy is
// communicated via contract + consultation. Penalty schedule is enough for
// the booking-decision context.
---

<!-- Operations standard guide + event refund policy -->
<section class="bg-bg-light py-12 lg:py-16">
  <div class="mx-auto max-w-5xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">SERVICE GUIDE</span>
      <h2 class="mt-3 text-[clamp(1.5rem,2.6vw,2.4rem)] font-bold text-primary">운영 표준 안내</h2>
      <div class="mt-4 h-[2px] w-8 bg-olive"></div>
      <p class="mt-3 text-sm text-secondary leading-relaxed">{operations[context]}.</p>
    </div>

    <div class="rounded-lg border border-border-light bg-white">
      <table class="w-full text-sm">
        <caption class="sr-only">심플큐브 포토부스 운영 표준 안내</caption>
        <tbody>
          {operationsTable.map((row, idx) => (
            <tr class:list={[idx > 0 ? 'border-t border-border-light/60' : '']}>
              <th scope="row" class="px-5 py-4 align-top w-28 sm:w-40 text-left font-semibold text-primary whitespace-nowrap">{row.item}</th>
              <td class="px-5 py-4 align-top text-secondary leading-relaxed break-keep" set:html={row.detail}></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {showEventRefund && (
      <Fragment>
        <!-- Cancellation, penalty, refund policy (general event contract terms §10) -->
        <div class="mt-10 lg:mt-12">
          <h3 class="text-lg font-bold text-primary md:text-xl">취소·위약금·환불 규정</h3>
        </div>

        <div class="mt-5 rounded-lg border border-border-light bg-white">
          <h4 class="border-b border-border-light px-5 py-3 text-sm font-semibold text-primary">1. 환불 조건</h4>
          <table class="w-full text-sm">
            <caption class="sr-only">환불 조건</caption>
            <tbody>
              {refundConditions.map((row, idx) => (
                <tr class:list={[idx > 0 ? 'border-t border-border-light/60' : '']}>
                  <td class="px-5 py-3 align-top w-1/2 sm:w-2/5 font-semibold text-primary leading-relaxed break-keep">{row.when}</td>
                  <td class="px-5 py-3 align-top text-secondary leading-relaxed break-keep">
                    {row.amount}
                    {row.note && <span class="block text-xs text-secondary/70 mt-1">· {row.note}</span>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="mt-4 rounded-lg border border-border-light bg-white">
          <h4 class="border-b border-border-light px-5 py-3 text-sm font-semibold text-primary">2. 위약금 (행사일까지 잔여 기간 기준)</h4>
          <table class="w-full text-sm">
            <caption class="sr-only">행사 잔여 기간별 위약금</caption>
            <tbody>
              {penaltyRows.map((row, idx) => (
                <tr class:list={[idx > 0 ? 'border-t border-border-light/60' : '']}>
                  <th scope="row" class="px-5 py-3 align-top w-1/2 sm:w-2/5 text-left font-semibold text-primary whitespace-normal break-keep">{row.period}</th>
                  <td class="px-5 py-3 align-top text-secondary leading-relaxed break-keep">{row.amount}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="mt-4 rounded-lg border border-border-light bg-white">
          <h4 class="border-b border-border-light px-5 py-3 text-sm font-semibold text-primary">3. 보상 규정 (심플큐브 과실 시)</h4>
          <table class="w-full text-sm">
            <caption class="sr-only">심플큐브 과실 시 보상 규정</caption>
            <tbody>
              {compensationRows.map((row, idx) => (
                <tr class:list={[idx > 0 ? 'border-t border-border-light/60' : '']}>
                  <th scope="row" class="px-5 py-3 align-top w-1/2 sm:w-3/5 text-left font-semibold text-primary whitespace-normal break-keep">{row.situation}</th>
                  <td class="px-5 py-3 align-top text-secondary leading-relaxed break-keep">{row.detail}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="mt-4 text-xs text-secondary/70 leading-relaxed">※ 정확한 견적·운영 옵션은 행사 일정과 장소가 확정된 후 별도로 안내해드립니다. 약관 원본은 계약 시 임차인에게 전달되며, 위 내용과 약관 본문에 차이가 있는 경우 약관 본문이 우선합니다.</p>
      </Fragment>
    )}

    {showWeddingRefund && (
      <Fragment>
        <!-- Wedding cancellation, penalty, compensation policy (contract §12·§13) -->
        <div class="mt-10 lg:mt-12">
          <h3 class="text-lg font-bold text-primary md:text-xl">웨딩 포토부스 취소·위약금·환불 규정</h3>
        </div>

        <div class="mt-5 rounded-lg border border-border-light bg-white">
          <h4 class="border-b border-border-light px-5 py-3 text-sm font-semibold text-primary">1. 위약금 (행사일까지 잔여 기간 기준)</h4>
          <table class="w-full text-sm">
            <caption class="sr-only">웨딩 포토부스 잔여 기간별 위약금</caption>
            <tbody>
              {penaltyRows.map((row, idx) => (
                <tr class:list={[idx > 0 ? 'border-t border-border-light/60' : '']}>
                  <th scope="row" class="px-5 py-3 align-top w-1/2 sm:w-2/5 text-left font-semibold text-primary whitespace-normal break-keep">{row.period}</th>
                  <td class="px-5 py-3 align-top text-secondary leading-relaxed break-keep">{row.amount}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="mt-4 text-xs text-secondary/70 leading-relaxed">※ 심플큐브 과실에 따른 보상·전액·부분 환불 규정은 별도 약관에 명시되어 있으며 계약 시 임차인에게 전달됩니다. 위 내용과 약관 본문에 차이가 있는 경우 약관 본문이 우선합니다. 자세한 안내는 카카오톡 또는 전화 상담 시 받아보실 수 있습니다.</p>
      </Fragment>
    )}
  </div>
</section>
