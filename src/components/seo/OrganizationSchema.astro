---
// Multi-branch Organization + LocalBusiness schema for the homepage.
// Replaces the single LocalBusiness JSON-LD with a richer Organization graph
// that exposes the 4 branches (서울 본사 + 부산·대전·전주 지점) so Google can
// understand each as a distinct local business for regional searches.

// Single Organization + headquarters LocalBusiness for the homepage.
// Regional branches (부산·대전·전주) operate as private offices and are not
// publicly registered as separate LocalBusinesses, so they are omitted from
// the structured data to avoid representing unregistered local businesses.

const siteUrl = 'https://simplecube.net';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#org`,
      name: '심플큐브',
      alternateName: ['SIMPLE CUBE', '심플큐브 포토부스', 'SIMPLE CUBE Photo Booth'],
      url: siteUrl,
      logo: `${siteUrl}/favicon.svg`,
      description: '2019년 설립된 한국의 1세대 오픈형 포토부스 브랜드. 14,000건 이상의 행사 운영 경력을 바탕으로 웨딩·팝업스토어·기업행사·페스티벌에 맞춤 포토부스 대여 서비스를 제공합니다.',
      foundingDate: '2019',
      sameAs: [
        'https://www.instagram.com/simplecube_photobooth',
        'https://pf.kakao.com/_simplecube',
      ],
      contactPoint: [
        {
          '@type': 'ContactPoint',
          telephone: '+82-2-338-9180',
          contactType: 'reservations',
          areaServed: 'KR',
          availableLanguage: ['Korean', 'English'],
        },
      ],
      knowsAbout: [
        '포토부스 대여',
        '웨딩 포토부스',
        '결혼식 포토부스',
        '팝업 포토부스',
        '기업행사 포토부스',
        '브랜드 팝업스토어 포토부스',
        '페스티벌 포토부스',
        '포토부스 렌탈',
      ],
      areaServed: [
        { '@type': 'Country', name: '대한민국' },
      ],
    },
    {
      '@type': 'LocalBusiness',
      '@id': `${siteUrl}/#hq`,
      name: '심플큐브',
      alternateName: 'SIMPLE CUBE',
      url: siteUrl,
      telephone: '+82-2-338-9180',
      address: {
        '@type': 'PostalAddress',
        addressLocality: '서울',
        addressRegion: 'Seoul',
        addressCountry: 'KR',
      },
      sameAs: [
        'https://www.instagram.com/simplecube_photobooth',
        'https://pf.kakao.com/_simplecube',
      ],
      areaServed: [
        { '@type': 'Country', name: '대한민국' },
      ],
      priceRange: '₩₩',
      openingHours: 'Mo-Fr 10:00-18:00',
      parentOrganization: { '@id': `${siteUrl}/#org` },
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
