---
import SectionHeading from '@components/common/SectionHeading.astro';

const templates = [
  { src: 'https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=400&h=600&fit=crop&q=80', name: 'Classic White' },
  { src: 'https://images.unsplash.com/photo-1465495976277-4387d4b0b4c6?w=400&h=600&fit=crop&q=80', name: 'Romantic Blush' },
  { src: 'https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=400&h=600&fit=crop&q=80', name: 'Modern Minimal' },
  { src: 'https://images.unsplash.com/photo-1478146059778-26028b07395a?w=400&h=600&fit=crop&q=80', name: 'Floral Garden' },
  { src: 'https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=400&h=600&fit=crop&q=80', name: 'Vintage Gold' },
  { src: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&h=600&fit=crop&q=80', name: 'Elegant Black' },
];
---

<section class="bg-bg-light py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <SectionHeading
      title="포토 템플릿"
      subtitle="웨딩 컨셉에 맞는 다양한 템플릿을 제공합니다."
    />

    <div class="gs-stagger grid grid-cols-2 gap-4 md:grid-cols-3 lg:gap-6">
      {templates.map((template) => (
        <div class="group cursor-pointer overflow-hidden rounded-xl">
          <div class="relative">
            <img
              src={template.src}
              alt={template.name}
              class="aspect-[2/3] w-full object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/50 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <p class="p-4 text-sm font-medium text-white">{template.name}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
