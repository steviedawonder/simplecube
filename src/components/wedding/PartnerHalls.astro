---

<section id="partner-halls" class="bg-white py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="gs-fade-up text-center">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">Partners</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold leading-tight text-primary">
        제휴 웨딩홀
      </h2>
      <div class="mx-auto mt-6 h-[2px] w-10 bg-olive"></div>
      <p class="mt-8 text-base leading-relaxed text-secondary">
        심플큐브와 제휴된 웨딩홀에서 더욱 특별한 포토부스 서비스를 만나보세요.
      </p>
    </div>

    <!-- Partner Grid -->
    <div class="gs-stagger mt-10 grid grid-cols-3 gap-3 lg:grid-cols-4 lg:gap-5">
      {partners.map((partner) => (
        <div class="group relative overflow-hidden rounded-xl">
          <img
            src={partner.image}
            alt={partner.name}
            class="aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          <div class="absolute bottom-0 left-0 right-0 p-3 translate-y-2 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
            <p class="text-xs font-semibold text-white lg:text-sm">{partner.name}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
