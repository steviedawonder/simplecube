---
import db from '@lib/db';

// Icon mapping by package name
const iconMap: Record<string, string> = {
  '무제한 사진 인화': '📸',
  '포토 방명록': '📖',
  '원목 액자': '🖼️',
  '원본 & GIF USB': '💾',
};

// Hardcoded fallback
const defaultItems = [
  { name: '무제한 사진 인화', desc: '동일 사진 2장 즉시 인화', detail: '한 장은 하객에게 기념으로, 한 장은 방명록용으로 제공됩니다.', image_url: '/images/wedding/booth-print.jpg' },
  { name: '포토 방명록', desc: '사진+축하 메시지를 담은 바인더', detail: '바인더형 방명록에 사진과 축하 메시지를 담아 신랑·신부님께 선물합니다.', image_url: '/images/wedding/photo-strips.jpg' },
  { name: '원목 액자', desc: '대표 사진을 액자에 담아 제공', detail: '신랑·신부님의 대표 사진을 원목 액자에 넣어 전달드립니다.', image_url: '/images/wedding/frame.jpg' },
  { name: '원본 & GIF USB', desc: '모든 원본 사진+GIF USB 전달', detail: '촬영된 모든 원본 사진과 GIF 파일을 USB에 담아 드립니다.', image_url: '/images/wedding/giftbox.jpg' },
];

// Try loading from DB
let packageItems: { icon: string; name: string; desc: string; detail: string; image_url: string }[] = [];
try {
  const result = await db.execute({
    sql: "SELECT * FROM package_items WHERE page = 'wedding' ORDER BY sort_order ASC, id ASC",
    args: [],
  });
  if (result.rows.length > 0) {
    packageItems = (result.rows as any[]).map(row => {
      const fullDesc = row.description || '';
      const dotIdx = fullDesc.indexOf('. ');
      const desc = dotIdx > 0 ? fullDesc.substring(0, dotIdx) : fullDesc;
      const detail = dotIdx > 0 ? fullDesc.substring(dotIdx + 2) : fullDesc;
      return {
        icon: iconMap[row.name] || '📦',
        name: row.name,
        desc,
        detail,
        image_url: row.image_url || '/images/wedding/booth-print.jpg',
      };
    });
  }
} catch { /* table may not exist yet */ }

// Fallback to hardcoded
if (packageItems.length === 0) {
  packageItems = defaultItems.map(d => ({
    icon: iconMap[d.name] || '📦',
    ...d,
  }));
}

const specs = [
  { label: '촬영 배경', value: '백드롭 6종 택 1' },
  { label: '현장 스텝', value: '전담 스텝 2인' },
  { label: '촬영 소품', value: '웨딩 소품 제공' },
  { label: '사진 인화', value: '무제한' },
  { label: '개별 포장', value: '필름 개별 포장' },
  { label: '방명록 용지', value: '무제한 제공' },
  { label: '안내 카드', value: '동봉카드 100매' },
];
---

<section id="packages" class="bg-bg-light py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
      <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PACKAGE</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">패키지 구성</h2>
      <p class="mt-4 text-sm text-secondary">웨딩 포토부스 예약 시 모두 포함됩니다.</p>
    </div>

    {/* Mobile: 1 col, Desktop: 2 col - Option D style */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-2 gs-stagger">
      {packageItems.map((item, i) => (
        <button class="pkg-card flex items-center gap-5 md:gap-6 p-4 md:p-5 bg-white border border-[#e8e8ed] text-left transition-all hover:border-[#D4AA45]/30 active:scale-[0.99]" data-pkg-idx={i}>
          <div class="flex-shrink-0 w-[100px] h-[75px] md:w-[120px] md:h-[90px] rounded-[6px] overflow-hidden">
            <img src={item.image_url} alt={item.name} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="flex-1 flex items-center">
            <div>
              <span class="text-[10px] md:text-[11px] font-bold tracking-[0.1em] text-[#D4AA45]">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="text-[17px] md:text-xl font-bold text-[#2E2318] mt-1">{item.name}</h3>
              <p class="text-[13px] md:text-sm text-[#8B7E72] mt-1">{item.desc}</p>
            </div>
          </div>
        </button>
      ))}
    </div>

    {/* Mobile modal */}
    <div id="pkg-modal" style="display:none" class="fixed inset-0 z-50 items-center justify-center bg-black/50 p-4">
      <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-auto overflow-hidden">
        <div class="relative">
          <img id="pkg-modal-img" src="" alt="" class="w-full h-48 object-cover" />
          <button id="pkg-modal-close" class="absolute top-3 right-3 w-8 h-8 bg-black/40 backdrop-blur rounded-full flex items-center justify-center text-white text-sm">✕</button>
        </div>
        <div class="p-5">
          <h3 id="pkg-modal-title" class="text-lg font-bold text-primary"></h3>
          <p id="pkg-modal-detail" class="mt-2 text-sm text-secondary leading-relaxed"></p>
        </div>
      </div>
    </div>

    {/* Included items - compact */}
    <div class="mt-6 rounded-xl border border-border-light bg-white p-5 md:p-8">
      <h4 class="text-sm font-bold text-primary mb-4">기본 구성에 포함</h4>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-4 gap-y-3">
        {specs.map((spec) => (
          <div>
            <span class="text-[11px] text-secondary/60">{spec.label}</span>
            <p class="text-xs md:text-sm font-semibold text-primary">{spec.value}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script define:vars={{ packageItems }}>
  const modal = document.getElementById('pkg-modal');
  const modalImg = document.getElementById('pkg-modal-img');
  const modalTitle = document.getElementById('pkg-modal-title');
  const modalDetail = document.getElementById('pkg-modal-detail');
  const modalClose = document.getElementById('pkg-modal-close');

  document.querySelectorAll('.pkg-card').forEach((btn) => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.dataset.pkgIdx);
      const item = packageItems[idx];
      modalImg.src = item.image_url;
      modalImg.alt = item.name;
      modalTitle.textContent = item.name;
      modalDetail.textContent = item.detail;
      modal.style.display = 'flex';
    });
  });

  modalClose?.addEventListener('click', () => { modal.style.display = 'none'; });
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal) modal.style.display = 'none'; });
</script>
