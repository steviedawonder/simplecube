---
const base = import.meta.env.BASE_URL;

const packageItems = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>`,
    title: '하객 제공 사진',
    desc: '촬영 즉시 동일 사진 2장 인화. 한 장은 하객에게, 한 장은 방명록용.',
    image: `${base}/images/wedding/booth-print.jpg`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>`,
    title: '포토 방명록',
    desc: '바인더형 방명록에 사진과 축하 메시지를 담아 신랑·신부님께 선물.',
    image: `${base}/images/wedding/photo-strips.jpg`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>`,
    title: '원목 액자',
    desc: '신랑·신부님의 대표 사진을 원목 액자에 담아 제공.',
    image: `${base}/images/wedding/frame.jpg`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" /></svg>`,
    title: '원본 사진 & GIF USB',
    desc: '모든 촬영 원본 사진과 GIF 파일을 USB에 담아 전달.',
    image: `${base}/images/wedding/giftbox.jpg`,
  },
];
---

<section class="bg-bg-light py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-16">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PACKAGE</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">패키지 구성</h2>
      <p class="mt-4 text-sm text-secondary">웨딩 포토부스 예약 시 모두 포함되는 구성입니다.</p>
    </div>

    <!-- Package items grid -->
    <div class="gs-stagger grid gap-4 md:grid-cols-2">
      {packageItems.map((item) => (
        <div class="group overflow-hidden rounded-2xl border border-border-light bg-white transition-all duration-300 hover:border-olive/30 hover:shadow-sm">
          <div class="grid md:grid-cols-[1fr_1.1fr]">
            <!-- Text -->
            <div class="p-8 flex flex-col justify-center">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-olive/10 text-olive mb-4">
                <Fragment set:html={item.icon} />
              </div>
              <h3 class="text-lg font-bold text-primary">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-secondary">{item.desc}</p>
            </div>
            <!-- Image -->
            <div class="overflow-hidden">
              <img
                src={item.image}
                alt={item.title}
                class="h-48 md:h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Included items -->
    <div class="mt-8 rounded-xl border border-border-light bg-white p-8">
      <h4 class="text-sm font-bold text-primary mb-5">기본 구성에 포함</h4>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { label: '촬영용 배경', value: '백드롭 7종 중 택 1' },
          { label: '촬영 조명', value: '전문 스튜디오 조명' },
          { label: '현장 스텝', value: '진행 스텝 2인' },
          { label: '촬영 소품', value: '다양한 웨딩 소품' },
        ].map((spec) => (
          <div>
            <span class="text-xs text-secondary-light">{spec.label}</span>
            <p class="mt-1 text-sm font-semibold text-primary">{spec.value}</p>
          </div>
        ))}
      </div>
      <div class="mt-5 pt-5 border-t border-border-light grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { label: '사진 인화', value: '무제한 (인원수별 맞춤)' },
          { label: '개별 포장', value: '필름 개별 포장' },
          { label: '방명록 용지', value: '무제한 제공' },
          { label: '안내 카드', value: '포토부스 동봉카드 100매' },
        ].map((spec) => (
          <div>
            <span class="text-xs text-secondary-light">{spec.label}</span>
            <p class="mt-1 text-sm font-semibold text-primary">{spec.value}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
