---
import db from '@lib/db';

// Icon mapping by package name
const iconMap: Record<string, string> = {
  '무제한 사진 인화': '📸',
  '포토 방명록': '📖',
  '원목 액자': '🖼️',
  '원본 & GIF USB': '💾',
};

// Hardcoded fallback
const defaultItems = [
  { name: '무제한 사진 인화', desc: '동일 사진 2장 즉시 인화', detail: '한 장은 하객에게 기념으로, 한 장은 방명록용으로 제공됩니다.', image_url: '/images/wedding/booth-print.jpg' },
  { name: '포토 방명록', desc: '사진+축하 메시지를 담은 바인더', detail: '바인더형 방명록에 사진과 축하 메시지를 담아 신랑·신부님께 선물합니다.', image_url: '/images/wedding/photo-strips.jpg' },
  { name: '원목 액자', desc: '대표 사진을 액자에 담아 제공', detail: '신랑·신부님의 대표 사진을 원목 액자에 넣어 전달드립니다.', image_url: '/images/wedding/frame.jpg' },
  { name: '원본 & GIF USB', desc: '모든 원본 사진+GIF USB 전달', detail: '촬영된 모든 원본 사진과 GIF 파일을 USB에 담아 드립니다.', image_url: '/images/wedding/giftbox.jpg' },
];

// Try loading from DB
let packageItems: { icon: string; name: string; desc: string; detail: string; image_url: string }[] = [];
try {
  const result = await db.execute({
    sql: "SELECT * FROM package_items WHERE page = 'wedding' ORDER BY sort_order ASC, id ASC",
    args: [],
  });
  if (result.rows.length > 0) {
    packageItems = (result.rows as any[]).map(row => {
      const fullDesc = row.description || '';
      // ||| 구분자 또는 '. ' 구분자 지원
      let desc = fullDesc;
      let detail = fullDesc;
      if (fullDesc.includes('|||')) {
        const parts = fullDesc.split('|||');
        desc = parts[0].trim();
        detail = parts[1]?.trim() || '';
      } else {
        const dotIdx = fullDesc.indexOf('. ');
        if (dotIdx > 0) {
          desc = fullDesc.substring(0, dotIdx);
          detail = fullDesc.substring(dotIdx + 2);
        }
      }
      return {
        icon: iconMap[row.name] || '📦',
        name: row.name,
        desc,
        detail,
        image_url: row.image_url || '/images/wedding/booth-print.jpg',
      };
    });
  }
} catch { /* table may not exist yet */ }

// Fallback to hardcoded
if (packageItems.length === 0) {
  packageItems = defaultItems.map(d => ({
    icon: iconMap[d.name] || '📦',
    ...d,
  }));
}

const defaultSpecs = [
  { label: '촬영 배경', value: '백드롭 6종 택 1', desc: '', image_url: '' },
  { label: '현장 스텝', value: '전담 스텝 2인', desc: '', image_url: '' },
  { label: '촬영 소품', value: '웨딩 소품 제공', desc: '', image_url: '' },
  { label: '사진 인화', value: '무제한', desc: '', image_url: '' },
  { label: '개별 포장', value: '필름 개별 포장', desc: '', image_url: '' },
  { label: '방명록 용지', value: '무제한 제공', desc: '', image_url: '' },
  { label: '안내 카드', value: '동봉카드 100매', desc: '', image_url: '' },
];

// DB에서 기본 구성 항목 로드
let specs = defaultSpecs;
try {
  const specResult = await db.execute({
    sql: "SELECT value FROM page_contents WHERE page = 'wedding' AND section = 'package' AND key = 'specs'",
    args: [],
  });
  if (specResult.rows.length > 0) {
    const parsed = JSON.parse((specResult.rows[0] as any).value);
    if (Array.isArray(parsed) && parsed.length > 0) {
      specs = parsed;
    }
  }
} catch { /* use defaults */ }
---

<section id="packages" class="bg-bg-light py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
      <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PACKAGE</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">패키지 구성</h2>
      <p class="mt-4 text-sm text-secondary">웨딩 포토부스 예약 시 모두 포함됩니다.</p>
    </div>

    {/* Accordion Package Cards */}
    <div class="flex flex-col gap-2 gs-stagger">
      {packageItems.map((item, i) => (
        <div class="pkg-accordion" data-pkg-idx={i}>
          {/* Card Header (clickable) */}
          <button
            type="button"
            class="pkg-header w-full flex items-center gap-5 md:gap-6 p-4 md:p-5 bg-white border border-[#e8e8ed] text-left transition-all hover:border-[#D4AA45]/30 cursor-pointer"
          >
            <div class="flex-shrink-0 w-[100px] h-[75px] md:w-[120px] md:h-[90px] rounded-[6px] overflow-hidden">
              <img src={item.image_url} alt={item.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="flex-1 flex items-center">
              <div>
                <span class="text-[10px] md:text-[11px] font-bold tracking-[0.1em] text-[#D4AA45]">{String(i + 1).padStart(2, '0')}</span>
                <h3 class="text-[17px] md:text-xl font-bold text-[#2E2318] mt-1">{item.name}</h3>
                <p class="text-[13px] md:text-sm text-[#8B7E72] mt-1">{item.desc}</p>
              </div>
            </div>
            {/* Arrow indicator */}
            <div class="pkg-arrow flex-shrink-0 text-[#8B7E72] transition-transform duration-300">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </button>

          {/* Dropdown Content */}
          <div class="pkg-dropdown overflow-hidden transition-all duration-400 ease-in-out" style="max-height: 0;">
            <div class="bg-white border-x border-b border-[#e8e8ed] p-5 md:p-8">
              <div class="flex flex-col md:flex-row gap-5 md:gap-8">
                {/* Image */}
                <div class="flex-shrink-0 md:w-[280px]">
                  <img
                    src={item.image_url}
                    alt={item.name}
                    class="w-full rounded-lg object-cover"
                    loading="lazy"
                  />
                </div>
                {/* Detail text */}
                <div class="flex-1">
                  <h4 class="text-base md:text-lg font-bold text-[#2E2318] mb-3">{item.name}</h4>
                  <p class="text-sm md:text-[15px] text-[#6B5B4D] leading-relaxed whitespace-pre-line">{item.detail}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Included items - with hover popover */}
    <div class="mt-6 rounded-xl border border-border-light bg-white p-5 md:p-8">
      <h4 class="text-sm font-bold text-primary mb-4">기본 구성에 포함</h4>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-4 gap-y-3">
        {specs.map((spec: any, i: number) => (
          <div class="spec-item relative group cursor-default" data-spec-idx={i}>
            <span class="text-[11px] text-secondary/60">{spec.label}</span>
            <p class="text-xs md:text-sm font-semibold text-primary group-hover:text-[#D4AA45] transition-colors">{spec.value}</p>
            {/* Hover popover — only if desc or image exists */}
            {(spec.desc || spec.image_url) && (
              <div class="spec-popover absolute z-30 bottom-full left-1/2 -translate-x-1/2 mb-2 w-72 bg-white rounded-lg shadow-xl border border-[#e8e8ed] p-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 pointer-events-none">
                {spec.image_url && (
                  <img src={spec.image_url} alt={spec.label} class="w-full h-36 object-cover rounded-md mb-2" loading="lazy" />
                )}
                {spec.desc && (
                  <p class="text-xs text-[#6B5B4D] leading-relaxed">{spec.desc}</p>
                )}
                <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-full w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[6px] border-t-white"></div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
{
  const accordions = document.querySelectorAll<HTMLDivElement>('.pkg-accordion');

  accordions.forEach(acc => {
    const header = acc.querySelector('.pkg-header') as HTMLButtonElement;
    const dropdown = acc.querySelector('.pkg-dropdown') as HTMLDivElement;
    const arrow = acc.querySelector('.pkg-arrow') as HTMLDivElement;

    header.addEventListener('click', () => {
      const isOpen = dropdown.style.maxHeight !== '0px' && dropdown.style.maxHeight !== '';

      // Close all
      accordions.forEach(other => {
        const otherDropdown = other.querySelector('.pkg-dropdown') as HTMLDivElement;
        const otherArrow = other.querySelector('.pkg-arrow') as HTMLDivElement;
        const otherHeader = other.querySelector('.pkg-header') as HTMLButtonElement;
        otherDropdown.style.maxHeight = '0px';
        otherArrow.style.transform = 'rotate(0deg)';
        otherHeader.classList.remove('border-[#D4AA45]', 'shadow-sm');
        otherHeader.classList.add('border-[#e8e8ed]');
      });

      // Toggle current
      if (!isOpen) {
        dropdown.style.maxHeight = dropdown.scrollHeight + 'px';
        arrow.style.transform = 'rotate(180deg)';
        header.classList.remove('border-[#e8e8ed]');
        header.classList.add('border-[#D4AA45]', 'shadow-sm');
      }
    });
  });
}
</script>
