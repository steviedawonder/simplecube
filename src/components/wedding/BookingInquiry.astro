---
const steps = [
  {
    step: '01',
    title: '예약 문의',
    desc: '카카오톡 채널을 통해 예약 가능 여부를 확인합니다.',
    detail: '행사 장소, 날짜, 사용 시간 안내',
  },
  {
    step: '02',
    title: '계약 진행',
    desc: '견적서와 대여약관 확인 후 계약서를 작성합니다.',
    detail: '전자 계약서 날인 후 예약 완료',
  },
  {
    step: '03',
    title: '옵션 선택',
    desc: '대기화면, 포토 스트립 디자인, 백드롭을 선택합니다.',
    detail: '40종+ 포토 스트립 & 6종 백드롭',
  },
  {
    step: '04',
    title: '디자인 확인',
    desc: '웨딩이 있는 주간에 디자인 시안을 전달해 드립니다.',
    detail: '디자인 수정 2회 가능',
  },
  {
    step: '05',
    title: '행사 진행',
    desc: '설치 완료 후 전담 스텝 2인이 행사를 진행합니다.',
    detail: '최종 안내 및 현장 점검',
  },
];
---

<!-- Process -->
<section class="bg-bg-light py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-16">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PROCESS</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">예약 진행 순서</h2>
      <p class="mt-4 text-sm text-secondary">
        문의부터 웨딩 당일까지, 심플큐브가 함께합니다.
      </p>
    </div>

    <!-- Steps -->
    <div class="gs-stagger grid gap-3 md:grid-cols-5">
      {steps.map((item, i) => (
        <div class="relative group">
          <div class="rounded-xl border border-border-light bg-white p-6 transition-all duration-300 hover:border-olive/30 hover:shadow-sm h-full">
            <span class="text-2xl font-bold text-olive/40">{item.step}</span>
            <h3 class="mt-3 text-base font-bold text-primary">{item.title}</h3>
            <p class="mt-2 text-xs leading-relaxed text-secondary">{item.desc}</p>
            <span class="mt-3 inline-block text-[10px] text-olive/70">{item.detail}</span>
          </div>
          {i < steps.length - 1 && (
            <div class="hidden md:flex absolute -right-2 top-1/2 -translate-y-1/2 z-10 text-border">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Booking CTA -->
<section class="relative flex min-h-[50vh] items-center justify-center overflow-hidden bg-[#6B5B4D]">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/wedding/outdoor-setup.jpg"
      alt="웨딩 포토부스 세팅"
      class="h-full w-full object-cover opacity-30"
      loading="lazy"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 px-6 py-20 text-center">
    <h2 class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold leading-snug text-[#FFFAF4]">
      웨딩 포토부스에 대해<br />궁금한 점이 있으신가요?
    </h2>
    <p class="mt-4 text-base text-[#FFFAF4]/60">
      편하게 문의해 주세요. 친절하게 안내드리겠습니다.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="https://pf.kakao.com/_simplecube"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-olive px-8 py-4 text-sm font-semibold tracking-wider text-white transition-all duration-300 hover:bg-olive-hover rounded-full"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 3c-4.97 0-9 3.185-9 7.115 0 2.557 1.707 4.8 4.27 6.054-.188.702-.682 2.545-.78 2.94-.123.496.182.489.382.356.157-.105 2.501-1.7 3.515-2.389.533.078 1.08.12 1.613.12 4.97 0 9-3.186 9-7.115C21 6.185 16.97 3 12 3z"/>
        </svg>
        카카오톡으로 문의하기
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-full border border-[#FFFAF4]/30 px-8 py-4 text-sm font-semibold tracking-wider text-[#FFFAF4] transition-all duration-300 hover:bg-[#FFFAF4] hover:text-[#2E2318]"
      >
        예약 문의 페이지
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
