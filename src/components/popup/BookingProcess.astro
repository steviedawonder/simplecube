---
const steps = [
  {
    step: '01',
    title: '예약 문의',
    desc: '카카오톡 채널을 통해 예약 가능 여부를 확인합니다.',
    detail: '행사 장소, 날짜, 사용 시간 안내',
  },
  {
    step: '02',
    title: '계약 진행',
    desc: '견적서 확인 후 렌탈 계약서를 작성합니다.',
    detail: '전자 계약서 날인 후 예약 완료',
  },
  {
    step: '03',
    title: '옵션 선택',
    desc: '기기 선택, 메인화면 제작, 백드롭 선택 등 옵션을 결정합니다.',
    detail: '브랜드에 맞는 커스텀 옵션 협의',
  },
  {
    step: '04',
    title: '디자인 확인',
    desc: '디자인 시안과 샘플을 확인하고 최종 점검합니다.',
    detail: '포토 템플릿 행사 3일 전, 백월 10일 전 전달',
  },
  {
    step: '05',
    title: '행사 진행',
    desc: '일정에 맞춰 설치 완료 후 행사를 진행합니다.',
    detail: '현장 설치 및 운영 지원',
  },
];
---

<section class="bg-bg-light py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PROCESS</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">예약 진행 순서</h2>
      <p class="mt-4 text-sm text-secondary">
        문의부터 행사 당일까지, 심플큐브가 함께합니다.
      </p>
    </div>

    <!-- Steps -->
    <div class="gs-stagger relative">
      <!-- Mobile: compact timeline -->
      <div class="md:hidden relative pl-8">
        <div class="absolute left-[11px] top-1 bottom-1 w-[1px] bg-olive/20"></div>
        <div class="space-y-4">
          {steps.map((item, i) => (
            <button type="button" data-step-idx={i} class="step-card relative text-left w-full cursor-pointer group">
              <div class="absolute -left-8 top-1 h-[9px] w-[9px] rounded-full bg-olive border-2 border-olive/30 transition-all group-hover:scale-125"></div>
              <div>
                <div class="flex items-baseline gap-2">
                  <span class="text-[10px] font-bold text-olive/50">{item.step}</span>
                  <h3 class="text-sm font-bold text-primary group-hover:text-olive transition-colors">{item.title}</h3>
                </div>
                <p class="mt-0.5 text-xs text-secondary leading-relaxed">{item.desc}</p>
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- Desktop: horizontal step bar -->
      <div class="hidden md:block">
        <div class="relative flex items-start justify-between">
          <!-- Connection line -->
          <div class="absolute top-5 left-[40px] right-[40px] h-[1px] bg-olive/20"></div>

          {steps.map((item, i) => (
            <button
              type="button"
              data-step-idx={i}
              class="step-card relative flex flex-col items-center text-center cursor-pointer group flex-1"
            >
              <div class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full border-2 border-olive/30 bg-bg-light text-sm font-bold text-olive transition-all duration-300 group-hover:bg-olive group-hover:text-white group-hover:border-olive group-hover:scale-110">
                {item.step}
              </div>
              <h3 class="mt-3 text-sm font-bold text-primary group-hover:text-olive transition-colors">{item.title}</h3>
              <p class="mt-1 text-xs text-secondary/60 max-w-[120px] leading-tight">{item.desc}</p>
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-12 md:mt-16 text-center">
      <a
        href="https://pf.kakao.com/_vxhEfj/chat"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 border border-olive px-8 py-4 text-sm font-semibold tracking-wider text-olive transition-all duration-300 hover:bg-olive hover:text-white rounded-full"
      >
        카카오톡으로 문의하기
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Modal -->
<div id="stepModal" class="fixed inset-0 z-50 flex items-center justify-center" style="display:none">
  <div class="step-modal-backdrop absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
  <div class="step-modal-content relative mx-4 w-full max-w-sm rounded-2xl bg-white p-6 md:p-8 shadow-2xl transform scale-95 opacity-0 transition-all duration-300">
    <button type="button" id="stepModalClose" class="absolute top-4 right-4 text-secondary/40 hover:text-primary transition-colors">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <div class="flex items-center gap-3 mb-4">
      <div id="stepModalNum" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-olive text-white text-sm font-bold"></div>
      <h3 id="stepModalTitle" class="text-lg font-bold text-primary"></h3>
    </div>
    <p id="stepModalDesc" class="text-sm leading-relaxed text-secondary"></p>
    <div class="mt-4 flex items-center gap-2 bg-olive/5 rounded-lg px-3 py-2">
      <svg class="h-4 w-4 text-olive/60 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>
      <span id="stepModalDetail" class="text-xs text-olive/80"></span>
    </div>
  </div>
</div>

<script define:vars={{ steps }}>
  const cards = document.querySelectorAll('.step-card');
  const modal = document.getElementById('stepModal');
  const modalNum = document.getElementById('stepModalNum');
  const modalTitle = document.getElementById('stepModalTitle');
  const modalDesc = document.getElementById('stepModalDesc');
  const modalDetail = document.getElementById('stepModalDetail');
  const modalClose = document.getElementById('stepModalClose');
  const modalBackdrop = modal.querySelector('.step-modal-backdrop');
  const modalContent = modal.querySelector('.step-modal-content');

  function openModal(idx) {
    const step = steps[idx];
    modalNum.textContent = step.step;
    modalTitle.textContent = step.title;
    modalDesc.textContent = step.desc;
    modalDetail.textContent = step.detail;
    modal.style.display = 'flex';
    requestAnimationFrame(() => {
      modalContent.classList.remove('scale-95', 'opacity-0');
      modalContent.classList.add('scale-100', 'opacity-100');
    });
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modalContent.classList.remove('scale-100', 'opacity-100');
    modalContent.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }, 200);
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const idx = parseInt(card.dataset.stepIdx);
      openModal(idx);
    });
  });

  modalClose.addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
  });
</script>
