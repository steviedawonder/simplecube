---
import { POPUP_DEFAULT_TAGS, POPUP_CUSTOM_TAGS } from '@lib/defaultTags';
---

<section id="portfolio" class="bg-bg-light py-10 lg:py-14 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">02</div>
      <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PORTFOLIO</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">포트폴리오</h2>
      <p class="mt-4 text-sm text-secondary">심플큐브가 함께한 특별한 순간들</p>
    </div>

    <div id="pf-tags" class="flex flex-wrap gap-2.5 mb-8 hidden"></div>
  </div>

  <!-- Marquee rows with nav arrows -->
  <div id="pf-marquee-wrap" class="relative hidden">
    <!-- Left arrow -->
    <button id="pf-nav-prev" class="absolute left-2 lg:left-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 lg:w-12 lg:h-12 rounded-full bg-white/90 shadow-lg flex items-center justify-center text-[#2E2318] hover:bg-white hover:scale-105 transition-all" aria-label="이전">
      <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <!-- Right arrow -->
    <button id="pf-nav-next" class="absolute right-2 lg:right-4 top-1/2 -translate-y-1/2 z-10 w-10 h-10 lg:w-12 lg:h-12 rounded-full bg-white/90 shadow-lg flex items-center justify-center text-[#2E2318] hover:bg-white hover:scale-105 transition-all" aria-label="다음">
      <svg class="w-5 h-5 lg:w-6 lg:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </button>

    <div class="flex flex-col gap-2">
      <div class="pf-marquee-row overflow-hidden" data-row="0">
        <div class="pf-marquee-track flex gap-2 will-change-transform"></div>
      </div>
      <div class="pf-marquee-row overflow-hidden" data-row="1">
        <div class="pf-marquee-track flex gap-2 will-change-transform"></div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div id="pf-empty" class="text-center py-16 hidden">
      <p class="text-secondary text-sm">준비 중입니다.</p>
    </div>

    <div id="pf-loading" class="text-center py-16">
      <p class="text-secondary text-sm">불러오는 중...</p>
    </div>
  </div>
</section>

<!-- Portfolio Lightbox -->
<div id="pf-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
  <button id="pf-lb-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
  </button>
  <button id="pf-lb-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
  </button>
  <button id="pf-lb-close" class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors" aria-label="닫기">
    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>
  <img id="pf-lb-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
  <p id="pf-lb-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm"></p>
</div>

<style is:global>
  .pf-marquee-track {
    animation: pf-scroll var(--duration, 30s) linear infinite;
  }
  .pf-marquee-row:hover .pf-marquee-track,
  #pf-marquee-wrap.paused .pf-marquee-track {
    animation-play-state: paused;
  }
  /* Row 2 slightly different speed */
  .pf-marquee-row[data-row="1"] .pf-marquee-track {
    animation-duration: var(--duration2, 35s);
  }
  @keyframes pf-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .pf-marquee-item {
    flex-shrink: 0;
    width: 150px;
    height: 112px;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: pointer;
  }
  @media (min-width: 768px) {
    .pf-marquee-item {
      width: 300px;
      height: 225px;
    }
  }
  .pf-marquee-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .pf-marquee-item:hover img {
    transform: scale(1.05);
  }
</style>

<script is:inline define:vars={{ defaultTags: POPUP_DEFAULT_TAGS, customTags: POPUP_CUSTOM_TAGS }}>
  window.__popupDefaultTags = defaultTags;
  window.__popupCustomTags = customTags;
</script>

<script>
  const defaultTags: string[] = (window as any).__popupDefaultTags || [];
  const hardcodedCustomTags: string[] = (window as any).__popupCustomTags || [];

  // 커스텀 범위에서 실제 사용 중인 태그를 DOM에서 읽어 합침
  const domCustomTags = Array.from(document.querySelectorAll('.custom-portfolio-area'))
    .map(el => (el as HTMLElement).dataset.tag || '')
    .filter(Boolean);
  const customTags = [...new Set([...hardcodedCustomTags, ...domCustomTags])];

  async function loadPortfolio() {
    const tagsContainer = document.getElementById('pf-tags')!;
    const marqueeWrap = document.getElementById('pf-marquee-wrap')!;
    const empty = document.getElementById('pf-empty')!;
    const loading = document.getElementById('pf-loading')!;
    const tracks = document.querySelectorAll<HTMLDivElement>('.pf-marquee-track');

    try {
      const res = await fetch('/api/portfolio?page_tag=popup');
      const items: any[] = await res.json();

      loading.classList.add('hidden');

      if (items.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      // 커스텀 전용 태그만 가진 항목은 포트폴리오에서 제외
      const filteredItems = items.filter((item: any) => {
        if (!item.tags) return true;
        const itemTags = item.tags.split(',').map((t: string) => t.trim()).filter(Boolean);
        if (itemTags.length === 0) return true;
        return itemTags.some((t: string) => !customTags.includes(t));
      });
      let allItems = filteredItems;
      let activeTag = '';

      // Collect tags
      const allTags = new Set<string>();
      items.forEach((item: any) => {
        if (item.tags) {
          item.tags.split(',').map((t: string) => t.trim()).filter(Boolean).forEach((t: string) => allTags.add(t));
        }
      });
      const tagList = Array.from(allTags).sort();

      // 커스텀 범위 전용 태그는 포트폴리오 갤러리에서 제외
      const filteredTagList = tagList.filter(t => !customTags.includes(t));
      const orderedTags = [
        ...defaultTags.filter(t => filteredTagList.includes(t)),
        ...filteredTagList.filter(t => !defaultTags.includes(t)),
      ];

      if (orderedTags.length > 0) {
        tagsContainer.classList.remove('hidden');
        tagsContainer.innerHTML = `
          <button class="pf-tag-btn px-5 py-2 text-sm rounded-full bg-primary text-white font-medium transition-colors" data-tag="">전체</button>
          ${orderedTags.map(tag => `<button class="pf-tag-btn px-5 py-2 text-sm rounded-full bg-white border border-gray-200 text-secondary hover:border-olive hover:text-olive font-medium transition-colors" data-tag="${tag}">${tag}</button>`).join('')}
        `;

        tagsContainer.querySelectorAll('.pf-tag-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const tag = (btn as HTMLElement).dataset.tag!;
            activeTag = tag;
            tagsContainer.querySelectorAll('.pf-tag-btn').forEach((b) => {
              if (b === btn) {
                b.classList.remove('bg-white', 'border', 'border-gray-200', 'text-secondary');
                b.classList.add('bg-primary', 'text-white');
              } else {
                b.classList.remove('bg-primary', 'text-white');
                b.classList.add('bg-white', 'border', 'border-gray-200', 'text-secondary');
              }
            });
            renderMarquee(tag ? filteredItems.filter(i => (i.tags || '').split(',').map((t: string) => t.trim()).includes(tag)) : filteredItems);
          });
        });
      }

      renderMarquee(filteredItems);
      marqueeWrap.classList.remove('hidden');

      // Setup lightbox
      setupLightbox();

    } catch {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  function renderMarquee(items: any[]) {
    const tracks = document.querySelectorAll<HTMLDivElement>('.pf-marquee-track');
    const marqueeWrap = document.getElementById('pf-marquee-wrap')!;

    if (items.length === 0) {
      marqueeWrap.classList.add('hidden');
      document.getElementById('pf-empty')!.classList.remove('hidden');
      return;
    }
    marqueeWrap.classList.remove('hidden');
    document.getElementById('pf-empty')!.classList.add('hidden');

    // Split items into 2 rows
    const mid = Math.ceil(items.length / 2);
    const row1Items = items.slice(0, mid);
    const row2Items = items.slice(mid);

    // If row2 is empty, duplicate row1
    const rows = [row1Items, row2Items.length > 0 ? row2Items : [...row1Items].reverse()];

    rows.forEach((rowItems, rowIdx) => {
      const track = tracks[rowIdx];
      if (!track) return;

      // Duplicate items enough times for seamless loop
      const minRepeats = Math.max(3, Math.ceil(20 / rowItems.length));
      let html = '';
      for (let r = 0; r < minRepeats * 2; r++) {
        rowItems.forEach((item: any, i: number) => {
          const globalIdx = rowIdx === 0 ? i : mid + i;
          // Cloudinary URL에 리사이즈 transform 적용 (마키 썸네일용)
          const thumbUrl = item.image_url.includes('res.cloudinary.com')
            ? item.image_url.replace('/upload/', '/upload/w_400,f_auto,q_auto/')
            : item.image_url;
          html += `
            <div class="pf-marquee-item" data-src="${item.image_url}" data-alt="${item.title || '포트폴리오'}" data-idx="${globalIdx}">
              <img src="${thumbUrl}" alt="${item.title || '포트폴리오'}" loading="lazy" />
            </div>
          `;
        });
      }
      track.innerHTML = html;

      // Set animation duration based on actual track width for constant speed
      // Speed: ~150px/s regardless of item count
      const SPEED = 1000; // pixels per second
      requestAnimationFrame(() => {
        const trackWidth = track.scrollWidth / 2; // animation moves 50%
        const duration = trackWidth / SPEED;
        track.style.setProperty('--duration', `${duration}s`);
        track.style.setProperty('--duration2', `${duration * 1.1}s`);
      });
    });

    // Setup nav arrows
    setupNavArrows();
  }

  function setupNavArrows() {
    const prevBtn = document.getElementById('pf-nav-prev');
    const nextBtn = document.getElementById('pf-nav-next');
    const tracks = document.querySelectorAll<HTMLDivElement>('.pf-marquee-track');
    const wrap = document.getElementById('pf-marquee-wrap')!;

    function scrollTracks(direction: number) {
      // direction: -1 = left (prev), 1 = right (next)
      const scrollAmount = direction * 600; // px to jump

      tracks.forEach(track => {
        // Pause animation
        wrap.classList.add('paused');

        // Get current computed transform
        const computed = getComputedStyle(track);
        const matrix = new DOMMatrix(computed.transform);
        const currentX = matrix.m41;

        // Apply new position smoothly
        track.style.animation = 'none';
        track.style.transform = `translateX(${currentX}px)`;

        // Force reflow
        track.offsetHeight;

        // Animate to new position
        track.style.transition = 'transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1)';
        track.style.transform = `translateX(${currentX + scrollAmount}px)`;

        // After transition, resume CSS animation from new position
        const onEnd = () => {
          track.removeEventListener('transitionend', onEnd);
          track.style.transition = '';
          track.style.transform = '';
          track.style.animation = '';
          wrap.classList.remove('paused');
        };
        track.addEventListener('transitionend', onEnd);
      });
    }

    prevBtn?.addEventListener('click', () => scrollTracks(1));
    nextBtn?.addEventListener('click', () => scrollTracks(-1));
  }

  function setupLightbox() {
    const lightbox = document.getElementById('pf-lightbox')!;
    const lbImg = document.getElementById('pf-lb-img') as HTMLImageElement;
    const lbCaption = document.getElementById('pf-lb-caption')!;
    const lbPrev = document.getElementById('pf-lb-prev')!;
    const lbNext = document.getElementById('pf-lb-next')!;
    const lbClose = document.getElementById('pf-lb-close')!;

    let visibleItems: { src: string; alt: string }[] = [];
    let currentIdx = 0;

    function getAllItems() {
      // Collect unique items from marquee
      const seen = new Set<string>();
      const result: { src: string; alt: string }[] = [];
      document.querySelectorAll('.pf-marquee-item').forEach(el => {
        const src = (el as HTMLElement).dataset.src || '';
        if (!seen.has(src)) {
          seen.add(src);
          result.push({ src, alt: (el as HTMLElement).dataset.alt || '' });
        }
      });
      return result;
    }

    function openLb(src: string) {
      visibleItems = getAllItems();
      currentIdx = visibleItems.findIndex(i => i.src === src);
      if (currentIdx < 0) currentIdx = 0;
      showLbImage();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLb() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    function showLbImage() {
      const item = visibleItems[currentIdx];
      if (!item) return;
      lbImg.src = item.src;
      lbImg.alt = item.alt;
      lbCaption.textContent = item.alt;
    }

    document.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest('.pf-marquee-item');
      if (!item) return;
      openLb((item as HTMLElement).dataset.src || '');
    });

    lbPrev.addEventListener('click', (e) => { e.stopPropagation(); currentIdx = (currentIdx - 1 + visibleItems.length) % visibleItems.length; showLbImage(); });
    lbNext.addEventListener('click', (e) => { e.stopPropagation(); currentIdx = (currentIdx + 1) % visibleItems.length; showLbImage(); });
    lbClose.addEventListener('click', closeLb);
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLb(); });

    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLb();
      if (e.key === 'ArrowLeft') { currentIdx = (currentIdx - 1 + visibleItems.length) % visibleItems.length; showLbImage(); }
      if (e.key === 'ArrowRight') { currentIdx = (currentIdx + 1) % visibleItems.length; showLbImage(); }
    });
  }

  // Expose tag activation for external use (CustomOptions "더보기" button)
  (window as any).__activatePortfolioTag = function(tag: string) {
    const btn = document.querySelector(`.pf-tag-btn[data-tag="${tag}"]`) as HTMLButtonElement | null;
    if (btn) btn.click();
  };

  loadPortfolio();
</script>
