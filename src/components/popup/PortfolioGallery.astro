---
import SectionHeading from '@components/common/SectionHeading.astro';

const portfolioImages = [
  { src: 'https://images.unsplash.com/photo-1511578314322-379afb476865?w=600&h=400&fit=crop&q=90', alt: '팝업 포트폴리오 1' },
  { src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=600&h=400&fit=crop&q=90', alt: '팝업 포트폴리오 2' },
  { src: 'https://images.unsplash.com/photo-1497366858526-0766dd9e0c05?w=600&h=400&fit=crop&q=90', alt: '팝업 포트폴리오 3' },
  { src: 'https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=600&h=400&fit=crop&q=90', alt: '팝업 포트폴리오 4' },
  { src: 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=600&h=400&fit=crop&q=90', alt: '팝업 포트폴리오 5' },
  { src: 'https://images.unsplash.com/photo-1517457373958-b7bdd4587205?w=600&h=400&fit=crop&q=90', alt: '팝업 포트폴리오 6' },
];
---

<section id="portfolio" class="bg-bg-light py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">PORTFOLIO</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">포트폴리오</h2>
      <p class="mt-4 text-sm text-secondary">심플큐브가 함께한 특별한 순간들</p>
    </div>

    <div class="gs-stagger grid grid-cols-2 gap-2 md:grid-cols-3">
      {portfolioImages.map((img) => (
        <div class="group cursor-pointer overflow-hidden rounded-lg">
          <img
            src={img.src}
            alt={img.alt}
            class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
