---

---

<section class="bg-bg-dark py-24 lg:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <div class="gs-slide-left">
        <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">SERVICE</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold leading-tight text-white">
          브랜드를 위한<br />맞춤형 포토부스
        </h2>
        <div class="mt-6 h-[2px] w-10 bg-olive"></div>
        <p class="mt-8 text-base leading-relaxed text-white/50">
          팝업스토어, 기업 행사, 제품 런칭, 페스티벌 등
          다양한 행사에 최적화된 포토부스 서비스를 제공합니다.
          브랜드 아이덴티티에 맞춘 커스텀 디자인부터
          현장 운영까지 원스톱으로 진행합니다.
        </p>
      </div>
      <div class="gs-slide-right overflow-hidden">
        <img
          src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&h=600&fit=crop&q=80"
          alt="팝업 포토부스 서비스"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Features -->
    <div class="gs-stagger mt-20 grid gap-0 md:grid-cols-3 border border-white/8">
      {[
        { icon: '✦', title: '커스텀 디자인', desc: '브랜드에 맞춘 맞춤형 포토 프레임과 배경 디자인' },
        { icon: '✦', title: '즉석 출력', desc: '촬영 즉시 고품질 포토 카드를 현장에서 출력' },
        { icon: '✦', title: '디지털 공유', desc: 'QR코드를 통한 즉시 디지털 파일 다운로드' },
      ].map((feature, i) => (
        <div class:list={[
          'p-8 transition-colors duration-300 hover:bg-white/4 border-b border-white/8 md:border-b-0',
          i < 2 ? 'md:border-r md:border-white/8' : '',
          i === 2 ? 'border-b-0' : '',
        ]}>
          <span class="text-olive text-xl">{feature.icon}</span>
          <h3 class="mt-4 text-base font-bold text-white">{feature.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/45">{feature.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
