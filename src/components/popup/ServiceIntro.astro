---
const strengths = [
  { number: 'Since 2019', label: '1세대 포토부스', desc: '2019년 설립, 업계를 이끌어온 노하우' },
  { number: '1,600+', label: '연간 진행 건수', desc: '웨딩 및 브랜드 행사 연 1,600건 이상' },
  { number: '전국', label: '서비스 지역', desc: '서울, 수도권, 부산, 대전까지 전국 대응' },
];
---

<section class="bg-white py-24 lg:py-32 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Intro -->
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <div class="gs-slide-left">
        <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">ABOUT</span>
        <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold leading-tight text-primary">
          브랜드를 위한<br />맞춤형 포토부스
        </h2>
        <div class="mt-6 h-[2px] w-10 bg-olive"></div>
        <p class="mt-8 text-base leading-relaxed text-secondary">
          심플큐브는 2019년에 설립된 1세대 포토부스 업체입니다.<br />
          국내 최초로 원목 부스를 자체 설계·제작하여
          모던하고 럭셔리한 포토부스 서비스를 제공하고 있습니다.
        </p>
        <p class="mt-4 text-base leading-relaxed text-secondary">
          브랜드 팝업스토어, 기업 행사, 제품 런칭, 페스티벌 등
          다양한 현장에 최적화된 맞춤형 서비스를 제공하며,
          기기 외관 랩핑부터 UI 화면, 포토 템플릿까지
          브랜드 아이덴티티에 맞춘 커스텀이 가능합니다.
        </p>
      </div>
      <div class="gs-slide-right overflow-hidden rounded-2xl">
        <img
          src="/images/popup/booth.jpg"
          alt="심플큐브 팝업 포토부스"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Strength Numbers -->
    <div class="gs-stagger mt-20 grid gap-0 md:grid-cols-3 border border-border-light">
      {strengths.map((item, i) => (
        <div class:list={[
          'p-8 transition-colors duration-300 hover:bg-bg-light border-b border-border-light md:border-b-0',
          i < 2 ? 'md:border-r md:border-border-light' : '',
          i === 2 ? 'border-b-0' : '',
        ]}>
          <span class="text-olive text-2xl font-bold tracking-tight">{item.number}</span>
          <h3 class="mt-3 text-base font-bold text-primary">{item.label}</h3>
          <p class="mt-2 text-sm leading-relaxed text-secondary">{item.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
