---
const base = import.meta.env.BASE_URL;

const featured = [
  {
    name: '팝업부스 모델',
    desc: '팝업스토어와 브랜드 행사에 특화된 모델. 알루미늄 소재로 가볍고 외관 커스텀이 자유롭습니다.',
    specs: ['DSLR 촬영', '즉석 출력', '알루미늄 소재', '외관 랩핑'],
    image: `${base}/images/popup/popup-model.png`,
    badge: '추천',
  },
  {
    name: '모듈 모델',
    desc: '아크릴 소재의 모듈형 디자인. 독립적인 사이즈 조절과 다양한 구성이 가능합니다.',
    specs: ['DSLR 촬영', '아크릴 소재', '모듈형 구성', '등판 커스텀'],
    image: `${base}/images/popup/module-model.png`,
    badge: '추천',
  },
];

const others = [
  {
    name: '우드 모델 (Edge Type)',
    desc: '국내 최초 원목 부스. 모던하고 럭셔리한 디자인.',
    specs: ['DSLR 촬영', '즉석 출력', '원목 자체 제작', 'UI 커스텀'],
    image: `${base}/images/popup/wood-edge.jpg`,
  },
  {
    name: '우드 모델 (Round Type)',
    desc: '부드러운 곡선의 라운드 타입. 세련된 공간 연출에 최적화.',
    specs: ['DSLR 촬영', '즉석 출력', '라운드 디자인', 'UI 커스텀'],
    image: `${base}/images/popup/wood-round.png`,
  },
  {
    name: '우드 랩핑 모델',
    desc: '원목 부스에 브랜드 맞춤 랩핑을 적용한 모델.',
    specs: ['DSLR 촬영', '외관 랩핑', '화이트 베이스', 'UI 커스텀'],
    image: `${base}/images/popup/wood-wrapping.png`,
  },
];
---

<section class="bg-bg-light py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-16">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">EQUIPMENT</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">장비 소개</h2>
      <p class="mt-4 text-sm text-secondary">
        행사 목적과 공간에 맞는 최적의 기기를 선택하세요.
      </p>
    </div>

    <!-- Featured: 이미지 좌/우 + 텍스트 교차 배치 -->
    <div class="gs-stagger space-y-8 mb-12">
      {featured.map((machine, i) => (
        <div class:list={[
          'group grid items-center gap-8 lg:gap-14 rounded-2xl border border-border-light bg-white overflow-hidden transition-all duration-300 hover:border-olive/40 hover:shadow-lg',
          'md:grid-cols-[1fr_1.2fr]',
        ]}>
          <!-- Image -->
          <div class:list={[
            'flex items-center justify-center bg-[#f5f5f3] p-8 lg:p-12',
            i % 2 === 1 ? 'md:order-2' : '',
          ]}>
            <img
              src={machine.image}
              alt={machine.name}
              class="h-[360px] lg:h-[440px] w-auto object-contain transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          <!-- Text -->
          <div class:list={[
            'p-8 lg:p-12',
            i % 2 === 1 ? 'md:order-1' : '',
          ]}>
            {machine.badge && (
              <span class="inline-block bg-olive/10 text-olive text-[10px] font-semibold tracking-wider uppercase px-3 py-1 rounded mb-4">
                {machine.badge}
              </span>
            )}
            <h3 class="text-2xl font-bold text-primary">{machine.name}</h3>
            <p class="mt-3 text-sm leading-relaxed text-secondary">{machine.desc}</p>
            <ul class="mt-6 flex flex-wrap gap-2">
              {machine.specs.map((spec) => (
                <li class="border border-olive/40 px-3 py-1 text-xs font-medium text-olive rounded-full">
                  {spec}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Others: 세로형 카드 그리드 -->
    <div class="gs-stagger grid gap-6 grid-cols-2 lg:grid-cols-3">
      {others.map((machine) => (
        <div class="group flex flex-col rounded-2xl border border-border-light bg-white overflow-hidden transition-all duration-300 hover:border-olive/40 hover:shadow-lg">
          <div class="flex items-center justify-center bg-[#f5f5f3] p-6 lg:p-8 flex-1">
            <img
              src={machine.image}
              alt={machine.name}
              class="h-[240px] lg:h-[300px] w-auto object-contain transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-5 lg:p-6">
            <h3 class="text-base lg:text-lg font-bold text-primary">{machine.name}</h3>
            <p class="mt-2 text-xs lg:text-sm text-secondary">{machine.desc}</p>
            <ul class="mt-4 flex flex-wrap gap-1.5">
              {machine.specs.map((spec) => (
                <li class="border border-olive/40 px-2 py-0.5 text-[10px] lg:text-xs font-medium text-olive rounded-full">
                  {spec}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Common specs -->
    <div class="mt-12 border border-border-light rounded-xl bg-white p-8">
      <h4 class="text-sm font-bold text-primary mb-4">공통 사양</h4>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-sm">
        <div>
          <span class="text-secondary">촬영 방식</span>
          <p class="mt-1 font-semibold text-primary">DSLR / 4K</p>
        </div>
        <div>
          <span class="text-secondary">출력 방식</span>
          <p class="mt-1 font-semibold text-primary">즉석 포토 프린터</p>
        </div>
        <div>
          <span class="text-secondary">출력 속도</span>
          <p class="mt-1 font-semibold text-primary">약 8초</p>
        </div>
        <div>
          <span class="text-secondary">디지털 공유</span>
          <p class="mt-1 font-semibold text-primary">QR 다운로드</p>
        </div>
      </div>
    </div>
  </div>
</section>
