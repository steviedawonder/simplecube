---

<section id="machines" class="bg-bg-light py-24 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section heading -->
    <div class="mb-10 lg:mb-16">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">MODELS</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">모델 소개</h2>
      <p class="mt-4 text-sm text-secondary">
        행사 목적과 공간에 맞는 최적의 기기를 선택하세요.
      </p>
    </div>

    <!-- ===== Model Grid: 모바일 2x2, 데스크탑 4열 ===== -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-5">
      {models.map((model) => (
        <button
          class="model-card group relative flex flex-col rounded-xl lg:rounded-2xl border border-border-light bg-white overflow-hidden transition-all duration-300 hover:border-olive/40 hover:shadow-lg text-left"
          data-model-id={model.id}
        >
          {/* Badge */}
          {model.badge && (
            <span class:list={[
              'absolute top-2 right-2 lg:top-3 lg:right-3 text-white text-[9px] lg:text-[10px] font-bold px-2 lg:px-3 py-1 rounded-full z-10',
              model.badgeColor,
            ]}>
              {model.badge}
            </span>
          )}

          {/* Image — big and prominent */}
          <div class="flex items-center justify-center bg-[#f5f5f3] p-4 lg:p-5 aspect-[3/4] lg:aspect-auto lg:h-[320px]">
            <img
              src={model.image}
              alt={model.name}
              class="h-full w-auto object-contain transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          {/* Name only */}
          <div class="px-3 py-2.5 lg:px-4 lg:py-3">
            <h3 class="text-sm lg:text-base font-bold text-primary">{model.name}</h3>
            <p class="text-[10px] lg:text-xs text-secondary/60 mt-0.5">{model.modelNo}</p>
          </div>

          {/* Hover indicator */}
          <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/5 transition-colors duration-300 pointer-events-none">
            <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white/90 rounded-full px-4 py-2 shadow-lg">
              <span class="text-xs font-semibold text-primary">자세히 보기</span>
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- Common specs -->
    <div class="mt-10 lg:mt-12 border border-border-light rounded-xl bg-white p-6 lg:p-8">
      <h4 class="text-xs lg:text-sm font-bold text-primary mb-3 lg:mb-4">공통 사양</h4>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 lg:gap-6 text-xs lg:text-sm">
        <div>
          <span class="text-secondary">촬영 방식</span>
          <p class="mt-1 font-semibold text-primary">DSLR / 4K</p>
        </div>
        <div>
          <span class="text-secondary">출력 방식</span>
          <p class="mt-1 font-semibold text-primary">즉석 포토 프린터</p>
        </div>
        <div>
          <span class="text-secondary">출력 속도</span>
          <p class="mt-1 font-semibold text-primary">약 8초</p>
        </div>
        <div>
          <span class="text-secondary">디지털 공유</span>
          <p class="mt-1 font-semibold text-primary">QR 다운로드</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== Detail Modal (fullscreen on mobile, centered on desktop) ===== -->
<div id="model-modal" class="fixed inset-0 z-[9998] hidden">
  {/* Backdrop */}
  <div id="modal-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  {/* Modal content */}
  <div class="relative z-10 h-full overflow-y-auto">
    <div class="min-h-full flex items-start lg:items-center justify-center lg:py-10">
      <div id="modal-content" class="w-full lg:max-w-5xl lg:mx-6 bg-white lg:rounded-2xl overflow-hidden min-h-screen lg:min-h-0">

        {/* Modal header */}
        <div class="sticky top-0 z-20 bg-white/95 backdrop-blur-sm border-b border-border-light px-4 lg:px-8 py-3 flex items-center justify-between">
          <h3 id="modal-title" class="text-base lg:text-lg font-bold text-primary"></h3>
          <button id="modal-close" class="p-1.5 rounded-full hover:bg-[#f5f5f3] transition-colors" aria-label="닫기">
            <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        {/* Modal body — will be populated by JS */}
        <div id="modal-body"></div>
      </div>
    </div>
  </div>
</div>

<!-- ===== Lightbox ===== -->
<div id="model-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
  <button id="lightbox-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button id="lightbox-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
  <p id="lightbox-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm"></p>
</div>

<!-- Pass data to script -->
<script is:inline define:vars={{ models: JSON.parse(JSON.stringify(models)) }}>
  // Store models data for JS access
  window.__models = models;
</script>

<script>
  {
    const modelsData = (window as any).__models;
    const modal = document.getElementById('model-modal') as HTMLDivElement;
    const modalBackdrop = document.getElementById('modal-backdrop') as HTMLDivElement;
    const modalTitle = document.getElementById('modal-title') as HTMLHeadingElement;
    const modalBody = document.getElementById('modal-body') as HTMLDivElement;
    const modalClose = document.getElementById('modal-close') as HTMLButtonElement;
    const cards = document.querySelectorAll<HTMLButtonElement>('.model-card');

    // === Open modal ===
    function openModal(modelId: string) {
      const model = modelsData.find((m: any) => m.id === modelId);
      if (!model) return;

      modalTitle.textContent = model.name;

      // Build modal content
      modalBody.innerHTML = `
        <!-- Image -->
        <div class="flex items-center justify-center bg-[#f5f5f3] p-8 lg:p-14">
          <img src="${model.image}" alt="${model.name}" class="h-[240px] lg:h-[380px] w-auto object-contain" />
        </div>

        <!-- Specs -->
        <div class="px-5 lg:px-8 py-6 lg:py-8">
          <p class="text-[10px] font-medium tracking-widest text-secondary/50 uppercase">${model.modelNo}</p>
          <h4 class="text-xl lg:text-2xl font-bold text-primary mt-1 mb-6">${model.name}</h4>

          <div class="space-y-0">
            ${model.specs.map((s: any, i: number) => `
              <div class="flex items-baseline gap-3 py-3 ${i < model.specs.length - 1 ? 'border-b border-dashed border-[#e5e5e3]' : ''}">
                <span class="shrink-0 text-[12px] font-medium text-[#888] w-[85px] lg:w-[100px]">${s.label}</span>
                <span class="flex-1 border-b border-dotted border-[#ddd] mb-1 hidden lg:block"></span>
                <span class="text-[13px] font-semibold text-[#1d1d1f] lg:text-right lg:max-w-[55%]">${s.value}</span>
              </div>
            `).join('')}
          </div>

          ${model.note ? `<p class="mt-4 text-[10px] text-[#999] text-right">${model.note}</p>` : ''}
        </div>

        <!-- Portfolio -->
        <div class="px-5 lg:px-8 pb-8">
          <div class="flex items-center justify-between mb-4">
            <h4 class="text-sm font-bold text-[#1d1d1f] tracking-wide uppercase">Portfolio</h4>
            <span class="text-xs text-[#999]">${model.portfolio.length}건</span>
          </div>
          <div class="grid grid-cols-2 lg:grid-cols-3 gap-2 lg:gap-3">
            ${model.portfolio.map((p: any) => `
              <div class="modal-portfolio-thumb cursor-pointer overflow-hidden rounded-lg relative group" data-src="${p.src}" data-alt="${p.alt}">
                <img src="${p.src}" alt="${p.alt}" class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
                  <svg class="w-7 h-7 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
                  </svg>
                </div>
              </div>
            `).join('')}
          </div>
        </div>
      `;

      // Bind portfolio thumb clicks
      const thumbs = modalBody.querySelectorAll<HTMLDivElement>('.modal-portfolio-thumb');
      const images = Array.from(thumbs).map(t => ({
        src: t.dataset.src || '',
        alt: t.dataset.alt || '',
      }));
      thumbs.forEach((thumb, idx) => {
        thumb.addEventListener('click', () => openLightbox(images, idx));
      });

      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // Card clicks
    cards.forEach(card => {
      card.addEventListener('click', () => {
        const id = card.dataset.modelId;
        if (id) openModal(id);
      });
    });

    // Close triggers
    modalClose.addEventListener('click', closeModal);
    modalBackdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        // If lightbox is open, close lightbox first
        if (!lightbox.classList.contains('hidden')) {
          closeLightbox();
        } else {
          closeModal();
        }
      }
    });

    // === Lightbox ===
    const lightbox = document.getElementById('model-lightbox') as HTMLDivElement;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lbCaption = document.getElementById('lightbox-caption') as HTMLParagraphElement;
    const lbPrev = document.getElementById('lightbox-prev') as HTMLButtonElement;
    const lbNext = document.getElementById('lightbox-next') as HTMLButtonElement;

    let currentImages: { src: string; alt: string }[] = [];
    let currentIdx = 0;

    function openLightbox(images: { src: string; alt: string }[], idx: number) {
      currentImages = images;
      currentIdx = idx;
      showImage();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
    }

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
    }

    function showImage() {
      const item = currentImages[currentIdx];
      if (!item) return;
      lbImg.src = item.src;
      lbImg.alt = item.alt;
      lbCaption.textContent = item.alt;
    }

    function prevImage() {
      currentIdx = (currentIdx - 1 + currentImages.length) % currentImages.length;
      showImage();
    }

    function nextImage() {
      currentIdx = (currentIdx + 1) % currentImages.length;
      showImage();
    }

    lbPrev.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
    lbNext.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });

    lightbox.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === lightbox || target === lbCaption) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'ArrowLeft') prevImage();
      if (e.key === 'ArrowRight') nextImage();
    });
  }
</script>
