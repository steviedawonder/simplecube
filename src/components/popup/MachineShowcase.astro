---
import db from '@lib/db';

// Model ID mapping: component id → DB model_id
const modelIdMap: Record<string, string> = {
  'popup-booth': 'popup',
  'module': 'module',
  'wood-edge': 'wood-edge',
  'wood-round': 'wood-round',
};

// Model → portfolio tag mapping
const modelTagMap: Record<string, string> = {
  'popup-booth': '팝업부스',
  'module': '모듈형',
  'wood-edge': '우드Edge',
  'wood-round': '우드Round',
};

// Fetch model photos from DB
let modelPhotosMap: Record<string, { src: string; alt: string }[]> = {};
try {
  const result = await db.execute('SELECT * FROM model_photos ORDER BY sort_order ASC, id DESC');
  const photos = result.rows as any[];
  for (const p of photos) {
    if (!modelPhotosMap[p.model_id]) modelPhotosMap[p.model_id] = [];
    modelPhotosMap[p.model_id].push({
      src: p.image_url,
      alt: `모델 사진 ${p.id}`,
    });
  }
} catch { /* table may not exist yet */ }

// Fetch related portfolio for each model (max 6, filtered by model tag)
let modelPortfolioMap: Record<string, { src: string; alt: string }[]> = {};
try {
  for (const [componentId, tag] of Object.entries(modelTagMap)) {
    const result = await db.execute({
      sql: "SELECT image_url, title FROM portfolio WHERE visible = 1 AND page_tag = 'popup' AND (',' || tags || ',') LIKE ? ORDER BY sort_order ASC, created_at DESC LIMIT 6",
      args: [`%,${tag},%`],
    });
    if (result.rows.length > 0) {
      modelPortfolioMap[componentId] = (result.rows as any[]).map(r => ({
        src: r.image_url,
        alt: r.title || `${tag} 포트폴리오`,
      }));
    }
  }
} catch { /* table may not exist yet */ }

const models = [
