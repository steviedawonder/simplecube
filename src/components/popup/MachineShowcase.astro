---

<section id="machines" class="bg-white py-12 lg:py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section heading -->
    <div class="mb-6 lg:mb-10">
      <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">01</div>
      <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">MODELS</span>
      <h2 class="mt-3 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">모델 소개</h2>
      <p class="mt-2 text-sm text-secondary">
        행사 목적과 공간에 맞는 최적의 기기를 선택하세요.
      </p>
    </div>

    <!-- ===== Model Grid: 모바일 2x2, 데스크탑 4열 ===== -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-5">
      {models.map((model) => (
        <button
          class="model-card group relative flex flex-col rounded-xl lg:rounded-2xl border border-border-light bg-white overflow-hidden transition-all duration-300 hover:border-olive/40 hover:shadow-lg text-left"
          data-model-id={model.id}
        >
          {/* Badge */}
          {model.badge && (
            <span class:list={[
              'absolute top-2 right-2 lg:top-3 lg:right-3 text-white text-[9px] lg:text-[10px] font-bold px-2 lg:px-3 py-1 rounded-full z-10',
              model.badgeColor,
            ]}>
              {model.badge}
            </span>
          )}

          {/* Image — big and prominent */}
          <div class="flex items-center justify-center bg-[#f5f5f3] p-4 lg:p-5 aspect-[2/3] lg:aspect-auto lg:h-[420px]">
            <img
              src={model.image}
              alt={model.name}
              class="h-full w-auto object-contain transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          {/* Name only */}
          <div class="px-3 py-2.5 lg:px-4 lg:py-3 text-center">
            <h3 class="text-sm lg:text-base font-bold text-primary">{model.name}</h3>
          </div>

          {/* Hover indicator */}
          <div class="absolute inset-0 flex items-center justify-center bg-black/0 group-hover:bg-black/5 transition-colors duration-300 pointer-events-none">
            <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white/90 rounded-full px-4 py-2 shadow-lg">
              <span class="text-xs font-semibold text-primary">자세히 보기</span>
            </div>
          </div>
        </button>
      ))}
    </div>

    <!-- Common specs -->
    <div class="mt-8 lg:mt-10 grid grid-cols-4 divide-x divide-border-light text-center py-4 border-t border-border-light">
      <div class="px-2">
        <p class="text-[10px] lg:text-[11px] text-secondary/60 mb-0.5">촬영</p>
        <p class="text-[11px] lg:text-xs font-bold text-primary leading-tight">DSLR<br/>WEBCAM</p>
      </div>
      <div class="px-2">
        <p class="text-[10px] lg:text-[11px] text-secondary/60 mb-0.5">출력</p>
        <p class="text-[11px] lg:text-xs font-bold text-primary leading-tight">즉석<br/>프린터</p>
      </div>
      <div class="px-2">
        <p class="text-[10px] lg:text-[11px] text-secondary/60 mb-0.5">속도</p>
        <p class="text-[11px] lg:text-xs font-bold text-primary leading-tight">약 8초</p>
      </div>
      <div class="px-2">
        <p class="text-[10px] lg:text-[11px] text-secondary/60 mb-0.5">공유</p>
        <p class="text-[11px] lg:text-xs font-bold text-primary leading-tight">QR<br/>다운로드</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== Detail Modal: 센터 팝업 (컴팩트) ===== -->
<div id="model-modal" class="fixed inset-0 z-[9998] hidden" style="pointer-events:none;">
  {/* Backdrop */}
  <div id="modal-backdrop" class="absolute inset-0 bg-black/0 transition-all duration-400" style="pointer-events:auto;"></div>

  {/* Centered card */}
  <div class="relative z-10 h-full flex items-center justify-center px-4 lg:px-6" style="pointer-events:none;">
    <div id="modal-card" class="w-full max-w-sm lg:max-w-md bg-white rounded-2xl overflow-hidden shadow-2xl opacity-0 scale-90 transition-all duration-400 ease-out max-h-[88vh] flex flex-col" style="pointer-events:auto;">
      {/* Image + close */}
      <div class="relative flex items-center justify-center bg-[#f5f5f3] p-6 shrink-0">
        <img id="modal-img" src="" alt="" class="h-[160px] lg:h-[220px] w-auto object-contain" />
        <button id="modal-close" class="absolute top-3 right-3 p-1.5 rounded-full bg-white/80 hover:bg-white transition-colors shadow-sm" style="pointer-events:auto;cursor:pointer;" aria-label="닫기">
          <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>

      {/* Scrollable content */}
      <div id="modal-body" class="overflow-y-auto flex-1"></div>
    </div>
  </div>
</div>

<!-- ===== Lightbox ===== -->
<div id="model-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
  <button id="lightbox-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button id="lightbox-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
  <p id="lightbox-caption" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/70 text-sm"></p>
</div>

<!-- Pass data to script -->
<script is:inline define:vars={{ models: JSON.parse(JSON.stringify(models)), modelPhotosMap: JSON.parse(JSON.stringify(modelPhotosMap)), modelIdMap: JSON.parse(JSON.stringify(modelIdMap)), modelPortfolioMap: JSON.parse(JSON.stringify(modelPortfolioMap)) }}>
  // Merge DB model photos + DB portfolio into models
  window.__models = models.map(function(m) {
    var dbModelId = modelIdMap[m.id] || m.id;
    var dbPhotos = modelPhotosMap[dbModelId];
    if (dbPhotos && dbPhotos.length > 0) {
      m.modelPhotos = dbPhotos;
    } else {
      m.modelPhotos = [];
    }
    // DB portfolio takes priority over hardcoded
    var dbPortfolio = modelPortfolioMap[m.id];
    if (dbPortfolio && dbPortfolio.length > 0) {
      m.portfolio = dbPortfolio;
    }
    return m;
  });
</script>

<script>
  {
    const modelsData = (window as any).__models;
    const modal = document.getElementById('model-modal') as HTMLDivElement;
    const modalBackdrop = document.getElementById('modal-backdrop') as HTMLDivElement;
    const modalCard = document.getElementById('modal-card') as HTMLDivElement;
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const modalBody = document.getElementById('modal-body') as HTMLDivElement;
    const modalClose = document.getElementById('modal-close') as HTMLButtonElement;
    const cards = document.querySelectorAll<HTMLButtonElement>('.model-card');

    // === Open modal ===
    function openModal(modelId: string) {
      const model = modelsData.find((m: any) => m.id === modelId);
      if (!model) return;

      // Set image - hide main image if model photos slider will be shown
      const imgContainer = modalImg.parentElement as HTMLDivElement;
      const hasSlider = model.modelPhotos && model.modelPhotos.length > 0;
      if (hasSlider) {
        imgContainer.style.display = 'none';
      } else {
        imgContainer.style.display = '';
        modalImg.src = model.image;
        modalImg.alt = model.name;
      }

      // Build scrollable content
      const hasModelPhotos = model.modelPhotos && model.modelPhotos.length > 0;
      modalBody.innerHTML = `
        ${hasModelPhotos ? `
        <!-- Model Photos Slider -->
        <div class="relative">
          <div id="modal-slider" class="overflow-hidden">
            <div id="modal-slider-track" class="flex transition-transform duration-300">
              ${model.modelPhotos.map((p: any) => `
                <div class="w-full shrink-0">
                  <img src="${p.src}" alt="${p.alt}" class="w-full aspect-[2/3] object-contain bg-[#f5f5f3] cursor-pointer model-photo-click" data-src="${p.src}" data-alt="${p.alt}" loading="lazy" />
                </div>
              `).join('')}
            </div>
          </div>
          ${model.modelPhotos.length > 1 ? `
          <button class="slider-prev absolute left-2 top-1/2 -translate-y-1/2 w-7 h-7 bg-black/30 hover:bg-black/50 text-white rounded-full flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button class="slider-next absolute right-2 top-1/2 -translate-y-1/2 w-7 h-7 bg-black/30 hover:bg-black/50 text-white rounded-full flex items-center justify-center transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
          <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1.5">
            ${model.modelPhotos.map((_: any, i: number) => `<span class="slider-dot w-1.5 h-1.5 rounded-full ${i === 0 ? 'bg-white' : 'bg-white/40'} transition-colors"></span>`).join('')}
          </div>
          ` : ''}
        </div>
        ` : ''}

        <!-- Specs -->
        <div class="px-5 py-5">
          <h4 class="text-lg font-bold text-primary mb-4">${model.name}</h4>

          ${model.specs.map((s: any, i: number) => `
            <div class="flex items-baseline justify-between py-2.5 ${i < model.specs.length - 1 ? 'border-b border-dashed border-[#e5e5e3]' : ''}">
              <span class="text-[12px] text-[#888]">${s.label}</span>
              <span class="text-[13px] font-semibold text-[#1d1d1f]">${s.value}</span>
            </div>
          `).join('')}

          ${model.note ? `<p class="mt-3 text-[10px] text-[#999] text-right">${model.note}</p>` : ''}
        </div>

        <!-- Portfolio -->
        ${model.portfolio.length > 0 ? `
        <div class="px-5 pb-5 pt-1">
          <div class="flex items-center justify-between mb-3">
            <h4 class="text-xs font-bold text-[#1d1d1f] tracking-wide uppercase">Portfolio</h4>
            <span class="text-[10px] text-[#999]">${model.portfolio.length}건</span>
          </div>
          <div class="grid grid-cols-3 gap-1.5">
            ${model.portfolio.map((p: any) => `
              <div class="modal-portfolio-thumb cursor-pointer overflow-hidden rounded-lg relative group" data-src="${p.src}" data-alt="${p.alt}">
                <img src="${p.src}" alt="${p.alt}" class="aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
                  </svg>
                </div>
              </div>
            `).join('')}
          </div>
        </div>
        ` : ''}
      `;

      // Bind portfolio thumb clicks
      const thumbs = modalBody.querySelectorAll<HTMLDivElement>('.modal-portfolio-thumb');
      const images = Array.from(thumbs).map(t => ({
        src: t.dataset.src || '',
        alt: t.dataset.alt || '',
      }));
      thumbs.forEach((thumb, idx) => {
        thumb.addEventListener('click', () => openLightbox(images, idx));
      });

      // Slider logic for model photos
      const sliderTrack = modalBody.querySelector('#modal-slider-track') as HTMLDivElement | null;
      if (sliderTrack && model.modelPhotos && model.modelPhotos.length > 1) {
        let slideIdx = 0;
        const total = model.modelPhotos.length;
        const dots = modalBody.querySelectorAll('.slider-dot');
        const updateSlider = () => {
          sliderTrack.style.transform = `translateX(-${slideIdx * 100}%)`;
          dots.forEach((d: Element, i: number) => {
            (d as HTMLElement).classList.toggle('bg-white', i === slideIdx);
            (d as HTMLElement).classList.toggle('bg-white/40', i !== slideIdx);
          });
        };
        modalBody.querySelector('.slider-prev')?.addEventListener('click', () => {
          slideIdx = (slideIdx - 1 + total) % total;
          updateSlider();
        });
        modalBody.querySelector('.slider-next')?.addEventListener('click', () => {
          slideIdx = (slideIdx + 1) % total;
          updateSlider();
        });

        // Model photo click → lightbox
        modalBody.querySelectorAll('.model-photo-click').forEach((img, i) => {
          img.addEventListener('click', (e) => {
            e.stopPropagation();
            const images = model.modelPhotos.map((p: any) => ({ src: p.src, alt: p.alt }));
            openLightbox(images, i);
          });
        });
      }

      // Show modal with animation
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        modalBackdrop.classList.replace('bg-black/0', 'bg-black/40');
        modalCard.classList.remove('opacity-0', 'scale-90');
        modalCard.classList.add('opacity-100', 'scale-100');
      });
    }

    function closeModal() {
      if (modal.classList.contains('hidden')) return;
      modalBackdrop.classList.replace('bg-black/40', 'bg-black/0');
      modalCard.classList.remove('opacity-100', 'scale-100');
      modalCard.classList.add('opacity-0', 'scale-90');
      setTimeout(() => {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }, 400);
    }

    // Card clicks
    cards.forEach(card => {
      card.addEventListener('click', () => {
        const id = card.dataset.modelId;
        if (id) openModal(id);
      });
    });

    // Close triggers
    modalClose.addEventListener('click', (e) => { e.stopPropagation(); e.preventDefault(); closeModal(); });
    modalBackdrop.addEventListener('click', (e) => { if (e.target === modalBackdrop) closeModal(); });
    modalCard.addEventListener('click', (e) => { e.stopPropagation(); });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        // If lightbox is open, close lightbox first
        if (!lightbox.classList.contains('hidden')) {
          closeLightbox();
        } else {
          closeModal();
        }
      }
    });

    // === Lightbox ===
    const lightbox = document.getElementById('model-lightbox') as HTMLDivElement;
    const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lbCaption = document.getElementById('lightbox-caption') as HTMLParagraphElement;
    const lbPrev = document.getElementById('lightbox-prev') as HTMLButtonElement;
    const lbNext = document.getElementById('lightbox-next') as HTMLButtonElement;

    let currentImages: { src: string; alt: string }[] = [];
    let currentIdx = 0;

    function openLightbox(images: { src: string; alt: string }[], idx: number) {
      currentImages = images;
      currentIdx = idx;
      showImage();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
    }

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
    }

    function showImage() {
      const item = currentImages[currentIdx];
      if (!item) return;
      lbImg.src = item.src;
      lbImg.alt = item.alt;
      lbCaption.textContent = item.alt;
    }

    function prevImage() {
      currentIdx = (currentIdx - 1 + currentImages.length) % currentImages.length;
      showImage();
    }

    function nextImage() {
      currentIdx = (currentIdx + 1) % currentImages.length;
      showImage();
    }

    lbPrev.addEventListener('click', (e) => { e.stopPropagation(); prevImage(); });
    lbNext.addEventListener('click', (e) => { e.stopPropagation(); nextImage(); });

    lightbox.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === lightbox || target === lbCaption) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'ArrowLeft') prevImage();
      if (e.key === 'ArrowRight') nextImage();
    });
  }
</script>
