---

<section class="bg-white py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">CLIENTS</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">고객사</h2>
      <p class="mt-4 text-sm text-secondary">다양한 브랜드와 함께했습니다.</p>
    </div>

    <div class="gs-stagger grid grid-cols-3 gap-4 md:grid-cols-4 lg:grid-cols-6">
      {clients.map((client) => (
        <div class="flex h-20 items-center justify-center rounded-lg border border-border-light bg-bg-light px-4 transition-all duration-300 hover:border-olive/40 hover:shadow-sm md:h-24">
          <img
            src={client.src}
            alt={client.name}
            class={`max-w-full object-contain opacity-70 transition-opacity duration-300 hover:opacity-100 ${client.lg ? 'max-h-14 md:max-h-16' : 'max-h-10 md:max-h-12'}`}
            loading="lazy"
            style="mix-blend-mode: multiply;"
          />
        </div>
      ))}
    </div>
  </div>
</section>
