  { name: 'BMW', src: '/images/logos/BMW.png' },
  { name: 'Nike', src: '/images/logos/%EB%82%98%EC%9D%B4%ED%82%A4%20NIKE.png' },
  { name: 'Adidas', src: '/images/logos/%EC%95%84%EB%94%94%EB%8B%A4%EC%8A%A4%20ADIDAS.png', lg: true },
