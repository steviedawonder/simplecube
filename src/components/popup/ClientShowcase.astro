  { name: '우리은행', src: '/images/logos/%EC%9A%B0%EB%A6%AC%EC%9D%80%ED%96%89.png' },

  { name: '유모멘트 더채플', src: '/images/logos/%EC%9C%A0%EB%AA%A8%EB%A9%98%ED%8A%B8_%EB%8D%94%EC%B1%84%ED%94%8C.png' },
  { name: '아난티', src: '/images/logos/%EC%95%84%EB%82%9C%ED%8B%B0.svg' },
  { name: '파타고니아', src: '/images/logos/%ED%8C%8C%ED%83%80%EA%B3%A0%EB%8B%88%EC%95%84.png' },
  { name: '하이브', src: '/images/logos/%ED%95%98%EC%9D%B4%EB%B8%8C.png' },
  { name: 'SM엔터테인먼트', src: '/images/logos/SM%EC%97%94%ED%84%B0%ED%85%8C%EC%9D%B8%EB%A8%BC%ED%8A%B8.png' },
