  { name: '현대카드', src: '/images/logos/%ED%98%84%EB%8C%80%EC%B9%B4%EB%93%9C.png' },
  { name: '스와로브스키', src: '/images/logos/%EC%8A%A4%EC%99%80%EB%A1%9C%EB%B8%8C%EC%8A%A4%ED%82%A4.png' },
