---

<section id="custom" class="bg-white py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">CUSTOMIZATION</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">커스텀 범위</h2>
      <p class="mt-4 text-sm text-secondary max-w-xl">
        기기 외관부터 UI 화면, 촬영 배경까지.<br />
        브랜드에 맞춘 자유로운 커스텀이 가능합니다.
      </p>
    </div>

    <div class="gs-stagger grid gap-3 grid-cols-2 md:grid-cols-4 md:gap-4">
      {options.map((option, i) => (
        <button
          type="button"
          data-custom-idx={i}
          class="custom-card group cursor-pointer rounded-xl border border-border-light bg-bg-light p-4 md:p-6 transition-all duration-300 hover:border-olive/40 hover:bg-white hover:shadow-lg text-center"
        >
          <div class="flex flex-col items-center gap-2 md:gap-3">
            <div class="flex h-10 w-10 md:h-12 md:w-12 shrink-0 items-center justify-center rounded-xl bg-olive/10 text-olive transition-colors duration-300 group-hover:bg-olive group-hover:text-white">
              <Fragment set:html={option.icon} />
            </div>
            <h3 class="text-sm md:text-base font-bold text-primary">{option.title}</h3>
            <span class="text-[10px] md:text-xs text-olive/70 bg-olive/5 px-2 md:px-3 py-0.5 md:py-1 rounded-full leading-tight">
              {option.note}
            </span>
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<!-- Modal -->
<div id="customModal" class="fixed inset-0 z-50 flex items-center justify-center" style="display:none">
  <div class="custom-modal-backdrop absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
  <div class="custom-modal-content relative mx-4 w-full max-w-md rounded-2xl bg-white p-6 md:p-8 shadow-2xl transform scale-95 opacity-0 transition-all duration-300">
    <button type="button" id="customModalClose" class="absolute top-4 right-4 text-secondary/40 hover:text-primary transition-colors">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <div class="flex items-center gap-3 mb-4">
      <div id="customModalIcon" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-olive text-white"></div>
      <h3 id="customModalTitle" class="text-lg font-bold text-primary"></h3>
    </div>
    <p id="customModalDesc" class="text-sm leading-relaxed text-secondary"></p>
    <div class="mt-4 flex items-center gap-2">
      <svg class="h-4 w-4 text-olive/60 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>
      <span id="customModalNote" class="text-xs text-olive/70"></span>
    </div>
  </div>
</div>

<script define:vars={{ options }}>
  const cards = document.querySelectorAll('.custom-card');
  const modal = document.getElementById('customModal');
  const modalIcon = document.getElementById('customModalIcon');
  const modalTitle = document.getElementById('customModalTitle');
  const modalDesc = document.getElementById('customModalDesc');
  const modalNote = document.getElementById('customModalNote');
  const modalClose = document.getElementById('customModalClose');
  const modalBackdrop = modal.querySelector('.custom-modal-backdrop');
  const modalContent = modal.querySelector('.custom-modal-content');

  function openModal(idx) {
    const opt = options[idx];
    modalIcon.innerHTML = opt.icon;
    modalTitle.textContent = opt.title;
    modalDesc.textContent = opt.desc;
    modalNote.textContent = opt.note;
    modal.style.display = 'flex';
    requestAnimationFrame(() => {
      modalContent.classList.remove('scale-95', 'opacity-0');
      modalContent.classList.add('scale-100', 'opacity-100');
    });
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modalContent.classList.remove('scale-100', 'opacity-100');
    modalContent.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }, 200);
  }

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const idx = parseInt(card.dataset.customIdx);
      openModal(idx);
    });
  });

  modalClose.addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
  });
</script>
