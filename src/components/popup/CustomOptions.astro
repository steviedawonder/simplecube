        <div class="pt-2 border-t border-border-light">
          <p class="text-xs text-secondary/70 leading-relaxed">
            ※ 인화지 영역이 제한적이므로 문구는 짧고 직관적으로 구성하는 것이 좋습니다.<br />
            ※ 레이아웃과 인화지 종류는 행사 목적에 따라 추천 가능합니다.
          </p>
        </div>
      </div>`,
  },
];
---

<section id="custom" class="bg-white py-10 lg:py-14">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8 lg:mb-12">
      <div class="inline-flex items-center justify-center w-9 h-9 rounded-full border-[1.5px] border-olive text-olive text-[13px] font-bold mb-4">03</div>
      <span class="block text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">CUSTOMIZATION</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">커스텀 범위</h2>
      <p class="mt-4 text-sm text-secondary max-w-xl">
        기기 외관부터 UI 화면, 촬영 배경까지.<br />
        브랜드에 맞춘 자유로운 커스텀이 가능합니다.
      </p>
    </div>

    <!-- Main layout: Left menu + Right content -->
    <div class="flex flex-col lg:flex-row gap-5 lg:gap-8">

      <!-- Left: Vertical menu -->
      <div class="lg:w-[220px] shrink-0">
        <!-- Mobile: horizontal -->
        <div class="flex lg:hidden gap-2 overflow-x-auto pb-3 scrollbar-hide">
          {menus.map((menu, i) => (
            <button
              type="button"
              class:list={[
                'custom-menu-btn shrink-0 cursor-pointer rounded-lg px-4 py-3 transition-all duration-300 text-center min-w-[110px]',
                i === 0
                  ? 'bg-primary text-white shadow-md is-active'
                  : 'bg-bg-light text-secondary hover:bg-primary/5',
              ]}
              data-menu-id={menu.id}
            >
              <div class="flex flex-col items-center gap-1.5">
                <div class:list={[
                  'flex h-8 w-8 shrink-0 items-center justify-center rounded-lg transition-colors duration-300',
                  i === 0 ? 'bg-white/20 text-white' : 'bg-olive/10 text-olive',
                ]}>
                  <Fragment set:html={menu.icon} />
                </div>
                <h3 class="text-xs font-bold whitespace-nowrap">{menu.title}</h3>
              </div>
            </button>
          ))}
        </div>

        <!-- Desktop: vertical tabs -->
        <div class="hidden lg:flex flex-col gap-1.5 sticky top-24">
          {menus.map((menu, i) => (
            <button
              type="button"
              class:list={[
                'custom-menu-btn group w-full cursor-pointer rounded-xl px-5 py-4 transition-all duration-300 text-left relative overflow-hidden',
                i === 0
                  ? 'bg-primary text-white shadow-md is-active'
                  : 'bg-bg-light text-secondary hover:bg-white hover:shadow-sm',
              ]}
              data-menu-id={menu.id}
            >
              <div class="flex items-center gap-3">
                <div class:list={[
                  'flex h-9 w-9 shrink-0 items-center justify-center rounded-lg transition-colors duration-300',
                  i === 0 ? 'bg-white/20 text-white' : 'bg-olive/10 text-olive group-hover:bg-olive group-hover:text-white',
                ]}>
                  <Fragment set:html={menu.icon} />
                </div>
                <h3 class:list={[
                  'text-sm font-bold transition-colors',
                  i === 0 ? 'text-white' : 'text-primary',
                ]}>{menu.title}</h3>
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- Right: Content area -->
      <div class="flex-1 min-w-0">
        {menus.map((menu, i) => (
          <div
            class:list={[
              'custom-panel',
              i === 0 ? '' : 'hidden',
            ]}
            data-panel-id={menu.id}
          >
            <!-- Title bar -->
            <div class="flex items-center gap-3 mb-6">
              <div class="w-1 h-7 rounded-full bg-olive"></div>
              <h3 class="text-lg md:text-xl font-bold text-primary">{menu.title}</h3>
            </div>

            <!-- Description -->
            <div class="bg-white rounded-2xl border border-border-light/60 shadow-sm p-6 md:p-8 mb-5">
              {menu.descHtml ? (
                <Fragment set:html={menu.descHtml} />
              ) : (
                <p class="text-sm text-secondary leading-relaxed">{menu.desc}</p>
              )}
            </div>

            <!-- Portfolio photos -->
            <div class="bg-white rounded-2xl border border-border-light/60 shadow-sm p-6 md:p-8">
              <h4 class="text-sm font-bold text-primary mb-4 flex items-center gap-2">
                <svg class="w-4 h-4 text-olive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v13.5A1.5 1.5 0 003.75 21z" /></svg>
                포트폴리오
              </h4>
              <div class="custom-portfolio-area" data-tag={menu.tag}>
                <div class="custom-pf-grid grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3"></div>
                <div class="custom-pf-loading text-center py-6">
                  <p class="text-secondary text-xs">불러오는 중...</p>
                </div>
                <div class="custom-pf-empty hidden text-center py-6">
                  <p class="text-secondary/60 text-xs">등록된 사진이 없습니다.</p>
                </div>
                <div class="custom-pf-more hidden mt-4 text-center">
                  <button class="custom-more-btn text-xs font-medium text-olive hover:text-primary transition-colors">
                    더보기 →
                  </button>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Custom Lightbox -->
<div id="custom-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
  <button id="custom-lb-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
  </button>
  <button id="custom-lb-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
  </button>
  <button id="custom-lb-close" class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors" aria-label="닫기">
    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>
  <img id="custom-lb-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
</div>

<script>
{
  const menuBtns = document.querySelectorAll<HTMLButtonElement>('.custom-menu-btn');
  const panels = document.querySelectorAll<HTMLDivElement>('.custom-panel');
  const loadedPanels = new Set<string>();

  function activateMenu(menuId: string) {
    // Update buttons
    menuBtns.forEach(b => {
      const isActive = b.dataset.menuId === menuId;
      if (isActive) {
        b.classList.remove('bg-bg-light', 'text-secondary', 'hover:bg-white', 'hover:shadow-sm');
        b.classList.add('bg-primary', 'text-white', 'shadow-md', 'is-active');
      } else {
        b.classList.remove('bg-primary', 'text-white', 'shadow-md', 'is-active');
        b.classList.add('bg-bg-light', 'text-secondary', 'hover:bg-white', 'hover:shadow-sm');
      }

      // Update icon
      const iconDiv = b.querySelector('[class*="h-9"][class*="w-9"], [class*="h-8"][class*="w-8"]') as HTMLElement;
      if (iconDiv) {
        if (isActive) {
          iconDiv.className = iconDiv.className.replace('bg-olive/10', 'bg-white/20').replace('text-olive', 'text-white');
        } else {
          iconDiv.className = iconDiv.className.replace('bg-white/20', 'bg-olive/10').replace('text-white', 'text-olive');
        }
      }

      // Update title color
      const title = b.querySelector('h3');
      if (title) {
        if (isActive) {
          title.classList.remove('text-primary');
          title.classList.add('text-white');
        } else {
          title.classList.remove('text-white');
          title.classList.add('text-primary');
        }
      }
    });

    // Show panel
    panels.forEach(p => {
      p.classList.toggle('hidden', p.dataset.panelId !== menuId);
    });

    // Load portfolio if needed
    if (!loadedPanels.has(menuId)) {
      const panel = document.querySelector(`[data-panel-id="${menuId}"]`) as HTMLElement;
      if (panel) {
        loadPanelPortfolio(panel);
        loadedPanels.add(menuId);
      }
    }
  }

  // Click handlers - use event delegation on section
  document.getElementById('custom')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.custom-menu-btn') as HTMLElement | null;
    if (btn && btn.dataset.menuId) {
      activateMenu(btn.dataset.menuId);
    }
  });

  // Load first panel on page load
  activateMenu('wrapping');

  async function loadPanelPortfolio(panel: HTMLElement) {
    const area = panel.querySelector('.custom-portfolio-area') as HTMLElement | null;
    if (!area) return;

    const tag = area.dataset.tag;
    if (!tag) return;

    const grid = area.querySelector('.custom-pf-grid') as HTMLElement;
    const loading = area.querySelector('.custom-pf-loading') as HTMLElement;
    const empty = area.querySelector('.custom-pf-empty') as HTMLElement;
    const moreWrap = area.querySelector('.custom-pf-more') as HTMLElement;

    try {
      const res = await fetch(`/api/portfolio?page_tag=popup&tags=${encodeURIComponent(tag)}`);
      const items: any[] = await res.json();
      loading.classList.add('hidden');

      if (items.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      const maxShow = 8;
      const showItems = items.slice(0, maxShow);

      grid.innerHTML = showItems.map((item: any) => `
        <div class="custom-pf-thumb group cursor-pointer overflow-hidden rounded-lg relative" data-url="${item.image_url}" data-title="${item.title || ''}">
          <img
            src="${item.image_url}"
            alt="${item.title || ''}"
            class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
            <svg class="w-5 h-5 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
            </svg>
          </div>
        </div>
      `).join('');

      if (items.length > maxShow) {
        moreWrap.classList.remove('hidden');
        const moreBtn = moreWrap.querySelector('.custom-more-btn') as HTMLButtonElement;
        moreBtn.addEventListener('click', () => {
          const pfSection = document.getElementById('portfolio');
          if (pfSection) {
            pfSection.scrollIntoView({ behavior: 'smooth' });
            setTimeout(() => {
              const tagBtns = pfSection.querySelectorAll('.pf-tag-btn');
              tagBtns.forEach(b => {
                if ((b as HTMLElement).dataset.tag === tag) {
                  (b as HTMLElement).click();
                }
              });
            }, 500);
          }
        });
      }

      bindCustomLightbox(grid);
    } catch {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  // Lightbox
  const lightbox = document.getElementById('custom-lightbox')!;
  const lbImg = document.getElementById('custom-lb-img') as HTMLImageElement;
  let lbImages: { url: string; title: string }[] = [];
  let lbIdx = 0;

  function bindCustomLightbox(grid: HTMLElement) {
    const thumbs = grid.querySelectorAll('.custom-pf-thumb');
    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => {
        lbImages = Array.from(grid.querySelectorAll('.custom-pf-thumb')).map(t => ({
          url: (t as HTMLElement).dataset.url || '',
          title: (t as HTMLElement).dataset.title || '',
        }));
        lbIdx = i;
        showLb();
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });
  }

  function showLb() {
    const item = lbImages[lbIdx];
    if (!item) return;
    lbImg.src = item.url;
    lbImg.alt = item.title;
  }

  function closeLb() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.getElementById('custom-lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); lbIdx = (lbIdx - 1 + lbImages.length) % lbImages.length; showLb(); });
  document.getElementById('custom-lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); lbIdx = (lbIdx + 1) % lbImages.length; showLb(); });
  document.getElementById('custom-lb-close')!.addEventListener('click', closeLb);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLb(); });
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') { lbIdx = (lbIdx - 1 + lbImages.length) % lbImages.length; showLb(); }
    if (e.key === 'ArrowRight') { lbIdx = (lbIdx + 1) % lbImages.length; showLb(); }
  });
}
</script>
