---
import db from '@lib/db';

// Load custom descriptions and tag mappings from DB
let customData: Record<string, string> = {
  desc_wrapping: '브랜드 아이덴티티를 담은 외관 래핑으로 특별한 포토부스를 만들어보세요.',
  desc_main: '메인 화면을 브랜드에 맞게 커스터마이징할 수 있습니다.',
  desc_backdrop: '다양한 백드롭과 백월로 공간을 연출합니다.',
  desc_paper: '다양한 인화지 옵션으로 특별한 사진을 완성합니다.',
  tag_wrapping: '랩핑',
  tag_main: '메인화면',
  tag_backdrop: '배경',
};

try {
  const result = await db.execute({
    sql: "SELECT key, value FROM page_contents WHERE page = 'popup' AND section = 'custom'",
    args: [],
  });
  for (const row of result.rows as any[]) {
    customData[row.key] = row.value;
  }
} catch { /* use defaults */ }

const menus = [
  {
    id: 'wrapping',
    title: '외관 랩핑',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" /></svg>`,
    desc: customData.desc_wrapping,
    tag: customData.tag_wrapping,
    hasPortfolio: true,
  },
  {
    id: 'main',
    title: '메인화면 커스텀',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" /></svg>`,
    desc: customData.desc_main,
    tag: customData.tag_main,
    hasPortfolio: true,
  },
  {
    id: 'backdrop',
    title: '백드롭·백월',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" /></svg>`,
    desc: customData.desc_backdrop,
    tag: customData.tag_backdrop,
    hasPortfolio: true,
  },
  {
    id: 'paper',
    title: '인화지',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18.75 12h.008v.008h-.008V12zm-2.25 0h.008v.008H16.5V12z" /></svg>`,
    desc: customData.desc_paper,
    tag: '',
    hasPortfolio: false,
  },
];
---

<section id="custom" class="bg-white py-14 lg:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mb-8 lg:mb-10">
      <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">CUSTOMIZATION</span>
      <h2 class="mt-5 text-[clamp(1.75rem,3vw,2.8rem)] font-bold text-primary">커스텀 범위</h2>
      <p class="mt-4 text-sm text-secondary max-w-xl">
        기기 외관부터 UI 화면, 촬영 배경까지.<br />
        브랜드에 맞춘 자유로운 커스텀이 가능합니다.
      </p>
    </div>

    <!-- Menu buttons -->
    <div class="gs-stagger grid gap-3 grid-cols-2 md:grid-cols-4 md:gap-4">
      {menus.map((menu) => (
        <button
          type="button"
          class="custom-menu-btn group cursor-pointer rounded-xl border border-border-light bg-bg-light p-4 md:p-5 transition-all duration-300 hover:border-olive/40 hover:bg-white hover:shadow-lg text-center"
          data-menu-id={menu.id}
        >
          <div class="flex flex-col items-center gap-2">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-olive/10 text-olive transition-colors duration-300 group-hover:bg-olive group-hover:text-white">
              <Fragment set:html={menu.icon} />
            </div>
            <h3 class="text-sm md:text-base font-bold text-primary">{menu.title}</h3>
          </div>
        </button>
      ))}
    </div>

    <!-- Accordion panels -->
    {menus.map((menu) => (
      <div class="custom-panel hidden mt-6" data-panel-id={menu.id}>
        <div class="rounded-2xl border border-border-light bg-bg-light p-5 md:p-8">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-olive text-white">
                <Fragment set:html={menu.icon} />
              </div>
              <h3 class="text-base md:text-lg font-bold text-primary">{menu.title}</h3>
            </div>
            <button class="custom-panel-close p-1.5 rounded-full hover:bg-white transition-colors" aria-label="닫기">
              <svg class="w-4 h-4 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <p class="text-sm text-secondary leading-relaxed mb-5">{menu.desc}</p>

          {menu.hasPortfolio && (
            <div class="custom-portfolio-area" data-tag={menu.tag}>
              <div class="custom-pf-grid grid grid-cols-2 md:grid-cols-4 gap-2"></div>
              <div class="custom-pf-loading text-center py-6">
                <p class="text-secondary text-xs">불러오는 중...</p>
              </div>
              <div class="custom-pf-empty hidden text-center py-6">
                <p class="text-secondary text-xs">등록된 사진이 없습니다.</p>
              </div>
              <div class="custom-pf-more hidden mt-4 text-center">
                <button class="custom-more-btn text-xs font-medium text-olive hover:text-primary transition-colors">
                  더보기 →
                </button>
              </div>
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<!-- Custom Lightbox -->
<div id="custom-lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/80 backdrop-blur-sm">
  <button id="custom-lb-prev" class="absolute left-3 lg:left-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="이전">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
  </button>
  <button id="custom-lb-next" class="absolute right-3 lg:right-4 top-1/2 -translate-y-1/2 z-10 text-white/60 hover:text-white transition-colors" aria-label="다음">
    <svg class="w-8 lg:w-10 h-8 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
  </button>
  <button id="custom-lb-close" class="absolute top-4 right-4 z-10 text-white/60 hover:text-white transition-colors" aria-label="닫기">
    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
  </button>
  <img id="custom-lb-img" src="" alt="" class="max-h-[85vh] max-w-[90vw] object-contain rounded-lg shadow-2xl" />
</div>

<script>
{
  const menuBtns = document.querySelectorAll<HTMLButtonElement>('.custom-menu-btn');
  const panels = document.querySelectorAll<HTMLDivElement>('.custom-panel');
  let activePanel: string | null = null;
  const loadedPanels = new Set<string>();

  // Toggle accordion
  menuBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const menuId = btn.dataset.menuId!;

      if (activePanel === menuId) {
        // Close
        panels.forEach(p => p.classList.add('hidden'));
        menuBtns.forEach(b => {
          b.classList.remove('border-olive', 'bg-white', 'shadow-lg');
          b.classList.add('border-border-light', 'bg-bg-light');
        });
        activePanel = null;
        return;
      }

      // Open
      panels.forEach(p => p.classList.add('hidden'));
      menuBtns.forEach(b => {
        b.classList.remove('border-olive', 'bg-white', 'shadow-lg');
        b.classList.add('border-border-light', 'bg-bg-light');
      });

      const panel = document.querySelector(`[data-panel-id="${menuId}"]`) as HTMLDivElement;
      panel.classList.remove('hidden');
      btn.classList.remove('border-border-light', 'bg-bg-light');
      btn.classList.add('border-olive', 'bg-white', 'shadow-lg');
      activePanel = menuId;

      // Load portfolio if not loaded
      if (!loadedPanels.has(menuId)) {
        loadPanelPortfolio(panel);
        loadedPanels.add(menuId);
      }

      // Scroll into view
      panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });

  // Close buttons
  document.querySelectorAll('.custom-panel-close').forEach(btn => {
    btn.addEventListener('click', () => {
      panels.forEach(p => p.classList.add('hidden'));
      menuBtns.forEach(b => {
        b.classList.remove('border-olive', 'bg-white', 'shadow-lg');
        b.classList.add('border-border-light', 'bg-bg-light');
      });
      activePanel = null;
    });
  });

  async function loadPanelPortfolio(panel: HTMLElement) {
    const area = panel.querySelector('.custom-portfolio-area') as HTMLElement | null;
    if (!area) return;

    const tag = area.dataset.tag;
    if (!tag) return;

    const grid = area.querySelector('.custom-pf-grid') as HTMLElement;
    const loading = area.querySelector('.custom-pf-loading') as HTMLElement;
    const empty = area.querySelector('.custom-pf-empty') as HTMLElement;
    const moreWrap = area.querySelector('.custom-pf-more') as HTMLElement;

    try {
      const res = await fetch(`/api/portfolio?page_tag=popup&tags=${encodeURIComponent(tag)}`);
      const items: any[] = await res.json();
      loading.classList.add('hidden');

      if (items.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      const maxShow = 8;
      const showItems = items.slice(0, maxShow);

      grid.innerHTML = showItems.map((item: any) => `
        <div class="custom-pf-thumb group cursor-pointer overflow-hidden rounded-lg relative" data-url="${item.image_url}" data-title="${item.title || ''}">
          <img
            src="${item.image_url}"
            alt="${item.title || ''}"
            class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
            <svg class="w-5 h-5 text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
            </svg>
          </div>
        </div>
      `).join('');

      // Show "더보기" if more items exist
      if (items.length > maxShow) {
        moreWrap.classList.remove('hidden');
        const moreBtn = moreWrap.querySelector('.custom-more-btn') as HTMLButtonElement;
        moreBtn.addEventListener('click', () => {
          // Scroll to portfolio section and activate the tag filter
          const pfSection = document.getElementById('portfolio');
          if (pfSection) {
            pfSection.scrollIntoView({ behavior: 'smooth' });
            // Activate the matching tag button
            setTimeout(() => {
              const tagBtns = pfSection.querySelectorAll('.pf-tag-btn');
              tagBtns.forEach(b => {
                if ((b as HTMLElement).dataset.tag === tag) {
                  (b as HTMLElement).click();
                }
              });
            }, 500);
          }
        });
      }

      // Lightbox for thumbs
      bindCustomLightbox(grid);
    } catch {
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  }

  // Lightbox
  const lightbox = document.getElementById('custom-lightbox')!;
  const lbImg = document.getElementById('custom-lb-img') as HTMLImageElement;
  let lbImages: { url: string; title: string }[] = [];
  let lbIdx = 0;

  function bindCustomLightbox(grid: HTMLElement) {
    const thumbs = grid.querySelectorAll('.custom-pf-thumb');
    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => {
        lbImages = Array.from(grid.querySelectorAll('.custom-pf-thumb')).map(t => ({
          url: (t as HTMLElement).dataset.url || '',
          title: (t as HTMLElement).dataset.title || '',
        }));
        lbIdx = i;
        showLb();
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });
  }

  function showLb() {
    const item = lbImages[lbIdx];
    if (!item) return;
    lbImg.src = item.url;
    lbImg.alt = item.title;
  }

  function closeLb() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.getElementById('custom-lb-prev')!.addEventListener('click', (e) => { e.stopPropagation(); lbIdx = (lbIdx - 1 + lbImages.length) % lbImages.length; showLb(); });
  document.getElementById('custom-lb-next')!.addEventListener('click', (e) => { e.stopPropagation(); lbIdx = (lbIdx + 1) % lbImages.length; showLb(); });
  document.getElementById('custom-lb-close')!.addEventListener('click', closeLb);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLb(); });
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') { lbIdx = (lbIdx - 1 + lbImages.length) % lbImages.length; showLb(); }
    if (e.key === 'ArrowRight') { lbIdx = (lbIdx + 1) % lbImages.length; showLb(); }
  });
}
</script>
