  desc_wrapping: '브랜드 아이덴티티를 담은 외관 래핑으로 특별한 포토부스를 만들어보세요. 기기 외관 전체에 브랜드 컬러와 디자인을 적용하여 행사 현장에서 눈에 띄는 포토부스를 제공합니다.',
  desc_main: '촬영 시작 전 메인 화면을 브랜드에 맞게 커스터마이징할 수 있습니다. 로고, 이벤트 문구, 브랜드 컬러 등을 반영하여 일관된 브랜드 경험을 제공합니다.',
  desc_backdrop: '촬영 배경이 되는 백드롭과 백월을 브랜드 콘셉트에 맞게 연출합니다. 다양한 소재와 디자인으로 행사의 분위기를 한층 높여줍니다.',
  desc_paper: '인화지 디자인을 브랜드에 맞게 커스텀할 수 있습니다. 로고, QR코드, 이벤트 문구 등을 넣어 특별한 기념 사진을 완성합니다.',
  tag_wrapping: '랩핑',
  tag_main: '프로그램 배경',
  tag_backdrop: '백드롭백월',
  tag_paper: '인화지',
};

try {
  const result = await db.execute({
    sql: "SELECT key, value FROM page_contents WHERE page = 'popup' AND section = 'custom'",
    args: [],
  });
  for (const row of result.rows as any[]) {
    customData[row.key] = row.value;
  }
} catch { /* use defaults */ }

