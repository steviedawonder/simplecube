---
---

<section class="relative flex min-h-[60vh] items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/main.webp"
      alt="심플큐브 포토부스"
      class="h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-[#6B5B4D]/65"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 px-6 py-20 text-center">
    <h2 class="text-[clamp(1.5rem,4vw,2.5rem)] font-bold leading-snug text-[#FFFAF4]">
      심플큐브와<br />지금 함께하세요.
    </h2>

    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-full border border-[#FFFAF4]/40 px-8 py-3.5 text-sm font-semibold tracking-wider text-[#FFFAF4] transition-all duration-300 hover:bg-[#FFFAF4] hover:text-[#2E2318]"
      >
        웨딩문의
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-full border border-[#FFFAF4]/40 px-8 py-3.5 text-sm font-semibold tracking-wider text-[#FFFAF4] transition-all duration-300 hover:bg-[#FFFAF4] hover:text-[#2E2318]"
      >
        팝업문의
      </a>
    </div>
  </div>
</section>
