---
---

<section id="hero" class="relative flex min-h-screen flex-col overflow-hidden bg-white" data-fullpage-section>
  <!-- Background Image (subtle) -->
  <div class="absolute inset-0 z-0">
    <img src="/images/hero/main.jpg" alt="" class="h-full w-full object-cover opacity-[0.08]" aria-hidden="true" loading="eager" />
  </div>

  <!-- Top spacer -->
  <div class="flex-1"></div>

  <!-- Content -->
  <div class="hero-content relative z-10 w-full px-6 pt-16 text-center md:px-16 md:pt-0 lg:px-24">
    <div class="mx-auto max-w-4xl">
      <!-- Eyebrow label -->
      <p class="mb-4 text-lg font-medium tracking-[0.3em] text-[#8B7E72] md:text-2xl md:tracking-[0.4em]">
        국내 오픈형 포토부스 대표 브랜드
      </p>

      <!-- Decorative line -->
      <div class="mx-auto mb-6 h-[1px] w-16 bg-olive/40"></div>

      <!-- Main headline -->
      <h1 class="text-[clamp(4.5rem,12vw,10rem)] leading-[0.9] text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.12em;">
        <span class="relative inline-block">
          <span class="relative z-10">심플큐브</span>
          <span class="absolute bottom-[0.1em] left-0 right-0 h-[0.35em] bg-olive/30 -z-0"></span>
        </span>
      </h1>

      <!-- Decorative line -->
      <div class="mx-auto mt-6 h-[1px] w-16 bg-olive/40"></div>

      <!-- Subtitle -->
      <p class="mt-6 text-xl font-light leading-relaxed text-[#8B7E72] md:text-2xl">
        브랜드 팝업부터 웨딩까지,<br />
        특별한 순간을 완성하는 포토부스
      </p>

      <!-- Stats -->
      <div class="mt-10 md:mt-14">
        <!-- 누적행사 (메인) -->
        <p class="text-sm font-medium tracking-[0.25em] text-[#8B7E72]/70 md:text-base">누적행사</p>
        <p class="mt-2 text-[clamp(2.8rem,8vw,5.5rem)] font-bold leading-none text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.03em;">
          <span class="counter-number" data-target="12000">0</span><span class="text-olive">+</span>
        </p>

        <!-- 브랜드 협업 / 웨딩 (서브) -->
        <div class="mt-5 flex items-center justify-center gap-6 md:gap-10">
          <div class="text-center">
            <p class="text-[10px] font-medium tracking-[0.15em] text-[#8B7E72]/50 md:text-xs">브랜드 협업</p>
            <p class="mt-0.5 text-[clamp(1.1rem,3vw,1.6rem)] font-bold leading-none text-[#2E2318]/60" style="font-family: 'ONE Mobile Title', sans-serif;">
              <span class="counter-number" data-target="4000">0</span><span class="text-olive/60">+</span>
            </p>
          </div>

          <div class="h-6 w-[1px] bg-[#8B7E72]/15"></div>

          <div class="text-center">
            <p class="text-[10px] font-medium tracking-[0.15em] text-[#8B7E72]/50 md:text-xs">웨딩</p>
            <p class="mt-0.5 text-[clamp(1.1rem,3vw,1.6rem)] font-bold leading-none text-[#2E2318]/60" style="font-family: 'ONE Mobile Title', sans-serif;">
              <span class="counter-number" data-target="8000">0</span><span class="text-olive/60">+</span>
            </p>
          </div>
        </div>
      </div>

      <!-- Client Logos -->
      <div class="mt-10 md:mt-14">
        <p class="mb-5 text-[10px] font-medium tracking-[0.3em] text-[#8B7E72]/40 uppercase md:text-xs">Trusted by</p>
        <div class="client-logos flex flex-wrap items-center justify-center gap-8 md:gap-12">
          <img src="/images/logos/samsung.svg" alt="Samsung" class="h-5 opacity-15 transition-opacity duration-300 hover:opacity-30 md:h-7" loading="lazy" />
          <img src="/images/logos/hyundai.svg" alt="Hyundai" class="h-5 opacity-15 transition-opacity duration-300 hover:opacity-30 md:h-7" loading="lazy" />
          <img src="/images/logos/nike.svg" alt="Nike" class="h-5 opacity-15 transition-opacity duration-300 hover:opacity-30 md:h-7" loading="lazy" />
          <img src="/images/logos/cj.svg" alt="CJ" class="h-5 opacity-15 transition-opacity duration-300 hover:opacity-30 md:h-7" loading="lazy" />
          <img src="/images/logos/shinsegae.svg" alt="Shinsegae" class="h-5 opacity-15 transition-opacity duration-300 hover:opacity-30 md:h-7" loading="lazy" />
          <img src="/images/logos/honda.svg" alt="Honda" class="h-5 opacity-15 transition-opacity duration-300 hover:opacity-30 md:h-7" loading="lazy" />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom spacer -->
  <div class="flex-1"></div>

  <!-- Scroll Down Button -->
  <button id="scroll-down-btn" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-[#8B7E72]/60 hover:text-olive transition-colors duration-300 cursor-pointer" aria-label="아래로 스크롤">
    <span class="text-xs font-medium tracking-[0.2em]">SCROLL</span>
    <div class="scroll-arrow-wrap w-6 h-10 flex items-center justify-center">
      <svg class="w-5 h-5 scroll-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
      </svg>
    </div>
  </button>
</section>

<style>
  @keyframes bounce-arrow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  .scroll-arrow {
    animation: bounce-arrow 2s ease-in-out infinite;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const heroContent = document.querySelector('.hero-content');
  const scrollBtn = document.getElementById('scroll-down-btn');

  // Counter animation for all counters
  document.querySelectorAll('.counter-number').forEach((el) => {
    const target = parseInt(el.getAttribute('data-target') || '0', 10);
    const obj = { val: 0 };
    gsap.to(obj, {
      val: target,
      duration: 2.2,
      delay: 0.5,
      ease: 'power2.out',
      onUpdate: () => {
        el.textContent = Math.floor(obj.val).toLocaleString();
      },
    });
  });

  // Parallax fade on scroll
  if (heroContent) {
    gsap.to(heroContent, {
      y: 40,
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: '80% top',
        scrub: true,
      },
    });
  }

  // Hide scroll button on scroll
  if (scrollBtn) {
    gsap.to(scrollBtn, {
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: '10% top',
        end: '30% top',
        scrub: true,
      },
    });
  }
</script>
