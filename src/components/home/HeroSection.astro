---
---

<section id="hero" class="relative flex h-screen min-h-screen flex-col overflow-hidden bg-[#FAF8F5]" data-fullpage-section>
  <!-- Top: Typography -->
  <div class="flex flex-1 flex-col items-center justify-center px-6">
    <p class="mb-3 text-[10px] font-medium tracking-[0.5em] text-[#D4AA45] uppercase">Est. 2015</p>
    <h1 class="text-[clamp(3.5rem,10vw,8rem)] leading-[1.05] text-[#2E2318] text-center" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.12em;">심플큐브</h1>
    <p class="mt-4 text-[clamp(0.8rem,1.3vw,1rem)] font-light tracking-[0.08em] text-[#8B7E72]">특별한 순간을 완성하는 포토부스</p>
    <div class="mt-6 flex items-center gap-6">
      <p class="text-2xl font-bold text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif;">12,000<span class="text-[#D4AA45]">+</span></p>
      <div class="h-5 w-[1px] bg-[#2E2318]/10"></div>
      <p class="text-[9px] tracking-[0.2em] text-[#8B7E72]/40 uppercase">Events</p>
    </div>
  </div>

  <!-- Scroll Down Button -->
  <button id="scroll-down-btn" class="absolute bottom-2 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-[#8B7E72]/40 hover:text-[#D4AA45] transition-colors duration-300 cursor-pointer" aria-label="아래로 스크롤">
    <span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
    <div class="h-8 w-[1px] bg-[#8B7E72]/15 relative overflow-hidden"><div class="absolute top-0 left-0 w-full h-1/2 bg-[#8B7E72]/40 animate-hero-scroll-line"></div></div>
  </button>
</section>

<style>
  @keyframes hero-scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  .animate-hero-scroll-line {
    animation: hero-scroll-line 1.8s ease-in-out infinite;
  }
</style>
