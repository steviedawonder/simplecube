          <p class="-mt-1 md:-mt-3 text-center text-[clamp(1.8rem,5vw,4.4rem)] font-bold leading-none text-[#2E2318]" style="font-family: 'ONE Mobile Title', sans-serif; letter-spacing: 0.03em;">
            <span class="counter-number" data-target="12000">0</span><span class="text-olive">+</span>
          </p>
