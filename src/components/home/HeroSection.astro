<style>
  /* D2: 대각선 텍스트 마퀴 배경 */
  .typo-marquee-container {
    position: absolute;
    inset: -40%;
    width: 180%;
    height: 180%;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transform: rotate(-15deg);
    transform-origin: center;
  }
  .typo-row {
    display: flex;
    white-space: nowrap;
    font-size: 56px;
    font-weight: 900;
    letter-spacing: 0.02em;
    color: #8B7E72;
  }
  .typo-row span {
    padding: 16px 20px;
    flex-shrink: 0;
  }
  .typo-odd {
    opacity: 0.06;
  }
  .typo-even {
    opacity: 0.045;
  }
  @media (min-width: 768px) {
    .typo-row { font-size: 80px; }
    .typo-row span { padding: 20px 28px; }
  }
  @keyframes typo-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  @keyframes typo-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  @keyframes bounce-arrow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
  .scroll-arrow {
    animation: bounce-arrow 2s ease-in-out infinite;
  }

  /* Logo marquee */
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .logo-marquee {
    animation: marquee-scroll 70s linear infinite;
    width: max-content;
  }
  .logo-marquee:hover {
    animation-play-state: paused;
  }
  .logo-marquee img,
  .logo-marquee svg {
    flex-shrink: 0;
    max-height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const heroContent = document.querySelector('.hero-content');
  const scrollBtn = document.getElementById('scroll-down-btn');

  // Counter animation for all counters
  document.querySelectorAll('.counter-number').forEach((el) => {
    const target = parseInt(el.getAttribute('data-target') || '0', 10);
    const obj = { val: 0 };
    gsap.to(obj, {
      val: target,
      duration: 2.2,
      delay: 0.5,
      ease: 'power2.out',
      onUpdate: () => {
        el.textContent = Math.floor(obj.val).toLocaleString();
      },
    });
  });

  // Parallax fade on scroll
  if (heroContent) {
    gsap.to(heroContent, {
      y: 40,
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: '80% top',
        scrub: true,
      },
    });
  }

  // Hide scroll button on scroll
  if (scrollBtn) {
    gsap.to(scrollBtn, {
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: '10% top',
        end: '30% top',
        scrub: true,
      },
    });
  }

  // Match eyebrow text width to h1
  function matchEyebrowWidth() {
    const h1 = document.querySelector('#hero h1');
    const eyebrow = document.querySelector('.eyebrow-text') as HTMLElement;
    if (h1 && eyebrow) {
      const h1Width = h1.querySelector('span')?.offsetWidth || h1.offsetWidth;
      // Reset first to measure natural width
      eyebrow.style.letterSpacing = '0.3em';
      eyebrow.style.width = '';
      eyebrow.style.whiteSpace = 'nowrap';
      eyebrow.style.textAlign = 'center';

      const naturalWidth = eyebrow.scrollWidth;
      if (naturalWidth < h1Width) {
        // Calculate spacing to fill h1 width, but use total chars (including spaces)
        const totalChars = eyebrow.textContent?.trim().length || 1;
        const currentSpacing = parseFloat(getComputedStyle(eyebrow).letterSpacing) || 0;
        const extraSpace = h1Width - naturalWidth;
        const additionalSpacing = extraSpace / totalChars;
        const newSpacing = currentSpacing + additionalSpacing;
        // Cap max letter-spacing to prevent overflow
        const fontSize = parseFloat(getComputedStyle(eyebrow).fontSize);
        const maxSpacing = fontSize * 1.5;
        eyebrow.style.letterSpacing = Math.min(newSpacing, maxSpacing) + 'px';
      }
      eyebrow.style.width = h1Width + 'px';
    }
  }
  matchEyebrowWidth();
  window.addEventListener('resize', matchEyebrowWidth);
</script>
