---
---

<section class="relative h-screen min-h-screen overflow-hidden bg-[#111]" id="hero" data-fullpage-section>

  <!-- 배경 이미지 레이어들 (각 키워드별) -->
  <div class="hero-bg-layer active" data-bg="wedding">
    <img src="/images/hero/wedding.webp" alt="" class="h-full w-full object-cover md:object-center object-[85%_center]" />
  </div>
  <div class="hero-bg-layer" data-bg="brand">
    <img src="/images/popup/simplecube-module-photobooth-honda.webp" alt="" class="h-full w-full object-cover" loading="lazy" />
  </div>
  <div class="hero-bg-layer" data-bg="corporate">
    <img src="/images/popup/simplecube-module-photobooth-shinsegae.webp" alt="" class="h-full w-full object-cover" loading="lazy" />
  </div>
  <div class="hero-bg-layer" data-bg="festival">
    <img src="/images/hero/festival.webp" alt="" class="h-full w-full object-cover" loading="lazy" />
  </div>
  <!-- "모든 순간" - 빠르게 바뀌는 이미지들 -->
  <div class="hero-bg-layer" data-bg="all">
    <div class="rapid-slideshow absolute inset-0">
      <img src="/images/moments/simplecube-photobooth-moment-1.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" />
      <img src="/images/moments/simplecube-photobooth-moment-2.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-3.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-4.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-5.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-6.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-7.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-8.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-9.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
      <img src="/images/moments/simplecube-photobooth-moment-10.webp" alt="" class="rapid-slide absolute inset-0 h-full w-full object-cover" loading="lazy" />
    </div>
  </div>

  <!-- 어두운 오버레이 -->
  <div class="absolute inset-0 z-[2] bg-black/70"></div>

  <!-- 콘텐츠 -->
  <div class="relative z-10 flex h-full flex-col items-center justify-center px-6">

    <!-- 브랜드 -->
    <p class="mb-[3.3rem] text-[15.8px] font-medium tracking-[0.5em] text-[#D4AA45]/70 uppercase">Simple Cube</p>

    <!-- 롤링 텍스트 영역 -->
    <div class="text-center">
      <p class="text-[clamp(1.32rem,2.75vw,1.76rem)] text-white/50 tracking-wide mb-[1.1rem] font-medium">심플큐브는</p>

      <!-- 키워드 영역 -->
      <div class="keyword-container relative" style="height: clamp(6.05rem, 14.3vw, 9.68rem);">
        <div class="keyword-item active" data-keyword="wedding">
          <span class="hero-keyword text-white">웨딩</span>
        </div>
        <div class="keyword-item" data-keyword="brand">
          <span class="hero-keyword text-white">브랜드</span>
        </div>
        <div class="keyword-item" data-keyword="corporate">
          <span class="hero-keyword text-white">기업행사</span>
        </div>
        <div class="keyword-item" data-keyword="festival">
          <span class="hero-keyword text-white">페스티벌</span>
        </div>
        <div class="keyword-item" data-keyword="all">
          <span class="hero-keyword hero-keyword-all text-[#D4AA45]">모든 순간</span>
        </div>
      </div>

      <p class="text-[clamp(1.21rem,2.42vw,1.54rem)] text-white/50 tracking-wide mt-[1.1rem] font-bold">의 파트너입니다<span class="text-[#D4AA45]">.</span></p>
    </div>

    <!-- 하단 설명 -->
    <div class="mt-[3.3rem] text-white/40 text-center leading-relaxed tracking-wide max-w-[75vw] md:max-w-none mx-auto">
      <p class="text-[clamp(0.7rem,1.21vw,0.97rem)]">2019년부터 지금까지, 14,000개 이상의 행사를 함께한</p>
      <p class="text-[clamp(1.02rem,1.76vw,1.41rem)]">대한민국 대표 오픈형 포토부스 브랜드</p>
    </div>

    <!-- 프로그레스 도트 -->
    <div class="mt-[2.2rem] flex gap-2.5" id="progressDots">
      <button class="progress-dot active" data-index="0" aria-label="웨딩"></button>
      <button class="progress-dot" data-index="1" aria-label="브랜드"></button>
      <button class="progress-dot" data-index="2" aria-label="기업행사"></button>
      <button class="progress-dot" data-index="3" aria-label="페스티벌"></button>
      <button class="progress-dot" data-index="4" aria-label="모든 순간"></button>
    </div>
  </div>

  <!-- Scroll Down -->
  <button id="scroll-down-btn" class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 text-white/25 hover:text-[#D4AA45] transition-colors duration-300 cursor-pointer" aria-label="아래로 스크롤">
    <span class="text-[9px] tracking-[0.3em] uppercase">Scroll</span>
    <div class="h-8 w-[1px] bg-white/10 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1/2 bg-white/30 animate-hero-scroll-line"></div>
    </div>
  </button>
</section>

<style>
  /* ===== 배경 이미지 레이어 ===== */
  .hero-bg-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
    will-change: opacity;
  }
  .hero-bg-layer.active {
    opacity: 1;
  }
  .hero-bg-layer img {
    transform: scale(1.05);
    transition: transform 8s ease-out;
  }
  .hero-bg-layer.active img {
    transform: scale(1);
  }

  /* ===== 키워드 텍스트 ===== */
  .keyword-item {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
    pointer-events: none;
  }
  .keyword-item.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .keyword-item.exiting {
    opacity: 0;
    transform: translateY(-30px);
  }

  /* ===== 프로그레스 도트 ===== */
  .progress-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.4s ease;
    position: relative;
  }
  .progress-dot.active {
    background: #D4AA45;
    width: 24px;
    border-radius: 3px;
  }

  /* ===== 빠른 슬라이드쇼 (모든 순간) ===== */
  .rapid-slide {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .rapid-slide.active {
    opacity: 1;
  }

  /* ===== 키워드 텍스트 스타일 ===== */
  .hero-keyword {
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
    font-size: clamp(3.52rem, 12.1vw, 7.26rem);
    font-weight: 900;
    display: block;
    line-height: 1.15;
    white-space: nowrap;
    letter-spacing: 0.02em;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }
  .hero-keyword-all {
    font-size: clamp(4.18rem, 14.3vw, 8.58rem);
  }

  /* ===== 스크롤 라인 ===== */
  @keyframes hero-scroll-line {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  .animate-hero-scroll-line {
    animation: hero-scroll-line 1.8s ease-in-out infinite;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const keywords = ['wedding', 'brand', 'corporate', 'festival', 'all'];
    const keywordEls = document.querySelectorAll('.keyword-item');
    const bgLayers = document.querySelectorAll('.hero-bg-layer');
    const dots = document.querySelectorAll('.progress-dot');
    const rapidSlides = document.querySelectorAll('.rapid-slide');

    let currentIndex = 0;
    let rapidIndex = 0;
    let rapidTimer: ReturnType<typeof setInterval> | null = null;
    let mainTimer: ReturnType<typeof setInterval> | null = null;

    // 각 키워드별 표시 시간 (ms)
    const durations = [1700, 1700, 1700, 1700, 4000];

    function switchTo(index: number) {
      const prevIndex = currentIndex;
      currentIndex = index;

      keywordEls[prevIndex]?.classList.remove('active');
      keywordEls[prevIndex]?.classList.add('exiting');
      setTimeout(() => {
        keywordEls[prevIndex]?.classList.remove('exiting');
      }, 600);

      keywordEls[currentIndex]?.classList.add('active');

      bgLayers.forEach(layer => layer.classList.remove('active'));
      const targetBg = document.querySelector(`[data-bg="${keywords[currentIndex]}"]`);
      targetBg?.classList.add('active');

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
      });

      if (keywords[currentIndex] === 'all') {
        startRapidSlideshow();
      } else {
        stopRapidSlideshow();
      }
    }

    function startRapidSlideshow() {
      rapidIndex = 0;
      rapidSlides.forEach(s => s.classList.remove('active'));
      if (rapidSlides[0]) rapidSlides[0].classList.add('active');

      rapidTimer = setInterval(() => {
        rapidSlides[rapidIndex]?.classList.remove('active');
        rapidIndex = (rapidIndex + 1) % rapidSlides.length;
        rapidSlides[rapidIndex]?.classList.add('active');
      }, 400);
    }

    function stopRapidSlideshow() {
      if (rapidTimer) {
        clearInterval(rapidTimer);
        rapidTimer = null;
      }
      rapidSlides.forEach(s => s.classList.remove('active'));
    }

    function scheduleNext() {
      mainTimer = setTimeout(() => {
        const nextIndex = (currentIndex + 1) % keywords.length;
        switchTo(nextIndex);
        scheduleNext();
      }, durations[currentIndex]);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (mainTimer) clearTimeout(mainTimer);
        switchTo(i);
        scheduleNext();
      });
    });

    switchTo(0);
    scheduleNext();
  });
</script>
