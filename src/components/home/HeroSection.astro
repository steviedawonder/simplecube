---
const base = import.meta.env.BASE_URL;
---

<section id="hero" class="relative flex h-screen min-h-[600px] items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src={`${base}/images/hero/main.jpg`}
      alt="심플큐브 포토부스 이벤트"
      class="hero-bg h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/20 to-black/60"></div>
  </div>

  <!-- Content -->
  <div class="hero-content relative z-10 px-6 text-center text-white">
    <p class="mb-4 text-sm font-medium tracking-[0.3em] text-white/70 md:text-base">
      PHOTO BOOTH SERVICE
    </p>
    <h1 class="text-[clamp(2.5rem,6vw,5rem)] font-bold leading-tight tracking-tight">
      SIMPLE CUBE
    </h1>
    <p class="mx-auto mt-6 max-w-lg text-base font-light leading-relaxed text-white/80 md:text-lg">
      특별한 순간을 담다
    </p>
  </div>

  <!-- Scroll Indicator -->
  <div class="scroll-indicator absolute bottom-8 left-1/2 z-10 -translate-x-1/2">
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs tracking-[0.2em] text-white/50">SCROLL</span>
      <svg class="h-5 w-5 animate-bounce-slow text-white/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7" />
      </svg>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Hero parallax effect
  const heroBg = document.querySelector('.hero-bg');
  const heroContent = document.querySelector('.hero-content');
  const scrollIndicator = document.querySelector('.scroll-indicator');

  if (heroBg) {
    gsap.to(heroBg, {
      yPercent: 30,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: 'bottom top',
        scrub: true,
      },
    });
  }

  if (heroContent) {
    gsap.to(heroContent, {
      y: 100,
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: 'top top',
        end: '60% top',
        scrub: true,
      },
    });
  }

  if (scrollIndicator) {
    gsap.to(scrollIndicator, {
      opacity: 0,
      ease: 'none',
      scrollTrigger: {
        trigger: '#hero',
        start: '10% top',
        end: '30% top',
        scrub: true,
      },
    });
  }
</script>
