---
const popupImages = [
  '/images/popup/모듈형모델.png',
  '/images/popup/모듈포토부스_혼다.png',
  '/images/popup/booth.jpg',
  '/images/popup/popup-model.jpg',
  '/images/popup/팝업포토부스_CJ.jpg',
  '/images/popup/wood-wrapping.jpg',
  '/images/popup/wood-round.jpg',
];
---

<!-- Two-Column Services: POPUP (left) | WEDDING (right) -->
<section class="grid grid-cols-1 md:grid-cols-2" data-fullpage-section>
  <!-- POPUP with slideshow -->
  <a href="/popup" class="service-card group relative flex items-end overflow-hidden h-[50vh] md:h-screen">
    <!-- Slideshow images -->
    {popupImages.map((src, i) => (
      <img
        src={src}
        alt="심플큐브 팝업 포토부스"
        class:list={[
          'popup-slide absolute inset-0 h-full w-full object-cover transition-opacity duration-1000',
          'object-[center_20%] md:object-[center_30%]',
          i === 0 ? 'opacity-100' : 'opacity-0',
        ]}
        loading={i === 0 ? 'eager' : 'lazy'}
        data-index={i}
      />
    ))}
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div class="relative z-10 w-full p-8 md:p-10 lg:p-12">
      <p class="mb-2 text-sm font-medium tracking-[0.2em] text-white/70">BRAND EXPERIENCE</p>
      <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-bold leading-[1.05] tracking-tight text-white">
        POP-UP
      </h2>
      <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-white/80 transition-all duration-300 group-hover:text-olive group-hover:gap-3">
        더 알아보기
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </div>
    </div>
  </a>

  <!-- WEDDING -->
  <a href="/wedding" class="service-card group relative flex items-end overflow-hidden h-[50vh] md:h-screen">
    <img
      src="/images/wedding/hero.png"
      alt="심플큐브 웨딩 포토부스"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div class="relative z-10 w-full p-8 md:p-10 lg:p-12">
      <p class="mb-2 text-sm font-medium tracking-[0.2em] text-white/70">SPECIAL MOMENT</p>
      <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-bold leading-[1.05] tracking-tight text-white">
        WEDDING
      </h2>
      <div class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-white/80 transition-all duration-300 group-hover:text-olive group-hover:gap-3">
        더 알아보기
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </div>
    </div>
  </a>
</section>

<script>
  const slides = document.querySelectorAll<HTMLImageElement>('.popup-slide');
  if (slides.length > 1) {
    let current = 0;
    setInterval(() => {
      slides[current].classList.remove('opacity-100');
      slides[current].classList.add('opacity-0');
      current = (current + 1) % slides.length;
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-100');
    }, 2000);
  }
</script>
