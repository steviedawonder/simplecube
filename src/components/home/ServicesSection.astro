---
---

<section class="flex flex-col lg:flex-row" style="min-height: 600px;">

  <!-- Pop-Up Panel -->
  <a
    href="/popup"
    class="service-panel group relative flex flex-1 min-h-[400px] lg:min-h-[600px] cursor-pointer overflow-hidden"
    aria-label="팝업 포토부스 자세히 보기"
  >
    <!-- Background Image -->
    <img
      src="/images/popup/booth.jpg"
      alt="팝업 포토부스"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
    />

    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>

    <!-- Vertical divider (desktop right side) -->
    <div class="absolute right-0 top-0 bottom-0 w-[1px] bg-white/10 hidden lg:block"></div>

    <!-- Content -->
    <div class="relative z-10 flex w-full flex-col justify-end p-10 md:p-14">
      <!-- Label -->
      <span class="mb-3 text-[11px] font-semibold tracking-[0.4em] text-olive uppercase">
        POP-UP
      </span>

      <!-- Title -->
      <h2 class="text-[clamp(1.8rem,3vw,2.8rem)] font-bold leading-tight text-white">
        팝업 포토부스
      </h2>

      <!-- Description -->
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/55 transition-all duration-500 group-hover:text-white/75">
        브랜드 팝업스토어, 기업 행사, 페스티벌까지.<br />
        맞춤형 디자인으로 브랜드를 특별하게.
      </p>

      <!-- Arrow link -->
      <div class="mt-8 flex items-center gap-3 text-sm font-medium text-white/50 transition-all duration-300 group-hover:text-white group-hover:gap-4">
        <span class="tracking-[0.1em]">자세히 보기</span>
        <div class="h-[1px] w-8 bg-current transition-all duration-300 group-hover:w-12"></div>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </a>

  <!-- Wedding Panel -->
  <a
    href="/wedding"
    class="service-panel group relative flex flex-1 min-h-[400px] lg:min-h-[600px] cursor-pointer overflow-hidden"
    aria-label="웨딩 포토부스 자세히 보기"
  >
    <!-- Background Image -->
    <img
      src="/images/wedding/hero.png"
      alt="웨딩 포토부스"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      loading="lazy"
    />

    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>

    <!-- Content -->
    <div class="relative z-10 flex w-full flex-col justify-end p-10 md:p-14">
      <!-- Label -->
      <span class="mb-3 text-[11px] font-semibold tracking-[0.4em] text-olive uppercase">
        WEDDING
      </span>

      <!-- Title -->
      <h2 class="text-[clamp(1.8rem,3vw,2.8rem)] font-bold leading-tight text-white">
        웨딩 포토부스
      </h2>

      <!-- Description -->
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/55 transition-all duration-500 group-hover:text-white/75">
        인생에서 가장 아름다운 날,<br />
        소중한 분들과의 순간을 더 특별하게.
      </p>

      <!-- Arrow link -->
      <div class="mt-8 flex items-center gap-3 text-sm font-medium text-white/50 transition-all duration-300 group-hover:text-white group-hover:gap-4">
        <span class="tracking-[0.1em]">자세히 보기</span>
        <div class="h-[1px] w-8 bg-current transition-all duration-300 group-hover:w-12"></div>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </a>

</section>
