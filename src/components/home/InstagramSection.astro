        <!-- KakaoTalk -->
        <a
          href="https://pf.kakao.com/_simplecube"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-[#FFFAF4]/60 transition-colors duration-300 hover:text-[#FFFAF4]"
          aria-label="KakaoTalk"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3c-4.97 0-9 3.185-9 7.115 0 2.557 1.707 4.8 4.27 6.054-.188.702-.682 2.545-.78 2.94-.123.496.182.489.382.356.157-.105 2.501-1.7 3.515-2.389.533.078 1.08.12 1.613.12 4.97 0 9-3.186 9-7.115C21 6.185 16.97 3 12 3z"/>
          </svg>
          <span class="text-sm font-medium">KakaoTalk</span>
        </a>
      </div>
    </div>
  </div>
</section>
