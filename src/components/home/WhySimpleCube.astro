---
const features = [
  {
    num: '01',
    title: '맞춤형 디자인',
    desc: '브랜드 아이덴티티에 맞는 커스텀 프레임, 테마, UI를 완전 제작합니다.',
  },
  {
    num: '02',
    title: '즉석 인화',
    desc: '현장에서 바로 고품질 사진을 출력. 하이엔드 장비로 최상의 결과물을 제공합니다.',
  },
  {
    num: '03',
    title: '디지털 공유',
    desc: 'QR코드로 디지털 파일을 즉시 전송. 소셜 미디어 공유도 한 번에 가능합니다.',
  },
  {
    num: '04',
    title: '전문 운영',
    desc: '경험 많은 전담 스태프가 처음부터 끝까지 현장에서 완벽한 운영을 책임집니다.',
  },
];
---

<section class="bg-bg-dark py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid gap-16 lg:grid-cols-2 lg:gap-24 items-start">

      <!-- Left: Heading block -->
      <div class="gs-slide-left">
        <span class="text-[11px] font-semibold tracking-[0.5em] text-olive uppercase">
          WHY SIMPLE CUBE
        </span>
        <h2 class="mt-5 text-[clamp(2rem,4vw,3.2rem)] font-bold leading-tight text-white">
          특별함이 필요한<br />모든 순간을 위해
        </h2>
        <div class="mt-7 h-[2px] w-12 bg-olive"></div>
        <p class="mt-8 max-w-md text-base leading-relaxed text-white/50">
          심플큐브는 단순한 포토부스 대여를 넘어,<br />
          브랜드와 순간을 잇는 특별한 경험을 만들어 드립니다.
        </p>

        <!-- Stats -->
        <div class="mt-12 flex gap-10">
          <div>
            <p class="text-3xl font-bold text-white">200<span class="text-olive">+</span></p>
            <p class="mt-1 text-xs tracking-[0.2em] text-white/40 uppercase">행사 진행</p>
          </div>
          <div class="w-[1px] bg-white/10"></div>
          <div>
            <p class="text-3xl font-bold text-white">98<span class="text-olive">%</span></p>
            <p class="mt-1 text-xs tracking-[0.2em] text-white/40 uppercase">만족도</p>
          </div>
          <div class="w-[1px] bg-white/10"></div>
          <div>
            <p class="text-3xl font-bold text-white">3<span class="text-olive">개</span></p>
            <p class="mt-1 text-xs tracking-[0.2em] text-white/40 uppercase">전국 거점</p>
          </div>
        </div>
      </div>

      <!-- Right: Numbered features grid -->
      <div class="gs-slide-right grid grid-cols-1 gap-0 sm:grid-cols-2">
        {features.map((feature, i) => (
          <div class:list={[
            'feature-card border-white/8 p-8 transition-all duration-300 hover:bg-white/4',
            i % 2 === 0 ? 'border-r' : '',
            i < 2 ? 'border-b' : '',
          ]}
          style="border-color: rgba(255,255,255,0.08);"
          >
            <span class="text-[3rem] font-bold leading-none text-white/8">
              {feature.num}
            </span>
            <h3 class="mt-3 text-base font-semibold text-white">
              {feature.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-white/45">
              {feature.desc}
            </p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>
