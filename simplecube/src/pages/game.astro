---
// Cat Galaga - 고양이 슈팅 게임
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cat Galaga - 고양이 슈팅 게임</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        background: #000;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        font-family: 'Courier New', monospace;
      }
      canvas {
        display: block;
        image-rendering: pixelated;
      }
      #ui-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        pointer-events: none;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        padding: 16px 24px;
        color: #fff;
        font-size: 18px;
        font-weight: bold;
        text-shadow: 0 0 8px rgba(0,200,255,0.6);
      }
      #start-screen, #gameover-screen {
        position: fixed;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        background: rgba(0,0,0,0.85);
        z-index: 20;
        color: #fff;
        text-align: center;
      }
      #start-screen h1, #gameover-screen h1 {
        font-size: 48px;
        margin-bottom: 12px;
        text-shadow: 0 0 20px rgba(0,200,255,0.8);
      }
      #start-screen .cat-art {
        font-size: 64px;
        margin: 20px 0;
      }
      #start-screen p, #gameover-screen p {
        font-size: 16px;
        color: #aaa;
        margin-bottom: 8px;
      }
      .btn {
        margin-top: 24px;
        padding: 14px 40px;
        font-size: 20px;
        font-family: 'Courier New', monospace;
        font-weight: bold;
        background: transparent;
        color: #0cf;
        border: 2px solid #0cf;
        cursor: pointer;
        pointer-events: all;
        transition: all 0.2s;
        text-transform: uppercase;
        letter-spacing: 2px;
      }
      .btn:hover {
        background: #0cf;
        color: #000;
        box-shadow: 0 0 20px rgba(0,200,255,0.5);
      }
      #gameover-screen .score-display {
        font-size: 36px;
        color: #0cf;
        margin: 16px 0;
      }
      .hidden { display: none !important; }

      /* Mobile controls */
      #mobile-controls {
        position: fixed;
        bottom: 20px;
        left: 0;
        width: 100%;
        display: none;
        justify-content: space-between;
        align-items: flex-end;
        padding: 0 20px;
        z-index: 15;
        pointer-events: none;
      }
      .dpad {
        display: grid;
        grid-template-columns: 60px 60px 60px;
        grid-template-rows: 60px 60px;
        gap: 4px;
        pointer-events: all;
      }
      .dpad button {
        width: 60px;
        height: 60px;
        background: rgba(255,255,255,0.15);
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 12px;
        color: #fff;
        font-size: 24px;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        touch-action: manipulation;
      }
      .dpad button:active {
        background: rgba(0,200,255,0.4);
      }
      .dpad .empty { visibility: hidden; }
      .fire-btn {
        width: 80px;
        height: 80px;
        background: rgba(255,60,60,0.3);
        border: 3px solid rgba(255,60,60,0.6);
        border-radius: 50%;
        color: #fff;
        font-size: 14px;
        font-weight: bold;
        cursor: pointer;
        pointer-events: all;
        -webkit-tap-highlight-color: transparent;
        touch-action: manipulation;
      }
      .fire-btn:active {
        background: rgba(255,60,60,0.7);
      }

      @media (pointer: coarse) {
        #mobile-controls { display: flex; }
      }
    </style>
  </head>
  <body>
    <div id="ui-overlay">
      <div id="score-text">SCORE: 0</div>
      <div id="lives-text">LIVES: ♥♥♥</div>
    </div>

    <canvas id="game"></canvas>

    <div id="start-screen">
      <div class="cat-art">🐱</div>
      <h1>CAT GALAGA</h1>
      <p>우주를 지키는 고양이 전투기!</p>
      <p>← → 이동 | SPACE 발사</p>
      <button class="btn" id="start-btn">START</button>
    </div>

    <div id="gameover-screen" class="hidden">
      <h1>GAME OVER</h1>
      <p>최종 점수</p>
      <div class="score-display" id="final-score">0</div>
      <button class="btn" id="restart-btn">RESTART</button>
    </div>

    <div id="mobile-controls">
      <div class="dpad">
        <div class="empty"></div>
        <button id="btn-up">▲</button>
        <div class="empty"></div>
        <button id="btn-left">◀</button>
        <button id="btn-down">▼</button>
        <button id="btn-right">▶</button>
      </div>
      <button class="fire-btn" id="btn-fire">FIRE</button>
    </div>

    <script>
      const canvas = document.getElementById('game') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;

      // --- Sizing ---
      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      // --- Game State ---
      let score = 0;
      let lives = 3;
      let gameRunning = false;
      let gameOver = false;
      let level = 1;
      let enemySpawnTimer = 0;
      let enemySpawnInterval = 90;
      let frame = 0;

      // --- Stars Background ---
      interface Star { x: number; y: number; speed: number; size: number; brightness: number; }
      let stars: Star[] = [];
      function initStars() {
        stars = [];
        for (let i = 0; i < 120; i++) {
          stars.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            speed: 0.3 + Math.random() * 1.5,
            size: 0.5 + Math.random() * 2,
            brightness: 0.3 + Math.random() * 0.7,
          });
        }
      }
      initStars();

      function updateStars() {
        for (const s of stars) {
          s.y += s.speed;
          if (s.y > canvas.height) {
            s.y = 0;
            s.x = Math.random() * canvas.width;
          }
        }
      }
      function drawStars() {
        for (const s of stars) {
          ctx.fillStyle = `rgba(255,255,255,${s.brightness})`;
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // --- Player (Gray Cat) ---
      const player = {
        x: 0, y: 0, w: 48, h: 48, speed: 6,
        invincible: 0, // invincibility frames after hit
      };

      function resetPlayer() {
        player.x = canvas.width / 2;
        player.y = canvas.height - 100;
        player.invincible = 0;
      }

      function drawCat(x: number, y: number, w: number, h: number, flash: boolean) {
        const cx = x;
        const cy = y;
        const s = w / 48; // scale factor

        if (flash && Math.floor(frame / 4) % 2 === 0) {
          ctx.globalAlpha = 0.3;
        }

        // Thruster flame
        const flameH = 8 + Math.sin(frame * 0.5) * 4;
        const grad = ctx.createLinearGradient(cx, cy + h/2, cx, cy + h/2 + flameH * s);
        grad.addColorStop(0, '#ff6600');
        grad.addColorStop(0.5, '#ffcc00');
        grad.addColorStop(1, 'rgba(255,100,0,0)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.moveTo(cx - 6*s, cy + h/2);
        ctx.lineTo(cx + 6*s, cy + h/2);
        ctx.lineTo(cx + 2*s, cy + h/2 + flameH*s);
        ctx.lineTo(cx - 2*s, cy + h/2 + flameH*s);
        ctx.fill();

        // Body (gray oval)
        ctx.fillStyle = '#999';
        ctx.beginPath();
        ctx.ellipse(cx, cy + 4*s, 16*s, 20*s, 0, 0, Math.PI * 2);
        ctx.fill();

        // Body lighter belly
        ctx.fillStyle = '#ccc';
        ctx.beginPath();
        ctx.ellipse(cx, cy + 8*s, 10*s, 14*s, 0, 0, Math.PI * 2);
        ctx.fill();

        // Head
        ctx.fillStyle = '#aaa';
        ctx.beginPath();
        ctx.arc(cx, cy - 14*s, 14*s, 0, Math.PI * 2);
        ctx.fill();

        // Ears (triangles)
        ctx.fillStyle = '#888';
        // Left ear
        ctx.beginPath();
        ctx.moveTo(cx - 12*s, cy - 20*s);
        ctx.lineTo(cx - 6*s, cy - 30*s);
        ctx.lineTo(cx - 2*s, cy - 18*s);
        ctx.fill();
        // Right ear
        ctx.beginPath();
        ctx.moveTo(cx + 12*s, cy - 20*s);
        ctx.lineTo(cx + 6*s, cy - 30*s);
        ctx.lineTo(cx + 2*s, cy - 18*s);
        ctx.fill();

        // Inner ears
        ctx.fillStyle = '#d4a0a0';
        ctx.beginPath();
        ctx.moveTo(cx - 10*s, cy - 20*s);
        ctx.lineTo(cx - 6*s, cy - 27*s);
        ctx.lineTo(cx - 3*s, cy - 19*s);
        ctx.fill();
        ctx.beginPath();
        ctx.moveTo(cx + 10*s, cy - 20*s);
        ctx.lineTo(cx + 6*s, cy - 27*s);
        ctx.lineTo(cx + 3*s, cy - 19*s);
        ctx.fill();

        // Eyes
        ctx.fillStyle = '#2d2';
        ctx.beginPath();
        ctx.ellipse(cx - 5*s, cy - 16*s, 3.5*s, 4*s, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.ellipse(cx + 5*s, cy - 16*s, 3.5*s, 4*s, 0, 0, Math.PI * 2);
        ctx.fill();

        // Pupils (slit)
        ctx.fillStyle = '#111';
        ctx.beginPath();
        ctx.ellipse(cx - 5*s, cy - 16*s, 1.5*s, 3.5*s, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.beginPath();
        ctx.ellipse(cx + 5*s, cy - 16*s, 1.5*s, 3.5*s, 0, 0, Math.PI * 2);
        ctx.fill();

        // Nose
        ctx.fillStyle = '#e8a';
        ctx.beginPath();
        ctx.moveTo(cx, cy - 10*s);
        ctx.lineTo(cx - 2*s, cy - 8*s);
        ctx.lineTo(cx + 2*s, cy - 8*s);
        ctx.fill();

        // Mouth
        ctx.strokeStyle = '#666';
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(cx, cy - 8*s);
        ctx.lineTo(cx - 3*s, cy - 6*s);
        ctx.moveTo(cx, cy - 8*s);
        ctx.lineTo(cx + 3*s, cy - 6*s);
        ctx.stroke();

        // Whiskers
        ctx.strokeStyle = '#ddd';
        ctx.lineWidth = 0.8;
        // Left
        ctx.beginPath();
        ctx.moveTo(cx - 8*s, cy - 12*s);
        ctx.lineTo(cx - 20*s, cy - 14*s);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(cx - 8*s, cy - 10*s);
        ctx.lineTo(cx - 20*s, cy - 10*s);
        ctx.stroke();
        // Right
        ctx.beginPath();
        ctx.moveTo(cx + 8*s, cy - 12*s);
        ctx.lineTo(cx + 20*s, cy - 14*s);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(cx + 8*s, cy - 10*s);
        ctx.lineTo(cx + 20*s, cy - 10*s);
        ctx.stroke();

        // Wing-like paws (for spaceship feel)
        ctx.fillStyle = '#888';
        // Left wing
        ctx.beginPath();
        ctx.moveTo(cx - 14*s, cy);
        ctx.lineTo(cx - 26*s, cy + 14*s);
        ctx.lineTo(cx - 22*s, cy + 10*s);
        ctx.lineTo(cx - 12*s, cy + 8*s);
        ctx.fill();
        // Right wing
        ctx.beginPath();
        ctx.moveTo(cx + 14*s, cy);
        ctx.lineTo(cx + 26*s, cy + 14*s);
        ctx.lineTo(cx + 22*s, cy + 10*s);
        ctx.lineTo(cx + 12*s, cy + 8*s);
        ctx.fill();

        ctx.globalAlpha = 1;
      }

      // --- Bullets ---
      interface Bullet { x: number; y: number; speed: number; }
      let bullets: Bullet[] = [];
      let shootCooldown = 0;

      function shoot() {
        if (shootCooldown > 0) return;
        bullets.push({ x: player.x, y: player.y - 28, speed: -10 });
        shootCooldown = 12;
      }

      function drawBullet(b: Bullet) {
        // Glowing yellow bullet
        const grad = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, 6);
        grad.addColorStop(0, '#fff');
        grad.addColorStop(0.4, '#ff0');
        grad.addColorStop(1, 'rgba(255,200,0,0)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(b.x, b.y, 6, 0, Math.PI * 2);
        ctx.fill();

        ctx.fillStyle = '#fff';
        ctx.beginPath();
        ctx.arc(b.x, b.y, 2, 0, Math.PI * 2);
        ctx.fill();
      }

      // --- Enemies ---
      interface Enemy {
        x: number; y: number; w: number; h: number;
        speed: number; hp: number; type: number;
        phase: number; amplitude: number;
        startX: number;
      }
      let enemies: Enemy[] = [];

      function spawnEnemy() {
        const type = Math.random() < 0.2 + level * 0.05 ? 1 : 0;
        const w = type === 1 ? 40 : 32;
        const x = w + Math.random() * (canvas.width - w * 2);
        enemies.push({
          x, y: -40,
          w, h: type === 1 ? 40 : 32,
          speed: 1.5 + Math.random() * 1 + level * 0.2,
          hp: type === 1 ? 3 : 1,
          type,
          phase: Math.random() * Math.PI * 2,
          amplitude: 30 + Math.random() * 40,
          startX: x,
        });
      }

      function drawEnemy(e: Enemy) {
        const s = e.w / 32;
        const cx = e.x;
        const cy = e.y;

        if (e.type === 0) {
          // Small alien bug
          ctx.fillStyle = '#f44';
          ctx.beginPath();
          ctx.ellipse(cx, cy, 12*s, 14*s, 0, 0, Math.PI * 2);
          ctx.fill();

          ctx.fillStyle = '#d22';
          ctx.beginPath();
          ctx.ellipse(cx, cy - 2*s, 8*s, 10*s, 0, 0, Math.PI * 2);
          ctx.fill();

          // Eyes
          ctx.fillStyle = '#ff0';
          ctx.beginPath();
          ctx.arc(cx - 4*s, cy - 4*s, 3*s, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(cx + 4*s, cy - 4*s, 3*s, 0, Math.PI * 2);
          ctx.fill();

          ctx.fillStyle = '#000';
          ctx.beginPath();
          ctx.arc(cx - 4*s, cy - 4*s, 1.5*s, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(cx + 4*s, cy - 4*s, 1.5*s, 0, Math.PI * 2);
          ctx.fill();

          // Wings
          ctx.fillStyle = '#f66';
          ctx.beginPath();
          ctx.ellipse(cx - 14*s, cy + 2*s, 6*s, 10*s, -0.3, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.ellipse(cx + 14*s, cy + 2*s, 6*s, 10*s, 0.3, 0, Math.PI * 2);
          ctx.fill();
        } else {
          // Boss-type enemy (bigger, purple)
          ctx.fillStyle = '#a0f';
          ctx.beginPath();
          ctx.ellipse(cx, cy, 18*s, 16*s, 0, 0, Math.PI * 2);
          ctx.fill();

          ctx.fillStyle = '#80c';
          ctx.beginPath();
          ctx.ellipse(cx, cy, 12*s, 12*s, 0, 0, Math.PI * 2);
          ctx.fill();

          // Eyes (3 eyes!)
          ctx.fillStyle = '#f0f';
          ctx.beginPath();
          ctx.arc(cx - 7*s, cy - 3*s, 3*s, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(cx, cy - 5*s, 3*s, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(cx + 7*s, cy - 3*s, 3*s, 0, Math.PI * 2);
          ctx.fill();

          ctx.fillStyle = '#fff';
          ctx.beginPath();
          ctx.arc(cx - 7*s, cy - 3*s, 1.5*s, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(cx, cy - 5*s, 1.5*s, 0, Math.PI * 2);
          ctx.fill();
          ctx.beginPath();
          ctx.arc(cx + 7*s, cy - 3*s, 1.5*s, 0, Math.PI * 2);
          ctx.fill();

          // Tentacles
          ctx.strokeStyle = '#a0f';
          ctx.lineWidth = 2*s;
          for (let i = -2; i <= 2; i++) {
            ctx.beginPath();
            ctx.moveTo(cx + i*6*s, cy + 14*s);
            ctx.quadraticCurveTo(
              cx + i*6*s + Math.sin(frame*0.1 + i)*4*s,
              cy + 22*s,
              cx + i*6*s,
              cy + 28*s
            );
            ctx.stroke();
          }
        }
      }

      // --- Enemy Bullets ---
      interface EnemyBullet { x: number; y: number; speed: number; }
      let enemyBullets: EnemyBullet[] = [];

      function drawEnemyBullet(b: EnemyBullet) {
        const grad = ctx.createRadialGradient(b.x, b.y, 0, b.x, b.y, 5);
        grad.addColorStop(0, '#fff');
        grad.addColorStop(0.4, '#f4f');
        grad.addColorStop(1, 'rgba(255,0,255,0)');
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(b.x, b.y, 5, 0, Math.PI * 2);
        ctx.fill();
      }

      // --- Particles ---
      interface Particle {
        x: number; y: number; vx: number; vy: number;
        life: number; maxLife: number; color: string; size: number;
      }
      let particles: Particle[] = [];

      function explode(x: number, y: number, color: string, count: number) {
        for (let i = 0; i < count; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 1 + Math.random() * 4;
          particles.push({
            x, y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            life: 30 + Math.random() * 20,
            maxLife: 30 + Math.random() * 20,
            color,
            size: 2 + Math.random() * 3,
          });
        }
      }

      // --- Collision ---
      function circleCollision(ax: number, ay: number, ar: number, bx: number, by: number, br: number) {
        const dx = ax - bx;
        const dy = ay - by;
        return dx*dx + dy*dy < (ar+br)*(ar+br);
      }

      // --- Input ---
      const keys: Record<string, boolean> = {};
      window.addEventListener('keydown', (e) => {
        keys[e.code] = true;
        if (e.code === 'Space') e.preventDefault();
      });
      window.addEventListener('keyup', (e) => {
        keys[e.code] = false;
      });

      // Mobile controls
      function setupMobileBtn(id: string, key: string) {
        const btn = document.getElementById(id);
        if (!btn) return;
        btn.addEventListener('touchstart', (e) => { e.preventDefault(); keys[key] = true; });
        btn.addEventListener('touchend', (e) => { e.preventDefault(); keys[key] = false; });
        btn.addEventListener('touchcancel', (e) => { e.preventDefault(); keys[key] = false; });
      }
      setupMobileBtn('btn-left', 'ArrowLeft');
      setupMobileBtn('btn-right', 'ArrowRight');
      setupMobileBtn('btn-up', 'ArrowUp');
      setupMobileBtn('btn-down', 'ArrowDown');
      setupMobileBtn('btn-fire', 'Space');

      // --- UI ---
      function updateUI() {
        document.getElementById('score-text')!.textContent = `SCORE: ${score}`;
        let heartsStr = '';
        for (let i = 0; i < lives; i++) heartsStr += '♥';
        document.getElementById('lives-text')!.textContent = `LIVES: ${heartsStr}`;
      }

      // --- Game Flow ---
      const startScreen = document.getElementById('start-screen')!;
      const gameoverScreen = document.getElementById('gameover-screen')!;

      function startGame() {
        score = 0;
        lives = 3;
        level = 1;
        gameRunning = true;
        gameOver = false;
        bullets = [];
        enemies = [];
        enemyBullets = [];
        particles = [];
        enemySpawnTimer = 0;
        enemySpawnInterval = 90;
        frame = 0;
        resetPlayer();
        updateUI();
        startScreen.classList.add('hidden');
        gameoverScreen.classList.add('hidden');
      }

      function endGame() {
        gameRunning = false;
        gameOver = true;
        document.getElementById('final-score')!.textContent = String(score);
        gameoverScreen.classList.remove('hidden');
      }

      document.getElementById('start-btn')!.addEventListener('click', startGame);
      document.getElementById('restart-btn')!.addEventListener('click', startGame);
      window.addEventListener('keydown', (e) => {
        if (e.code === 'Enter' || e.code === 'Space') {
          if (!gameRunning && !gameOver) startGame();
          else if (gameOver) startGame();
        }
      });

      // --- Main Loop ---
      function update() {
        frame++;

        // Player movement
        if (keys['ArrowLeft'] || keys['KeyA']) player.x -= player.speed;
        if (keys['ArrowRight'] || keys['KeyD']) player.x += player.speed;
        if (keys['ArrowUp'] || keys['KeyW']) player.y -= player.speed;
        if (keys['ArrowDown'] || keys['KeyS']) player.y += player.speed;

        // Clamp player
        player.x = Math.max(28, Math.min(canvas.width - 28, player.x));
        player.y = Math.max(40, Math.min(canvas.height - 40, player.y));

        // Shoot
        if (keys['Space']) shoot();
        if (shootCooldown > 0) shootCooldown--;

        // Invincibility
        if (player.invincible > 0) player.invincible--;

        // Bullets
        for (let i = bullets.length - 1; i >= 0; i--) {
          bullets[i].y += bullets[i].speed;
          if (bullets[i].y < -10) bullets.splice(i, 1);
        }

        // Enemy spawn
        enemySpawnTimer++;
        if (enemySpawnTimer >= enemySpawnInterval) {
          enemySpawnTimer = 0;
          spawnEnemy();
        }

        // Level up
        if (score > level * 500) {
          level++;
          enemySpawnInterval = Math.max(30, 90 - level * 5);
        }

        // Enemies
        for (let i = enemies.length - 1; i >= 0; i--) {
          const e = enemies[i];
          e.y += e.speed;
          e.x = e.startX + Math.sin(frame * 0.03 + e.phase) * e.amplitude;

          // Enemy shooting
          if (Math.random() < 0.005 + level * 0.001) {
            enemyBullets.push({ x: e.x, y: e.y + e.h/2, speed: 3 + Math.random() * 2 });
          }

          // Off screen
          if (e.y > canvas.height + 50) {
            enemies.splice(i, 1);
            continue;
          }

          // Bullet-enemy collision
          for (let j = bullets.length - 1; j >= 0; j--) {
            if (circleCollision(bullets[j].x, bullets[j].y, 4, e.x, e.y, e.w/2)) {
              e.hp--;
              explode(bullets[j].x, bullets[j].y, '#ff0', 5);
              bullets.splice(j, 1);
              if (e.hp <= 0) {
                explode(e.x, e.y, e.type === 0 ? '#f44' : '#a0f', 20);
                score += e.type === 0 ? 100 : 300;
                enemies.splice(i, 1);
                updateUI();
              }
              break;
            }
          }
        }

        // Enemy bullets
        for (let i = enemyBullets.length - 1; i >= 0; i--) {
          enemyBullets[i].y += enemyBullets[i].speed;
          if (enemyBullets[i].y > canvas.height + 10) {
            enemyBullets.splice(i, 1);
            continue;
          }

          // Hit player
          if (player.invincible <= 0 &&
              circleCollision(enemyBullets[i].x, enemyBullets[i].y, 4, player.x, player.y, 16)) {
            enemyBullets.splice(i, 1);
            lives--;
            player.invincible = 90;
            explode(player.x, player.y, '#0cf', 15);
            updateUI();
            if (lives <= 0) endGame();
          }
        }

        // Player-enemy collision
        if (player.invincible <= 0) {
          for (let i = enemies.length - 1; i >= 0; i--) {
            const e = enemies[i];
            if (circleCollision(player.x, player.y, 18, e.x, e.y, e.w/2)) {
              explode(e.x, e.y, '#f44', 20);
              enemies.splice(i, 1);
              lives--;
              player.invincible = 90;
              explode(player.x, player.y, '#0cf', 15);
              updateUI();
              if (lives <= 0) endGame();
              break;
            }
          }
        }

        // Particles
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.x += p.vx;
          p.y += p.vy;
          p.life--;
          if (p.life <= 0) particles.splice(i, 1);
        }
      }

      function draw() {
        // Clear
        ctx.fillStyle = '#0a0a1a';
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        drawStars();

        if (!gameRunning) {
          // Still draw stars when not playing
          updateStars();
          requestAnimationFrame(draw);
          return;
        }

        // Bullets
        for (const b of bullets) drawBullet(b);

        // Enemy bullets
        for (const b of enemyBullets) drawEnemyBullet(b);

        // Enemies
        for (const e of enemies) drawEnemy(e);

        // Player
        drawCat(player.x, player.y, player.w, player.h, player.invincible > 0);

        // Particles
        for (const p of particles) {
          ctx.globalAlpha = p.life / p.maxLife;
          ctx.fillStyle = p.color;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size * (p.life / p.maxLife), 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;

        // Level display
        ctx.fillStyle = 'rgba(0,200,255,0.3)';
        ctx.font = '14px "Courier New"';
        ctx.textAlign = 'center';
        ctx.fillText(`LEVEL ${level}`, canvas.width / 2, 36);
        ctx.textAlign = 'start';

        update();
        updateStars();
        requestAnimationFrame(draw);
      }

      draw();
    </script>
  </body>
</html>
